# Build output
/build/

# cyrius deps target (kernel has [deps] stdlib=[] — wrapper may still
# create an empty ./lib/ on `cyrius deps`. Root-anchored; the kernel's
# freestanding stdlib lives at kernel/klib/, not kernel/lib/.)
/lib/

# cyrius dep-resolver lock file. The kernel build uses `cyrius build --no-deps`
# and prepends `../kashi/src/font_data.cyr` directly in scripts/build.sh, so
# the lock never participates in the build. Ignore so an accidental
# `cyrius build` (without --no-deps) doesn't leave a tracked stray.
/cyrius.lock

