# === kybernet (PID 1 init) ===
fn kybernet() {
    kprintln("kybernet: starting init", 23);
    kprint("kybernet: ", 10);
    kprint_num(proc_count);
    kprintln(" processes", 10);
    kprint("kybernet: ", 10);
    kprint_num(pmm_free_count());
    kprintln(" free pages", 11);
    kprintln("kybernet: launching shell", 25);
    shell();
    kprintln("kybernet: shell exited", 22);
    return 0;
}
