# === Test Processes ===
# Simple loop functions for context switch testing.
# Each prints its ID to serial, then halts until next timer tick.
# Why busy-loops: the function MUST NOT return — its `ret` would pop an
# uninitialized stack word and jump to garbage. Iron-boot Attempt 12
# (2026-05-14) triple-faulted on iter 0 of the scheduler loop with the
# previous `if (0 == 1) { ... } return 0;` shape. See
# docs/development/iron-boot-testing-log.md § Attempt 12 for the trace.
# Coupled file: scripts/bench.sh inverts `while (1 == 1)` → `if (0 == 1)`
# for bench builds so the scheduler doesn't keep these alive past
# arch_halt. bench.sh guards on a match-count of exactly 2 — if you
# add/remove a test_proc here, update bench.sh's guard accordingly.

fn test_proc_a() {
    # CMOS CP 0x20: context switch into test_proc_a succeeded (pre-loop reached).
    asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x20; 0xE6; 0x71; }
    var iter = 0;
    while (1 == 1) {
        serial_print("A", 1);
        if (iter == 0) {
            # CMOS CP 0x21: first serial_print in proc context returned.
            asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x21; 0xE6; 0x71; }
        }
        arch_wait();
        if (iter == 0) {
            # CMOS CP 0x22: first arch_wait round-trip (hlt → timer ISR → resume).
            asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x22; 0xE6; 0x71; }
        }
        iter = iter + 1;
    }
    return 0;
}

fn test_proc_b() {
    # CMOS CP 0x23: sched_next rotated from test_proc_a → test_proc_b
    # (proves the round-robin is alive between user procs).
    asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x23; 0xE6; 0x71; }
    while (1 == 1) {
        serial_print("B", 1);
        arch_wait();
    }
    return 0;
}

# Test the SYSCALL interface via direct kernel call (not the instruction).
fn test_hw_syscall() {
    ksyscall(1, 0, "HW-OK\n", 6);
    serial_print("HW getpid=", 11);
    kprint_num(ksyscall(2, 0, 0, 0));
    serial_println("", 0);
    return 0;
}

# User-mode test process. Runs in ring 3.
# Uses the SYSCALL instruction to communicate with the kernel.
# Prints "U" repeatedly via syscall write, then exits.
fn user_test_proc() {
    # Ring 3. write(1, fd=0, buf, len)
    var msg = "U";
    var count = 0;
    while (count < 10) {
        # rax=1(write), rdi=0(fd serial), rsi=msg, rdx=1(len)
        asm {
            0x48; 0xC7; 0xC0; 0x01; 0x00; 0x00; 0x00;
            0x48; 0x31; 0xFF;
            0x48; 0x8B; 0x75; 0xF8;
            0x48; 0xC7; 0xC2; 0x01; 0x00; 0x00; 0x00;
            0x0F; 0x05;
        }
        count = count + 1;
    }
    asm { 0x48; 0x31; 0xC0; 0x48; 0x31; 0xFF; 0x0F; 0x05; }
    asm { 0xEB; 0xFE; }
    return 0;
}
