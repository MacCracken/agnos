            store8(stub + 216, 0x8A); store8(stub + 217, 0x40); store8(stub + 218, 0x1B);  # mov al,[rax+0x1B]
            store8(stub + 219, 0xE6); store8(stub + 220, 0x71);
            # 0x76 <- iretq FRAME POINTER bits 7:0   = the saved RSP value itself ([rsp+0x20])
