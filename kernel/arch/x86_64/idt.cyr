            store8(stub + 371, 0xB0); store8(stub + 372, 0x7F);  # mov al,0x7F
            store8(stub + 373, 0xE6); store8(stub + 374, 0x70);  # out 0x70,al  (select CMOS 0x7F)
            store8(stub + 375, 0x48); store8(stub + 376, 0xB8);  # mov rax, imm64 &gdtr_scratch
            store8(stub + 377, gsc & 0xFF); store8(stub + 378, (gsc >> 8) & 0xFF);
            store8(stub + 379, (gsc >> 16) & 0xFF); store8(stub + 380, (gsc >> 24) & 0xFF);
            store8(stub + 381, (gsc >> 32) & 0xFF); store8(stub + 382, (gsc >> 40) & 0xFF);
            store8(stub + 383, (gsc >> 48) & 0xFF); store8(stub + 384, (gsc >> 56) & 0xFF);
            store8(stub + 385, 0x0F); store8(stub + 386, 0x01); store8(stub + 387, 0x00);  # sgdt [rax]  (limit@+0, base@+2)
            store8(stub + 388, 0x48); store8(stub + 389, 0x8B); store8(stub + 390, 0x40); store8(stub + 391, 0x02);  # mov rax,[rax+2]  (GDTR base)
            store8(stub + 392, 0x8A); store8(stub + 393, 0x40); store8(stub + 394, 0x1D);  # mov al,[rax+0x1D]  (GDT[3] access byte)
            store8(stub + 395, 0xE6); store8(stub + 396, 0x71);  # out 0x71,al
