            store8(stub + 285, 0xE6); store8(stub + 286, 0x70);
            store8(stub + 287, 0x48); store8(stub + 288, 0xB8);                       # mov rax, imm64 &g_switch_log
            store8(stub + 289, hbp & 0xFF); store8(stub + 290, (hbp >> 8) & 0xFF);
            store8(stub + 291, (hbp >> 16) & 0xFF); store8(stub + 292, (hbp >> 24) & 0xFF);
            store8(stub + 293, (hbp >> 32) & 0xFF); store8(stub + 294, (hbp >> 40) & 0xFF);
            store8(stub + 295, (hbp >> 48) & 0xFF); store8(stub + 296, (hbp >> 56) & 0xFF);
            store8(stub + 297, 0x48); store8(stub + 298, 0x8B); store8(stub + 299, 0x00);  # mov rax,[rax]
            store8(stub + 300, 0xE6); store8(stub + 301, 0x71);
            # 0x7C <- new_pid (byte1, shr 8)
            store8(stub + 302, 0xB0); store8(stub + 303, 0x7C);
            store8(stub + 304, 0xE6); store8(stub + 305, 0x70);
            store8(stub + 306, 0x48); store8(stub + 307, 0xB8);
            store8(stub + 308, hbp & 0xFF); store8(stub + 309, (hbp >> 8) & 0xFF);
            store8(stub + 310, (hbp >> 16) & 0xFF); store8(stub + 311, (hbp >> 24) & 0xFF);
            store8(stub + 312, (hbp >> 32) & 0xFF); store8(stub + 313, (hbp >> 40) & 0xFF);
            store8(stub + 314, (hbp >> 48) & 0xFF); store8(stub + 315, (hbp >> 56) & 0xFF);
            store8(stub + 316, 0x48); store8(stub + 317, 0x8B); store8(stub + 318, 0x00);  # mov rax,[rax]
            store8(stub + 319, 0x48); store8(stub + 320, 0xC1); store8(stub + 321, 0xE8); store8(stub + 322, 0x08);  # shr rax,8
            store8(stub + 323, 0xE6); store8(stub + 324, 0x71);
            # 0x7D <- counter (byte2, shr 16)
            store8(stub + 325, 0xB0); store8(stub + 326, 0x7D);
            store8(stub + 327, 0xE6); store8(stub + 328, 0x70);
            store8(stub + 329, 0x48); store8(stub + 330, 0xB8);
            store8(stub + 331, hbp & 0xFF); store8(stub + 332, (hbp >> 8) & 0xFF);
            store8(stub + 333, (hbp >> 16) & 0xFF); store8(stub + 334, (hbp >> 24) & 0xFF);
            store8(stub + 335, (hbp >> 32) & 0xFF); store8(stub + 336, (hbp >> 40) & 0xFF);
            store8(stub + 337, (hbp >> 48) & 0xFF); store8(stub + 338, (hbp >> 56) & 0xFF);
            store8(stub + 339, 0x48); store8(stub + 340, 0x8B); store8(stub + 341, 0x00);  # mov rax,[rax]
            store8(stub + 342, 0x48); store8(stub + 343, 0xC1); store8(stub + 344, 0xE8); store8(stub + 345, 0x10);  # shr rax,16
            store8(stub + 346, 0xE6); store8(stub + 347, 0x71);
            # 0x7E <- magic (byte3, shr 24)  — expect 0x5C; gates the read-boot-log heartbeat decode
            store8(stub + 348, 0xB0); store8(stub + 349, 0x7E);
            store8(stub + 350, 0xE6); store8(stub + 351, 0x70);
            store8(stub + 352, 0x48); store8(stub + 353, 0xB8);
            store8(stub + 354, hbp & 0xFF); store8(stub + 355, (hbp >> 8) & 0xFF);
            store8(stub + 356, (hbp >> 16) & 0xFF); store8(stub + 357, (hbp >> 24) & 0xFF);
            store8(stub + 358, (hbp >> 32) & 0xFF); store8(stub + 359, (hbp >> 40) & 0xFF);
            store8(stub + 360, (hbp >> 48) & 0xFF); store8(stub + 361, (hbp >> 56) & 0xFF);
            store8(stub + 362, 0x48); store8(stub + 363, 0x8B); store8(stub + 364, 0x00);  # mov rax,[rax]
            store8(stub + 365, 0x48); store8(stub + 366, 0xC1); store8(stub + 367, 0xE8); store8(stub + 368, 0x18);  # shr rax,24
            store8(stub + 369, 0xE6); store8(stub + 370, 0x71);
            # --- GDT[3] STATE capture: sgdt the LIVE GDTR -> read GDT[3] access byte -> CMOS 0x7F ---
            # 1.46.x sub-bite 8 (2026-06-26): now that H1 (CR3 asymmetry) is DEAD — agnos collapsed the
            # KPTI split in 1.40.3, so proc_get_user_cr3 == proc_get_cr3 (proc.cyr:486), and the resume
            # iretq + the proven enter_ring3 iretq run under the SAME per-proc pml4 — the live remaining
            # questions are H3 (frame contents, captured at 0x72-0x75) and H2 (GDT[3] descriptor state).
            # Stamp GDT[3]'s ACCESS byte read THROUGH the live GDTR (so a relocated GDTR shows up too):
            # sgdt into gdtr_scratch (boot_data.cyr), load the 8-byte base at scratch+2, read [base+0x1D]
            # = GDT[3] (0x18) + access-byte offset (5). Expect 0xF2 (= P=1,DPL=3,S=1,data,writable =
            # gdt.cyr:17's 0x00CFF2000000FFFF). ANY other value ⇒ GDT[3] corrupted OR GDTR relocated (H2);
            # 0xF2 ⇒ descriptor intact, so a loaded-CS=0x23 (0x71) frame is a GENUINE silicon rejection of
            # a valid SS-load. sgdt is unprivileged + faultless; gdtr_scratch is kernel BSS (0x83, mapped
            # in every CR3). Slot 0x7F is the last virgin low-bank scratch (sole writer = this stub).
            var gsc = &gdtr_scratch;
