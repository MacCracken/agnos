            store8(stub + 223, 0xE6); store8(stub + 224, 0x70);
            store8(stub + 225, 0x48); store8(stub + 226, 0x8B); store8(stub + 227, 0x44); store8(stub + 228, 0x24); store8(stub + 229, 0x20);  # mov rax,[rsp+0x20]  (al = its low byte)
            store8(stub + 230, 0xE6); store8(stub + 231, 0x71);
            # 0x77 <- iretq FRAME POINTER bits 23:16 = saved RSP >> 16  (b2 ~0x0E-0x0F => region-7 per-proc kstack)
            store8(stub + 232, 0xB0); store8(stub + 233, 0x77);
            store8(stub + 234, 0xE6); store8(stub + 235, 0x70);
            store8(stub + 236, 0x48); store8(stub + 237, 0x8B); store8(stub + 238, 0x44); store8(stub + 239, 0x24); store8(stub + 240, 0x20);  # mov rax,[rsp+0x20]
            store8(stub + 241, 0x48); store8(stub + 242, 0xC1); store8(stub + 243, 0xE8); store8(stub + 244, 0x10);  # shr rax,16
            store8(stub + 245, 0xE6); store8(stub + 246, 0x71);
            # 0x78 <- CR3 bits 19:12 (mov rax,cr3; shr 12)  — per-proc pml4 fingerprint (boot CR3 0x1000 reads 0x01)
            store8(stub + 247, 0xB0); store8(stub + 248, 0x78);
            store8(stub + 249, 0xE6); store8(stub + 250, 0x70);
            store8(stub + 251, 0x0F); store8(stub + 252, 0x20); store8(stub + 253, 0xD8);  # mov rax,cr3
            store8(stub + 254, 0x48); store8(stub + 255, 0xC1); store8(stub + 256, 0xE8); store8(stub + 257, 0x0C);  # shr rax,12
            store8(stub + 258, 0xE6); store8(stub + 259, 0x71);
            # 0x79 <- CR3 bits 27:20 (mov rax,cr3; shr 20)
            store8(stub + 260, 0xB0); store8(stub + 261, 0x79);
            store8(stub + 262, 0xE6); store8(stub + 263, 0x70);
            store8(stub + 264, 0x0F); store8(stub + 265, 0x20); store8(stub + 266, 0xD8);  # mov rax,cr3
            store8(stub + 267, 0x48); store8(stub + 268, 0xC1); store8(stub + 269, 0xE8); store8(stub + 270, 0x14);  # shr rax,20
            store8(stub + 271, 0xE6); store8(stub + 272, 0x71);
            # 0x7A <- SAVED RFLAGS-at-fault bits 15:8 = [rsp+0x19]  (kernel-context IF/IOPL at the moment of fault)
            store8(stub + 273, 0xB0); store8(stub + 274, 0x7A);
            store8(stub + 275, 0xE6); store8(stub + 276, 0x70);
            store8(stub + 277, 0x8A); store8(stub + 278, 0x44); store8(stub + 279, 0x24); store8(stub + 280, 0x19);  # mov al,[rsp+0x19]
            store8(stub + 281, 0xE6); store8(stub + 282, 0x71);
