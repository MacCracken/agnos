# === PIC + Timer ===

fn pic_init() {
    # Remap PIC: IRQ 0-7 → INT 32-39, IRQ 8-15 → INT 40-47
    # ICW1: init + ICW4 needed
    asm { 0xB0; 0x11; 0xBA; 0x20; 0x00; 0x00; 0x00; 0xEE; }  # out 0x20, 0x11
    asm { 0xB0; 0x11; 0xBA; 0xA0; 0x00; 0x00; 0x00; 0xEE; }  # out 0xA0, 0x11
    # ICW2: vector offsets
    asm { 0xB0; 0x20; 0xBA; 0x21; 0x00; 0x00; 0x00; 0xEE; }  # out 0x21, 0x20 (IRQ0=INT32)
    asm { 0xB0; 0x28; 0xBA; 0xA1; 0x00; 0x00; 0x00; 0xEE; }  # out 0xA1, 0x28 (IRQ8=INT40)
    # ICW3: master has slave on IRQ2, slave ID=2
    asm { 0xB0; 0x04; 0xBA; 0x21; 0x00; 0x00; 0x00; 0xEE; }  # out 0x21, 0x04
    asm { 0xB0; 0x02; 0xBA; 0xA1; 0x00; 0x00; 0x00; 0xEE; }  # out 0xA1, 0x02
    # ICW4: 8086 mode
    asm { 0xB0; 0x01; 0xBA; 0x21; 0x00; 0x00; 0x00; 0xEE; }  # out 0x21, 0x01
    asm { 0xB0; 0x01; 0xBA; 0xA1; 0x00; 0x00; 0x00; 0xEE; }  # out 0xA1, 0x01
    # Mask all IRQs except IRQ0 (timer) + IRQ1 (keyboard)
    asm { 0xB0; 0xFC; 0xBA; 0x21; 0x00; 0x00; 0x00; 0xEE; }  # out 0x21, 0xFC
    asm { 0xB0; 0xFF; 0xBA; 0xA1; 0x00; 0x00; 0x00; 0xEE; }  # out 0xA1, 0xFF
    # Program PIT channel 0: mode 2 (rate generator), ~100 Hz
    # Command: channel 0, lobyte/hibyte, mode 2, binary
    # out 0x43, 0x34
    asm { 0xB0; 0x34; 0xBA; 0x43; 0x00; 0x00; 0x00; 0xEE; }
    # Divisor = 1193180 / 100 = 11932 = 0x2E9C
    # out 0x40, low byte
    asm { 0xB0; 0x9C; 0xBA; 0x40; 0x00; 0x00; 0x00; 0xEE; }
    # out 0x40, high byte
    asm { 0xB0; 0x2E; 0xBA; 0x40; 0x00; 0x00; 0x00; 0xEE; }
    return 0;
}

# Mask the legacy PIT (IRQ0) at the master PIC once the LAPIC timer owns the
# timebase. pic_init leaves the PIT free-running (mode-2 rate generator) AND
# unmasks IRQ0, and apic_timer_init puts the LAPIC timer on the SAME vector
# (INT32). Because timer_handler always EOIs the LAPIC when apic_enabled==1,
# a PIT-delivered IRQ0 would leave the 8259's IRQ0 in-service bit set forever
# -> the PIC then refuses to deliver the lower-priority IRQ1 (keyboard) ->
# keyboard input dies on iron. kb_isr/IRQ1 IS the archaemenid keystroke path
# (keyboard.cyr); QEMU types via the USB hid_poll ring, so the wedge is
# invisible in every QEMU smoke. Fix: mask IRQ0, keep IRQ1 (master mask
# 0xFC -> 0xFD). The LAPIC timer (INT32) never traverses the PIC, so the
# timebase is unaffected. Prior art: Linux/xv6/SeaBIOS all disable the PIT
# when switching the timebase to the LAPIC timer. Call AFTER apic_timer_init,
# while IF=0 (no IRQ0 can have been delivered yet, so no unwedge is needed).
fn pic_mask_pit() {
    asm { 0xB0; 0xFD; 0xBA; 0x21; 0x00; 0x00; 0x00; 0xEE; }  # out 0x21, 0xFD (IRQ0 masked, IRQ1 keyboard live)
    return 0;
}

# Timer ISR handler — called from the ISR bytecode after regs are pushed.
# rsp_after_push is the stack pointer with all 9 regs + hardware frame on it.
fn timer_handler(rsp_after_push) {
    # 1.46.x SMP sub-bite 6b: the BSP owns the wall clock + the single NIC ring. An AP's
    # timer tick must NOT bump timer_ticks (one global clock) nor re-enter net_rx_drain (one
    # shared r8169 ring, single-consumer). Gate both behind pcpu_cpu()==0. ALWAYS-TRUE
    # single-core (pcpu_cpu()==0), so this is byte-identical today; INERT until an AP arms its
    # APIC timer at sub-bite 7. do_context_switch runs on EVERY CPU (each schedules its own).
    if (pcpu_cpu() == 0) {
        timer_ticks = timer_ticks + 1;
        # Service the NIC RX ring every tick (100 Hz) so it stays drained even when no
        # ring-3 tool is in a poll loop. Otherwise LAN broadcast/multicast chatter
        # overruns the 64-deep r8169 ring during sleep_ms / idle gaps and the NIC drops
        # replies (the iron 50%-loss; QEMU's quiet point-to-point SLIRP never showed
        # it). net_rx_drain is RX-only + self-guarded (net_rx_lock atomic try-lock, 1.46.x #5), so it
        # issues no TX from interrupt context and no-ops (trylock fails) rather than re-enter a tool's
        # in-flight drain — now correct cross-CPU. Runs before the context switch so it executes in the kernel context
        # established at ISR entry (pre-CR3-swap); nic_ready() gates it to a no-op
        # until the NIC is up, so early-boot ticks are safe.
        net_rx_drain();
    }
    do_context_switch(rsp_after_push);
    # EOI: APIC if enabled, otherwise legacy PIC
    if (apic_enabled == 1) {
        apic_eoi();
    } else {
        asm { 0xB0; 0x20; 0xBA; 0x20; 0x00; 0x00; 0x00; 0xEE; }
    }
    return 0;
}

fn timer_isr_build() {
    # Build timer ISR in data buffer.
    # Strategy: push ALL 15 general-purpose regs (9 caller-saved + 6 callee-saved)
    # so the full proc state is captured by proc_save_context. Pre-Attempt-15
    # this ISR only pushed the 9 caller-saved regs despite a stale comment
    # claiming otherwise; the missing callee-saved push leaked rbx/rbp/r12-r15
    # between procs, corrupting frame-pointer-relative locals (idle_count etc.)
    # when the kernel idle proc was finally re-selected. See iron-boot Attempt
    # 15 § Repair (C) — sub-case 2 territory.
    var p = &timer_isr;
    var handler_addr = &timer_handler;
    var off = 0;

    # Caller-saved: rax rcx rdx rsi rdi r8 r9 r10 r11
    store8(p + off, 0x50); off = off + 1;  # push rax
    store8(p + off, 0x51); off = off + 1;  # push rcx
    store8(p + off, 0x52); off = off + 1;  # push rdx
    store8(p + off, 0x56); off = off + 1;  # push rsi
    store8(p + off, 0x57); off = off + 1;  # push rdi
    store8(p + off, 0x41); store8(p + off + 1, 0x50); off = off + 2;  # push r8
    store8(p + off, 0x41); store8(p + off + 1, 0x51); off = off + 2;  # push r9
    store8(p + off, 0x41); store8(p + off + 1, 0x52); off = off + 2;  # push r10
    store8(p + off, 0x41); store8(p + off + 1, 0x53); off = off + 2;  # push r11

    # Callee-saved: rbx rbp r12 r13 r14 r15 (Attempt-15 Repair C addition).
    # After these pushes, [rsp+0..47] = {r15,r14,r13,r12,rbp,rbx} and
    # [rsp+48..119] = {r11,r10,r9,r8,rdi,rsi,rdx,rcx,rax}; hw frame moves
    # from [rsp+72..104] to [rsp+120..152]. proc_save/restore_context are
    # updated to read/write these new offsets.
    store8(p + off, 0x53); off = off + 1;  # push rbx
    store8(p + off, 0x55); off = off + 1;  # push rbp
    store8(p + off, 0x41); store8(p + off + 1, 0x54); off = off + 2;  # push r12
    store8(p + off, 0x41); store8(p + off + 1, 0x55); off = off + 2;  # push r13
    store8(p + off, 0x41); store8(p + off + 1, 0x56); off = off + 2;  # push r14
    store8(p + off, 0x41); store8(p + off + 1, 0x57); off = off + 2;  # push r15

    # rdi = rsp (pass stack pointer as first arg to timer_handler)
    # mov rdi, rsp (48 89 E7)
    store8(p + off, 0x48); store8(p + off + 1, 0x89); store8(p + off + 2, 0xE7); off = off + 3;

    # call timer_handler: mov rax, imm64; call rax
    # mov rax, handler_addr (48 B8 imm64)
    store8(p + off, 0x48); store8(p + off + 1, 0xB8); off = off + 2;
    store64(p + off, handler_addr); off = off + 8;
    # call rax (FF D0)
    store8(p + off, 0xFF); store8(p + off + 1, 0xD0); off = off + 2;

    # Pop callee-saved first (reverse of push): r15 r14 r13 r12 rbp rbx
    store8(p + off, 0x41); store8(p + off + 1, 0x5F); off = off + 2;  # pop r15
    store8(p + off, 0x41); store8(p + off + 1, 0x5E); off = off + 2;  # pop r14
    store8(p + off, 0x41); store8(p + off + 1, 0x5D); off = off + 2;  # pop r13
    store8(p + off, 0x41); store8(p + off + 1, 0x5C); off = off + 2;  # pop r12
    store8(p + off, 0x5D); off = off + 1;  # pop rbp
    store8(p + off, 0x5B); off = off + 1;  # pop rbx

    # Pop caller-saved: r11 r10 r9 r8 rdi rsi rdx rcx rax (reverse of push)
    store8(p + off, 0x41); store8(p + off + 1, 0x5B); off = off + 2;  # pop r11
    store8(p + off, 0x41); store8(p + off + 1, 0x5A); off = off + 2;  # pop r10
    store8(p + off, 0x41); store8(p + off + 1, 0x59); off = off + 2;  # pop r9
    store8(p + off, 0x41); store8(p + off + 1, 0x58); off = off + 2;  # pop r8
    store8(p + off, 0x5F); off = off + 1;  # pop rdi
    store8(p + off, 0x5E); off = off + 1;  # pop rsi
    store8(p + off, 0x5A); off = off + 1;  # pop rdx
    store8(p + off, 0x59); off = off + 1;  # pop rcx
    store8(p + off, 0x58); off = off + 1;  # pop rax
    # iretq
    store8(p + off, 0x48); store8(p + off + 1, 0xCF);
    return 0;
}

# 1.51.5 — NIC RX MSI-X interrupt handler. Same body the 100 Hz timer tick runs
# (net_rx_drain), but triggered by the NIC on packet arrival so a blocked hlt wakes
# immediately instead of on the next tick — the proper fix for the tick-paced net
# latency floor (obsoletes the 1.51.3 busy-poll for the common case). RX-only,
# self-guarded (net_rx_lock trylock), issues no TX, and NEVER schedules — so it is
# safe in the preempt-held connect/recv window (the serial-kstack invariant holds,
# exactly as the timer ISR's drain already does). nic_ready() gates net_rx_drain to
# a no-op before the NIC is up. LAPIC-EOI (MSI-X delivers via the LAPIC).
fn nic_rx_handler() {
    net_rx_drain();
    apic_eoi();
    return 0;
}

# Build the NIC RX ISR stub (machine code) into nic_rx_isr. Mirrors timer_isr_build
# EXACTLY (15-register push → 16-byte-aligned call, the proven layout) minus the
# `mov rdi,rsp` (nic_rx_handler takes no arg) and the do_context_switch (no schedule).
fn nic_rx_isr_build() {
    var p = &nic_rx_isr;
    var handler_addr = &nic_rx_handler;
    var off = 0;
    # caller-saved: rax rcx rdx rsi rdi r8 r9 r10 r11
    store8(p + off, 0x50); off = off + 1;  # push rax
    store8(p + off, 0x51); off = off + 1;  # push rcx
    store8(p + off, 0x52); off = off + 1;  # push rdx
    store8(p + off, 0x56); off = off + 1;  # push rsi
    store8(p + off, 0x57); off = off + 1;  # push rdi
    store8(p + off, 0x41); store8(p + off + 1, 0x50); off = off + 2;  # push r8
    store8(p + off, 0x41); store8(p + off + 1, 0x51); off = off + 2;  # push r9
    store8(p + off, 0x41); store8(p + off + 1, 0x52); off = off + 2;  # push r10
    store8(p + off, 0x41); store8(p + off + 1, 0x53); off = off + 2;  # push r11
    # callee-saved: rbx rbp r12 r13 r14 r15 (→ 15 pushes, matches timer's alignment)
    store8(p + off, 0x53); off = off + 1;  # push rbx
    store8(p + off, 0x55); off = off + 1;  # push rbp
    store8(p + off, 0x41); store8(p + off + 1, 0x54); off = off + 2;  # push r12
    store8(p + off, 0x41); store8(p + off + 1, 0x55); off = off + 2;  # push r13
    store8(p + off, 0x41); store8(p + off + 1, 0x56); off = off + 2;  # push r14
    store8(p + off, 0x41); store8(p + off + 1, 0x57); off = off + 2;  # push r15
    # call nic_rx_handler: mov rax, imm64; call rax
    store8(p + off, 0x48); store8(p + off + 1, 0xB8); off = off + 2;
    store64(p + off, handler_addr); off = off + 8;
    store8(p + off, 0xFF); store8(p + off + 1, 0xD0); off = off + 2;  # call rax
    # pop callee-saved: r15 r14 r13 r12 rbp rbx
    store8(p + off, 0x41); store8(p + off + 1, 0x5F); off = off + 2;  # pop r15
    store8(p + off, 0x41); store8(p + off + 1, 0x5E); off = off + 2;  # pop r14
    store8(p + off, 0x41); store8(p + off + 1, 0x5D); off = off + 2;  # pop r13
    store8(p + off, 0x41); store8(p + off + 1, 0x5C); off = off + 2;  # pop r12
    store8(p + off, 0x5D); off = off + 1;  # pop rbp
    store8(p + off, 0x5B); off = off + 1;  # pop rbx
    # pop caller-saved: r11 r10 r9 r8 rdi rsi rdx rcx rax
    store8(p + off, 0x41); store8(p + off + 1, 0x5B); off = off + 2;  # pop r11
    store8(p + off, 0x41); store8(p + off + 1, 0x5A); off = off + 2;  # pop r10
    store8(p + off, 0x41); store8(p + off + 1, 0x59); off = off + 2;  # pop r9
    store8(p + off, 0x41); store8(p + off + 1, 0x58); off = off + 2;  # pop r8
    store8(p + off, 0x5F); off = off + 1;  # pop rdi
    store8(p + off, 0x5E); off = off + 1;  # pop rsi
    store8(p + off, 0x5A); off = off + 1;  # pop rdx
    store8(p + off, 0x59); off = off + 1;  # pop rcx
    store8(p + off, 0x58); off = off + 1;  # pop rax
    # iretq
    store8(p + off, 0x48); store8(p + off + 1, 0xCF);
    return 0;
}
