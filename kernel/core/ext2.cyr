# === ext2 / ext4 Read-Only Filesystem (1.31.5 Phase 1) ===
#
# Minimal ext2-format reader over the block dispatch layer (blk_read).
# Phase 1 scope: superblock + BGDT + inode-by-number + direct-block file
# read (i_block[0..11]). Caps file reads at 48 KB on 4K-block filesystems
# (12 direct blocks). Phase 2 adds indirect blocks; Phase 3 adds dirent
# walk + `ls` / `cat`; Phase 4 adds ext4 extents.
#
# Mounting modes:
#   - whole-disk: ext2_init() reads superblock from LBA 2/3 (byte 1024).
#     Matches the fatfs precedent (test images are whole-disk formatted).
#   - partition: Phase 3/4 will add ext2_init_partition(first_lba) which
#     resolves a GPT partition's first_lba and offsets all reads.
#
# Per agnosticos/docs/development/ext2-ext4-extents-prior-art.md §§ 3, 7.

# --- Globals --------------------------------------------------------

var ext2_active             = 0;    # 0 = not mounted; 1 = mounted
var ext2_write_ok           = 0;    # WRITE arc: 1 = FS is write-safe; set at mount (refuses metadata_csum / uninit_bg / bigalloc until the csum bites land — 64bit supported since 1.33.1 bite 1). Doc §§ 10, 14
var ext2_csum_on            = 0;    # 1 = metadata_csum FS (ro_compat 0x400); set at mount — every metadata block carries a CRC32c (1.33.1 bites 2+)
var ext2_fs_dirty           = 0;    # WRITE arc 1.33.3 bite 4: 1 once we've cleared s_state EXT2_VALID_FS on the first write this mount; `sync` sets it back. In-memory latch so we flush the dirty SB only once. Doc § 10 item 4
var ext2_csum_seed          = 0;    # crc32c seed for per-metadata checksums: UUID-derived, or s_checksum_seed if the CSUM_SEED feature is set; computed at mount
var ext2_desc_size          = 32;   # BGDT entry size: 32 (legacy) or 64 (ext4 64BIT)
var ext2_blocksize          = 0;    # bytes per FS block (1024/2048/4096)
var ext2_blocks_per_group   = 0;
var ext2_inodes_per_group   = 0;
var ext2_inode_size         = 0;    # 128 (legacy) or 256 (modern ext4)
var ext2_first_data_block   = 0;    # 0 for blocksize >= 2048, 1 for blocksize == 1024
var ext2_partition_first_lba = 0;   # 0 = whole-disk; set by Phase 3+ partition mount
var ext2_sectors_per_block  = 0;    # cached: blocksize / 512

# Bite (G) — the backend tag this ext2 mount lives on. Set by the
# multi-backend probe in `ext2_init` to one of BLK_NVME / BLK_AHCI /
# BLK_USB_MS / BLK_VIRTIO / BLK_RAMDISK. All in-driver block reads go
# through `ext2_blk_read` which dispatches via `blk_read_on(ext2_backend,
# ...)` instead of the global `blk_read` (which would route to
# blk_active). This decouples the ext2 mount from the override-policy
# winner — needed on archaemenid where NVMe wins `blk_active` but the
# ext2 partition lives on AHCI/SATA or a different NVMe partition.
var ext2_backend            = 0;    # BLK_NONE; set during probe

# Buffers — sized for max-blocksize (4096) since blocks bigger than that
# are out of scope for Phase 1-4. Module-global var X[N] in Cyrius
# allocates N u64 = 8N bytes (vs function-local var X[N] which is N
# bytes — see kprint_num's var buf[24] for the locals convention).
var ext2_sb_buf[128];      # 1024 bytes — superblock at byte 1024 of FS
var ext2_bgdt_buf[512];    # 4096 bytes — one BGDT block (32 BGDT entries × 32 bytes legacy fits in 1 KB; up to 128 entries fit in 4 KB)
var ext2_inode_buf[32];    # 256 bytes — one inode (covers both 128-legacy + 256-modern)
var ext2_block_buf[512];   # 4096 bytes — scratch for one data block

# Phase 2 indirect-block scratch buffers — one per depth level so a
# triple-indirect walk has three live blocks at once without reusing the
# data-block scratch. Each [512] = 4096 bytes covers the max blocksize.
# Allocated as module globals (vs pmm_alloc) per fatfs / nvme precedent;
# total cost = 12 KB BSS, fixed.
var ext2_indirect_buf_l1[512];  # single-indirect level (i_block[12] → here)
var ext2_indirect_buf_l2[512];  # double-indirect level 2 (i_block[13] → l1 → here)
var ext2_indirect_buf_l3[512];  # triple-indirect level 3 (i_block[14] → l1 → l2 → here)

# Phase 4 extent-walk scratch buffer — single buffer reused per descent
# level. Safe because the extent walk is "pick from current level, read
# next-level block, repeat": once we've picked from a level, we never
# need its data again. Cap MAX_EXTENT_DEPTH at 5 per Linux convention
# (audit § 5.3). 4 KB BSS.
var ext2_extent_buf[512];

# WRITE arc (1.33.x) bitmap scratch — one block holds a full group's
# block- or inode-bitmap (4096 B = 32768 bits >= blocks_per_group). Kept
# distinct from ext2_block_buf / ext2_bgdt_buf so an allocator can hold
# the BGDT block, the bitmap block, and a data block live at once.
var ext2_bitmap_buf[512];

# --- Endian-aware byte helpers (ext2/ext4 is little-endian on disk) -

fn ext2_load16_le(ptr, off) {
    return load8(ptr + off) | (load8(ptr + off + 1) << 8);
}

fn ext2_load32_le(ptr, off) {
    return load8(ptr + off)
    | (load8(ptr + off + 1) << 8)
    | (load8(ptr + off + 2) << 16)
    | (load8(ptr + off + 3) << 24);
}

# --- Endian-aware byte STORES (WRITE arc 1.33.x — mirror of the loaders) -
# Splice a 16/32-bit value little-endian into a buffer. Used by the
# metadata write-back path (superblock/BGDT/inode field mutation).

fn ext2_store16_le(ptr, off, val) {
    store8(ptr + off,     val & 0xFF);
    store8(ptr + off + 1, (val >> 8) & 0xFF);
    return 0;
}

fn ext2_store32_le(ptr, off, val) {
    store8(ptr + off,     val & 0xFF);
    store8(ptr + off + 1, (val >> 8) & 0xFF);
    store8(ptr + off + 2, (val >> 16) & 0xFF);
    store8(ptr + off + 3, (val >> 24) & 0xFF);
    return 0;
}

# --- Superblock field accessors (Haiku-style — endian-handled at boundary) -

fn ext2_sb_blocks_count(sb)      { return ext2_load32_le(sb, 4); }
fn ext2_sb_first_data_block(sb)  { return ext2_load32_le(sb, 20); }
fn ext2_sb_log_block_size(sb)    { return ext2_load32_le(sb, 24); }
fn ext2_sb_blocks_per_group(sb)  { return ext2_load32_le(sb, 32); }
fn ext2_sb_inodes_per_group(sb)  { return ext2_load32_le(sb, 40); }
fn ext2_sb_magic(sb)             { return ext2_load16_le(sb, 56); }
fn ext2_sb_rev_level(sb)         { return ext2_load32_le(sb, 76); }
fn ext2_sb_inode_size(sb)        { return ext2_load16_le(sb, 88); }
fn ext2_sb_feature_incompat(sb)  { return ext2_load32_le(sb, 96); }
fn ext2_sb_feature_ro_compat(sb) { return ext2_load32_le(sb, 100); }
fn ext2_sb_desc_size(sb)         { return ext2_load16_le(sb, 254); }
fn ext2_sb_checksum_seed(sb)     { return ext2_load32_le(sb, 0x270); }

# --- CRC32c (Castagnoli) for ext4 metadata_csum (1.33.1 bites 2+) ------
#
# DISTINCT from gpt.cyr's IEEE-802.3 CRC32 (poly 0xEDB88320): ext4 uses the
# CASTAGNOLI polynomial, bit-reflected 0x82F63B78. Two CRITICAL departures
# from gpt_crc32 (audit § 14.1, derived from e2fsprogs lib/ext2fs/csum.c):
#   - NO implicit init, NO final XOR. The CALLER supplies the running `crc`
#     (a seed, or 0xFFFFFFFF for a fresh start) and uses the result AS-IS.
#     (gpt folds init=~0 + final ^~0 into wrappers; ext4 folds them into how
#      seeds are passed, so the raw running value is what gets stored.)
# Same reflected shift-right structure as gpt_crc32_chunk; only the poly +
# the no-finalize contract differ. Self-test (bite 2): ext2_crc32c(
# 0xFFFFFFFF, "123456789", 9) == 0x1CF96D7C  (^0xFFFFFFFF == 0xE3069283,
# the canonical iSCSI CRC32C check value — proves the algorithm is real).
fn ext2_crc32c(crc, buf, len) {
    var i = 0;
    while (i < len) {
        crc = crc ^ load8(buf + i);
        var k = 0;
        while (k < 8) {
            if ((crc & 1) == 1) {
                crc = (crc >> 1) ^ 0x82F63B78;
            } else {
                crc = crc >> 1;
            }
            k = k + 1;
        }
        i = i + 1;
    }
    return crc & 0xFFFFFFFF;
}

# Compute the per-metadata checksum seed at mount (audit § 14.2). With the
# CSUM_SEED incompat feature (0x2000) the seed is the stored s_checksum_seed
# (+0x270); otherwise it's crc32c(~0, s_uuid[16] @ +0x68). Default mkfs.ext4
# does NOT set CSUM_SEED, so the UUID path is the common one. NOTE: the
# superblock's OWN checksum is seeded with ~0, not this value (§ 14.3) —
# that is handled at ext2_write_superblock, not here.
fn ext2_compute_csum_seed() {
    if ((ext2_sb_feature_incompat(&ext2_sb_buf) & 0x2000) != 0) {
        return ext2_sb_checksum_seed(&ext2_sb_buf);
    }
    return ext2_crc32c(0xFFFFFFFF, &ext2_sb_buf + 0x68, 16);
}

# Superblock checksum (1.33.1 bite 3, audit § 14.3): crc32c over the first
# 1020 bytes of the SB (everything before s_checksum @ 0x3FC), seeded with
# ~0 — NOT ext2_csum_seed (the SB is the one structure seeded with ~0).
# Full 32-bit, stored at 0x3FC. The compute naturally excludes the stored
# field (it ends at 0x3FC), so no zeroing dance is needed.
fn ext2_sb_csum_compute() {
    return ext2_crc32c(0xFFFFFFFF, &ext2_sb_buf, 0x3FC);
}

# Free-space accounting (WRITE arc) — s_free_blocks_count @ +12,
# s_free_inodes_count @ +16 (both u32). The read path never needed these
# (reading existing files doesn't consume space); the allocator does.
fn ext2_sb_free_blocks_count(sb)        { return ext2_load32_le(sb, 12); }
fn ext2_sb_free_inodes_count(sb)        { return ext2_load32_le(sb, 16); }
fn ext2_sb_set_free_blocks_count(sb, v) { return ext2_store32_le(sb, 12, v); }
fn ext2_sb_set_free_inodes_count(sb, v) { return ext2_store32_le(sb, 16, v); }

# --- Inode field accessors ----------------------------------------------

fn ext2_inode_mode(inode)        { return ext2_load16_le(inode, 0); }
fn ext2_inode_size_lo(inode)     { return ext2_load32_le(inode, 4); }
fn ext2_inode_size_hi(inode)     { return ext2_load32_le(inode, 108); }
fn ext2_inode_flags(inode)       { return ext2_load32_le(inode, 32); }

# i_block[i] is a 32-bit LE block pointer at byte offset 40 + i*4
fn ext2_inode_block_ptr(inode, i) { return ext2_load32_le(inode, 40 + i * 4); }

# Inode field STORES (WRITE arc). i_size_lo @ +4, i_links_count @ +26
# (u16), i_blocks_lo @ +28 (in 512-B sectors — the classic ext2 trap: a
# 4 KB block adds 8, not 1), i_block[i] @ +40+4i. i_mode @ +0.
fn ext2_inode_set_mode(inode, v)         { return ext2_store16_le(inode, 0, v); }
fn ext2_inode_set_size_lo(inode, v)      { return ext2_store32_le(inode, 4, v); }
fn ext2_inode_links_count(inode)         { return ext2_load16_le(inode, 26); }
fn ext2_inode_set_links_count(inode, v)  { return ext2_store16_le(inode, 26, v); }
fn ext2_inode_blocks_lo(inode)           { return ext2_load32_le(inode, 28); }
fn ext2_inode_set_blocks_lo(inode, v)    { return ext2_store32_le(inode, 28, v); }
fn ext2_inode_set_block_ptr(inode, i, v) { return ext2_store32_le(inode, 40 + i * 4, v); }

# Composite file size: low 32 + high 32 (LARGE_FILE feature) for regular files.
# For Phase 1 we cap at 2 GB regardless (i_size_hi == 0 always on small test images).
fn ext2_inode_filesize(inode) {
    var lo = ext2_inode_size_lo(inode);
    var hi = ext2_inode_size_hi(inode);
    return lo | (hi << 32);
}

# --- Mount -------------------------------------------------------------
#
# Reads superblock @ byte 1024 of partition (= LBA 2-3 of partition's
# first_lba). Validates magic 0xEF53, checks feature flags, caches
# blocksize and inode geometry. Returns 0 on success, -1 on any failure.
#
# Phase 1-3 supported-incompat mask: FILETYPE | RECOVER | MMP | FLEX_BG |
# EA_INODE | CSUM_SEED | LARGEDIR = 0x6706. Anything else triggers
# refusal with a clear "unsupported incompat bits" log line.

# Bite (G) helper — internal block read that routes through whichever
# backend ext2 successfully probed, not the global `blk_active` winner.
# All ext2 sub-helpers (ext2_read_block, ext2_get_inode, ...) use this.
fn ext2_blk_read(sector, buf) {
    return blk_read_on(ext2_backend, sector, buf);
}

# Bite (G) probe helper — reads candidate backend's LBA 2 + LBA 3 into
# `ext2_sb_buf`, returns 1 if the bytes look like an ext2 superblock
# (magic + sanity checks) or 0 on miss / IO error. The sanity gate is
# stricter than just `magic == 0xEF53` per audit § 3 H5: a 16-bit value
# can collide by accident in random data, so we also require log_block_size
# <= 2 and inodes_per_group > 0. Three-check gate is the documented
# defense against false positives on btrfs / NTFS / random-data sectors.
fn ext2_probe_backend(tag, partition_lba) {
    var sb_lba_lo = partition_lba + 2;
    var sb_lba_hi = partition_lba + 3;
    if (blk_read_on(tag, sb_lba_lo, &ext2_sb_buf) != 0) { return 0; }
    if (blk_read_on(tag, sb_lba_hi, &ext2_sb_buf + 512) != 0) { return 0; }

    var magic = ext2_sb_magic(&ext2_sb_buf);
    if (magic != 0xEF53) { return 0; }
    var log_bs = ext2_sb_log_block_size(&ext2_sb_buf);
    if (log_bs > 2) { return 0; }
    var ipg = ext2_sb_inodes_per_group(&ext2_sb_buf);
    if (ipg == 0) { return 0; }
    if (ipg > 1048576) { return 0; }
    return 1;
}

# Bite (H) — partition-aware mount helper. For a given backend `tag`,
# walks the parsed GPT partition table (gpt.cyr module-state, populated
# by gpt_init on the active backend at boot) looking for a partition
# with the Linux-FS type GUID; for each match, probes ext2 at the
# partition's first LBA + 2 (where the ext2 superblock lives by spec —
# byte offset 1024 from the partition start). Returns 1 on first match
# (ext2_backend + ext2_partition_first_lba set), 0 otherwise.
#
# Constraint: the GPT module currently parses GPT against `blk_active`,
# so this partition-aware mount can only see partitions on the backend
# holding blk_active. For Attempt 90 on archaemenid that's the NVMe
# (with its 3-partition layout including p3 = `agnos-fs` ext4 carve).
# Partitions on other backends (the AHCI/SATA `agnos-fs` carve at
# sda1) are NOT reachable via this path; they'd need either a separate
# GPT parse-per-backend or a whole-disk mkfs.ext4 on a non-GPT'd
# backend. The audit doc § 8 H4 documents this constraint.
fn ext2_try_partition_mount(tag) {
    if (gpt_present == 0) { return 0; }
    if (tag != blk_active) { return 0; }   # see comment above

    for (var pi = 0; pi < gpt_partition_count; pi = pi + 1) {
        if (gpt_partition_info(pi) != 1) { continue; }

        # Bite (H) — gate on Linux-FS type GUID per audit § 3 H1/H4.
        # Other type GUIDs (ESP, MSFT Basic, btrfs root) won't have ext2
        # at their first sector; skipping them avoids both wasted probe
        # IO and accidental false-positive on incidental 0xEF53 patterns
        # in foreign filesystems.
        if (gpt_q_type_lo != GPT_TYPE_LINUX_FS_LO) { continue; }
        if (gpt_q_type_hi != GPT_TYPE_LINUX_FS_HI) { continue; }

        if (ext2_probe_backend(tag, gpt_q_first_lba) == 1) {
            ext2_backend = tag;
            ext2_partition_first_lba = gpt_q_first_lba;
            return 1;
        }
    }
    return 0;
}

fn ext2_init() {
    # Bite (G) multi-backend probe. Walk all registered backends in
    # priority order (NVMe → AHCI → USB-MS → VirtIO → RAMDISK), reading
    # each one's LBA 2-3 for an ext2 superblock signature. First match
    # wins; non-matches are silent (every backend probes itself even on
    # non-ext2 disks, so noise-free is the right shape).
    #
    # On archaemenid: NVMe holds blk_active (btrfs root) but the carved
    # ext4 partition lives on a different backend or different partition
    # offset — bite (H) covers the partition-offset case via per-backend
    # GPT consumption.
    var candidates_n = 5;
    var candidates[5];
    store8(&candidates + 0, BLK_NVME);
    store8(&candidates + 1, BLK_AHCI);
    store8(&candidates + 2, BLK_USB_MS);
    store8(&candidates + 3, BLK_VIRTIO);
    store8(&candidates + 4, BLK_RAMDISK);

    var matched = 0;
    for (var ci = 0; ci < candidates_n; ci = ci + 1) {
        var tag = load8(&candidates + ci);
        if (blk_is_registered(tag) == 0) { continue; }

        # First attempt: whole-disk (partition_lba = 0). Common for
        # mkfs.ext2-on-raw-image (QEMU smoke test path).
        if (ext2_probe_backend(tag, 0) == 1) {
            ext2_backend = tag;
            ext2_partition_first_lba = 0;
            matched = 1;
            break;
        }

        # Bite (H) — partition-aware mount. If whole-disk missed AND this
        # backend has a parsed GPT (NVMe + AHCI typical), iterate the
        # partition table looking for a Linux-FS partition with an ext2
        # superblock at its offset+LBA-2. Reuses `gpt_partition_info(idx)`
        # which returns (first_lba, last_lba, type_guid_class) packed.
        # Bite (H) is gated on the gpt module being initialized (which it
        # is, called before ext2_init in main.cyr).
        if (ext2_try_partition_mount(tag) == 1) {
            matched = 1;
            break;
        }
    }

    if (matched == 0) {
        # No backend matched. Silent — every boot reads each backend's
        # sector 2, but most aren't ext2. Don't log noise.
        return 0 - 1;
    }

    # Magic matched — from here on, log loudly: ext2 is the FS, and any
    # failure deserves an explanation.

    kprint("ext2: probe matched backend=", 28);
    kprint_num(ext2_backend);
    if (ext2_partition_first_lba > 0) {
        kprint(" partition_lba=", 15);
        kprint_num(ext2_partition_first_lba);
    } else {
        kprint(" whole-disk", 11);
    }
    kprintln("", 0);

    # Feature gate. Phase 1-3 mask was 0x6706 (FILETYPE | RECOVER | MMP
    # | FLEX_BG | EA_INODE | CSUM_SEED | LARGEDIR). Phase 4 adds EXTENTS
    # (0x0040) → 0x6746 so mkfs.ext4 -O extents mounts succeed; the
    # actual extent-walk dispatch happens per-inode via i_flags &
    # EXT4_EXTENTS_FL, not at mount time. Phase 5 (1.31.7 bite A) adds
    # 64BIT (0x0080) → 0x67C6 so modern mkfs.ext4 defaults (which set
    # 64BIT even on sub-16-TB partitions) mount. The BGDT stride switches
    # to s_desc_size below; bg_inode_table_hi is guarded in ext2_get_inode.
    # Full prior-art audit: ext4-64bit-prior-art.md.
    var supported_mask = 0x67C6;
    var incompat = ext2_sb_feature_incompat(&ext2_sb_buf);
    var unsupported = incompat & (0xFFFFFFFF ^ supported_mask);
    if (unsupported != 0) {
        kprint("ext2: unsupported incompat bits: ", 33);
        kprint_num(unsupported);
        kprintln("", 0);
        return 0 - 1;
    }

    # WRITE arc — write-safety gate (prior-art doc §§ 10, 14). Reads
    # tolerate ro_compat freely (an RO mount ignores it); WRITE must HONOR
    # it or refuse. We refuse write (mount stays fully readable, just
    # immutable) only on the ro_compat bits we do NOT maintain:
    #   GDT_CSUM/uninit_bg (0x10) — lazy-bg-init + the legacy crc16 group-
    #                               desc checksum; a separate deferred feature
    #   BIGALLOC (0x200)          — cluster allocation; not ported
    # METADATA_CSUM (0x400) is NO LONGER refused (1.33.1 bites 2-7): the
    # write path now maintains CRC32c across the superblock, group
    # descriptors, block+inode bitmaps, inodes, and directory leaves
    # (§ 14). 64BIT (incompat 0x80) was lifted at bite 1 (§ 14.4). So a
    # default-`mkfs.ext4` FS (metadata_csum + 64bit, no uninit_bg) — i.e.
    # the real agnos-fs partition — is now fully writable.
    var ro_compat = ext2_sb_feature_ro_compat(&ext2_sb_buf);
    var ro_danger = 0x0010 | 0x0200;
    ext2_write_ok = 1;
    if ((ro_compat & ro_danger) != 0) { ext2_write_ok = 0; }

    # metadata_csum (1.33.1 bite 2): detect + compute the csum seed NOW, so
    # the write-back primitives can recompute checksums once the later bites
    # hook them. Detection + seed only — write stays gated on ro_danger
    # (metadata_csum is in it) until the final csum bite flips it.
    ext2_csum_on = 0;
    if ((ro_compat & 0x400) != 0) {
        ext2_csum_on = 1;
        ext2_csum_seed = ext2_compute_csum_seed();
    }

    # Decode geometry.
    var log_bs               = ext2_sb_log_block_size(&ext2_sb_buf);

    # Bite (A) input validation: log_block_size must be 0/1/2 — anything
    # else either overflows `1024 << log_bs` (>= 32 would shift past u32)
    # or yields blocksize 8192+ which we refuse below anyway. Defensive
    # cap before the shift so we never compute a nonsense blocksize from
    # a corrupt superblock.
    if (log_bs > 2) {
        kprint("ext2: log_block_size out of range: ", 35);
        kprint_num(log_bs);
        kprintln("", 0);
        return 0 - 1;
    }

    ext2_blocksize           = 1024 << log_bs;
    ext2_blocks_per_group    = ext2_sb_blocks_per_group(&ext2_sb_buf);
    ext2_inodes_per_group    = ext2_sb_inodes_per_group(&ext2_sb_buf);
    ext2_first_data_block    = ext2_sb_first_data_block(&ext2_sb_buf);
    ext2_sectors_per_block   = ext2_blocksize / 512;

    # Bite (A) input validation: superblock geometry sanity. Each of these
    # would either lead to a divide-by-zero (per-group counts) or
    # absurd-sized scans (inodes_per_group beyond reason). Cap chosen at
    # 1M inodes/group — Linux's `mke2fs -i` minimum bytes-per-inode = 1024
    # gives 4M inodes max at 4 KB blocksize × 32K-blocks/group, but we
    # cap at 1M for defensive sanity (realistic FSes are 8K-32K). Beyond
    # this, refuse mount rather than walk into corrupt territory.
    if (ext2_blocks_per_group == 0) {
        kprintln("ext2: blocks_per_group=0 (corrupt sb)", 37);
        return 0 - 1;
    }
    if (ext2_inodes_per_group == 0) {
        kprintln("ext2: inodes_per_group=0 (corrupt sb)", 37);
        return 0 - 1;
    }
    if (ext2_inodes_per_group > 1048576) {
        kprint("ext2: inodes_per_group > 1M absurd: ", 36);
        kprint_num(ext2_inodes_per_group);
        kprintln("", 0);
        return 0 - 1;
    }
    # first_data_block is 0 for blocksize >= 2048, 1 for blocksize == 1024.
    # Anything else means the superblock is lying or the spec was misread.
    if (ext2_first_data_block > 1) {
        kprint("ext2: first_data_block invalid: ", 32);
        kprint_num(ext2_first_data_block);
        kprintln("", 0);
        return 0 - 1;
    }

    # Inode size: DYNAMIC_REV (rev_level >= 1) reads from offset 88;
    # GOOD_OLD_REV defaults to 128. Defensive cap at 256 for our buffer.
    var rev = ext2_sb_rev_level(&ext2_sb_buf);
    if (rev >= 1) {
        ext2_inode_size = ext2_sb_inode_size(&ext2_sb_buf);
        if (ext2_inode_size == 0) { ext2_inode_size = 128; }
        if (ext2_inode_size > 256) {
            kprintln("ext2: inode_size > 256 unsupported", 34);
            return 0 - 1;
        }
    } else {
        ext2_inode_size = 128;
    }

    # Phase 5 (1.31.7 bite A): BGDT descriptor size. Default 32 (legacy
    # ext2/ext4); 64BIT-enabled FSes (sb +254) bump to 64. Anything else
    # is forward-compat we don't yet understand → refuse. Only valid when
    # rev >= 1 AND 64BIT bit is set in incompat. See ext4-64bit-prior-art.md.
    ext2_desc_size = 32;
    if (rev >= 1) {
        if ((incompat & 0x80) != 0) {
            var ds = ext2_sb_desc_size(&ext2_sb_buf);
            if (ds == 0) { ds = 32; }
            if (ds > 64) {
                kprint("ext2: s_desc_size > 64 unsupported: ", 36);
                kprint_num(ds);
                kprintln("", 0);
                return 0 - 1;
            }
            ext2_desc_size = ds;
        }
    }

    # Blocksize sanity. 1024/2048/4096 are the realistic values; refuse
    # anything else (Phase 1 buffer is 4096).
    if ((ext2_blocksize != 1024)
    & (ext2_blocksize != 2048)
    & (ext2_blocksize != 4096)) {
        kprint("ext2: unsupported blocksize ", 28);
        kprint_num(ext2_blocksize);
        kprintln("", 0);
        return 0 - 1;
    }

    # Mount complete. Log geometry for diagnostic continuity.
    kprint("ext2: mounted (blocksize=", 25);
    kprint_num(ext2_blocksize);
    kprint(", inode_size=", 13);
    kprint_num(ext2_inode_size);
    kprint(", inodes_per_group=", 19);
    kprint_num(ext2_inodes_per_group);
    kprintln(")", 1);

    ext2_active = 1;
    return 0;
}

# --- Block# → LBA conversion ------------------------------------------
#
# FS block N starts at byte offset N * blocksize from the START of the
# partition (or disk in whole-disk mode). Convert to LBA via:
#   LBA = partition_first_lba + N * sectors_per_block

fn ext2_block_to_lba(block_num) {
    return ext2_partition_first_lba + block_num * ext2_sectors_per_block;
}

# Read one FS block into the caller's buffer (buf must be sized >=
# ext2_blocksize). Returns 0 on success, -1 on read error.

fn ext2_read_block(block_num, buf) {
    var lba = ext2_block_to_lba(block_num);
    for (var i = 0; i < ext2_sectors_per_block; i = i + 1) {
        # Bite (G) — explicit per-backend dispatch via ext2_blk_read
        # ensures the read lands on the backend that probed positive,
        # not whatever holds blk_active.
        if (ext2_blk_read(lba + i, buf + i * 512) != 0) {
            return 0 - 1;
        }
    }
    return 0;
}

# --- Block write (WRITE arc 1.33.x — mirror of ext2_read_block) -------
# Per-backend dispatch via blk_write_on(ext2_backend, ...) so mutations
# land on the FS's actual backend, not the blk_active winner (same
# decoupling as the read side on archaemenid). The block-device write
# primitives are already iron-validated (USB-MS Attempt 87, AHCI demos).

fn ext2_blk_write(sector, buf) {
    return blk_write_on(ext2_backend, sector, buf);
}

fn ext2_write_block(block_num, buf) {
    ext2_mark_dirty();          # 1.33.3 bite 4: first write of the mount clears s_state VALID_FS
    var lba = ext2_block_to_lba(block_num);
    for (var i = 0; i < ext2_sectors_per_block; i = i + 1) {
        if (ext2_blk_write(lba + i, buf + i * 512) != 0) {
            return 0 - 1;
        }
    }
    return 0;
}

# Write the in-memory superblock (ext2_sb_buf, 1024 bytes) back to disk.
# The superblock lives at byte offset 1024 of the partition = LBA
# first_lba+2..+3 (two 512-B sectors) regardless of FS blocksize, so we
# write the 1024 bytes directly rather than block-RMW. Caller mutates
# ext2_sb_buf via the set_* accessors first. Returns 0 / -1.
fn ext2_write_superblock() {
    # metadata_csum (bite 3): recompute s_checksum over [0,0x3FC) before the
    # write, so the on-disk SB stays e2fsck-clean. No-op on a non-csum FS.
    if (ext2_csum_on != 0) {
        ext2_store32_le(&ext2_sb_buf, 0x3FC, ext2_sb_csum_compute());
    }
    var base = ext2_partition_first_lba + 2;
    if (ext2_blk_write(base,     &ext2_sb_buf)       != 0) { return 0 - 1; }
    if (ext2_blk_write(base + 1, &ext2_sb_buf + 512) != 0) { return 0 - 1; }
    return 0;
}

# === s_state dirty/clean + sync (WRITE arc 1.33.3 — bite 4, cycle close)
#
# The honest no-journal story (doc § 10 item 4). s_state lives at SB offset
# 0x3A (u16); bit 0 = EXT2_VALID_FS ("cleanly unmounted"). On the FIRST write
# of a mount we clear it (mark dirty) and flush the SB; `sync` sets it back.
# So a power-cycle AFTER `sync` leaves an e2fsck-"clean" FS, while a yanked
# burn WITHOUT `sync` leaves VALID_FS clear → e2fsck reports "not cleanly
# unmounted" and the user knows to run a check. AGNOS writes synchronously
# through blk_write (no writeback cache, prior-art § 2.3), so there is no
# cached data to flush here — only the state bit. A real drive FLUSH-CACHE
# barrier is the separate 1.33.5 bite. NOTE write_superblock writes via
# blk_write directly (not ext2_write_block), so calling it from the
# write_block hook does not recurse.
fn ext2_mark_dirty() {
    if (ext2_write_ok == 0) { return 0; }
    if (ext2_fs_dirty != 0) { return 0; }                  # already dirty — no-op
    ext2_fs_dirty = 1;
    var st = ext2_load16_le(&ext2_sb_buf, 0x3A);
    ext2_store16_le(&ext2_sb_buf, 0x3A, st & 0xFFFE);      # clear EXT2_VALID_FS
    ext2_write_superblock();                               # flush (recomputes SB csum)
    return 0;
}

# Mark the FS clean (set EXT2_VALID_FS) + flush the superblock. Returns 0/-1.
fn ext2_sync() {
    if (ext2_active == 0) { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }
    var st = ext2_load16_le(&ext2_sb_buf, 0x3A);
    ext2_store16_le(&ext2_sb_buf, 0x3A, st | 0x0001);      # set EXT2_VALID_FS
    ext2_fs_dirty = 0;
    if (ext2_write_superblock() != 0) { return 0 - 1; }
    # 1.33.5 fsync barrier: force the drive to commit its volatile write
    # cache. Goes LAST — every preceding blk_write_on (incl. the clean-
    # state SB just written) has already completed at the controller;
    # the flush pushes that controller-acked data through the drive's
    # own cache to non-volatile media. Without it `sync` is honest only
    # at the FS level. flush-cache-prior-art.md § 3.
    blk_flush_on(ext2_backend);
    return 0;
}

# --- Inode lookup -----------------------------------------------------
#
# Inode-num → inode struct, copying ext2_inode_size bytes into out_buf.
# Algorithm is universally convergent (Linux/FreeBSD/OpenBSD/Haiku all
# identical):
#
#   inode_num -= 1                            # 1-indexed!
#   block_group       = inode_num / inodes_per_group
#   index_in_group    = inode_num % inodes_per_group
#   inode_table_block = bgdt[block_group].bg_inode_table
#   byte_offset       = index_in_group * inode_size
#   target_block      = inode_table_block + byte_offset / blocksize
#   offset_in_block   = byte_offset % blocksize
#
# Reserved inode numbers: 1 = bad blocks, 2 = root dir (every path
# lookup starts here), 11 = lost+found typical. Inode 0 is invalid.

fn ext2_get_inode(inode_num, out_buf) {
    if (ext2_active == 0) { return 0 - 1; }
    if (inode_num == 0)   { return 0 - 1; }

    # Bite (A) input validation: cap inode_num against the maximum
    # representable in our Phase 1 BGDT chunk. The BGDT block holds up to
    # (blocksize / 32) groups; each covers inodes_per_group inodes. For a
    # 4K-block FS that's 128 groups × inodes_per_group. Beyond this,
    # `ext2_get_inode` would fall through the block_group bounds check
    # below anyway, but checking up front avoids the BGDT read on
    # obviously-bogus inode numbers (defense vs malformed dirent
    # walks, fuzz inputs, etc).
    var max_inodes_in_chunk = (ext2_blocksize / 32) * ext2_inodes_per_group;
    if (inode_num > max_inodes_in_chunk) {
        return 0 - 1;
    }

    var n            = inode_num - 1;
    var block_group  = n / ext2_inodes_per_group;
    var idx_in_group = n - block_group * ext2_inodes_per_group;  # n % per_group

    # Read BGDT block. Lives at FS block (first_data_block + 1).
    # Phase 1 reads exactly one BGDT block; that holds the first
    # (blocksize / 32) groups. For a 4K-block FS that's 128 groups,
    # which covers FSes up to 128 * blocks_per_group * 4 KB = 128 *
    # 32768 * 4 KB = 16 GB. Larger FSes need Phase 4+ work (META_BG
    # or multi-chunk BGDT walk).
    var bgdt_block = ext2_first_data_block + 1;
    if (ext2_read_block(bgdt_block, &ext2_bgdt_buf) != 0) {
        return 0 - 1;
    }

    # BGDT entries are 32 bytes (legacy ext2) or s_desc_size bytes
    # (ext4 64BIT — typically 64). bg_inode_table is at byte offset 8
    # regardless; bg_inode_table_hi at offset 40 only exists when
    # desc_size==64 and gates the Phase 6 unlock for >16 TB FSes.
    var bgdt_entry_size = ext2_desc_size;
    var max_groups_in_chunk = ext2_blocksize / bgdt_entry_size;
    if (block_group >= max_groups_in_chunk) {
        kprintln("ext2: block_group beyond first BGDT chunk (Phase 1 limit)", 57);
        return 0 - 1;
    }
    var bgdt_off = &ext2_bgdt_buf + block_group * bgdt_entry_size;
    var inode_table_block = ext2_load32_le(bgdt_off, 8);

    # Phase 5 (1.31.7 bite A): 64BIT mode has a bg_inode_table_hi at byte
    # offset 40 of the BGDT entry. For FSes <= 16 TB it's always zero;
    # AGNOS test surfaces never exceed this. Guard so a forward-compat
    # >16 TB FS surfaces a clear refusal instead of silently truncating.
    if (ext2_desc_size == 64) {
        var inode_table_hi = ext2_load32_le(bgdt_off, 40);
        if (inode_table_hi != 0) {
            kprintln("ext2: bg_inode_table_hi != 0 (Phase 6 unlock)", 45);
            return 0 - 1;
        }
    }

    # Compute target block + offset.
    var byte_offset      = idx_in_group * ext2_inode_size;
    var blocks_into_table = byte_offset / ext2_blocksize;
    var off_in_block     = byte_offset - blocks_into_table * ext2_blocksize;
    var target_block     = inode_table_block + blocks_into_table;

    # Read the inode-table block containing our inode.
    if (ext2_read_block(target_block, &ext2_block_buf) != 0) {
        return 0 - 1;
    }

    # Copy inode_size bytes out.
    var src = &ext2_block_buf + off_in_block;
    for (var i = 0; i < ext2_inode_size; i = i + 1) {
        store8(out_buf + i, load8(src + i));
    }
    return 0;
}

# --- Inode write-back (WRITE arc 1.33.x) ------------------------------
#
# Inverse of ext2_get_inode. Read-modify-WRITE at BLOCK granularity: an
# inode is inode_size bytes but the inode table is block-packed, so we
# read the table block, splice inode_size bytes from in_buf at the
# inode's offset, and write the whole block back. A bare inode_size-byte
# write would clobber the adjacent inodes sharing the block. Location
# math mirrors ext2_get_inode exactly. `in_buf` holds inode_size bytes.
# Returns 0 / -1.

fn ext2_put_inode(inode_num, in_buf) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }   # refuse while write is gated (metadata_csum until bite 7; §§ 10, 14)
    if (inode_num == 0)     { return 0 - 1; }

    var max_inodes_in_chunk = (ext2_blocksize / 32) * ext2_inodes_per_group;
    if (inode_num > max_inodes_in_chunk) { return 0 - 1; }

    var n            = inode_num - 1;
    var block_group  = n / ext2_inodes_per_group;
    var idx_in_group = n - block_group * ext2_inodes_per_group;

    var bgdt_block = ext2_first_data_block + 1;
    if (ext2_read_block(bgdt_block, &ext2_bgdt_buf) != 0) { return 0 - 1; }

    var bgdt_entry_size = ext2_desc_size;
    var max_groups_in_chunk = ext2_blocksize / bgdt_entry_size;
    if (block_group >= max_groups_in_chunk) { return 0 - 1; }
    var bgdt_off = &ext2_bgdt_buf + block_group * bgdt_entry_size;
    var inode_table_block = ext2_load32_le(bgdt_off, 8);
    if (ext2_desc_size == 64) {
        if (ext2_load32_le(bgdt_off, 40) != 0) { return 0 - 1; }
    }

    var byte_offset       = idx_in_group * ext2_inode_size;
    var blocks_into_table = byte_offset / ext2_blocksize;
    var off_in_block      = byte_offset - blocks_into_table * ext2_blocksize;
    var target_block      = inode_table_block + blocks_into_table;

    # metadata_csum (bite 5): stamp i_checksum into in_buf before the splice
    # so the inode lands on disk with a valid CRC32c. No-op on a non-csum FS.
    if (ext2_csum_on != 0) { ext2_inode_csum_stamp(inode_num, in_buf); }

    # RMW: read the table block, splice our inode, write it back.
    if (ext2_read_block(target_block, &ext2_block_buf) != 0) { return 0 - 1; }
    var dst = &ext2_block_buf + off_in_block;
    for (var i = 0; i < ext2_inode_size; i = i + 1) {
        store8(dst + i, load8(in_buf + i));
    }
    if (ext2_write_block(target_block, &ext2_block_buf) != 0) { return 0 - 1; }
    return 0;
}

# === Block / inode allocators (WRITE arc 1.33.x — W2) =================
#
# Bitmap-walk allocators per the prior-art doc §§ 4-5 (FreeBSD ext2_alloc
# primary). A block/inode bitmap is one bit per block/inode in a group,
# packed LSB-first into <= one FS block. We TRUST the bitmap: reserved
# regions (SB / BGDT / bitmaps / inode-table / sparse-super backups) are
# pre-set by mkfs, so a first-0-bit scan skips them without us computing
# the layout. Commit order (doc § 3): set the alloc bit + write the bitmap
# BEFORE the caller uses the resource; bump free-counts (BGDT then SB)
# LAST — so a crash leaks (fsck-reclaimable) but never dangles. Free
# reverses. All gated on ext2_write_ok.

# --- BGDT block read / write (descriptor table at first_data_block+1) ---
fn ext2_read_bgdt()  { return ext2_read_block(ext2_first_data_block + 1, &ext2_bgdt_buf); }
fn ext2_write_bgdt() {
    # metadata_csum (bite 3): recompute each group's bg_checksum before the
    # write. No-op on a non-csum FS.
    if (ext2_csum_on != 0) { ext2_bgdt_recsum(); }
    return ext2_write_block(ext2_first_data_block + 1, &ext2_bgdt_buf);
}

# Group-descriptor field access within the loaded ext2_bgdt_buf. Counts
# are the u16 lo halves; on 64BIT FSes (desc_size==64) the _hi halves sit
# at 0x2C/0x2E/0x30 and are 0 on any <16 TB FS — the lo store touches only
# 2 bytes, so the whole-block RMW preserves the zeroed _hi, leaving lo the
# whole value (1.33.1 bite 1, audit § 14.4).
fn ext2_grp_off(group)              { return &ext2_bgdt_buf + group * ext2_desc_size; }
fn ext2_grp_block_bitmap(group)     { return ext2_load32_le(ext2_grp_off(group), 0); }
fn ext2_grp_inode_bitmap(group)     { return ext2_load32_le(ext2_grp_off(group), 4); }
fn ext2_grp_inode_table(group)      { return ext2_load32_le(ext2_grp_off(group), 8); }
# bg_flags (@0x12, u16): bit 0 INODE_UNINIT, bit 1 BLOCK_UNINIT, bit 2
# INODE_ZEROED. Set on a default `mkfs.ext4` (metadata_csum) for groups whose
# bitmaps mkfs left un-materialized — see ext2_materialize_* (1.33.4 bite 3).
fn ext2_grp_bg_flags(group)         { return ext2_load16_le(ext2_grp_off(group), 0x12); }
fn ext2_grp_set_bg_flags(group, v)  { return ext2_store16_le(ext2_grp_off(group), 0x12, v); }
fn ext2_grp_free_blocks(group)      { return ext2_load16_le(ext2_grp_off(group), 12); }
fn ext2_grp_free_inodes(group)      { return ext2_load16_le(ext2_grp_off(group), 14); }
fn ext2_grp_used_dirs(group)        { return ext2_load16_le(ext2_grp_off(group), 16); }
fn ext2_grp_set_free_blocks(group, v) { return ext2_store16_le(ext2_grp_off(group), 12, v); }
fn ext2_grp_set_free_inodes(group, v) { return ext2_store16_le(ext2_grp_off(group), 14, v); }
fn ext2_grp_set_used_dirs(group, v)   { return ext2_store16_le(ext2_grp_off(group), 16, v); }

# bg_itable_unused (@0x1C lo, @0x32 hi for 64bit) — the count of inodes at
# the TAIL of the group's inode table that have NEVER been used. Live when
# group-desc checksums are on (gdt_csum or metadata_csum): e2fsck uses it as
# a high-water mark to skip scanning/csum-checking guaranteed-unused inodes.
# Allocating an inode in that tail region MUST shrink it, or e2fsck flags the
# inode as "in the unused inodes area" (1.33.1 bite 7 accounting fix).
fn ext2_grp_itable_unused(group) {
    var lo = ext2_load16_le(ext2_grp_off(group), 0x1C);
    if (ext2_desc_size > 32) { return lo | (ext2_load16_le(ext2_grp_off(group), 0x32) << 16); }
    return lo;
}
fn ext2_grp_set_itable_unused(group, v) {
    ext2_store16_le(ext2_grp_off(group), 0x1C, v & 0xFFFF);
    if (ext2_desc_size > 32) { ext2_store16_le(ext2_grp_off(group), 0x32, (v >> 16) & 0xFFFF); }
    return 0;
}

# Group-descriptor checksum (1.33.1 bite 3, audit § 14.3). e2fsprogs
# ext2fs_group_desc_csum for metadata_csum: crc32c over the group number
# (LE32), then the descriptor [0, 0x1E), then 2 zero bytes standing in for
# the bg_checksum field, then (64bit only) [0x20, desc_size). Truncated to
# the low 16 bits, stored at 0x1E. Seeded with ext2_csum_seed.
fn ext2_grp_csum_compute(group) {
    var off = ext2_grp_off(group);
    var gle[4];                            # group number, little-endian
    ext2_store32_le(&gle, 0, group);
    var crc = ext2_crc32c(ext2_csum_seed, &gle, 4);
    crc = ext2_crc32c(crc, off, 0x1E);     # [0, bg_checksum)
    var z2[2];                             # the 2-byte bg_checksum field as 0
    store8(&z2, 0); store8(&z2 + 1, 0);
    crc = ext2_crc32c(crc, &z2, 2);
    if (ext2_desc_size > 0x20) {           # 64bit: the upper half of the desc
        crc = ext2_crc32c(crc, off + 0x20, ext2_desc_size - 0x20);
    }
    return crc & 0xFFFF;
}

# Recompute bg_checksum for every valid group present in the loaded BGDT
# block — called from ext2_write_bgdt before the write when csum is on. The
# loaded block is the first BGDT block (groups 0 .. blocksize/desc_size-1);
# only [0, ngroups) are real. Cheap (≤64 descriptors) and safe — untouched
# descriptors recompute to their existing value.
fn ext2_bgdt_recsum() {
    var per_block = ext2_blocksize / ext2_desc_size;
    var ng = ext2_ngroups();
    if (ng > per_block) { ng = per_block; }
    var g = 0;
    while (g < ng) {
        ext2_store16_le(ext2_grp_off(g), 0x1E, ext2_grp_csum_compute(g));
        g = g + 1;
    }
    return 0;
}

# Bitmap checksums (1.33.1 bite 4, audit § 14.3). The block/inode bitmap
# CRC32c lives in the group descriptor; set it when the bitmap is written
# (then bg_checksum, recomputed in ext2_write_bgdt, covers it). `bmbuf`
# holds the just-written bitmap block. Stored lo16 + (64bit) hi16.
#   block bitmap: span = (blocks_per_group+7)/8  → lo @ 0x18, hi @ 0x38
#   inode bitmap: span = (inodes_per_group+7)/8  → lo @ 0x1A, hi @ 0x3A
# ⚠ the inode-bitmap span is inodes_per_group/8 (e.g. 1024 B), NOT the full
# block — the #1 silent e2fsck trap (§ 14.7).
fn ext2_set_block_bitmap_csum(group, bmbuf) {
    var crc = ext2_crc32c(ext2_csum_seed, bmbuf, (ext2_blocks_per_group + 7) / 8);
    ext2_store16_le(ext2_grp_off(group), 0x18, crc & 0xFFFF);
    if (ext2_desc_size > 32) { ext2_store16_le(ext2_grp_off(group), 0x38, (crc >> 16) & 0xFFFF); }
    return 0;
}
fn ext2_set_inode_bitmap_csum(group, bmbuf) {
    var crc = ext2_crc32c(ext2_csum_seed, bmbuf, (ext2_inodes_per_group + 7) / 8);
    ext2_store16_le(ext2_grp_off(group), 0x1A, crc & 0xFFFF);
    if (ext2_desc_size > 32) { ext2_store16_le(ext2_grp_off(group), 0x3A, (crc >> 16) & 0xFFFF); }
    return 0;
}

# Inode checksum (1.33.1 bite 5, audit § 14.3). e2fsprogs ext2fs_inode_csum:
# crc32c(seed, ino#_le32) → +i_generation_le32 (@100) → +the WHOLE inode
# (inode_size bytes) with i_checksum_lo (@0x7C) and i_checksum_hi (@0x82)
# zeroed during the crc. lo16 → 0x7C; hi16 → 0x82, but only when the inode
# carries the extra region (inode_size > 128 AND i_extra_isize @128 >= 4 —
# the EXT4_FITS_IN_INODE gate). _calc is non-destructive (save/zero/crc/
# restore) for compute-and-compare; _stamp writes the result in place.
fn ext2_inode_has_hi(inode_buf) {
    if (ext2_inode_size <= 128) { return 0; }
    if (ext2_load16_le(inode_buf, 128) >= 4) { return 1; }
    return 0;
}
fn ext2_inode_csum_calc(inode_num, inode_buf) {
    var has_hi = ext2_inode_has_hi(inode_buf);
    var old_lo = ext2_load16_le(inode_buf, 0x7C);
    var old_hi = 0;
    ext2_store16_le(inode_buf, 0x7C, 0);
    if (has_hi == 1) { old_hi = ext2_load16_le(inode_buf, 0x82); ext2_store16_le(inode_buf, 0x82, 0); }
    var ile[4]; ext2_store32_le(&ile, 0, inode_num);
    var crc = ext2_crc32c(ext2_csum_seed, &ile, 4);
    var gle[4]; ext2_store32_le(&gle, 0, ext2_load32_le(inode_buf, 100));   # i_generation
    crc = ext2_crc32c(crc, &gle, 4);
    crc = ext2_crc32c(crc, inode_buf, ext2_inode_size);
    ext2_store16_le(inode_buf, 0x7C, old_lo);                              # restore
    if (has_hi == 1) { ext2_store16_le(inode_buf, 0x82, old_hi); }
    return crc;
}
fn ext2_inode_csum_stamp(inode_num, inode_buf) {
    var crc = ext2_inode_csum_calc(inode_num, inode_buf);
    ext2_store16_le(inode_buf, 0x7C, crc & 0xFFFF);
    if (ext2_inode_has_hi(inode_buf) == 1) { ext2_store16_le(inode_buf, 0x82, (crc >> 16) & 0xFFFF); }
    return 0;
}

# Number of block groups = ceil((blocks_count - first_data_block) / bpg).
fn ext2_ngroups() {
    var total = ext2_sb_blocks_count(&ext2_sb_buf) - ext2_first_data_block;
    return (total + ext2_blocks_per_group - 1) / ext2_blocks_per_group;
}

# --- bitmap bit helpers (LSB-first within each byte) ---
fn ext2_bitmap_get(buf, bit)   { return (load8(buf + bit / 8) >> (bit & 7)) & 1; }
fn ext2_bitmap_set(buf, bit)   { var p = buf + bit / 8; store8(p, load8(p) | (1 << (bit & 7))); return 0; }
fn ext2_bitmap_clear(buf, bit) { var p = buf + bit / 8; store8(p, load8(p) & (0xFF ^ (1 << (bit & 7)))); return 0; }

# First 0-bit in [0, limit) of buf, or -1 if none.
fn ext2_bitmap_first_free(buf, limit) {
    var b = 0;
    while (b < limit) {
        if (ext2_bitmap_get(buf, b) == 0) { return b; }
        b = b + 1;
    }
    return 0 - 1;
}

# === uninit block-group materialization (WRITE arc 1.33.4 bite 3) ======
#
# A default `mkfs.ext4` (metadata_csum) flags metadata-free groups
# INODE_UNINIT / BLOCK_UNINIT and does NOT write their bitmaps — the on-disk
# bitmap block is stale/garbage, "calculable from the group descriptor"
# (ext4 disk layout § bg_flags). The allocators trust the on-disk bitmap, so
# allocating into an uninit group would scan garbage AND leave the UNINIT
# flag set → an e2fsck inconsistency on the real partition (the ^uninit_bg
# 67 MiB smoke is a single group 0 — always initialized — so it never caught
# this). Materialize = write the correct bitmap + clear the flag, on first
# allocation into the group.
#
# Empirically (dumpe2fs on a default mkfs.ext4): an UNINIT group reports its
# WHOLE range free — flex_bg relocates every group's bitmaps + inode table
# into the flex leader, and uninit groups are never sparse_super backups. So
# the materialized bitmap is "all free" + the standard trailing/padding bits.
# The guards below REFUSE (→ allocator skips the group) on any group that
# would carry metadata, so a wrong bitmap is never produced even on an FS
# that violates that invariant. Reference: Linux ext4_init_block_bitmap /
# ext4_mark_bitmap_end; e2fsprogs ext2fs_block_bitmap.

# 1 if g holds a superblock + GDT backup (sparse_super: group 0 + powers of
# 3/5/7; every group when sparse_super is off). Power-of-base via repeated
# multiply (group counts are tiny — ≤ a few thousand on base-stage FSes).
fn ext2_is_power_of(n, base) {
    var v = 1;
    while (v < n) { v = v * base; }
    if (v == n) { return 1; }
    return 0;
}
fn ext2_group_has_super(g) {
    if ((ext2_sb_feature_ro_compat(&ext2_sb_buf) & 0x1) == 0) { return 1; }  # not sparse_super
    if (g == 0) { return 1; }
    if (ext2_is_power_of(g, 3) == 1) { return 1; }   # also catches g==1 (3^0)
    if (ext2_is_power_of(g, 5) == 1) { return 1; }
    if (ext2_is_power_of(g, 7) == 1) { return 1; }
    return 0;
}
fn ext2_blk_in_group(blk, g_start, g_end) {
    if (blk < g_start) { return 0; }
    if (blk >= g_end)  { return 0; }
    return 1;
}

# Inode-table blocks per group = ceil(inodes_per_group * inode_size / bs).
fn ext2_itable_blocks() {
    return (ext2_inodes_per_group * ext2_inode_size + ext2_blocksize - 1) / ext2_blocksize;
}

# Materialize an INODE_UNINIT group's inode bitmap: all inodes free (the
# group has none in use — group 0, which holds reserved inodes, is never
# uninit), with bits beyond inodes_per_group padded to 1 (ext4_mark_bitmap_end).
# Writes the bitmap, sets its csum, clears INODE_UNINIT. Returns 0 / -1.
fn ext2_materialize_inode_bitmap(g) {
    var nbits = ext2_blocksize * 8;
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_bitmap_buf + z, 0); z = z + 1; }
    var pad = ext2_inodes_per_group;
    while (pad < nbits) { ext2_bitmap_set(&ext2_bitmap_buf, pad); pad = pad + 1; }
    var ibmp = ext2_grp_inode_bitmap(g);
    if (ext2_write_block(ibmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
    if (ext2_csum_on != 0) { ext2_set_inode_bitmap_csum(g, &ext2_bitmap_buf); }
    ext2_grp_set_bg_flags(g, ext2_grp_bg_flags(g) & (0xFFFF ^ 0x1));   # clear INODE_UNINIT
    return 0;
}

# Materialize a BLOCK_UNINIT group's block bitmap: all blocks free, with
# trailing blocks past s_blocks_count (final partial group) + bitmap-block
# padding beyond blocks_per_group marked used. REFUSES (-1 → allocator skips
# the group) if the group could carry metadata — a super backup, or its own
# bitmaps/inode-table landing in-group — so "all free" is never wrong.
fn ext2_materialize_block_bitmap(g) {
    if (ext2_group_has_super(g) != 0) { return 0 - 1; }    # backup group → has meta
    var bpg     = ext2_blocks_per_group;
    var g_start = ext2_first_data_block + g * bpg;
    var g_end   = g_start + bpg;
    if (ext2_blk_in_group(ext2_grp_block_bitmap(g), g_start, g_end) == 1) { return 0 - 1; }
    if (ext2_blk_in_group(ext2_grp_inode_bitmap(g), g_start, g_end) == 1) { return 0 - 1; }
    var itab = ext2_grp_inode_table(g);
    var itn  = ext2_itable_blocks();
    if (ext2_blk_in_group(itab, g_start, g_end) == 1) { return 0 - 1; }
    if (ext2_blk_in_group(itab + itn - 1, g_start, g_end) == 1) { return 0 - 1; }

    var nbits = ext2_blocksize * 8;
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_bitmap_buf + z, 0); z = z + 1; }
    # padding beyond blocks_per_group within the bitmap block
    var pad = bpg;
    while (pad < nbits) { ext2_bitmap_set(&ext2_bitmap_buf, pad); pad = pad + 1; }
    # trailing blocks past the FS end (final partial group)
    var total = ext2_sb_blocks_count(&ext2_sb_buf);
    if (g_end > total) {
        var b = total - g_start;
        if (b < 0) { b = 0; }
        while (b < bpg) { ext2_bitmap_set(&ext2_bitmap_buf, b); b = b + 1; }
    }
    var bbmp = ext2_grp_block_bitmap(g);
    if (ext2_write_block(bbmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
    if (ext2_csum_on != 0) { ext2_set_block_bitmap_csum(g, &ext2_bitmap_buf); }
    ext2_grp_set_bg_flags(g, ext2_grp_bg_flags(g) & (0xFFFF ^ 0x2));   # clear BLOCK_UNINIT
    return 0;
}

# --- block allocator --------------------------------------------------
# goal = a block to allocate near (its group is tried first); 0 = no hint.
# Returns the allocated block#, 0 on ENOSPC, -1 on IO/guard error.
fn ext2_alloc_block(goal) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }

    var ng = ext2_ngroups();
    var start = 0;
    if (goal > ext2_first_data_block) {
        start = (goal - ext2_first_data_block) / ext2_blocks_per_group;
    }
    if (start >= ng) { start = 0; }

    var gi = 0;
    while (gi < ng) {
        var group = start + gi;
        if (group >= ng) { group = group - ng; }      # wrap

        if (ext2_read_bgdt() != 0) { return 0 - 1; }
        if (ext2_grp_free_blocks(group) > 0) {
            # Materialize an uninit block group before trusting its on-disk
            # bitmap; skip it (try the next group) if it can't be safely
            # materialized (would carry metadata). 1.33.4 bite 3.
            var bg_ok = 1;
            if ((ext2_grp_bg_flags(group) & 0x2) != 0) {
                if (ext2_materialize_block_bitmap(group) != 0) { bg_ok = 0; }
            }
            if (bg_ok == 1) {
                var bbmp = ext2_grp_block_bitmap(group);
                if (ext2_read_block(bbmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
                var b = ext2_bitmap_first_free(&ext2_bitmap_buf, ext2_blocks_per_group);
                if (b >= 0) {
                    # set bit + write bitmap (step 1) — reserve before use
                    ext2_bitmap_set(&ext2_bitmap_buf, b);
                    if (ext2_write_block(bbmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
                    # accounting last: BGDT then SB (ext2_bgdt_buf still holds
                    # the descriptor table — bitmap read went to a separate buf)
                    if (ext2_csum_on != 0) { ext2_set_block_bitmap_csum(group, &ext2_bitmap_buf); }
                    ext2_grp_set_free_blocks(group, ext2_grp_free_blocks(group) - 1);
                    if (ext2_write_bgdt() != 0) { return 0 - 1; }
                    ext2_sb_set_free_blocks_count(&ext2_sb_buf, ext2_sb_free_blocks_count(&ext2_sb_buf) - 1);
                    if (ext2_write_superblock() != 0) { return 0 - 1; }
                    return ext2_first_data_block + group * ext2_blocks_per_group + b;
                }
            }
        }
        gi = gi + 1;
    }
    return 0;   # ENOSPC
}

# Free a data block. Caller must have cleared the pointer to it first
# (doc § 3 — free the pointer before the bit). Returns 0 / -1.
fn ext2_free_block(block_num) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (block_num < ext2_first_data_block) { return 0 - 1; }

    var rel   = block_num - ext2_first_data_block;
    var group = rel / ext2_blocks_per_group;
    var b     = rel - group * ext2_blocks_per_group;

    if (ext2_read_bgdt() != 0) { return 0 - 1; }
    var bbmp = ext2_grp_block_bitmap(group);
    if (ext2_read_block(bbmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
    if (ext2_bitmap_get(&ext2_bitmap_buf, b) == 0) { return 0 - 1; }   # double-free guard
    ext2_bitmap_clear(&ext2_bitmap_buf, b);
    if (ext2_write_block(bbmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
    if (ext2_csum_on != 0) { ext2_set_block_bitmap_csum(group, &ext2_bitmap_buf); }
    ext2_grp_set_free_blocks(group, ext2_grp_free_blocks(group) + 1);
    if (ext2_write_bgdt() != 0) { return 0 - 1; }
    ext2_sb_set_free_blocks_count(&ext2_sb_buf, ext2_sb_free_blocks_count(&ext2_sb_buf) + 1);
    if (ext2_write_superblock() != 0) { return 0 - 1; }
    return 0;
}

# --- inode allocator --------------------------------------------------
# is_dir != 0 bumps bg_used_dirs_count. Returns the (1-based) inode#, 0 if
# no free inode, -1 on IO/guard error. Reserved inodes (< s_first_ino) are
# pre-set in the bitmap by mkfs, so first-0-bit scan skips them. Group
# placement is first-fit (doc § 5 — Orlov / most-free deliberately not
# ported; placement is an optimization, not a correctness requirement).
fn ext2_alloc_inode(is_dir) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }

    var ng = ext2_ngroups();
    var group = 0;
    while (group < ng) {
        if (ext2_read_bgdt() != 0) { return 0 - 1; }
        if (ext2_grp_free_inodes(group) > 0) {
            # Materialize an INODE_UNINIT group's bitmap (all-free) + clear the
            # flag before trusting the on-disk bitmap. 1.33.4 bite 3.
            if ((ext2_grp_bg_flags(group) & 0x1) != 0) {
                if (ext2_materialize_inode_bitmap(group) != 0) { return 0 - 1; }
            }
            var ibmp = ext2_grp_inode_bitmap(group);
            if (ext2_read_block(ibmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
            var b = ext2_bitmap_first_free(&ext2_bitmap_buf, ext2_inodes_per_group);
            if (b >= 0) {
                ext2_bitmap_set(&ext2_bitmap_buf, b);
                if (ext2_write_block(ibmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
                if (ext2_csum_on != 0) {
                    ext2_set_inode_bitmap_csum(group, &ext2_bitmap_buf);
                    # shrink the never-used inode tail so e2fsck doesn't see
                    # this inode "in the unused inodes area". Only grows the
                    # used watermark downward; freeing never raises it back.
                    var wm = ext2_inodes_per_group - (b + 1);
                    if (ext2_grp_itable_unused(group) > wm) { ext2_grp_set_itable_unused(group, wm); }
                }
                ext2_grp_set_free_inodes(group, ext2_grp_free_inodes(group) - 1);
                if (is_dir != 0) {
                    ext2_grp_set_used_dirs(group, ext2_grp_used_dirs(group) + 1);
                }
                if (ext2_write_bgdt() != 0) { return 0 - 1; }
                ext2_sb_set_free_inodes_count(&ext2_sb_buf, ext2_sb_free_inodes_count(&ext2_sb_buf) - 1);
                if (ext2_write_superblock() != 0) { return 0 - 1; }
                return group * ext2_inodes_per_group + b + 1;
            }
        }
        group = group + 1;
    }
    return 0;   # no free inode
}

# Free an inode. is_dir != 0 decrements bg_used_dirs_count. Caller must
# have removed the dirent + freed the inode's data blocks first. 0 / -1.
fn ext2_free_inode(inode_num, is_dir) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (inode_num == 0)     { return 0 - 1; }

    var n     = inode_num - 1;
    var group = n / ext2_inodes_per_group;
    var b     = n - group * ext2_inodes_per_group;

    if (ext2_read_bgdt() != 0) { return 0 - 1; }
    var ibmp = ext2_grp_inode_bitmap(group);
    if (ext2_read_block(ibmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
    if (ext2_bitmap_get(&ext2_bitmap_buf, b) == 0) { return 0 - 1; }   # double-free guard
    ext2_bitmap_clear(&ext2_bitmap_buf, b);
    if (ext2_write_block(ibmp, &ext2_bitmap_buf) != 0) { return 0 - 1; }
    if (ext2_csum_on != 0) { ext2_set_inode_bitmap_csum(group, &ext2_bitmap_buf); }
    ext2_grp_set_free_inodes(group, ext2_grp_free_inodes(group) + 1);
    if (is_dir != 0) {
        ext2_grp_set_used_dirs(group, ext2_grp_used_dirs(group) - 1);
    }
    if (ext2_write_bgdt() != 0) { return 0 - 1; }
    ext2_sb_set_free_inodes_count(&ext2_sb_buf, ext2_sb_free_inodes_count(&ext2_sb_buf) + 1);
    if (ext2_write_superblock() != 0) { return 0 - 1; }
    return 0;
}

# --- ext4 extent walker (Phase 4) -------------------------------------
#
# Resolves a logical block# via the ext4 extent tree (used when an inode
# has i_flags & EXT4_EXTENTS_FL = 0x80000). Algorithm shape per FreeBSD
# `ext4_ext_find_extent` (audit § 5.3) — cleanest standalone RO reference;
# Linux's `extents.c` is tangled with delayed-allocation write paths.
#
# Tree shape (all structures 12 bytes, packed, little-endian):
#   ext4_extent_header:  eh_magic(2)=0xF30A | eh_entries(2) | eh_max(2)
#                        | eh_depth(2) | eh_generation(4)
#   ext4_extent       :  ee_block(4) | ee_len(2) | ee_start_hi(2) | ee_start_lo(4)
#   ext4_extent_idx   :  ei_block(4) | ei_leaf_lo(4) | ei_leaf_hi(2) | ei_unused(2)
#
# Root (when EXTENTS_FL set): bytes 0..11 of inode.i_block[] are the
# header; bytes 12..59 hold 4 × 12-byte entries (leaf entries if
# depth==0, index entries if depth>0).
#
# Returns physical block#, 0 for sparse hole / unwritten extent (caller
# zero-fills), -1 on error.

fn ext2_extent_header_validate(hdr) {
    var magic = ext2_load16_le(hdr, 0);
    if (magic != 0xF30A) { return 0; }
    var entries = ext2_load16_le(hdr, 2);
    var max     = ext2_load16_le(hdr, 4);
    if (entries > max) { return 0; }
    return 1;
}

fn ext2_extent_logical_to_physical(inode_buf, logical_block) {
    # The root header lives embedded in i_block[0..11] (inode_buf + 40).
    var hdr = inode_buf + 40;
    if (ext2_extent_header_validate(hdr) == 0) {
        kprintln("ext2: extent root: bad magic / entries", 38);
        return 0 - 1;
    }

    var depth = ext2_load16_le(hdr, 6);
    if (depth > 5) {
        kprintln("ext2: extent depth > 5 unsupported", 34);
        return 0 - 1;
    }

    # Walk index nodes from root depth down to leaf (depth==0).
    # At each level, find the LARGEST ei_block <= logical_block, follow
    # ei_leaf_hi:lo to the next-level block, read it into scratch.
    # The root walks against i_block[]; subsequent levels walk against
    # ext2_extent_buf.
    var current_hdr = hdr;
    var entries_off = 12;   # entries start after the 12-byte header

    while (depth > 0) {
        var entries = ext2_load16_le(current_hdr, 2);
        if (entries == 0) { return 0; }   # empty tree — sparse

        # Linear scan: at the root, max is 4 (60 - 12 = 48 / 12 = 4);
        # at deeper blocks, max is (blocksize - 12) / 12, fine to scan
        # linearly given small N per level. Find the LARGEST ei_block <=
        # target; that's the entry whose subtree covers logical_block.
        var pick_idx  = 0 - 1;
        var prev_block = 0;
        for (var i = 0; i < entries; i = i + 1) {
            var entry = current_hdr + entries_off + i * 12;
            var ei_block = ext2_load32_le(entry, 0);
            if (ei_block <= logical_block) {
                pick_idx   = i;
                prev_block = ei_block;
            } else {
                break;   # entries are sorted ascending by ei_block
            }
        }
        if (pick_idx < 0) { return 0; }   # logical_block before first entry — sparse

        var pick = current_hdr + entries_off + pick_idx * 12;
        var leaf_lo = ext2_load32_le(pick, 4);
        var leaf_hi = ext2_load16_le(pick, 8);
        # Note (audit § 5.4): Linux uses `<< 31 << 1` to defend against
        # u32 ext4_fsblk_t builds where `<< 32` is UB. Cyrius u64 is
        # unambiguous so `<< 32` is fine here.
        var next_phys = leaf_lo | (leaf_hi << 32);
        if (next_phys == 0) { return 0; }   # sparse hole

        if (ext2_read_block(next_phys, &ext2_extent_buf) != 0) { return 0 - 1; }

        # Re-validate the new level's header.
        if (ext2_extent_header_validate(&ext2_extent_buf) == 0) {
            kprintln("ext2: extent internal: bad magic", 32);
            return 0 - 1;
        }
        var new_depth = ext2_load16_le(&ext2_extent_buf, 6);
        if (new_depth != depth - 1) {
            kprintln("ext2: extent depth mismatch", 27);
            return 0 - 1;
        }
        current_hdr = &ext2_extent_buf;
        depth = new_depth;
    }

    # Leaf: find ext4_extent where ee_block <= logical_block <
    # ee_block + actual_len.
    var leaf_entries = ext2_load16_le(current_hdr, 2);
    if (leaf_entries == 0) { return 0; }

    for (var i = 0; i < leaf_entries; i = i + 1) {
        var entry = current_hdr + entries_off + i * 12;
        var ee_block    = ext2_load32_le(entry, 0);
        var ee_len_raw  = ext2_load16_le(entry, 4);
        var ee_start_hi = ext2_load16_le(entry, 6);
        var ee_start_lo = ext2_load32_le(entry, 8);

        # ee_len > 32768 means unwritten extent (audit § 5.5). actual_len
        # = ee_len - 32768; physical blocks ARE allocated but content
        # undefined → zero-fill at caller (we return 0 to signal sparse).
        var unwritten = 0;
        var actual_len = ee_len_raw;
        if (ee_len_raw > 0x8000) {
            unwritten  = 1;
            actual_len = ee_len_raw - 0x8000;
        }

        if (logical_block < ee_block) { return 0; }   # before first → sparse
        if (logical_block >= ee_block + actual_len) { continue; }   # past this extent

        if (unwritten == 1) { return 0; }   # zero-fill at caller

        var phys_start = ee_start_lo | (ee_start_hi << 32);
        return phys_start + (logical_block - ee_block);
    }
    return 0;   # past all leaf entries → sparse / EOF
}

# --- ext4 extent ALLOCATION (write — 1.37.0 depth-0, 1.37.1 depth-1, 1.37.3 depth-2) ---
#
# Grows an EXTENTS_FL inode by allocating a block and mapping it via the extent
# tree. Depth 0 = inline root (≤ 4 extents, in the inode); depth 1 = inline index
# entries (≤ 4) → leaf BLOCKs (≤ eh_max extents each); depth 2 = inline index → an
# INDEX block (≤ eh_max leaf pointers) → leaf blocks. The tree grows on demand:
# 0→1 (grow_indepth, inline root full) and 1→2 (grow_indepth2, inline index full).
# Sibling index blocks / depth>2 are deferred (unreachable for realistic files —
# would need eh_max full leaves). Multi-source: Linux ext4_ext_insert_extent +
# ext4_ext_grow_indepth, FreeBSD ext4_ext_*, e2fsprogs ext2fs_extent_insert. See
# agnosticos/docs/development/ext4-extent-alloc-prior-art.md.

# Extent tree-block (leaf/index) checksum tail (metadata_csum only). Same seed
# as the inode csum: crc32c(crc32c(crc32c(seed, ino), i_generation), node[0..tail))
# stored at EXT4_EXTENT_TAIL_OFFSET = 12 + eh_max*12. The INLINE ROOT carries no
# tail (the inode checksum covers it); only on-disk tree blocks need this.
fn ext2_extent_node_csum_stamp(node_buf, inode_num, inode_buf) {
    if (ext2_csum_on == 0) { return 0; }
    var tail = 12 + ext2_load16_le(node_buf, 4) * 12;          # after eh_max entries
    var ile[4]; ext2_store32_le(&ile, 0, inode_num);
    var crc = ext2_crc32c(ext2_csum_seed, &ile, 4);
    var gle[4]; ext2_store32_le(&gle, 0, ext2_load32_le(inode_buf, 100));   # i_generation
    crc = ext2_crc32c(crc, &gle, 4);
    crc = ext2_crc32c(crc, node_buf, tail);
    ext2_store32_le(node_buf, tail, crc);
    return 0;
}

# Grow depth 0 → 1: spill the inline root's extents into a freshly-allocated
# leaf block, then rewrite the root as a single index entry pointing at it.
# Returns the leaf block# (>0) or 0 on failure. Uses ext2_extent_buf as the
# node scratch. Counts the leaf toward i_blocks (a tree block).
fn ext2_extent_grow_indepth(inode_buf, inode_num) {
    var hdr = inode_buf + 40;
    var entries = ext2_load16_le(hdr, 2);
    var last = hdr + 12 + (entries - 1) * 12;
    var last_phys = ext2_load32_le(last, 8) | (ext2_load16_le(last, 6) << 32);
    var leafblk = ext2_alloc_block(last_phys + 1);
    if (leafblk <= 0) { return 0; }
    var lmax = (ext2_blocksize - 12) / 12;
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_extent_buf + z, 0); z = z + 1; }
    ext2_store16_le(&ext2_extent_buf, 0, 0xF30A);              # eh_magic
    ext2_store16_le(&ext2_extent_buf, 2, entries);            # eh_entries (spilled)
    ext2_store16_le(&ext2_extent_buf, 4, lmax);               # eh_max
    ext2_store16_le(&ext2_extent_buf, 6, 0);                  # eh_depth = 0 (leaf)
    var c = 0;
    while (c < entries * 12) { store8(&ext2_extent_buf + 12 + c, load8(hdr + 12 + c)); c = c + 1; }
    ext2_extent_node_csum_stamp(&ext2_extent_buf, inode_num, inode_buf);
    if (ext2_write_block(leafblk, &ext2_extent_buf) != 0) { ext2_free_block(leafblk); return 0; }
    # Rewrite the inline root as depth 1 with one index entry → leafblk.
    var first_block = ext2_load32_le(hdr + 12, 0);            # lowest logical
    var k = 12;
    while (k < 60) { store8(hdr + k, 0); k = k + 1; }
    ext2_store16_le(hdr, 2, 1);                               # eh_entries = 1
    ext2_store16_le(hdr, 4, 4);                               # eh_max (inline root)
    ext2_store16_le(hdr, 6, 1);                               # eh_depth = 1
    var ix = hdr + 12;
    ext2_store32_le(ix, 0, first_block);                      # ei_block
    ext2_store32_le(ix, 4, leafblk & 0xFFFFFFFF);             # ei_leaf_lo
    ext2_store16_le(ix, 8, (leafblk >> 32) & 0xFFFF);         # ei_leaf_hi
    ext2_store16_le(ix, 10, 0);                               # ei_unused
    ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;        # leaf block counts toward i_blocks
    return leafblk;
}

# Place an already-allocated block `nb` for logical `lblk` into a leaf BLOCK:
# extend the last extent (contiguous) or insert a new one (if room). Restamps
# the node csum + writes the leaf. Returns 1 on success, 0 if the leaf is full
# (→ 1.37.2) / out-of-order / IO error (caller frees nb). Uses ext2_extent_buf.
fn ext2_extent_leaf_place(leafblk, lblk, nb, inode_num, inode_buf) {
    if (ext2_read_block(leafblk, &ext2_extent_buf) != 0) { return 0; }
    if (ext2_extent_header_validate(&ext2_extent_buf) == 0) { return 0; }
    var le = ext2_load16_le(&ext2_extent_buf, 2);
    var lm = ext2_load16_le(&ext2_extent_buf, 4);
    var placed = 0;
    if (le == 0) {
        var e0 = &ext2_extent_buf + 12;
        ext2_store32_le(e0, 0, lblk); ext2_store16_le(e0, 4, 1);
        ext2_store16_le(e0, 6, (nb >> 32) & 0xFFFF); ext2_store32_le(e0, 8, nb & 0xFFFFFFFF);
        ext2_store16_le(&ext2_extent_buf, 2, 1);
        placed = 1;
    } else {
        var lst = &ext2_extent_buf + 12 + (le - 1) * 12;
        var lb = ext2_load32_le(lst, 0);
        var ll = ext2_load16_le(lst, 4);
        var lp = ext2_load32_le(lst, 8) | (ext2_load16_le(lst, 6) << 32);
        if (lblk == lb + ll) { if (nb == lp + ll) { if (ll < 0x8000) {
                    ext2_store16_le(lst, 4, ll + 1);
                    placed = 1;
                }}}
        if (placed == 0) {
            if (lblk < lb + ll) { return 0; }                # out-of-order — deferred
            if (le >= lm) { return 0; }                       # leaf full → 1.37.2
            var e = &ext2_extent_buf + 12 + le * 12;
            ext2_store32_le(e, 0, lblk); ext2_store16_le(e, 4, 1);
            ext2_store16_le(e, 6, (nb >> 32) & 0xFFFF); ext2_store32_le(e, 8, nb & 0xFFFFFFFF);
            ext2_store16_le(&ext2_extent_buf, 2, le + 1);
            placed = 1;
        }
    }
    if (placed == 0) { return 0; }
    ext2_extent_node_csum_stamp(&ext2_extent_buf, inode_num, inode_buf);
    if (ext2_write_block(leafblk, &ext2_extent_buf) != 0) { return 0; }
    return 1;
}

# Add a NEW sibling leaf to a depth-1 tree: build a leaf block holding the one
# extent {lblk, nbd}, then append an index entry to the inline root pointing at
# it (1.37.2 — when the rightmost leaf is full). Returns the leaf block# (>0) or
# 0 if the root index is also full (→ depth-2 grow, deferred to 1.37.3) / error.
# The new data block `nbd` is the caller's (counted there); this counts the leaf.
fn ext2_extent_add_sibling_leaf(inode_buf, lblk, nbd, inode_num) {
    var hdr = inode_buf + 40;
    var nent = ext2_load16_le(hdr, 2);
    if (nent >= 4) {                                          # inline root index full
        kprintln("ext2: extent root index full -- depth-2 deferred (1.37.3)", 56);
        return 0;
    }
    var newleaf = ext2_alloc_block(nbd);                      # goal: near the data block
    if (newleaf <= 0) { return 0; }
    var lmax = (ext2_blocksize - 12) / 12;
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_extent_buf + z, 0); z = z + 1; }
    ext2_store16_le(&ext2_extent_buf, 0, 0xF30A);             # eh_magic
    ext2_store16_le(&ext2_extent_buf, 2, 1);                 # eh_entries = 1
    ext2_store16_le(&ext2_extent_buf, 4, lmax);              # eh_max
    ext2_store16_le(&ext2_extent_buf, 6, 0);                 # eh_depth = 0 (leaf)
    var e0 = &ext2_extent_buf + 12;
    ext2_store32_le(e0, 0, lblk); ext2_store16_le(e0, 4, 1);
    ext2_store16_le(e0, 6, (nbd >> 32) & 0xFFFF); ext2_store32_le(e0, 8, nbd & 0xFFFFFFFF);
    ext2_extent_node_csum_stamp(&ext2_extent_buf, inode_num, inode_buf);
    if (ext2_write_block(newleaf, &ext2_extent_buf) != 0) { ext2_free_block(newleaf); return 0; }
    var ix = hdr + 12 + nent * 12;                            # next free root index slot
    ext2_store32_le(ix, 0, lblk);                            # ei_block = first logical in this leaf
    ext2_store32_le(ix, 4, newleaf & 0xFFFFFFFF);            # ei_leaf_lo
    ext2_store16_le(ix, 8, (newleaf >> 32) & 0xFFFF);        # ei_leaf_hi
    ext2_store16_le(ix, 10, 0);                              # ei_unused
    ext2_store16_le(hdr, 2, nent + 1);                       # eh_entries++
    ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;       # leaf tree block counts toward i_blocks
    return newleaf;
}

# Grow depth 1 → 2: spill the inline root's 4 INDEX entries into a freshly-
# allocated INDEX block (eh_depth=1, points to the existing leaves), then rewrite
# the root as a single index entry → that index block (eh_depth=2). Mirrors
# ext2_extent_grow_indepth but one level up. Returns the index block# (>0) or 0.
# Counts the index block toward i_blocks. Uses ext2_extent_buf as scratch.
fn ext2_extent_grow_indepth2(inode_buf, inode_num) {
    var hdr = inode_buf + 40;
    var entries = ext2_load16_le(hdr, 2);                     # 4 (inline root index full)
    var lastix = hdr + 12 + (entries - 1) * 12;
    var last_leaf = ext2_load32_le(lastix, 4) | (ext2_load16_le(lastix, 8) << 32);
    var idxblk = ext2_alloc_block(last_leaf + 1);
    if (idxblk <= 0) { return 0; }
    var lmax = (ext2_blocksize - 12) / 12;
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_extent_buf + z, 0); z = z + 1; }
    ext2_store16_le(&ext2_extent_buf, 0, 0xF30A);             # eh_magic
    ext2_store16_le(&ext2_extent_buf, 2, entries);           # eh_entries (the 4 spilled index entries)
    ext2_store16_le(&ext2_extent_buf, 4, lmax);              # eh_max
    ext2_store16_le(&ext2_extent_buf, 6, 1);                 # eh_depth = 1 (index node → leaves)
    var c = 0;
    while (c < entries * 12) { store8(&ext2_extent_buf + 12 + c, load8(hdr + 12 + c)); c = c + 1; }
    ext2_extent_node_csum_stamp(&ext2_extent_buf, inode_num, inode_buf);
    if (ext2_write_block(idxblk, &ext2_extent_buf) != 0) { ext2_free_block(idxblk); return 0; }
    # Rewrite the inline root as depth 2 with one index entry → idxblk.
    var first_block = ext2_load32_le(hdr + 12, 0);           # lowest logical
    var k = 12;
    while (k < 60) { store8(hdr + k, 0); k = k + 1; }
    ext2_store16_le(hdr, 2, 1);                              # eh_entries = 1
    ext2_store16_le(hdr, 4, 4);                              # eh_max (inline root)
    ext2_store16_le(hdr, 6, 2);                              # eh_depth = 2
    var ix = hdr + 12;
    ext2_store32_le(ix, 0, first_block);                     # ei_block
    ext2_store32_le(ix, 4, idxblk & 0xFFFFFFFF);             # ei_leaf_lo → idxblk
    ext2_store16_le(ix, 8, (idxblk >> 32) & 0xFFFF);         # ei_leaf_hi
    ext2_store16_le(ix, 10, 0);                              # ei_unused
    ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;       # index block counts toward i_blocks
    return idxblk;
}

# Add a NEW sibling leaf under a depth-1 INDEX block `idxblk`: build a leaf
# holding the one extent {lblk, nbd}, then append an index entry to idxblk
# pointing at it (the depth-2 analog of add_sibling_leaf — root index entry →
# index-block index entry). Returns the new leaf# (>0) or 0 if the index block
# is also full (→ sibling index block / depth-3, deferred — unreachable for any
# realistic file: needs eh_max full leaves). Re-stamps the index block's node
# csum. Holds idxblk in ext2_indirect_buf_l1 while the leaf builds in
# ext2_extent_buf (extent inodes never use the single-indirect scratch).
fn ext2_extent_add_leaf_to_idxblk(idxblk, lblk, nbd, inode_num, inode_buf) {
    if (ext2_read_block(idxblk, &ext2_indirect_buf_l1) != 0) { return 0; }
    if (ext2_extent_header_validate(&ext2_indirect_buf_l1) == 0) { return 0; }
    var inent = ext2_load16_le(&ext2_indirect_buf_l1, 2);
    var imax  = ext2_load16_le(&ext2_indirect_buf_l1, 4);
    if (inent >= imax) {                                      # index block full → deeper split deferred
        kprintln("ext2: extent index block full -- deeper split deferred", 53);
        return 0;
    }
    var newleaf = ext2_alloc_block(nbd);                      # goal: near the data block
    if (newleaf <= 0) { return 0; }
    var lmax = (ext2_blocksize - 12) / 12;
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_extent_buf + z, 0); z = z + 1; }
    ext2_store16_le(&ext2_extent_buf, 0, 0xF30A);             # eh_magic
    ext2_store16_le(&ext2_extent_buf, 2, 1);                 # eh_entries = 1
    ext2_store16_le(&ext2_extent_buf, 4, lmax);              # eh_max
    ext2_store16_le(&ext2_extent_buf, 6, 0);                 # eh_depth = 0 (leaf)
    var e0 = &ext2_extent_buf + 12;
    ext2_store32_le(e0, 0, lblk); ext2_store16_le(e0, 4, 1);
    ext2_store16_le(e0, 6, (nbd >> 32) & 0xFFFF); ext2_store32_le(e0, 8, nbd & 0xFFFFFFFF);
    ext2_extent_node_csum_stamp(&ext2_extent_buf, inode_num, inode_buf);
    if (ext2_write_block(newleaf, &ext2_extent_buf) != 0) { ext2_free_block(newleaf); return 0; }
    var ix = &ext2_indirect_buf_l1 + 12 + inent * 12;         # next free index slot in idxblk
    ext2_store32_le(ix, 0, lblk);                            # ei_block = first logical in this leaf
    ext2_store32_le(ix, 4, newleaf & 0xFFFFFFFF);            # ei_leaf_lo
    ext2_store16_le(ix, 8, (newleaf >> 32) & 0xFFFF);        # ei_leaf_hi
    ext2_store16_le(ix, 10, 0);                              # ei_unused
    ext2_store16_le(&ext2_indirect_buf_l1, 2, inent + 1);    # eh_entries++
    ext2_extent_node_csum_stamp(&ext2_indirect_buf_l1, inode_num, inode_buf);
    if (ext2_write_block(idxblk, &ext2_indirect_buf_l1) != 0) { return 0; }
    ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;       # leaf tree block counts toward i_blocks
    return newleaf;
}

fn ext2_extent_append_block(inode_buf, lblk, inode_num) {
    var hdr = inode_buf + 40;
    if (ext2_extent_header_validate(hdr) == 0) { return 0; }
    var depth = ext2_load16_le(hdr, 6);
    if (depth > 2) { kprintln("ext2: extent depth>2 append deferred", 36); return 0; }

    # --- depth 2: root → rightmost index block → rightmost leaf; extend / insert
    # / sibling-leaf-in-index-block. (Sibling index block / depth-3 is deferred —
    # unreachable for realistic files: would need eh_max full leaves.) ---
    if (depth == 2) {
        var rnent = ext2_load16_le(hdr, 2);
        if (rnent == 0) { return 0; }
        var rix = hdr + 12 + (rnent - 1) * 12;                # rightmost root index → idxblk
        var idxblk = ext2_load32_le(rix, 4) | (ext2_load16_le(rix, 8) << 32);
        if (idxblk == 0) { return 0; }
        if (ext2_read_block(idxblk, &ext2_indirect_buf_l1) != 0) { return 0; }
        if (ext2_extent_header_validate(&ext2_indirect_buf_l1) == 0) { return 0; }
        var inent = ext2_load16_le(&ext2_indirect_buf_l1, 2);
        if (inent == 0) { return 0; }
        var iix = &ext2_indirect_buf_l1 + 12 + (inent - 1) * 12;   # rightmost idxblk index → leaf
        var leafblk2 = ext2_load32_le(iix, 4) | (ext2_load16_le(iix, 8) << 32);
        if (leafblk2 == 0) { return 0; }
        if (ext2_read_block(leafblk2, &ext2_extent_buf) != 0) { return 0; }   # peek leaf
        var le2 = ext2_load16_le(&ext2_extent_buf, 2);
        var lm2 = ext2_load16_le(&ext2_extent_buf, 4);
        var lb2 = 0; var ll2 = 0; var lp2 = 0; var goal2 = 0;
        if (le2 > 0) {
            var lst2 = &ext2_extent_buf + 12 + (le2 - 1) * 12;
            lb2 = ext2_load32_le(lst2, 0); ll2 = ext2_load16_le(lst2, 4);
            lp2 = ext2_load32_le(lst2, 8) | (ext2_load16_le(lst2, 6) << 32);
            goal2 = lp2 + ll2;
        }
        var nbd2 = ext2_alloc_block(goal2);
        if (nbd2 <= 0) { return 0; }
        if (le2 > 0) { if (lblk < lb2 + ll2) { ext2_free_block(nbd2); return 0; } }  # out-of-order — deferred
        var is_ext2 = 0;
        if (le2 > 0) { if (lblk == lb2 + ll2) { if (nbd2 == lp2 + ll2) { if (ll2 < 0x8000) { is_ext2 = 1; } } } }
        var use_pl2 = 0;
        if (is_ext2 == 1) { use_pl2 = 1; }
        if (le2 < lm2) { use_pl2 = 1; }
        if (use_pl2 == 1) {                                   # extend last / insert into a non-full leaf
            if (ext2_extent_leaf_place(leafblk2, lblk, nbd2, inode_num, inode_buf) == 0) { ext2_free_block(nbd2); return 0; }
        } else {                                              # leaf full + new entry → sibling leaf under idxblk
            if (ext2_extent_add_leaf_to_idxblk(idxblk, lblk, nbd2, inode_num, inode_buf) == 0) { ext2_free_block(nbd2); return 0; }
        }
        ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
        ext2_bmap_was_new = 1;
        return nbd2;
    }

    # --- depth 1: descend to the rightmost leaf; extend / insert / split ---
    if (depth == 1) {
        var nent = ext2_load16_le(hdr, 2);
        if (nent == 0) { return 0; }
        var ix = hdr + 12 + (nent - 1) * 12;                  # rightmost index entry
        var leafblk = ext2_load32_le(ix, 4) | (ext2_load16_le(ix, 8) << 32);
        if (leafblk == 0) { return 0; }
        if (ext2_read_block(leafblk, &ext2_extent_buf) != 0) { return 0; }   # peek leaf
        var le = ext2_load16_le(&ext2_extent_buf, 2);
        var lm = ext2_load16_le(&ext2_extent_buf, 4);
        var lb = 0; var ll = 0; var lp = 0; var goal = 0;
        if (le > 0) {
            var lst = &ext2_extent_buf + 12 + (le - 1) * 12;
            lb = ext2_load32_le(lst, 0); ll = ext2_load16_le(lst, 4);
            lp = ext2_load32_le(lst, 8) | (ext2_load16_le(lst, 6) << 32);
            goal = lp + ll;
        }
        var nbd = ext2_alloc_block(goal);
        if (nbd <= 0) { return 0; }
        if (le > 0) { if (lblk < lb + ll) { ext2_free_block(nbd); return 0; } }  # out-of-order — deferred
        var is_extend = 0;
        if (le > 0) { if (lblk == lb + ll) { if (nbd == lp + ll) { if (ll < 0x8000) { is_extend = 1; } } } }
        var use_place = 0;
        if (is_extend == 1) { use_place = 1; }
        if (le < lm) { use_place = 1; }
        if (use_place == 1) {                                 # extend last, or insert into a non-full leaf
            if (ext2_extent_leaf_place(leafblk, lblk, nbd, inode_num, inode_buf) == 0) { ext2_free_block(nbd); return 0; }
        } else {                                              # leaf full + new entry
            var nent_root = ext2_load16_le(hdr, 2);
            if (nent_root < 4) {                              # inline root has room → sibling leaf
                if (ext2_extent_add_sibling_leaf(inode_buf, lblk, nbd, inode_num) == 0) { ext2_free_block(nbd); return 0; }
            } else {                                          # inline root full → grow depth 1→2, place in new index block
                var idxblk1 = ext2_extent_grow_indepth2(inode_buf, inode_num);
                if (idxblk1 <= 0) { ext2_free_block(nbd); return 0; }
                if (ext2_extent_add_leaf_to_idxblk(idxblk1, lblk, nbd, inode_num, inode_buf) == 0) { ext2_free_block(nbd); return 0; }
            }
        }
        ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
        ext2_bmap_was_new = 1;
        return nbd;
    }

    # --- depth 0: inline root ---
    var entries = ext2_load16_le(hdr, 2);
    var max     = ext2_load16_le(hdr, 4);

    if (entries == 0) {                                       # empty tree → first extent
        var nb0 = ext2_alloc_block(0);
        if (nb0 <= 0) { return 0; }
        var e0 = hdr + 12;
        ext2_store32_le(e0, 0, lblk); ext2_store16_le(e0, 4, 1);
        ext2_store16_le(e0, 6, (nb0 >> 32) & 0xFFFF); ext2_store32_le(e0, 8, nb0 & 0xFFFFFFFF);
        ext2_store16_le(hdr, 2, 1);
        ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
        ext2_bmap_was_new = 1;
        return nb0;
    }

    var last = hdr + 12 + (entries - 1) * 12;
    var last_block = ext2_load32_le(last, 0);
    var last_len   = ext2_load16_le(last, 4);
    var last_phys  = ext2_load32_le(last, 8) | (ext2_load16_le(last, 6) << 32);
    if (lblk < last_block + last_len) { return 0; }           # out-of-order hole fill — deferred

    var goal = last_phys + last_len;
    var nb = ext2_alloc_block(goal);
    if (nb <= 0) { return 0; }

    # Extend the last extent (no new entry — works even at entries==max).
    if (lblk == last_block + last_len) { if (nb == last_phys + last_len) { if (last_len < 0x8000) {
                ext2_store16_le(last, 4, last_len + 1);
                ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
                ext2_bmap_was_new = 1;
                return nb;
            }}}

    # New entry needed: insert into the inline root if it has room.
    if (entries < max) {
        var e = hdr + 12 + entries * 12;
        ext2_store32_le(e, 0, lblk); ext2_store16_le(e, 4, 1);
        ext2_store16_le(e, 6, (nb >> 32) & 0xFFFF); ext2_store32_le(e, 8, nb & 0xFFFFFFFF);
        ext2_store16_le(hdr, 2, entries + 1);
        ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
        ext2_bmap_was_new = 1;
        return nb;
    }

    # Inline root full → grow to depth 1, then place nb into the new leaf (1.37.1).
    var leafblk = ext2_extent_grow_indepth(inode_buf, inode_num);
    if (leafblk <= 0) { ext2_free_block(nb); return 0; }
    if (ext2_extent_leaf_place(leafblk, lblk, nb, inode_num, inode_buf) == 0) {
        ext2_free_block(nb); return 0;
    }
    ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
    ext2_bmap_was_new = 1;
    return nb;
}

# Resolve-or-append for an EXTENTS_FL inode: return the existing physical block
# for `lblk` (overwrite in place — works at any depth via the reader) or append
# a new one (depth 0/1). Mirrors ext2_bmap_alloc's was_new contract.
fn ext2_extent_bmap_alloc(inode_buf, lblk, inode_num) {
    ext2_bmap_was_new = 0;
    if (ext2_write_ok == 0) { return 0; }
    var existing = ext2_extent_logical_to_physical(inode_buf, lblk);
    if (existing > 0) { return existing; }     # already mapped → overwrite in place
    if (existing < 0) { return 0; }            # tree error
    return ext2_extent_append_block(inode_buf, lblk, inode_num);   # sparse/EOF → append
}

# --- Logical → physical block mapping (Phase 2 indirect + Phase 4 extents) --
#
# Maps a logical block# within a file to the physical FS block#. Dispatch:
#   - if inode.i_flags & EXT4_EXTENTS_FL (0x80000) → ext4 extent walker
#   - else → ext2 indirect-tree walker (i_block[0..14])
#
# The ext2 indirect tree (audit § 4.2):
#   i_block[0..11]   12 direct block pointers       (logical 0..11)
#   i_block[12]      single-indirect → ptrs entries (logical 12..11+ptrs)
#   i_block[13]      double-indirect (two levels)
#   i_block[14]      triple-indirect (three levels)
#
# where `ptrs = blocksize / 4`. For 4K blocks, ptrs = 1024 → file size cap
# ~4 TB (further capped by 64-bit i_size). Returns 0 for sparse holes
# (block# 0 is reserved by the FS) and for blocks beyond the file's
# allocated extent; -1 on disk-read failure.

fn ext2_logical_to_physical(inode_buf, logical_block) {
    # Phase 4 dispatch: ext4 extents inodes take a different code path
    # (Linux switched ext4 to extents as the default in 2008).
    var flags = ext2_inode_flags(inode_buf);
    if ((flags & 0x80000) != 0) {
        return ext2_extent_logical_to_physical(inode_buf, logical_block);
    }

    var ptrs = ext2_blocksize / 4;   # entries per indirect block

    # --- Direct (logical 0..11) ---
    if (logical_block < 12) {
        return ext2_inode_block_ptr(inode_buf, logical_block);
    }

    # --- Single-indirect (logical 12 .. 11 + ptrs) ---
    var ind_off = logical_block - 12;
    if (ind_off < ptrs) {
        var l1 = ext2_inode_block_ptr(inode_buf, 12);
        if (l1 == 0) { return 0; }   # sparse hole at the indirect-root level
        if (ext2_read_block(l1, &ext2_indirect_buf_l1) != 0) { return 0 - 1; }
        return ext2_load32_le(&ext2_indirect_buf_l1, ind_off * 4);
    }

    # --- Double-indirect (logical 12+ptrs .. 11+ptrs+ptrs*ptrs) ---
    var dind_off = logical_block - 12 - ptrs;
    var dind_double_cap = ptrs * ptrs;
    if (dind_off < dind_double_cap) {
        var d1 = ext2_inode_block_ptr(inode_buf, 13);
        if (d1 == 0) { return 0; }
        if (ext2_read_block(d1, &ext2_indirect_buf_l1) != 0) { return 0 - 1; }
        var d_level1_idx = dind_off / ptrs;
        var d_level2_idx = dind_off - d_level1_idx * ptrs;   # dind_off % ptrs
        var d2 = ext2_load32_le(&ext2_indirect_buf_l1, d_level1_idx * 4);
        if (d2 == 0) { return 0; }
        if (ext2_read_block(d2, &ext2_indirect_buf_l2) != 0) { return 0 - 1; }
        return ext2_load32_le(&ext2_indirect_buf_l2, d_level2_idx * 4);
    }

    # --- Triple-indirect ---
    var tind_off = logical_block - 12 - ptrs - dind_double_cap;
    var tind_triple_cap = ptrs * ptrs * ptrs;
    if (tind_off < tind_triple_cap) {
        var t1 = ext2_inode_block_ptr(inode_buf, 14);
        if (t1 == 0) { return 0; }
        if (ext2_read_block(t1, &ext2_indirect_buf_l1) != 0) { return 0 - 1; }
        var t_level1_idx = tind_off / dind_double_cap;
        var t_l1_rem     = tind_off - t_level1_idx * dind_double_cap;
        var t_level2_idx = t_l1_rem / ptrs;
        var t_level3_idx = t_l1_rem - t_level2_idx * ptrs;
        var t2 = ext2_load32_le(&ext2_indirect_buf_l1, t_level1_idx * 4);
        if (t2 == 0) { return 0; }
        if (ext2_read_block(t2, &ext2_indirect_buf_l2) != 0) { return 0 - 1; }
        var t3 = ext2_load32_le(&ext2_indirect_buf_l2, t_level2_idx * 4);
        if (t3 == 0) { return 0; }
        if (ext2_read_block(t3, &ext2_indirect_buf_l3) != 0) { return 0 - 1; }
        return ext2_load32_le(&ext2_indirect_buf_l3, t_level3_idx * 4);
    }

    # Beyond triple-indirect: file size physically impossible on ext2.
    kprintln("ext2: logical block beyond triple-indirect cap", 46);
    return 0;
}

# --- File read at arbitrary offset (Phase 2 — covers direct + indirect) --
#
# Reads up to maxlen bytes from a regular file starting at byte offset
# `offset`. Walks logical blocks via ext2_logical_to_physical (handles
# direct + single + double + triple indirection). Returns bytes_read on
# success (>= 0; can be < maxlen if hitting EOF or sparse tail), -1 on
# error.
#
# The offset-aware shape is what VFS integration in Phase 3 will consume
# (vfs_read tracks per-FD offset and calls ext2_read_at on each invocation).
# Phase 4 will add ext4 extents dispatch: when inode.i_flags & EXTENTS_FL
# is set, use the extent walker instead of the indirect tree.

fn ext2_read_at(inode_num, offset, buf, maxlen) {
    if (ext2_active == 0) { return 0 - 1; }
    if (buf == 0)         { return 0 - 1; }

    # Load inode.
    if (ext2_get_inode(inode_num, &ext2_inode_buf) != 0) {
        return 0 - 1;
    }

    # Refuse non-regular files (read paths handle regular file content
    # only; dirs use ext2_print_dir / ext2_dir_lookup; symlinks deferred).
    var mode = ext2_inode_mode(&ext2_inode_buf);
    var ftype = mode & 0xF000;
    if (ftype != 0x8000) {
        kprintln("ext2: ext2_read_at on non-regular inode", 39);
        return 0 - 1;
    }
    # Phase 4: ext4 EXTENTS_FL inodes ARE supported (dispatch in
    # ext2_logical_to_physical). No refusal here.

    # Effective read window = min(file_size - offset, maxlen).
    var file_size = ext2_inode_filesize(&ext2_inode_buf);
    if (offset >= file_size) { return 0; }
    var to_read = file_size - offset;
    if (to_read > maxlen) { to_read = maxlen; }
    if (to_read == 0) { return 0; }

    # Walk logical-block-by-logical-block. For each block, look up the
    # physical block# via ext2_logical_to_physical (handles direct +
    # indirect tree transparently), read it into scratch, copy the
    # in-range slice into caller's buf. Repeat until to_read bytes
    # copied. The first block may start mid-block (offset & blockmask);
    # the last block may end mid-block.
    var bytes_done = 0;
    while (bytes_done < to_read) {
        var abs_off = offset + bytes_done;
        var logical = abs_off / ext2_blocksize;
        var off_in_block = abs_off - logical * ext2_blocksize;

        var phys = ext2_logical_to_physical(&ext2_inode_buf, logical);
        if (phys == 0 - 1) { return 0 - 1; }   # disk-read error

        var remaining = to_read - bytes_done;
        var chunk = ext2_blocksize - off_in_block;
        if (chunk > remaining) { chunk = remaining; }

        if (phys == 0) {
            # Sparse hole (physical block 0 is reserved by ext2): zero-fill.
            for (var k = 0; k < chunk; k = k + 1) {
                store8(buf + bytes_done + k, 0);
            }
        } else {
            if (ext2_read_block(phys, &ext2_block_buf) != 0) {
                return 0 - 1;
            }
            for (var k = 0; k < chunk; k = k + 1) {
                store8(buf + bytes_done + k, load8(&ext2_block_buf + off_in_block + k));
            }
        }
        bytes_done = bytes_done + chunk;
    }

    return bytes_done;
}

# Thin wrapper for callers that want the start-of-file shape.
fn ext2_read_file(inode_num, buf, maxlen) {
    return ext2_read_at(inode_num, 0, buf, maxlen);
}

# --- Directory walk (Phase 3) -----------------------------------------
#
# Walks the dirents of a directory inode and either prints them (ls
# shape) or finds a named entry (path-lookup shape).
#
# Dirent format (audit § 3.4):
#   +0  inode  (4)   — 0 = tombstone, skip but advance
#   +4  rec_len(2)   — total entry length, multiple of 4, min 12
#   +6  name_len(1)  — actual name length (0-255)
#   +7  file_type(1) — only valid if EXT2_FEATURE_INCOMPAT_FILETYPE set
#   +8  name[]       — name_len bytes, not NUL-terminated
#
# Validation predicates per BSD per-entry shape (FreeBSD ext2_search_dirblock
# / OpenBSD ext2fs_search_dirblock): rec_len >= 12, rec_len & 3 == 0,
# rec_len >= 8 + name_len, rec_len doesn't span block boundary, rec_len > 0
# (the critical anti-infinite-loop check). Any failure aborts the walk.

# Directory scratch buffer — full blocksize, reused across blocks.
var ext2_dir_buf[512];   # 4096 bytes

# Validate a single dirent at byte offset `off_in_block`. Returns 1 if
# the entry is structurally valid (caller may use it), 0 if the walk
# should abort (corruption detected).
fn ext2_dirent_valid(off_in_block, rec_len, name_len) {
    if (rec_len == 0)                              { return 0; }  # critical: anti-infinite-loop
    if (rec_len < 12)                              { return 0; }
    if ((rec_len & 3) != 0)                        { return 0; }
    if (rec_len < 8 + name_len)                    { return 0; }
    if (off_in_block + rec_len > ext2_blocksize)   { return 0; }
    return 1;
}

# Print a single directory's contents (just names; ls-style). Returns the
# count of non-tombstone entries printed, or -1 on error.
fn ext2_print_dir(dir_inode_num) {
    if (ext2_active == 0) { return 0 - 1; }
    if (ext2_get_inode(dir_inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }

    # Validate inode is a directory (mode high nibble = 0x4 = S_IFDIR).
    var mode = ext2_inode_mode(&ext2_inode_buf);
    if ((mode & 0xF000) != 0x4000) {
        kprintln("ext2: not a directory", 21);
        return 0 - 1;
    }

    # Save the dir inode (we'll need to re-read it after every
    # ext2_logical_to_physical call, since that walks the inode tree
    # and uses ext2_inode_buf as scratch... actually it doesn't, it
    # takes a buf arg. But ext2_get_inode DOES use ext2_inode_buf.
    # So we re-fetch on each loop iteration if needed.)
    var dir_size = ext2_inode_filesize(&ext2_inode_buf);
    if (dir_size == 0) { return 0; }

    var count = 0;
    var bytes_done = 0;
    while (bytes_done < dir_size) {
        # Refresh inode in case any helper clobbered the buffer.
        if (ext2_get_inode(dir_inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }

        var logical = bytes_done / ext2_blocksize;
        var phys = ext2_logical_to_physical(&ext2_inode_buf, logical);
        if (phys == 0 - 1) { return 0 - 1; }
        if (phys == 0)     { bytes_done = bytes_done + ext2_blocksize; continue; }

        if (ext2_read_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }

        # Walk dirents within this block.
        var off = 0;
        while (off < ext2_blocksize) {
            var d = &ext2_dir_buf + off;
            var inode_num = ext2_load32_le(d, 0);
            var rec_len   = ext2_load16_le(d, 4);
            var name_len  = load8(d + 6);
            var ftype     = load8(d + 7);

            if (ext2_dirent_valid(off, rec_len, name_len) == 0) {
                kprintln("ext2: dirent validation failed; aborting walk", 45);
                return count;
            }

            if (inode_num != 0) {
                # Print name + '/' suffix for dirs (ftype==2 EXT2_FT_DIR).
                for (var k = 0; k < name_len; k = k + 1) {
                    kputc(load8(d + 8 + k));
                }
                if (ftype == 2) { kputc(47); }   # '/'
                kputc(32);                       # space separator
                count = count + 1;
            }

            off = off + rec_len;
        }

        bytes_done = bytes_done + ext2_blocksize;
    }

    if (count > 0) { kprintln("", 0); }
    return count;
}

# Find a named entry inside a directory inode. Returns the entry's inode
# number on hit, 0 if not found, -1 on error.
fn ext2_dir_lookup(dir_inode_num, name, name_len) {
    if (ext2_active == 0) { return 0 - 1; }
    if (ext2_get_inode(dir_inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }

    var mode = ext2_inode_mode(&ext2_inode_buf);
    if ((mode & 0xF000) != 0x4000) { return 0 - 1; }

    var dir_size = ext2_inode_filesize(&ext2_inode_buf);
    if (dir_size == 0) { return 0; }

    var bytes_done = 0;
    while (bytes_done < dir_size) {
        if (ext2_get_inode(dir_inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }
        var logical = bytes_done / ext2_blocksize;
        var phys = ext2_logical_to_physical(&ext2_inode_buf, logical);
        if (phys == 0 - 1) { return 0 - 1; }
        if (phys == 0)     { bytes_done = bytes_done + ext2_blocksize; continue; }

        if (ext2_read_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }

        var off = 0;
        while (off < ext2_blocksize) {
            var d = &ext2_dir_buf + off;
            var ent_inode = ext2_load32_le(d, 0);
            var rec_len   = ext2_load16_le(d, 4);
            var ent_namelen = load8(d + 6);

            if (ext2_dirent_valid(off, rec_len, ent_namelen) == 0) { return 0; }

            if (ent_inode != 0) {
                if (ent_namelen == name_len) {
                    if (memeq(d + 8, name, name_len) == 1) {
                        return ent_inode;
                    }
                }
            }
            off = off + rec_len;
        }
        bytes_done = bytes_done + ext2_blocksize;
    }
    return 0;   # not found
}

# === Directory mutation + create / unlink (WRITE arc 1.33.x — W4a) =====
#
# Dirent insert (rec_len split) + remove (coalesce into prev / tombstone
# the block head) per the prior-art doc § 7 (FreeBSD ext2_direnter /
# ext2_dirremove). create = alloc inode + init + insert dirent; unlink =
# remove dirent + dec links + (at 0) free blocks + inode. Linear dirs only
# (we never create htree-indexed dirs; the smoke image is `-O ^dir_index`).
# Uses ext2_dir_buf for the dir block. All gated on ext2_write_ok. Commit
# order per doc § 3.

fn ext2_round4(n) { var m = n + 3; return m - (m & 3); }

# Directory-leaf checksum + tail (1.33.1 bite 6, audit § 14.3). On a
# metadata_csum FS the last 12 bytes of every leaf dir block are an
# ext4_dir_entry_tail — a fake dirent (inode=0, rec_len=12, name_len=0,
# file_type=0xDE) whose final 4 bytes hold det_checksum. So usable dirent
# space is [0, blocksize-12); the rec_len walkers must stop there and never
# treat the tail as a reusable tombstone (§ 14.7).
fn ext2_dir_limit() {
    if (ext2_csum_on != 0) { return ext2_blocksize - 12; }
    return ext2_blocksize;
}
# Leaf csum: crc32c(seed, dir_ino#) → +dir i_generation → +dirents
# [0, blocksize-12). The tail itself is NOT covered. Returns the 32-bit crc.
fn ext2_dir_leaf_csum(dirbuf, dir_ino, dir_gen) {
    var ile[4]; ext2_store32_le(&ile, 0, dir_ino);
    var crc = ext2_crc32c(ext2_csum_seed, &ile, 4);
    var gle[4]; ext2_store32_le(&gle, 0, dir_gen);
    crc = ext2_crc32c(crc, &gle, 4);
    return ext2_crc32c(crc, dirbuf, ext2_blocksize - 12);
}
# Write the tail header + det_checksum into a dir block before it's flushed.
# Idempotent on an existing block (the header bytes already match). Caller
# guards on ext2_csum_on.
fn ext2_dir_tail_stamp(dirbuf, dir_ino, dir_gen) {
    var t = ext2_blocksize - 12;
    ext2_store32_le(dirbuf, t, 0);          # fake inode 0
    ext2_store16_le(dirbuf, t + 4, 12);     # rec_len = 12 (the tail)
    store8(dirbuf + t + 6, 0);              # name_len 0
    store8(dirbuf + t + 7, 0xDE);           # EXT4_FT_DIR_CSUM marker
    ext2_store32_le(dirbuf, ext2_blocksize - 4, ext2_dir_leaf_csum(dirbuf, dir_ino, dir_gen));
    return 0;
}

# Write a dirent record { inode, rec_len, name_len, file_type, name } into
# buf at byte offset `o`. ftype: 1=regular, 2=dir.
fn ext2_dirent_write(buf, o, inode, rec_len, name, name_len, ftype) {
    ext2_store32_le(buf, o, inode);
    ext2_store16_le(buf, o + 4, rec_len);
    store8(buf + o + 6, name_len);
    store8(buf + o + 7, ftype);
    var i = 0;
    while (i < name_len) { store8(buf + o + 8 + i, load8(name + i)); i = i + 1; }
    return 0;
}

# Try to place (child_ino, name, ftype) into the dir block already loaded
# in ext2_dir_buf. `needed` = round4(8 + name_len). Returns 1 if placed
# (buf modified — caller writes it back), 0 if the block has no room.
# Case A reuses a tombstone (inode 0) whose rec_len fits; case B splits a
# live entry's slack (rec_len beyond its real 8+name_len size).
fn ext2_dir_try_insert(child_ino, name, name_len, ftype, needed) {
    var off = 0;
    var lim = ext2_dir_limit();             # stop before the csum tail (§ 14.7)
    while (off < lim) {
        var d = &ext2_dir_buf + off;
        var e_ino = ext2_load32_le(d, 0);
        var e_rl  = ext2_load16_le(d, 4);
        var e_nl  = load8(d + 6);
        if (e_rl == 0) { return 0; }                  # corrupt — abandon block
        if (e_ino == 0) {
            if (e_rl >= needed) {
                ext2_dirent_write(&ext2_dir_buf, off, child_ino, e_rl, name, name_len, ftype);
                return 1;
            }
        } else {
            var e_real = ext2_round4(8 + e_nl);
            if (e_rl - e_real >= needed) {
                ext2_store16_le(&ext2_dir_buf, off + 4, e_real);   # shrink live entry
                ext2_dirent_write(&ext2_dir_buf, off + e_real, child_ino, e_rl - e_real, name, name_len, ftype);
                return 1;
            }
        }
        off = off + e_rl;
    }
    return 0;
}

# Insert a dirent into a directory. Returns 0 / -1.
fn ext2_dir_insert(dir_ino, name, name_len, child_ino, ftype) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (ext2_get_inode(dir_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0x4000) { return 0 - 1; }

    var needed = ext2_round4(8 + name_len);
    var dir_size = ext2_inode_size_lo(&ext2_inode_buf);
    var nblocks = dir_size / ext2_blocksize;
    var dir_gen = ext2_load32_le(&ext2_inode_buf, 100);   # for the leaf csum

    # 1. try the existing dir blocks
    var lb = 0;
    while (lb < nblocks) {
        var phys = ext2_logical_to_physical(&ext2_inode_buf, lb);
        if (phys == 0 - 1) { return 0 - 1; }
        if (phys != 0) {
            if (ext2_read_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
            if (ext2_dir_try_insert(child_ino, name, name_len, ftype, needed) == 1) {
                if (ext2_csum_on != 0) { ext2_dir_tail_stamp(&ext2_dir_buf, dir_ino, dir_gen); }
                if (ext2_write_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
                return 0;
            }
        }
        lb = lb + 1;
    }

    # 2. no slack anywhere — append a fresh dir block (direct only; an
    #    indirect-block dir append is deferred — base-stage dirs are tiny)
    if (nblocks >= 12) { return 0 - 1; }
    ext2_bmap_alloc_count = 0;
    var nb = ext2_bmap_alloc(&ext2_inode_buf, nblocks);
    if (nb <= 0) { return 0 - 1; }
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_dir_buf + z, 0); z = z + 1; }
    # first dirent's rec_len spans the usable region (up to the tail on a
    # csum FS), then stamp the tail.
    ext2_dirent_write(&ext2_dir_buf, 0, child_ino, ext2_dir_limit(), name, name_len, ftype);
    if (ext2_csum_on != 0) { ext2_dir_tail_stamp(&ext2_dir_buf, dir_ino, dir_gen); }
    if (ext2_write_block(nb, &ext2_dir_buf) != 0) { return 0 - 1; }
    ext2_inode_set_size_lo(&ext2_inode_buf, dir_size + ext2_blocksize);
    ext2_inode_set_blocks_lo(&ext2_inode_buf,
    ext2_inode_blocks_lo(&ext2_inode_buf) + ext2_bmap_alloc_count * (ext2_blocksize / 512));
    if (ext2_put_inode(dir_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    return 0;
}

# Remove the named entry from a directory. Coalesces its rec_len into the
# previous entry, or tombstones it if it's the block head. Returns 0 if
# removed, -1 on error / not found.
fn ext2_dir_remove(dir_ino, name, name_len) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (ext2_get_inode(dir_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0x4000) { return 0 - 1; }

    var dir_size = ext2_inode_size_lo(&ext2_inode_buf);
    var nblocks = dir_size / ext2_blocksize;
    var dir_gen = ext2_load32_le(&ext2_inode_buf, 100);   # for the leaf csum
    var lb = 0;
    while (lb < nblocks) {
        var phys = ext2_logical_to_physical(&ext2_inode_buf, lb);
        if (phys == 0 - 1) { return 0 - 1; }
        if (phys != 0) {
            if (ext2_read_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
            var off = 0;
            var prev = 0 - 1;               # byte offset of previous entry; -1 = block head
            var lim = ext2_dir_limit();     # stop before the csum tail
            while (off < lim) {
                var d = &ext2_dir_buf + off;
                var e_ino = ext2_load32_le(d, 0);
                var e_rl  = ext2_load16_le(d, 4);
                var e_nl  = load8(d + 6);
                if (e_rl == 0) { return 0 - 1; }
                if (e_ino != 0) {
                    if (e_nl == name_len) {
                        if (memeq(d + 8, name, name_len) == 1) {
                            if (prev == 0 - 1) {
                                ext2_store32_le(&ext2_dir_buf, off, 0);          # tombstone head
                            } else {
                                ext2_store16_le(&ext2_dir_buf, prev + 4,
                                ext2_load16_le(&ext2_dir_buf, prev + 4) + e_rl);  # coalesce
                            }
                            if (ext2_csum_on != 0) { ext2_dir_tail_stamp(&ext2_dir_buf, dir_ino, dir_gen); }
                            if (ext2_write_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
                            return 0;
                        }
                    }
                }
                prev = off;
                off = off + e_rl;
            }
        }
        lb = lb + 1;
    }
    return 0 - 1;   # not found
}

# Create a regular file `name` (0644) in directory `dir_ino`. Returns the
# new inode number (>0) or -1. Order (doc § 3): alloc inode (bitmap+count)
# → init inode → insert dirent; rolls back the inode if the dirent fails.
fn ext2_create(dir_ino, name, name_len) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    var ino = ext2_alloc_inode(0);
    if (ino <= 0) { return 0 - 1; }

    var z = 0;
    while (z < ext2_inode_size) { store8(&ext2_inode_buf + z, 0); z = z + 1; }
    ext2_inode_set_mode(&ext2_inode_buf, 0x81A4);          # S_IFREG | 0644
    ext2_inode_set_links_count(&ext2_inode_buf, 1);
    if (ext2_put_inode(ino, &ext2_inode_buf) != 0) { ext2_free_inode(ino, 0); return 0 - 1; }

    if (ext2_dir_insert(dir_ino, name, name_len, ino, 1) != 0) {
        ext2_free_inode(ino, 0);
        return 0 - 1;
    }
    return ino;
}

# Unlink a regular file `name` from `dir_ino`: remove dirent, dec links,
# and (at 0) free the file's blocks + inode. Refuses directories (rmdir is
# W5). Returns 0 / -1. Order (doc § 3): dirent-remove → links-- → free.
fn ext2_unlink(dir_ino, name, name_len) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    var ino = ext2_dir_lookup(dir_ino, name, name_len);
    if (ino <= 0) { return 0 - 1; }
    if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) == 0x4000) { return 0 - 1; }   # dir → rmdir

    if (ext2_dir_remove(dir_ino, name, name_len) != 0) { return 0 - 1; }

    if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    var links = ext2_inode_links_count(&ext2_inode_buf) - 1;
    ext2_inode_set_links_count(&ext2_inode_buf, links);
    if (links == 0) {
        # Mark the inode deleted: i_dtime (offset 20) must be non-zero AND
        # look like a TIMESTAMP, not a small integer. The orphan inode list
        # is threaded through i_dtime (each orphan's dtime = next orphan#),
        # so a small dtime (e.g. 1) makes e2fsck read the freed inode as an
        # orphan-chain link to inode 1 → "corrupted orphan linked list". A
        # value above any inode number can't be a next-pointer, so it's
        # treated as a deletion time. We have no RTC → fixed epoch sentinel
        # (2025-ish); e2fsck checks dtime!=0 + plausibility, not the value.
        # (truncate_zero below re-reads/re-writes the inode but leaves
        # i_dtime untouched, so it survives.)
        ext2_store32_le(&ext2_inode_buf, 20, 1748000000);
    }
    if (ext2_put_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    if (links == 0) {
        ext2_truncate_zero(ino);
        ext2_free_inode(ino, 0);
    }
    return 0;
}

# === mkdir / rmdir (WRITE arc 1.33.x — W5 FS layer) ===================
#
# A directory is a file whose data blocks hold dirents. mkdir: alloc a dir
# inode (bumps bg_used_dirs), give it one data block seeded with "." (self)
# and ".." (parent), links_count 2 (the "." self-ref + the entry the parent
# will hold); insert the entry into the parent and bump the parent's
# links_count (the new dir's ".." references it). rmdir reverses, but only
# for an EMPTY directory (just "." and ".."). Link accounting per the ext2
# spec; e2fsck Pass 4 cross-checks every count.

# Is `dir_ino` empty (only "." and "..")? Returns 1 if empty, 0 if it has
# any other live entry, -1 on error.
fn ext2_dir_is_empty(dir_ino) {
    if (ext2_get_inode(dir_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    var dir_size = ext2_inode_size_lo(&ext2_inode_buf);
    var nblocks = dir_size / ext2_blocksize;
    var lb = 0;
    while (lb < nblocks) {
        var phys = ext2_logical_to_physical(&ext2_inode_buf, lb);
        if (phys == 0 - 1) { return 0 - 1; }
        if (phys != 0) {
            if (ext2_read_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
            var off = 0;
            while (off < ext2_blocksize) {
                var d = &ext2_dir_buf + off;
                var e_ino = ext2_load32_le(d, 0);
                var e_rl  = ext2_load16_le(d, 4);
                var e_nl  = load8(d + 6);
                if (e_rl == 0) { return 0 - 1; }
                if (e_ino != 0) {
                    var is_dot = 0;
                    if (e_nl == 1) { if (load8(d + 8) == 46) { is_dot = 1; } }          # "."
                    if (e_nl == 2) { if (load8(d + 8) == 46) { if (load8(d + 9) == 46) { is_dot = 1; } } }  # ".."
                    if (is_dot == 0) { return 0; }   # a real entry → not empty
                }
                off = off + e_rl;
            }
        }
        lb = lb + 1;
    }
    return 1;
}

# Make a directory `name` (0755) in `parent_ino`. Returns the new inode
# number (>0) or -1. Rolls back the inode+block if the parent insert fails.
fn ext2_mkdir(parent_ino, name, name_len) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    var ino = ext2_alloc_inode(1);                 # is_dir → bg_used_dirs++
    if (ino <= 0) { return 0 - 1; }
    var db = ext2_alloc_block(0);
    if (db <= 0) { ext2_free_inode(ino, 1); return 0 - 1; }

    # seed the dir block: "." (self) then ".." (parent, rec_len spanning the
    # usable region up to the csum tail). The new dir inode is created with
    # i_generation = 0 (zeroed below), so the leaf csum uses gen 0.
    var z = 0;
    while (z < ext2_blocksize) { store8(&ext2_dir_buf + z, 0); z = z + 1; }
    ext2_dirent_write(&ext2_dir_buf, 0, ino, 12, ".", 1, 2);
    ext2_dirent_write(&ext2_dir_buf, 12, parent_ino, ext2_dir_limit() - 12, "..", 2, 2);
    if (ext2_csum_on != 0) { ext2_dir_tail_stamp(&ext2_dir_buf, ino, 0); }
    if (ext2_write_block(db, &ext2_dir_buf) != 0) { ext2_free_block(db); ext2_free_inode(ino, 1); return 0 - 1; }

    # init the dir inode: S_IFDIR|0755, links 2 ("." + parent's entry),
    # one block of dirents.
    z = 0;
    while (z < ext2_inode_size) { store8(&ext2_inode_buf + z, 0); z = z + 1; }
    ext2_inode_set_mode(&ext2_inode_buf, 0x41ED);          # S_IFDIR | 0755
    ext2_inode_set_links_count(&ext2_inode_buf, 2);
    ext2_inode_set_size_lo(&ext2_inode_buf, ext2_blocksize);
    ext2_inode_set_blocks_lo(&ext2_inode_buf, ext2_blocksize / 512);
    ext2_inode_set_block_ptr(&ext2_inode_buf, 0, db);
    if (ext2_put_inode(ino, &ext2_inode_buf) != 0) { ext2_free_block(db); ext2_free_inode(ino, 1); return 0 - 1; }

    # link into the parent (ftype 2 = dir)
    if (ext2_dir_insert(parent_ino, name, name_len, ino, 2) != 0) {
        ext2_free_block(db);
        ext2_free_inode(ino, 1);
        return 0 - 1;
    }
    # parent gains a link (the new dir's ".." references it)
    if (ext2_get_inode(parent_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    ext2_inode_set_links_count(&ext2_inode_buf, ext2_inode_links_count(&ext2_inode_buf) + 1);
    if (ext2_put_inode(parent_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    return ino;
}

# Remove an EMPTY directory `name` from `parent_ino`. Refuses non-empty
# dirs and non-directories. Returns 0 / -1.
fn ext2_rmdir(parent_ino, name, name_len) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    var ino = ext2_dir_lookup(parent_ino, name, name_len);
    if (ino <= 0) { return 0 - 1; }
    if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0x4000) { return 0 - 1; }  # not a dir
    if (ext2_dir_is_empty(ino) != 1) { return 0 - 1; }                            # non-empty / error

    # remove the parent's entry, then drop the parent's link (the ".." ref)
    if (ext2_dir_remove(parent_ino, name, name_len) != 0) { return 0 - 1; }
    if (ext2_get_inode(parent_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    ext2_inode_set_links_count(&ext2_inode_buf, ext2_inode_links_count(&ext2_inode_buf) - 1);
    if (ext2_put_inode(parent_ino, &ext2_inode_buf) != 0) { return 0 - 1; }

    # free the dir: links 0 + dtime, truncate its block(s), free the inode
    if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    ext2_inode_set_links_count(&ext2_inode_buf, 0);
    ext2_store32_le(&ext2_inode_buf, 20, 1748000000);    # i_dtime (see ext2_unlink)
    if (ext2_put_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    ext2_truncate_zero(ino);
    ext2_free_inode(ino, 1);                             # is_dir → bg_used_dirs--
    return 0;
}

# === rename / mv (WRITE arc 1.33.3 — bite 1) =========================
#
# Move/rename `src_name` in `src_parent` to `dst_name` in `dst_parent`.
# Pure recomposition of the W4 dirent insert/remove + inode link
# primitives — no new on-disk format. Ordered writes per doc § 3: add the
# NEW dirent first (the inode is reachable by both names through the
# window, never unreferenced), then fix the moved dir's ".." + parent link
# counts on a cross-parent move, then remove the OLD dirent last. e2fsck
# Pass-3 (directory connectivity) + Pass-4 (link counts) are the oracle.
#
# Base-stage scope (documented limits, each e2fsck-safe):
#   - refuses if `dst_name` already exists (rename-replace is a follow-on)
#   - refuses moving a directory into itself or one of its descendants
#     (would orphan the subtree / create a `..` cycle e2fsck must cut)
#   - linear dirs only (we never create htree-indexed dirs)
# Returns 0 on success, -1 on error/refusal.

# file_type byte from inode mode (the `filetype` feature is set on every
# default mkfs.ext4 FS, so the dirent must carry the right type).
fn ext2_ftype_from_mode(mode) {
    var t = mode & 0xF000;
    if (t == 0x8000) { return 1; }   # regular
    if (t == 0x4000) { return 2; }   # directory
    if (t == 0xA000) { return 7; }   # symlink
    if (t == 0x2000) { return 3; }   # char device
    if (t == 0x6000) { return 4; }   # block device
    if (t == 0x1000) { return 5; }   # fifo
    if (t == 0xC000) { return 6; }   # socket
    return 1;
}

# Rewrite the ".." entry of `dir_ino` to point at `new_parent`; re-stamp
# the leaf csum tail. Mirrors the ext2_dir_remove block walk. Returns 0/-1.
fn ext2_dir_set_dotdot(dir_ino, new_parent) {
    if (ext2_get_inode(dir_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    var dir_size = ext2_inode_size_lo(&ext2_inode_buf);
    var nblocks = dir_size / ext2_blocksize;
    var dir_gen = ext2_load32_le(&ext2_inode_buf, 100);
    var lb = 0;
    while (lb < nblocks) {
        var phys = ext2_logical_to_physical(&ext2_inode_buf, lb);
        if (phys == 0 - 1) { return 0 - 1; }
        if (phys != 0) {
            if (ext2_read_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
            var off = 0;
            while (off < ext2_blocksize) {
                var d = &ext2_dir_buf + off;
                var e_ino = ext2_load32_le(d, 0);
                var e_rl  = ext2_load16_le(d, 4);
                var e_nl  = load8(d + 6);
                if (e_rl == 0) { return 0 - 1; }
                if (e_ino != 0) {
                    if (e_nl == 2) {
                        if (load8(d + 8) == 46) { if (load8(d + 9) == 46) {
                                ext2_store32_le(&ext2_dir_buf, off, new_parent);
                                if (ext2_csum_on != 0) { ext2_dir_tail_stamp(&ext2_dir_buf, dir_ino, dir_gen); }
                                if (ext2_write_block(phys, &ext2_dir_buf) != 0) { return 0 - 1; }
                                return 0;
                            } }
                    }
                }
                off = off + e_rl;
            }
        }
        lb = lb + 1;
    }
    return 0 - 1;   # no ".." found
}

# Is `maybe_ancestor` equal to, or an ancestor of, `start_dir`? Walks ".."
# upward from start_dir toward root (inode 2), bounded at 64 levels.
# Returns 1 yes, 0 no, -1 error. Blocks moving a dir into its own subtree.
fn ext2_is_ancestor(maybe_ancestor, start_dir) {
    var cur = start_dir;
    var depth = 0;
    while (depth < 64) {
        if (cur == maybe_ancestor) { return 1; }
        if (cur == 2) { return 0; }                  # reached root, not found
        var up = ext2_dir_lookup(cur, "..", 2);
        if (up <= 0) { return 0 - 1; }
        if (up == cur) { return 0; }                 # ".." self-ref → stop
        cur = up;
        depth = depth + 1;
    }
    return 0 - 1;   # too deep — refuse rather than risk an undetected loop
}

fn ext2_rename(src_parent, src_name, src_nl, dst_parent, dst_name, dst_nl) {
    if (ext2_write_ok == 0) { return 0 - 1; }

    var src_ino = ext2_dir_lookup(src_parent, src_name, src_nl);
    if (src_ino <= 0) { return 0 - 1; }              # src must exist

    if (ext2_get_inode(src_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    var src_mode = ext2_inode_mode(&ext2_inode_buf);
    var src_is_dir = 0;
    if ((src_mode & 0xF000) == 0x4000) { src_is_dir = 1; }
    var ftype = ext2_ftype_from_mode(src_mode);

    # no-op: same parent + same name
    if (src_parent == dst_parent) {
        if (src_nl == dst_nl) {
            if (memeq(src_name, dst_name, src_nl) == 1) { return 0; }
        }
    }

    # refuse if the destination name already exists — rename-replace is a
    # follow-on bite; this keeps bite 1 e2fsck-trivially-clean.
    var dst_existing = ext2_dir_lookup(dst_parent, dst_name, dst_nl);
    if (dst_existing != 0) { return 0 - 1; }         # >0 exists, <0 error

    var cross = 0;
    if (src_parent != dst_parent) { cross = 1; }

    # directory-move safety: never into itself or a descendant
    if (src_is_dir == 1) {
        if (src_ino == dst_parent) { return 0 - 1; }
        if (cross == 1) {
            if (ext2_is_ancestor(src_ino, dst_parent) != 0) { return 0 - 1; }
        }
    }

    # 1. add the new dirent FIRST (inode reachable by both names)
    if (ext2_dir_insert(dst_parent, dst_name, dst_nl, src_ino, ftype) != 0) { return 0 - 1; }

    # 2. cross-parent directory move: repoint ".." + shift parent link counts
    if (src_is_dir == 1) {
        if (cross == 1) {
            if (ext2_dir_set_dotdot(src_ino, dst_parent) != 0) { return 0 - 1; }
            if (ext2_get_inode(dst_parent, &ext2_inode_buf) != 0) { return 0 - 1; }
            ext2_inode_set_links_count(&ext2_inode_buf, ext2_inode_links_count(&ext2_inode_buf) + 1);
            if (ext2_put_inode(dst_parent, &ext2_inode_buf) != 0) { return 0 - 1; }
            if (ext2_get_inode(src_parent, &ext2_inode_buf) != 0) { return 0 - 1; }
            ext2_inode_set_links_count(&ext2_inode_buf, ext2_inode_links_count(&ext2_inode_buf) - 1);
            if (ext2_put_inode(src_parent, &ext2_inode_buf) != 0) { return 0 - 1; }
        }
    }

    # 3. remove the OLD dirent last
    if (ext2_dir_remove(src_parent, src_name, src_nl) != 0) { return 0 - 1; }
    return 0;
}

# === hardlink / ln (WRITE arc 1.33.3 — bite 2) =======================
#
# Hard-link `dst_name` in `dst_parent` to the existing inode `target_ino`:
# a second dirent for one inode + i_links_count++. Refuses directories
# (dir hardlinks break the tree — e2fsck cuts them) and an already-existing
# dst name. Order (doc § 3): bump the link count FIRST, then add the dirent,
# so a crash leaves a too-HIGH count (a harmless leak e2fsck reclaims) rather
# than a too-LOW count that a later unlink could drive to 0 and free a still-
# referenced inode (a dangling-pointer corruption). ext2_unlink already
# decrements-and-conditionally-frees, so it unwinds a multi-link file cleanly.
# Returns 0 / -1.
fn ext2_link(target_ino, dst_parent, dst_name, dst_nl) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (target_ino <= 0) { return 0 - 1; }
    if (ext2_get_inode(target_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    var tmode = ext2_inode_mode(&ext2_inode_buf);
    if ((tmode & 0xF000) == 0x4000) { return 0 - 1; }    # refuse dir hardlink
    var ftype = ext2_ftype_from_mode(tmode);

    # refuse if the destination name already exists
    var ex = ext2_dir_lookup(dst_parent, dst_name, dst_nl);
    if (ex != 0) { return 0 - 1; }                       # >0 exists, <0 error

    # bump link count first (re-fetch — dir_lookup clobbered the buffer)
    if (ext2_get_inode(target_ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    var nl = ext2_inode_links_count(&ext2_inode_buf) + 1;
    ext2_inode_set_links_count(&ext2_inode_buf, nl);
    if (ext2_put_inode(target_ino, &ext2_inode_buf) != 0) { return 0 - 1; }

    # add the dirent; on failure roll the link count back
    if (ext2_dir_insert(dst_parent, dst_name, dst_nl, target_ino, ftype) != 0) {
        if (ext2_get_inode(target_ino, &ext2_inode_buf) == 0) {
            ext2_inode_set_links_count(&ext2_inode_buf, nl - 1);
            ext2_put_inode(target_ino, &ext2_inode_buf);
        }
        return 0 - 1;
    }
    return 0;
}

# === symlink-create / ln -s (WRITE arc 1.33.3 — bite 3) ==============
#
# Create symlink `name` in `parent_ino` pointing at `target`. FAST symlink
# (target < 60 B) stores the target inline in the 60-byte i_block array
# (i_blocks=0, no data block); SLOW symlink (>= 60 B) puts it in one data
# block (i_block[0], indirect-mapped — no EXTENTS_FL, like every file this
# arc creates). dirent file_type = 7 (S_IFLNK). This bite only CREATES
# symlinks e2fsck-clean; *resolving* them on traversal is the 1.33.4 item.
# Order (doc § 3): alloc inode (+ slow: data block) → init → insert dirent;
# rolls back on failure. NOTE the rollback must NOT call ext2_truncate_zero
# on a fast symlink — its i_block holds target TEXT, not block pointers.
# Returns the new inode (>0) or -1.
fn ext2_symlink(parent_ino, name, name_len, target, target_len) {
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (target_len < 1) { return 0 - 1; }
    if (target_len > ext2_blocksize) { return 0 - 1; }       # one block max (base-stage)
    if (ext2_dir_lookup(parent_ino, name, name_len) != 0) { return 0 - 1; }   # refuse exists/err

    var ino = ext2_alloc_inode(0);                           # not a dir
    if (ino <= 0) { return 0 - 1; }

    # slow symlink needs a data block — alloc before init so a failure unwinds
    var db = 0;
    if (target_len >= 60) {
        db = ext2_alloc_block(0);
        if (db <= 0) { ext2_free_inode(ino, 0); return 0 - 1; }
        var z = 0;
        while (z < ext2_blocksize) { store8(&ext2_block_buf + z, 0); z = z + 1; }
        var t = 0;
        while (t < target_len) { store8(&ext2_block_buf + t, load8(target + t)); t = t + 1; }
        if (ext2_write_block(db, &ext2_block_buf) != 0) { ext2_free_block(db); ext2_free_inode(ino, 0); return 0 - 1; }
    }

    # init the symlink inode (zeroed → i_flags 0, no EXTENTS_FL)
    var z2 = 0;
    while (z2 < ext2_inode_size) { store8(&ext2_inode_buf + z2, 0); z2 = z2 + 1; }
    ext2_inode_set_mode(&ext2_inode_buf, 0xA1FF);            # S_IFLNK | 0777
    ext2_inode_set_links_count(&ext2_inode_buf, 1);
    ext2_inode_set_size_lo(&ext2_inode_buf, target_len);
    if (target_len < 60) {
        # FAST: target inline in the i_block area (inode offset 40), 0 blocks
        var f = 0;
        while (f < target_len) { store8(&ext2_inode_buf + 40 + f, load8(target + f)); f = f + 1; }
        ext2_inode_set_blocks_lo(&ext2_inode_buf, 0);
    } else {
        # SLOW: one data block holds the target
        ext2_inode_set_block_ptr(&ext2_inode_buf, 0, db);
        ext2_inode_set_blocks_lo(&ext2_inode_buf, ext2_blocksize / 512);
    }
    if (ext2_put_inode(ino, &ext2_inode_buf) != 0) {
        if (db > 0) { ext2_free_block(db); }
        ext2_free_inode(ino, 0);
        return 0 - 1;
    }

    # link into the parent (ftype 7 = symlink)
    if (ext2_dir_insert(parent_ino, name, name_len, ino, 7) != 0) {
        if (db > 0) { ext2_free_block(db); }     # NOT truncate_zero (fast i_block = text)
        ext2_free_inode(ino, 0);
        return 0 - 1;
    }
    return ino;
}

# === Symlink resolution (WRITE arc 1.33.4) ============================
# Scratch for ext2_path_lookup's symlink following. Module-global `var
# X[N]` = N×u64 bytes ([[cyrius-var-array-u64-units]]): [512] = 4096 B =
# PATH_MAX; [64] = 512 B ≥ inode_size (256). Single-threaded kernel (shell
# context) → safe to share; ext2_path_lookup is not re-entrant.
var ext2_symres_work[512];    # rewritable path being resolved
var ext2_symres_tmp[512];     # scratch to assemble <target> + <remainder>
var ext2_symres_inode[64];    # symlink inode scratch (kept off ext2_inode_buf)

# Read a symlink target into `out` (cap bytes); returns length or -1.
# Fast symlinks (i_blocks == 0) inline the target in the i_block area at
# inode offset 40; slow symlinks store it in the first data block, mapped
# extent/indirect-aware via ext2_logical_to_physical (Linux ext4 slow
# symlinks on an extent FS are extent-mapped — reading i_block[0] as a raw
# pointer would corrupt). Mirrors ext2_symlink's create-side format split.
fn ext2_readlink(inode_num, out, cap) {
    if (ext2_get_inode(inode_num, &ext2_symres_inode) != 0) { return 0 - 1; }
    if ((ext2_inode_mode(&ext2_symres_inode) & 0xF000) != 0xA000) { return 0 - 1; }
    var tlen = ext2_inode_filesize(&ext2_symres_inode);
    if (tlen < 1)   { return 0 - 1; }
    if (tlen > cap) { return 0 - 1; }
    if (ext2_inode_blocks_lo(&ext2_symres_inode) == 0) {
        # FAST: target inline at inode offset 40
        var k = 0;
        while (k < tlen) { store8(out + k, load8(&ext2_symres_inode + 40 + k)); k = k + 1; }
        return tlen;
    }
    # SLOW: target in the first data block (direct or extent-mapped)
    var phys = ext2_logical_to_physical(&ext2_symres_inode, 0);
    if (phys <= 0) { return 0 - 1; }
    if (ext2_read_block(phys, &ext2_block_buf) != 0) { return 0 - 1; }
    var j = 0;
    while (j < tlen) { store8(out + j, load8(&ext2_block_buf + j)); j = j + 1; }
    return tlen;
}

# --- Path lookup (Phase 3) --------------------------------------------
#
# Resolves an absolute path "/foo/bar/baz" to an inode number, walking
# component-by-component from the root inode (always 2). Returns the
# inode number on success, 0 if any component not found, -1 on error.
#
# Path semantics:
#   - "/" alone → root inode 2
#   - leading "/" required; relative paths return -1
#   - trailing "/" tolerated (treated as empty trailing component, skipped)
#   - multiple consecutive "/" tolerated
#   - symlinks ARE resolved (1.33.4): a component that resolves to a
#     symlink inode is followed — its target (read via ext2_readlink:
#     fast inline or slow data-block) replaces the symlink + is spliced
#     ahead of the unparsed remainder. Absolute targets restart at root;
#     relative targets continue from the directory containing the link.
#     ELOOP-capped at 8 follows (Linux MAXSYMLINKS=40; 8 is ample for
#     base-stage and bounds the shared-scratch reuse).
#   - no ".."/"." resolution beyond their on-disk dirents (which point
#     to the right inodes anyway, so walking through them works trivially)

fn ext2_path_lookup(path, path_len) {
    if (ext2_active == 0)                  { return 0 - 1; }
    if (path_len < 1)                      { return 0 - 1; }
    if (load8(path) != 47)                 { return 0 - 1; }  # must start with '/'

    # Bite (A) input validation: PATH_MAX cap = 4096 bytes, matching
    # POSIX `_POSIX_PATH_MAX` and Linux's per-syscall path cap. Anything
    # longer is either a malicious input or a confused caller; refuse
    # before doing N dir-lookups. Single 4 KB cap covers all realistic
    # absolute paths in the AGNOS surface area today.
    if (path_len > 4096) { return 0 - 1; }

    # Copy the input into the rewritable work buffer. On hitting a symlink
    # we rewrite work = <target> + <unparsed remainder> and re-parse, so the
    # buffer (not the caller's `path`) is what the loop walks.
    var wl = path_len;
    var cp = 0;
    while (cp < wl) { store8(&ext2_symres_work + cp, load8(path + cp)); cp = cp + 1; }

    var nfollow = 0;
    var current_inode = 2;   # root
    var i = 1;               # skip leading '/'

    while (i < wl) {
        # Skip consecutive '/' separators.
        while (i < wl) {
            if (load8(&ext2_symres_work + i) != 47) { break; }
            i = i + 1;
        }
        if (i >= wl) { break; }

        # Find end of current component.
        var comp_start = i;
        while (i < wl) {
            if (load8(&ext2_symres_work + i) == 47) { break; }
            i = i + 1;
        }
        var comp_len = i - comp_start;
        if (comp_len < 1)   { continue; }
        if (comp_len > 255) { return 0 - 1; }   # ext2 max name_len = 255

        # Walk the current dir to find the component.
        var next_inode = ext2_dir_lookup(current_inode, &ext2_symres_work + comp_start, comp_len);
        if (next_inode == 0 - 1) { return 0 - 1; }
        if (next_inode == 0)     { return 0; }    # not found

        # Symlink? Follow it. (i now points just past the component — at the
        # '/' before the remainder, or at wl if this was the last component.)
        if (ext2_get_inode(next_inode, &ext2_symres_inode) != 0) { return 0 - 1; }
        if ((ext2_inode_mode(&ext2_symres_inode) & 0xF000) == 0xA000) {
            nfollow = nfollow + 1;
            if (nfollow > 8) { return 0 - 1; }   # ELOOP

            var tlen = ext2_readlink(next_inode, &ext2_symres_tmp, 4096);
            if (tlen < 1) { return 0 - 1; }

            # Append the unparsed remainder (work[i..wl), includes its leading
            # '/') to the target in tmp, then copy tmp back over work. Reading
            # the remainder out of work BEFORE writing work keeps it intact.
            var rem_len = wl - i;
            if (tlen + rem_len > 4096) { return 0 - 1; }
            var r = 0;
            while (r < rem_len) {
                store8(&ext2_symres_tmp + tlen + r, load8(&ext2_symres_work + i + r));
                r = r + 1;
            }
            wl = tlen + rem_len;
            var c = 0;
            while (c < wl) { store8(&ext2_symres_work + c, load8(&ext2_symres_tmp + c)); c = c + 1; }

            # Absolute target restarts at root; relative continues from the
            # directory that contained the link (current_inode, unchanged).
            if (wl > 0) { if (load8(&ext2_symres_work) == 47) { current_inode = 2; } }
            i = 0;
            continue;
        }

        current_inode = next_inode;
    }

    return current_inode;
}

# --- VFS-integrated open (Phase 3) ------------------------------------
#
# Opens a file by absolute path, allocates a VFS slot tagged
# VFS_EXT2_FILE, and returns the FD index for vfs_read / vfs_close.
# Returns -1 on lookup failure / non-regular / no free FD.

fn ext2_open(path, path_len) {
    var inode_num = ext2_path_lookup(path, path_len);
    if (inode_num == 0 - 1) { return 0 - 1; }
    if (inode_num == 0)     { return 0 - 1; }

    if (ext2_get_inode(inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }

    # Only allow opening regular files via VFS_EXT2_FILE. Dirs use the
    # ext2_print_dir path (no VFS fd needed for ls); other types deferred.
    # Phase 4: ext4 EXTENTS_FL inodes are fine here — ext2_read_at via
    # the VFS dispatch arm uses ext2_logical_to_physical, which routes
    # extents inodes through the extent walker transparently.
    var mode = ext2_inode_mode(&ext2_inode_buf);
    if ((mode & 0xF000) != 0x8000) { return 0 - 1; }

    var fsize = ext2_inode_filesize(&ext2_inode_buf);

    var fd = vfs_alloc();
    if (fd < 0) { return 0 - 1; }
    var base = &vfs_table + fd * 32;
    ktag_set(base, VFS_EXT2_FILE);
    kpayload_set(base, 0, 0);          # pos
    kpayload_set(base, 1, fsize);      # size
    kpayload_set(base, 2, inode_num);  # inode_num
    return fd;
}

# === File-data write + truncate (WRITE arc 1.33.x — W3) ===============
#
# ext2_write_at is the mutating sibling of ext2_read_at; ext2_bmap_alloc
# the allocating sibling of ext2_logical_to_physical. Scope: direct +
# single-indirect block allocation (covers files up to 12*bs + (bs/4)*bs
# = ~4 MB on 4K blocks — every base-stage file). Double/triple-indirect
# allocation is deferred (the read path supports reading all levels; we
# just don't write files that large at base stage). All gated on
# ext2_write_ok. Commit order per doc § 3.

# Per-op allocation accounting (for i_blocks) + "data block was freshly
# allocated" flag (for zero-vs-RMW on a partial write).
var ext2_bmap_alloc_count = 0;
var ext2_bmap_was_new     = 0;

# Map logical block -> physical, ALLOCATING the data block (and the
# single-indirect block, if needed) when absent. Mutates inode_buf in
# place (i_block[] for direct; i_block[12] when the indirect block is
# born). Bumps ext2_bmap_alloc_count per block allocated (data + indirect)
# and sets ext2_bmap_was_new=1 iff the returned DATA block is new. Returns
# phys block# (>0), or 0 on ENOSPC / unsupported depth.
fn ext2_bmap_alloc(inode_buf, lblk) {
    ext2_bmap_was_new = 0;
    if (ext2_write_ok == 0) { return 0; }
    # Extent-mapped inodes (i_flags & EXTENTS_FL 0x80000): i_block[] holds
    # an ext4 extent header, NOT direct/indirect pointers — walking it as
    # pointers corrupts the tree. Extent *allocation* is a deferred cycle
    # (audit § 11); refuse here so the writer never authors into an extent
    # inode. New AGNOS files are always indirect (ext2_create zeroes
    # i_flags), so this only fires on Linux-created (mkfs/cp) extent files
    # + dirs — for which inserting into an EXISTING block still works (that
    # path reads via the extent walker + writes the block back directly;
    # only block *append* lands here). 1.33.1 bite 1.
    if ((ext2_inode_flags(inode_buf) & 0x80000) != 0) { return 0; }
    var ptrs = ext2_blocksize / 4;

    # --- direct (0..11) ---
    if (lblk < 12) {
        var p = ext2_inode_block_ptr(inode_buf, lblk);
        if (p != 0) { return p; }
        var nb = ext2_alloc_block(0);
        if (nb <= 0) { return 0; }
        ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
        ext2_bmap_was_new = 1;
        ext2_inode_set_block_ptr(inode_buf, lblk, nb);
        return nb;
    }

    # --- single-indirect (12 .. 12+ptrs-1) ---
    if (lblk < 12 + ptrs) {
        var idx = lblk - 12;
        var ind = ext2_inode_block_ptr(inode_buf, 12);
        if (ind == 0) {
            # birth the indirect block: alloc + zero + write, then link it.
            ind = ext2_alloc_block(0);
            if (ind <= 0) { return 0; }
            ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
            var z = 0;
            while (z < ext2_blocksize) { store8(&ext2_indirect_buf_l1 + z, 0); z = z + 1; }
            if (ext2_write_block(ind, &ext2_indirect_buf_l1) != 0) { return 0; }
            ext2_inode_set_block_ptr(inode_buf, 12, ind);
        }
        if (ext2_read_block(ind, &ext2_indirect_buf_l1) != 0) { return 0; }
        var dp = ext2_load32_le(&ext2_indirect_buf_l1, idx * 4);
        if (dp != 0) { return dp; }
        var db = ext2_alloc_block(ind);             # goal: near the indirect block
        if (db <= 0) { return 0; }
        ext2_bmap_alloc_count = ext2_bmap_alloc_count + 1;
        ext2_bmap_was_new = 1;
        ext2_store32_le(&ext2_indirect_buf_l1, idx * 4, db);
        if (ext2_write_block(ind, &ext2_indirect_buf_l1) != 0) { return 0; }
        return db;
    }

    return 0;   # double/triple-indirect allocation deferred (base-stage cap)
}

# Write `len` bytes from `src` at byte `offset` into a regular file.
# Allocates blocks on demand (sparse holes between old EOF and offset stay
# holes — their pointers remain 0, read-zero-filled). Grows i_size; bumps
# i_blocks by (blocks allocated)*sectors_per_block. Returns bytes written
# (>=0, may be < len on ENOSPC) or -1 on error. Per doc § 3 the data lands
# before the inode pointer/size is persisted (put_inode is last).
fn ext2_write_at(inode_num, offset, src, len) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (len == 0)           { return 0; }
    if (ext2_get_inode(inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }
    if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0x8000) { return 0 - 1; }
    # EXTENTS_FL inodes route block-mapping through the extent path (1.37.0):
    # overwrite-in-place works at any depth (resolve via the reader); block
    # *append* is depth-0 only for now (extent-append returns 0 → partial
    # write past the inline-root / depth>0 cap). Indirect inodes keep the
    # ext2_bmap_alloc path. The shared tail (i_size / i_blocks / put_inode)
    # persists the extent root since it lives in the inode.
    var is_extent = 0;
    if ((ext2_inode_flags(&ext2_inode_buf) & 0x80000) != 0) { is_extent = 1; }

    ext2_bmap_alloc_count = 0;
    var written = 0;
    var cur = offset;
    var rem = len;
    while (rem > 0) {
        var lblk = cur / ext2_blocksize;
        var boff = cur - lblk * ext2_blocksize;
        var chunk = ext2_blocksize - boff;
        if (chunk > rem) { chunk = rem; }

        var phys = 0;
        if (is_extent == 1) { phys = ext2_extent_bmap_alloc(&ext2_inode_buf, lblk, inode_num); }
        else                { phys = ext2_bmap_alloc(&ext2_inode_buf, lblk); }
        if (phys <= 0) { break; }                    # ENOSPC / depth cap — return partial
        var was_new = ext2_bmap_was_new;

        if (chunk == ext2_blocksize) {
            # full-block overwrite — no need to preserve anything
            var c = 0;
            while (c < ext2_blocksize) {
                store8(&ext2_block_buf + c, load8(src + written + c));
                c = c + 1;
            }
        } else {
            # partial block: zero a freshly-born block, else RMW the old one
            if (was_new == 1) {
                var zz = 0;
                while (zz < ext2_blocksize) { store8(&ext2_block_buf + zz, 0); zz = zz + 1; }
            } else {
                if (ext2_read_block(phys, &ext2_block_buf) != 0) { break; }
            }
            var c2 = 0;
            while (c2 < chunk) {
                store8(&ext2_block_buf + boff + c2, load8(src + written + c2));
                c2 = c2 + 1;
            }
        }
        if (ext2_write_block(phys, &ext2_block_buf) != 0) { break; }

        written = written + chunk;
        cur = cur + chunk;
        rem = rem - chunk;
    }

    # grow i_size (base stage = lo half only); add allocated blocks to i_blocks
    var end_off = offset + written;
    if (end_off > ext2_inode_size_lo(&ext2_inode_buf)) {
        ext2_inode_set_size_lo(&ext2_inode_buf, end_off);
    }
    if (ext2_bmap_alloc_count > 0) {
        var add = ext2_bmap_alloc_count * (ext2_blocksize / 512);
        ext2_inode_set_blocks_lo(&ext2_inode_buf, ext2_inode_blocks_lo(&ext2_inode_buf) + add);
    }
    if (ext2_put_inode(inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }
    return written;
}

# Truncate a regular file to zero length: free all data blocks (direct +
# single-indirect) and the indirect block, then i_size = i_blocks = 0.
# Refuses (returns -1) if the file reaches double/triple-indirect — those
# this driver never creates, and freeing them is a deferred sub-cycle.
# Returns the count of blocks freed (>=0) or -1. Caller persists nothing
# else (put_inode is done here). Frees per doc § 3 (pointer cleared, then
# block freed).
fn ext2_truncate_zero(inode_num) {
    if (ext2_active == 0)   { return 0 - 1; }
    if (ext2_write_ok == 0) { return 0 - 1; }
    if (ext2_get_inode(inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }
    if ((ext2_inode_flags(&ext2_inode_buf) & 0x80000) != 0) {
        kprintln("ext2: truncate of extent inode unsupported (deferred)", 53);
        return 0 - 1;
    }

    var ptrs = ext2_blocksize / 4;
    var freed = 0;

    # double/triple-indirect present → refuse (we never create them)
    if (ext2_inode_block_ptr(&ext2_inode_buf, 13) != 0) { return 0 - 1; }
    if (ext2_inode_block_ptr(&ext2_inode_buf, 14) != 0) { return 0 - 1; }

    # direct blocks
    var i = 0;
    while (i < 12) {
        var p = ext2_inode_block_ptr(&ext2_inode_buf, i);
        if (p != 0) {
            ext2_inode_set_block_ptr(&ext2_inode_buf, i, 0);   # clear ptr first
            ext2_free_block(p);
            freed = freed + 1;
        }
        i = i + 1;
    }

    # single-indirect: free each data block, then the indirect block itself
    var ind = ext2_inode_block_ptr(&ext2_inode_buf, 12);
    if (ind != 0) {
        if (ext2_read_block(ind, &ext2_indirect_buf_l1) != 0) { return 0 - 1; }
        var k = 0;
        while (k < ptrs) {
            var dp = ext2_load32_le(&ext2_indirect_buf_l1, k * 4);
            if (dp != 0) { ext2_free_block(dp); freed = freed + 1; }
            k = k + 1;
        }
        ext2_inode_set_block_ptr(&ext2_inode_buf, 12, 0);
        ext2_free_block(ind);
        freed = freed + 1;
    }

    ext2_inode_set_size_lo(&ext2_inode_buf, 0);
    ext2_store32_le(&ext2_inode_buf, 108, 0);     # i_size_high = 0
    ext2_inode_set_blocks_lo(&ext2_inode_buf, 0);
    if (ext2_put_inode(inode_num, &ext2_inode_buf) != 0) { return 0 - 1; }
    return freed;
}

# === W1 write-path self-test (compile-gated EXT2_WRITE_SELFTEST) =======
#
# NON-DESTRUCTIVE proof of the WRITE primitives without changing FS
# content (so host `e2fsck -fn` stays clean). Three checks:
#   1. grp-0 BGDT accounting + superblock free totals — compare to host
#      `debugfs -R stats <img>`.
#   2. block-bitmap free-bit count — should track grp-0 bg_free_blocks.
#   3. identity write-back: read a metadata block + inode 2, write each
#      back UNCHANGED, re-read, assert byte-identical — exercises
#      ext2_write_block + ext2_put_inode end-to-end with zero net change.
# Driven from main.cyr right after ext2_init() under the #ifdef.

fn ext2_write_selftest() {
    # crc32c primitive self-test (1.33.1 bite 2) — mount-independent, so it
    # runs first. Canonical iSCSI vector: crc32c(~0,"123456789",9)=0x1CF96D7C.
    var cc = ext2_crc32c(0xFFFFFFFF, "123456789", 9);
    if (cc == 0x1CF96D7C) { kprintln("ext2w: crc32c selftest OK", 25); }
    else                  { kprintln("ext2w: crc32c selftest MISMATCH", 31); }

    if (ext2_active == 0) { kprintln("ext2w: not mounted -- skip", 26); return 0; }

    # metadata_csum state computed at mount (bite 2). seed is consumed by the
    # checksum recompute hooks in the later bites; printed here for the smoke
    # to cross-check against the host UUID-derived seed.
    kprint("ext2w: csum on=", 15); kprint_num(ext2_csum_on);
    kprint(" seed=", 6); kprint_hex(ext2_csum_seed); kprintln("", 0);

    # 1. group-0 BGDT accounting (group 0 entry is first in the block).
    var bgdt_block = ext2_first_data_block + 1;
    if (ext2_read_block(bgdt_block, &ext2_bgdt_buf) != 0) {
        kprintln("ext2w: BGDT read FAIL", 21); return 0 - 1;
    }
    var g0 = &ext2_bgdt_buf;
    var bbmp = ext2_load32_le(g0, 0);
    kprint("ext2w: grp0 free_blk=", 21); kprint_num(ext2_load16_le(g0, 12));
    kprint(" free_ino=", 10); kprint_num(ext2_load16_le(g0, 14));
    kprint(" dirs=", 6); kprint_num(ext2_load16_le(g0, 16));
    kprintln("", 0);
    kprint("ext2w: sb free_blk=", 19); kprint_num(ext2_sb_free_blocks_count(&ext2_sb_buf));
    kprint(" free_ino=", 10); kprint_num(ext2_sb_free_inodes_count(&ext2_sb_buf));
    kprintln("", 0);

    # bite 3 compute-and-compare: our SB + group-desc checksum routines must
    # reproduce the values e2fsprogs already wrote (the e2fsck reference).
    # ext2_bgdt_buf holds group 0's descriptor from the read just above.
    if (ext2_csum_on != 0) {
        var sbc = ext2_sb_csum_compute();
        var sbs = ext2_load32_le(&ext2_sb_buf, 0x3FC);
        if (sbc == sbs) { kprintln("ext2w: SB csum match", 20); }
        else { kprint("ext2w: SB csum MISMATCH calc=", 29); kprint_hex(sbc); kprint(" disk=", 6); kprint_hex(sbs); kprintln("", 0); }
        var gc = ext2_grp_csum_compute(0);
        var gs = ext2_load16_le(ext2_grp_off(0), 0x1E);
        if (gc == gs) { kprintln("ext2w: grp0 csum match", 22); }
        else { kprint("ext2w: grp0 csum MISMATCH calc=", 31); kprint_hex(gc); kprint(" disk=", 6); kprint_hex(gs); kprintln("", 0); }

        # bite 4: block + inode bitmap csum compute-and-compare for group 0.
        # Reads each bitmap into ext2_bitmap_buf (safe — write is gated on a
        # csum FS, so the W2 allocator that also uses this buffer won't run).
        var bbk = ext2_grp_block_bitmap(0);
        if (ext2_read_block(bbk, &ext2_bitmap_buf) == 0) {
            var bcrc = ext2_crc32c(ext2_csum_seed, &ext2_bitmap_buf, (ext2_blocks_per_group + 7) / 8);
            var bok = 1;
            if ((bcrc & 0xFFFF) != ext2_load16_le(ext2_grp_off(0), 0x18)) { bok = 0; }
            if (ext2_desc_size > 32) {
                if (((bcrc >> 16) & 0xFFFF) != ext2_load16_le(ext2_grp_off(0), 0x38)) { bok = 0; }
            }
            if (bok == 1) { kprintln("ext2w: blk-bitmap csum match", 28); }
            else          { kprintln("ext2w: blk-bitmap csum MISMATCH", 31); }
        }
        var ibk = ext2_grp_inode_bitmap(0);
        if (ext2_read_block(ibk, &ext2_bitmap_buf) == 0) {
            var icrc = ext2_crc32c(ext2_csum_seed, &ext2_bitmap_buf, (ext2_inodes_per_group + 7) / 8);
            var iok = 1;
            if ((icrc & 0xFFFF) != ext2_load16_le(ext2_grp_off(0), 0x1A)) { iok = 0; }
            if (ext2_desc_size > 32) {
                if (((icrc >> 16) & 0xFFFF) != ext2_load16_le(ext2_grp_off(0), 0x3A)) { iok = 0; }
            }
            if (iok == 1) { kprintln("ext2w: ino-bitmap csum match", 28); }
            else          { kprintln("ext2w: ino-bitmap csum MISMATCH", 31); }
        }

        # bite 5: inode csum compute-and-compare on the root inode (2). calc
        # is non-destructive, so the stored fields survive for the compare.
        if (ext2_get_inode(2, &ext2_inode_buf) == 0) {
            var icc = ext2_inode_csum_calc(2, &ext2_inode_buf);
            var nok = 1;
            if ((icc & 0xFFFF) != ext2_load16_le(&ext2_inode_buf, 0x7C)) { nok = 0; }
            if (ext2_inode_has_hi(&ext2_inode_buf) == 1) {
                if (((icc >> 16) & 0xFFFF) != ext2_load16_le(&ext2_inode_buf, 0x82)) { nok = 0; }
            }
            if (nok == 1) { kprintln("ext2w: inode2 csum match", 24); }
            else          { kprintln("ext2w: inode2 csum MISMATCH", 27); }
        }

        # bite 6: directory-leaf csum compute-and-compare on root's block 0.
        if (ext2_get_inode(2, &ext2_inode_buf) == 0) {
            var rgen = ext2_load32_le(&ext2_inode_buf, 100);
            var rphys = ext2_logical_to_physical(&ext2_inode_buf, 0);
            if (rphys > 0) {
                if (ext2_read_block(rphys, &ext2_dir_buf) == 0) {
                    var dcc = ext2_dir_leaf_csum(&ext2_dir_buf, 2, rgen);
                    var dstor = ext2_load32_le(&ext2_dir_buf, ext2_blocksize - 4);
                    if (dcc == dstor) { kprintln("ext2w: rootdir csum match", 25); }
                    else { kprint("ext2w: rootdir csum MISMATCH calc=", 34); kprint_hex(dcc); kprint(" disk=", 6); kprint_hex(dstor); kprintln("", 0); }
                }
            }
        }
    }

    # 2. block-bitmap free-bit count over the group's blocks_per_group bits.
    if (ext2_read_block(bbmp, &ext2_block_buf) != 0) {
        kprintln("ext2w: bbmp read FAIL", 21); return 0 - 1;
    }
    var free_bits = 0;
    var bit = 0;
    while (bit < ext2_blocks_per_group) {
        if ((load8(&ext2_block_buf + bit / 8) & (1 << (bit & 7))) == 0) {
            free_bits = free_bits + 1;
        }
        bit = bit + 1;
    }
    kprint("ext2w: bitmap free-bits=", 24); kprint_num(free_bits);
    kprintln("", 0);

    # Write checks below mutate the FS — gate on the write-safety flag so
    # a csum/64bit FS reports cleanly instead of failing put_inode.
    if (ext2_write_ok == 0) {
        kprintln("ext2w: read-only FS -- write checks skipped", 43);
        return 0;
    }

    # 3a. identity write-back of the block-bitmap block (still in
    #     ext2_block_buf): write unchanged, re-read into l1 scratch, diff.
    if (ext2_write_block(bbmp, &ext2_block_buf) != 0) {
        kprintln("ext2w: block id-write FAIL", 26); return 0 - 1;
    }
    if (ext2_read_block(bbmp, &ext2_indirect_buf_l1) != 0) {
        kprintln("ext2w: block reread FAIL", 24); return 0 - 1;
    }
    var ok = 1;
    var j = 0;
    while (j < ext2_blocksize) {
        if (load8(&ext2_block_buf + j) != load8(&ext2_indirect_buf_l1 + j)) {
            ok = 0; break;
        }
        j = j + 1;
    }
    if (ok == 1) { kprintln("ext2w: block id write-back OK", 29); }
    else         { kprintln("ext2w: block id write-back MISMATCH", 35); }

    # 3b. identity put_inode of root (inode 2): get -> put unchanged ->
    #     get into a distinct scratch (ext2_extent_buf) -> diff.
    if (ext2_get_inode(2, &ext2_inode_buf) != 0) {
        kprintln("ext2w: root get FAIL", 20); return 0 - 1;
    }
    if (ext2_put_inode(2, &ext2_inode_buf) != 0) {
        kprintln("ext2w: root put FAIL", 20); return 0 - 1;
    }
    if (ext2_get_inode(2, &ext2_extent_buf) != 0) {
        kprintln("ext2w: root reget FAIL", 22); return 0 - 1;
    }
    var iok = 1;
    var k = 0;
    while (k < ext2_inode_size) {
        if (load8(&ext2_inode_buf + k) != load8(&ext2_extent_buf + k)) {
            iok = 0; break;
        }
        k = k + 1;
    }
    if (iok == 1) { kprintln("ext2w: inode id put OK", 22); }
    else          { kprintln("ext2w: inode id put MISMATCH", 28); }

    # === W2: allocator round-trip — alloc 3 blocks + 1 inode, free them,
    #     assert free-counts return to baseline (proves bitmap set/clear +
    #     BGDT/SB accounting symmetry). Net FS change = zero → e2fsck clean.
    var fb0 = ext2_sb_free_blocks_count(&ext2_sb_buf);
    var fi0 = ext2_sb_free_inodes_count(&ext2_sb_buf);
    var a1 = ext2_alloc_block(0);
    var a2 = ext2_alloc_block(a1);
    var a3 = ext2_alloc_block(a2);
    var ain = ext2_alloc_inode(0);
    kprint("ext2w: alloc blk ", 17); kprint_num(a1);
    kprint(" ", 1); kprint_num(a2);
    kprint(" ", 1); kprint_num(a3);
    kprint(" ino ", 5); kprint_num(ain);
    kprintln("", 0);
    ext2_free_block(a3);
    ext2_free_block(a2);
    ext2_free_block(a1);
    ext2_free_inode(ain, 0);
    var fb1 = ext2_sb_free_blocks_count(&ext2_sb_buf);
    var fi1 = ext2_sb_free_inodes_count(&ext2_sb_buf);
    kprint("ext2w: free_blk ", 16); kprint_num(fb0);
    kprint(" -> ", 4); kprint_num(fb1);
    kprint(" free_ino ", 10); kprint_num(fi0);
    kprint(" -> ", 4); kprint_num(fi1);
    kprintln("", 0);
    if ((fb0 == fb1) & (fi0 == fi1) & (a1 > 0) & (ain > 0)) {
        kprintln("ext2w: W2 alloc/free round-trip OK", 34);
    } else {
        kprintln("ext2w: W2 alloc/free round-trip MISMATCH", 40);
    }

    # === W3: file-data write (ext2_write_at) + sparse alloc + truncate ===
    # W3 targets files the self-test CREATES (always indirect-mapped — see
    # ext2_create, which zeroes i_flags), NOT the mkfs `-d` seeds: on a
    # 64bit/ext4 image the seeds are extent-mapped (i_flags 0x80000) and
    # writing them is correctly refused (1.33.1 bite-1 guard, audit § 11).
    # Self-created files exercise the real write+alloc path on EVERY image
    # profile (stripped / 64bit / metadata_csum).
    var hino = ext2_create(2, "w3a.txt", 7);
    if (hino <= 0) { kprintln("ext2w: /w3a.txt create FAIL", 27); return 0; }
    # W3a: write a 200-byte pattern @0; read back, compare.
    var pi = 0;
    while (pi < 256) { store8(&ext2_extent_buf + pi, (pi * 7 + 3) & 0xFF); pi = pi + 1; }
    var wa = ext2_write_at(hino, 0, &ext2_extent_buf, 200);
    var ra = ext2_read_at(hino, 0, &ext2_indirect_buf_l2, 200);
    var w3a = 1;
    if (wa != 200) { w3a = 0; }
    if (ra != 200) { w3a = 0; }
    var ax = 0;
    while (ax < 200) {
        if (load8(&ext2_extent_buf + ax) != load8(&ext2_indirect_buf_l2 + ax)) { w3a = 0; break; }
        ax = ax + 1;
    }
    if (w3a == 1) { kprintln("ext2w: W3 write/read 200 OK", 27); }
    else          { kprintln("ext2w: W3 write/read 200 MISMATCH", 33); }

    # W3b: sparse write — 100 bytes at offset 8192 of a fresh /w3b.txt forces
    # a new block at logical 2 (blocks 0,1 stay holes); assert i_blocks grew
    # by 8 (one 4 KB block = 8 × 512-B sectors).
    var eino = ext2_create(2, "w3b.txt", 7);
    if (eino <= 0) { kprintln("ext2w: /w3b.txt create FAIL", 27); return 0; }
    var qi = 0;
    while (qi < 100) { store8(&ext2_extent_buf + qi, (qi + 65) & 0xFF); qi = qi + 1; }
    if (ext2_get_inode(eino, &ext2_inode_buf) != 0) { kprintln("ext2w: w3b get FAIL", 19); return 0; }
    var ib0 = ext2_inode_blocks_lo(&ext2_inode_buf);
    var wb = ext2_write_at(eino, 8192, &ext2_extent_buf, 100);
    var rb = ext2_read_at(eino, 8192, &ext2_indirect_buf_l2, 100);
    if (ext2_get_inode(eino, &ext2_inode_buf) != 0) { kprintln("ext2w: w3b reget FAIL", 21); return 0; }
    var ib1 = ext2_inode_blocks_lo(&ext2_inode_buf);
    var w3b = 1;
    if (wb != 100) { w3b = 0; }
    if (rb != 100) { w3b = 0; }
    var bx = 0;
    while (bx < 100) {
        if (load8(&ext2_extent_buf + bx) != load8(&ext2_indirect_buf_l2 + bx)) { w3b = 0; break; }
        bx = bx + 1;
    }
    if (ib1 != ib0 + 8) { w3b = 0; }
    if (w3b == 1) { kprintln("ext2w: W3 sparse-alloc write OK", 31); }
    else          { kprintln("ext2w: W3 sparse-alloc write MISMATCH", 37); }

    # W3c: truncate /w3a.txt to 0 — frees its block, i_size=0, read => 0.
    var tfb0 = ext2_sb_free_blocks_count(&ext2_sb_buf);
    var trc = ext2_truncate_zero(hino);
    var tfb1 = ext2_sb_free_blocks_count(&ext2_sb_buf);
    var rc3 = ext2_read_at(hino, 0, &ext2_indirect_buf_l2, 200);
    var w3c = 1;
    if (trc < 1)       { w3c = 0; }
    if (tfb1 <= tfb0)  { w3c = 0; }
    if (rc3 != 0)      { w3c = 0; }
    if (w3c == 1) { kprintln("ext2w: W3 truncate-to-zero OK", 29); }
    else          { kprintln("ext2w: W3 truncate-to-zero MISMATCH", 35); }

    # === W4a: create + write + read (kept for host verify), then a
    #     create→unlink round-trip (free-counts must return).
    var nino = ext2_create(2, "w4keep.txt", 10);
    var w4c = 1;
    if (nino <= 0) { w4c = 0; }
    if (nino > 0) {
        if (ext2_write_at(nino, 0, "AGNOS-W4-WROTE", 14) != 14) { w4c = 0; }
        if (ext2_path_lookup("/w4keep.txt", 11) != nino) { w4c = 0; }
        if (ext2_read_at(nino, 0, &ext2_indirect_buf_l2, 14) != 14) { w4c = 0; }
        if (memeq(&ext2_indirect_buf_l2, "AGNOS-W4-WROTE", 14) != 1) { w4c = 0; }
    }
    if (w4c == 1) { kprintln("ext2w: W4 create+write OK", 25); }
    else          { kprintln("ext2w: W4 create+write MISMATCH", 31); }

    var fb4 = ext2_sb_free_blocks_count(&ext2_sb_buf);
    var fi4 = ext2_sb_free_inodes_count(&ext2_sb_buf);
    var tino = ext2_create(2, "w4tmp.txt", 9);
    var w4u = 1;
    if (tino <= 0) { w4u = 0; }
    if (tino > 0) {
        ext2_write_at(tino, 0, "tmp", 3);
        if (ext2_unlink(2, "w4tmp.txt", 9) != 0) { w4u = 0; }
        if (ext2_path_lookup("/w4tmp.txt", 10) != 0) { w4u = 0; }
    }
    if (ext2_sb_free_blocks_count(&ext2_sb_buf) != fb4) { w4u = 0; }
    if (ext2_sb_free_inodes_count(&ext2_sb_buf) != fi4) { w4u = 0; }
    if (w4u == 1) { kprintln("ext2w: W4 unlink round-trip OK", 30); }
    else          { kprintln("ext2w: W4 unlink round-trip MISMATCH", 36); }

    # === W5: mkdir + rmdir (FS layer) ===
    # mkdir /w5keep (kept for host verify): lookup finds it, it's a dir,
    # root's link count bumps by 1 (the new dir's "..").
    var rl0 = 0;
    if (ext2_get_inode(2, &ext2_inode_buf) == 0) { rl0 = ext2_inode_links_count(&ext2_inode_buf); }
    var dkeep = ext2_mkdir(2, "w5keep", 6);
    var w5m = 1;
    if (dkeep <= 0) { w5m = 0; }
    if (ext2_path_lookup("/w5keep", 7) != dkeep) { w5m = 0; }
    if (dkeep > 0) {
        if (ext2_get_inode(dkeep, &ext2_inode_buf) != 0) { w5m = 0; }
        else { if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0x4000) { w5m = 0; } }
    }
    var rl1 = 0;
    if (ext2_get_inode(2, &ext2_inode_buf) == 0) { rl1 = ext2_inode_links_count(&ext2_inode_buf); }
    if (rl1 != rl0 + 1) { w5m = 0; }
    if (w5m == 1) { kprintln("ext2w: W5 mkdir OK", 18); }
    else          { kprintln("ext2w: W5 mkdir MISMATCH", 24); }

    # rmdir round-trip: mkdir /w5tmp, put a file in it, rmdir must REFUSE
    # (non-empty), unlink the file, rmdir succeeds; counts + parent link +
    # lookup all return to baseline.
    var fb5 = ext2_sb_free_blocks_count(&ext2_sb_buf);
    var fi5 = ext2_sb_free_inodes_count(&ext2_sb_buf);
    var rl5 = 0;
    if (ext2_get_inode(2, &ext2_inode_buf) == 0) { rl5 = ext2_inode_links_count(&ext2_inode_buf); }
    var dtmp = ext2_mkdir(2, "w5tmp", 5);
    var w5r = 1;
    if (dtmp <= 0) { w5r = 0; }
    if (dtmp > 0) {
        if (ext2_create(dtmp, "f", 1) <= 0) { w5r = 0; }
        if (ext2_rmdir(2, "w5tmp", 5) == 0) { w5r = 0; }   # must FAIL (non-empty)
        if (ext2_unlink(dtmp, "f", 1) != 0) { w5r = 0; }
        if (ext2_rmdir(2, "w5tmp", 5) != 0) { w5r = 0; }   # now succeeds
    }
    if (ext2_path_lookup("/w5tmp", 6) != 0) { w5r = 0; }
    if (ext2_sb_free_blocks_count(&ext2_sb_buf) != fb5) { w5r = 0; }
    if (ext2_sb_free_inodes_count(&ext2_sb_buf) != fi5) { w5r = 0; }
    var rl5b = 0;
    if (ext2_get_inode(2, &ext2_inode_buf) == 0) { rl5b = ext2_inode_links_count(&ext2_inode_buf); }
    if (rl5b != rl5) { w5r = 0; }
    if (w5r == 1) { kprintln("ext2w: W5 rmdir round-trip OK", 29); }
    else          { kprintln("ext2w: W5 rmdir round-trip MISMATCH", 35); }

    # === Wrename: rename / mv (1.33.3 bite 1) ===
    # (a) same-dir file rename: create /rnsrc.txt → rename to /rndst.txt
    #     (kept for host verify). Old name gone, new present.
    var wrf = 1;
    if (ext2_create(2, "rnsrc.txt", 9) <= 0) { wrf = 0; }
    if (ext2_rename(2, "rnsrc.txt", 9, 2, "rndst.txt", 9) != 0) { wrf = 0; }
    if (ext2_path_lookup("/rnsrc.txt", 10) != 0) { wrf = 0; }   # old gone
    if (ext2_path_lookup("/rndst.txt", 10) <= 0) { wrf = 0; }   # new present
    if (wrf == 1) { kprintln("ext2w: Wren file OK", 19); }
    else          { kprintln("ext2w: Wren file MISMATCH", 25); }

    # (b) cross-parent directory move: mkdir /rnp + /rnd, move /rnd into
    #     /rnp. Checks the ".." repoint + parent link-count shift (root
    #     loses a link, /rnp gains one). /rnp/rnd kept for host e2fsck Pass-3/4.
    var wrx = 1;
    var pino = ext2_mkdir(2, "rnp", 3);
    var dino = ext2_mkdir(2, "rnd", 3);
    if (pino <= 0) { wrx = 0; }
    if (dino <= 0) { wrx = 0; }
    var rootl_a = 0;
    if (ext2_get_inode(2, &ext2_inode_buf) == 0) { rootl_a = ext2_inode_links_count(&ext2_inode_buf); }
    var pl_a = 0;
    if (pino > 0) { if (ext2_get_inode(pino, &ext2_inode_buf) == 0) { pl_a = ext2_inode_links_count(&ext2_inode_buf); } }
    if (ext2_rename(2, "rnd", 3, pino, "rnd", 3) != 0) { wrx = 0; }
    if (ext2_path_lookup("/rnd", 4) != 0) { wrx = 0; }              # gone from root
    if (ext2_dir_lookup(pino, "rnd", 3) <= 0) { wrx = 0; }          # present in /rnp
    if (dino > 0) { if (ext2_dir_lookup(dino, "..", 2) != pino) { wrx = 0; } }   # ".." repointed
    var rootl_b = 0;
    if (ext2_get_inode(2, &ext2_inode_buf) == 0) { rootl_b = ext2_inode_links_count(&ext2_inode_buf); }
    var pl_b = 0;
    if (pino > 0) { if (ext2_get_inode(pino, &ext2_inode_buf) == 0) { pl_b = ext2_inode_links_count(&ext2_inode_buf); } }
    if (rootl_b != rootl_a - 1) { wrx = 0; }                       # root lost the ".." link
    if (pl_b != pl_a + 1) { wrx = 0; }                             # /rnp gained it
    if (wrx == 1) { kprintln("ext2w: Wren xdir OK", 19); }
    else          { kprintln("ext2w: Wren xdir MISMATCH", 25); }

    # (c) refuse rename onto an existing name (rename-replace is a follow-on).
    var wre = 1;
    if (ext2_create(2, "rnx.txt", 7) <= 0) { wre = 0; }
    if (ext2_create(2, "rny.txt", 7) <= 0) { wre = 0; }
    if (ext2_rename(2, "rnx.txt", 7, 2, "rny.txt", 7) == 0) { wre = 0; }   # must REFUSE
    if (ext2_path_lookup("/rnx.txt", 8) <= 0) { wre = 0; }         # src untouched
    if (ext2_path_lookup("/rny.txt", 8) <= 0) { wre = 0; }         # dst untouched
    if (wre == 1) { kprintln("ext2w: Wren refuse OK", 21); }
    else          { kprintln("ext2w: Wren refuse MISMATCH", 27); }

    # === Whardlink: ln (1.33.3 bite 2) ===
    # create /hl_a.txt (marker "HL"), hardlink to /hl_b.txt → same inode +
    # nlink 2; unlink /hl_a.txt → nlink 1, /hl_b.txt survives (kept for host).
    var whl = 1;
    var hla = ext2_create(2, "hl_a.txt", 8);
    if (hla <= 0) { whl = 0; }
    if (hla > 0) { ext2_write_at(hla, 0, "HL", 2); }
    if (ext2_link(hla, 2, "hl_b.txt", 8) != 0) { whl = 0; }
    if (ext2_path_lookup("/hl_b.txt", 9) != hla) { whl = 0; }       # same inode
    if (hla > 0) {
        if (ext2_get_inode(hla, &ext2_inode_buf) != 0) { whl = 0; }
        else { if (ext2_inode_links_count(&ext2_inode_buf) != 2) { whl = 0; } }
    }
    if (ext2_unlink(2, "hl_a.txt", 8) != 0) { whl = 0; }            # drop one link
    if (ext2_path_lookup("/hl_a.txt", 9) != 0) { whl = 0; }         # old name gone
    if (ext2_path_lookup("/hl_b.txt", 9) != hla) { whl = 0; }       # other survives
    if (hla > 0) {
        if (ext2_get_inode(hla, &ext2_inode_buf) != 0) { whl = 0; }
        else { if (ext2_inode_links_count(&ext2_inode_buf) != 1) { whl = 0; } }
    }
    if (whl == 1) { kprintln("ext2w: Whard link OK", 20); }
    else          { kprintln("ext2w: Whard link MISMATCH", 26); }

    # refuse a directory hardlink (would create a `..`-less second parent ref)
    var whd = 1;
    var hld = ext2_mkdir(2, "hl_d", 4);
    if (hld <= 0) { whd = 0; }
    if (ext2_link(hld, 2, "hl_d2", 5) == 0) { whd = 0; }            # must REFUSE
    if (ext2_path_lookup("/hl_d2", 6) != 0) { whd = 0; }            # no entry made
    if (whd == 1) { kprintln("ext2w: Whard refuse-dir OK", 26); }
    else          { kprintln("ext2w: Whard refuse-dir MISMATCH", 32); }

    # === Wsymlink: ln -s (1.33.3 bite 3) ===
    # FAST symlink /sl_f → "/hl_b.txt" (9 B inline, i_blocks 0); SLOW symlink
    # /sl_s → 70-B target in a data block. Both kept for host e2fsck (which
    # validates the fast/slow format + i_size + target).
    var wsf = 1;
    var slf = ext2_symlink(2, "sl_f", 4, "/hl_b.txt", 9);
    if (slf <= 0) { wsf = 0; }
    if (slf > 0) {
        if (ext2_get_inode(slf, &ext2_inode_buf) != 0) { wsf = 0; }
        else {
            if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0xA000) { wsf = 0; }   # S_IFLNK
            if (ext2_inode_size_lo(&ext2_inode_buf) != 9) { wsf = 0; }
            if (ext2_inode_blocks_lo(&ext2_inode_buf) != 0) { wsf = 0; }              # fast → 0 blocks
            if (load8(&ext2_inode_buf + 40) != 47) { wsf = 0; }                       # inline starts '/'
        }
    }
    if (wsf == 1) { kprintln("ext2w: Wsym fast OK", 19); }
    else          { kprintln("ext2w: Wsym fast MISMATCH", 25); }

    # slow symlink: 70-byte target ("/" + 69 'a')
    var stbuf[80];
    store8(&stbuf, 47);
    var sbi = 1;
    while (sbi < 70) { store8(&stbuf + sbi, 97); sbi = sbi + 1; }
    var wss = 1;
    var sls = ext2_symlink(2, "sl_s", 4, &stbuf, 70);
    if (sls <= 0) { wss = 0; }
    if (sls > 0) {
        if (ext2_get_inode(sls, &ext2_inode_buf) != 0) { wss = 0; }
        else {
            if ((ext2_inode_mode(&ext2_inode_buf) & 0xF000) != 0xA000) { wss = 0; }
            if (ext2_inode_size_lo(&ext2_inode_buf) != 70) { wss = 0; }
            if (ext2_inode_blocks_lo(&ext2_inode_buf) == 0) { wss = 0; }              # slow → has a block
        }
    }
    if (wss == 1) { kprintln("ext2w: Wsym slow OK", 19); }
    else          { kprintln("ext2w: Wsym slow MISMATCH", 25); }

    # === Wsymres: symlink RESOLUTION (1.33.4 bite 2) ===
    # ext2_path_lookup now FOLLOWS symlinks. /sl_f → "/hl_b.txt" (created in
    # Whard above, content "HL"); resolving /sl_f must yield hl_b.txt's inode
    # — pre-1.33.4 it returned the symlink's own inode. A relative link and a
    # self-referential ELOOP cycle exercise the relative + cap paths.
    var wsr = 1;
    var tgt_ino = ext2_path_lookup("/hl_b.txt", 9);
    if (tgt_ino <= 0) { wsr = 0; }
    if (ext2_path_lookup("/sl_f", 5) != tgt_ino) { wsr = 0; }   # absolute target → same inode

    # relative symlink /rl → "hl_b.txt" (no leading '/'); resolves in root.
    var rl = ext2_symlink(2, "rl", 2, "hl_b.txt", 8);
    if (rl <= 0) { wsr = 0; }
    if (rl > 0) {
        if (ext2_path_lookup("/rl", 3) != tgt_ino) { wsr = 0; }   # relative target → same inode
    }

    # ELOOP: /lp → "lp" (points at itself); lookup must bail (-1), not hang.
    var lp = ext2_symlink(2, "lp", 2, "lp", 2);
    if (lp <= 0) { wsr = 0; }
    if (lp > 0) {
        if (ext2_path_lookup("/lp", 3) != 0 - 1) { wsr = 0; }     # ELOOP → -1
    }
    if (wsr == 1) { kprintln("ext2w: Wsymres resolve OK", 25); }
    else          { kprintln("ext2w: Wsymres resolve MISMATCH", 31); }

    # === Wuninit: uninit-group materialization (1.33.4 bite 3) ===
    # Only meaningful on a multi-group flex_bg image (the 67 MiB write-smoke
    # is a single group 0 → SKIP). Scan for the first INODE_UNINIT + first
    # BLOCK_UNINIT group; exercise materialization on each. BLOCK side goes
    # through the real allocator (goal-directed) to prove the integrated
    # path; INODE side materializes directly (alloc is first-fit, so it can't
    # be steered to a high group — the block path proves the integration).
    var wun = 1;
    var did_uninit = 0;
    if (ext2_read_bgdt() == 0) {
        var ung = ext2_ngroups();
        var gi = 0 - 1;
        var gb = 0 - 1;
        var ug = 0;
        while (ug < ung) {
            var fl = ext2_grp_bg_flags(ug);
            if (gi < 0) { if ((fl & 0x1) != 0) { gi = ug; } }
            if (gb < 0) { if ((fl & 0x2) != 0) { gb = ug; } }
            ug = ug + 1;
        }
        # BLOCK_UNINIT: force an allocation into gb (goal) → materialize+alloc.
        if (gb > 0) {
            did_uninit = 1;
            var goal = ext2_first_data_block + gb * ext2_blocks_per_group;
            var blk = ext2_alloc_block(goal);
            if (blk <= 0) { wun = 0; }
            else {
                var bgrp = (blk - ext2_first_data_block) / ext2_blocks_per_group;
                if (bgrp != gb) { wun = 0; }                 # alloc must land in gb
                if (ext2_read_bgdt() != 0) { wun = 0; }
                else { if ((ext2_grp_bg_flags(gb) & 0x2) != 0) { wun = 0; } }  # flag cleared
                ext2_free_block(blk);                        # restore free count
            }
        }
        # INODE_UNINIT: materialize directly + persist via ext2_write_bgdt.
        if (gi > 0) {
            did_uninit = 1;
            if (ext2_read_bgdt() != 0) { wun = 0; }
            else {
                if (ext2_materialize_inode_bitmap(gi) != 0) { wun = 0; }
                if (ext2_write_bgdt() != 0) { wun = 0; }
                if ((ext2_grp_bg_flags(gi) & 0x1) != 0) { wun = 0; }  # flag cleared
            }
        }
    }
    if (did_uninit == 0) { kprintln("ext2w: Wuninit SKIP (single-group image)", 40); }
    else {
        if (wun == 1) { kprintln("ext2w: Wuninit materialize OK", 29); }
        else          { kprintln("ext2w: Wuninit materialize MISMATCH", 35); }
    }

    # === Wsync: s_state dirty/clean + sync (1.33.3 bite 4 — cycle close) ===
    # All the bites above mutated, so the first write already cleared
    # EXT2_VALID_FS → s_state must read DIRTY now. sync sets it back → CLEAN,
    # and leaves the post-boot image e2fsck-"cleanly unmounted".
    var wsy = 1;
    var st_dirty = ext2_load16_le(&ext2_sb_buf, 0x3A);
    if ((st_dirty & 0x0001) != 0) { wsy = 0; }              # expect VALID_FS CLEAR (dirty)
    if (ext2_sync() != 0) { wsy = 0; }
    var st_clean = ext2_load16_le(&ext2_sb_buf, 0x3A);
    if ((st_clean & 0x0001) == 0) { wsy = 0; }              # expect VALID_FS SET (clean)
    if (wsy == 1) { kprintln("ext2w: Wsync state OK", 21); }
    else          { kprintln("ext2w: Wsync state MISMATCH", 27); }

    return 0;
}

# === ext4 extent-ALLOCATION self-test (compile-gated EXT2_EXTENT_WRITE_SELFTEST, 1.37.0) ===
# Appends a known pattern past EOF of a SEED extent-mapped file (`/extseed.dat`,
# created by `mkfs.ext4 -d` so it carries EXTENTS_FL with a depth-0 inline root),
# exercising ext2_extent_append_block via ext2_write_at. The smoke
# (scripts/ext-extent-smoke.sh) then host-verifies: e2fsck -fn clean + the file
# grew + the appended bytes are 0xAB. Gate string: "ext-ext: append PASS".
# Self-seed: create /extseed.dat as an EMPTY depth-0 extent file under root (ino
# 2) when it's absent — so the iron burn is flash-and-test (no host-side mount /
# `mkfs.ext4 -d` seed needed). A freshly-allocated inode is zeroed (no stale
# indirect pointers), so setting EXTENTS_FL + an empty inline extent root
# (eh_entries=0) is sound; the subsequent sparse writes exercise the allocator
# from depth 0. Mirrors the ext2_symlink inode-init pattern. Returns the new
# inode (>0) or -1. (Compile-gated with the selftest — never called in production.)
fn ext2_extent_seed_create() {
    var ino = ext2_alloc_inode(0);                           # regular file (not dir)
    if (ino <= 0) { return 0 - 1; }
    var z = 0;
    while (z < ext2_inode_size) { store8(&ext2_inode_buf + z, 0); z = z + 1; }
    ext2_inode_set_mode(&ext2_inode_buf, 0x81FF);            # S_IFREG | 0777
    ext2_inode_set_links_count(&ext2_inode_buf, 1);
    ext2_inode_set_size_lo(&ext2_inode_buf, 0);
    ext2_inode_set_blocks_lo(&ext2_inode_buf, 0);
    ext2_store32_le(&ext2_inode_buf, 32, 0x80000);           # i_flags = EXT4_EXTENTS_FL
    var hdr = &ext2_inode_buf + 40;                          # empty depth-0 extent inline root
    ext2_store16_le(hdr, 0, 0xF30A);                         # eh_magic
    ext2_store16_le(hdr, 2, 0);                              # eh_entries
    ext2_store16_le(hdr, 4, 4);                              # eh_max (inline root)
    ext2_store16_le(hdr, 6, 0);                              # eh_depth
    ext2_store16_le(hdr, 8, 0);                              # eh_generation
    if (ext2_put_inode(ino, &ext2_inode_buf) != 0) { ext2_free_inode(ino, 0); return 0 - 1; }
    if (ext2_dir_insert(2, "extseed.dat", 11, ino, 1) != 0) { ext2_free_inode(ino, 0); return 0 - 1; }
    return ino;
}

fn ext2_extent_write_selftest() {
    if (ext2_active == 0)   { kprintln("ext-ext: not mounted -- skip", 28); return 0; }
    if (ext2_write_ok == 0) { kprintln("ext-ext: read-only -- skip", 26); return 0; }
    var ino = ext2_path_lookup("/extseed.dat", 12);
    if (ino <= 0) {                                          # absent → self-seed (flash-and-test)
        ino = ext2_extent_seed_create();
        if (ino <= 0) { kprintln("ext-ext: seed create FAIL", 25); return 0 - 1; }
        kprintln("ext-ext: seeded /extseed.dat (empty extent file)", 48);
    }
    if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { kprintln("ext-ext: get_inode FAIL", 23); return 0 - 1; }
    if ((ext2_inode_flags(&ext2_inode_buf) & 0x80000) == 0) {
        kprintln("ext-ext: seed not extent-mapped FAIL", 36); return 0 - 1;
    }
    kprint("ext-ext: ino=", 13); kprint_num(ino);
    kprint(" extent size0=", 14); kprint_num(ext2_inode_size_lo(&ext2_inode_buf)); kprintln("", 0);

    # Idempotent skip: a prior boot's run left /extseed.dat at depth=2 (the full
    # ladder already exercised + persisted on disk). Re-running the loop from
    # lblk=2 would write into already-allocated extents at depth 2 and exit
    # before the depth-0→1 grow (got_sibling) could be observed — falsely
    # reporting "no sibling leaf formed FAIL" against a healthy FS (boot-2 of
    # iron Attempt 1373). The persisted depth-2 tree IS the durability proof:
    # the extent metadata survived power-cycle and e2fsck stayed clean. Skip
    # with PASS rather than tear the file down + re-seed, which would discard
    # that evidence on every reboot.
    if (ext2_load16_le(&ext2_inode_buf + 40, 6) == 2) {
        kprintln("ext-ext: /extseed.dat already at depth=2 (prior boot) -- skip PASS", 66);
        return 0;
    }

    # Append 64 bytes of 0xAB at SPARSE logical blocks 2,4,6,… — each logical gap
    # forces a NEW (non-contiguous) extent. As the file grows the tree climbs the
    # full depth ladder: inline root fills → depth-0→1 grow (1.37.1); the leaf
    # fills (eh_max) → SIBLING leaf (1.37.2); all 4 inline-root index slots fill
    # (4 full leaves) → depth-1→2 grow into an INDEX block + a leaf under it
    # (1.37.3). Exercises every insert path + the metadata_csum leaf AND index
    # node checksums.
    var pat[64];
    var i = 0;
    while (i < 64) { store8(&pat + i, 0xAB); i = i + 1; }
    # Loop until the tree reaches depth 2 (≈ 4×eh_max extents — 1360 at a 4096-
    # block FS, ~336 at 1024). Cap is generous (6000) but the loop breaks the
    # instant depth==2 appears. Adaptive so it works at any block size.
    var lblk = 2;
    var got_sibling = 0;
    var got_depth2 = 0;
    while (lblk <= 6000) {
        var w = ext2_write_at(ino, lblk * ext2_blocksize, &pat, 64);
        if (w != 64) {
            kprint("ext-ext: write_at lblk=", 23); kprint_num(lblk);
            kprint(" returned ", 10); kprint_num(w); kprintln(" FAIL", 5);
            return 0 - 1;
        }
        if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
        var d = ext2_load16_le(&ext2_inode_buf + 40, 6);
        if (d == 1) { if (ext2_load16_le(&ext2_inode_buf + 40, 2) >= 2) { got_sibling = 1; } }
        if (d == 2) { got_depth2 = 1; lblk = 6002; }
        lblk = lblk + 2;
    }
    if (ext2_get_inode(ino, &ext2_inode_buf) != 0) { return 0 - 1; }
    kprint("ext-ext: final depth=", 21); kprint_num(ext2_load16_le(&ext2_inode_buf + 40, 6));
    kprint(" root_entries=", 14); kprint_num(ext2_load16_le(&ext2_inode_buf + 40, 2));
    kprint(" size=", 6); kprint_num(ext2_inode_size_lo(&ext2_inode_buf)); kprintln("", 0);
    if (got_sibling == 0) { kprintln("ext-ext: no sibling leaf formed FAIL", 36); return 0 - 1; }
    if (got_depth2 == 0) { kprintln("ext-ext: depth-2 not reached FAIL", 33); return 0 - 1; }
    kprintln("ext-ext: depth-2 PASS", 21);
    kprintln("ext-ext: append PASS", 20);
    return 0;
}
