# grad_ref_px — integer reference for the gradient, in the standard lerp form
#   sc = (c0*(den-y) + c1*y + den/2) / den
# which keeps every intermediate NON-NEGATIVE. The obvious `c0 + (c1-c0)*y/den` form has a negative
# numerator whenever the gradient descends, and Cyrius integer division truncates toward zero — so it would
# round the descending half in the opposite direction from the ascending half. That asymmetry is exactly
# the kind of bug a tolerance-based test hides.
fn grad_ref_px(c0, c1, y, den, dst) {
    var a0 = (c0 >> 24) & 0xFF;
    var a1 = (c1 >> 24) & 0xFF;
    var sa = (a0 * (den - y) + a1 * y + den / 2) / den;
    var ia = 255 - sa;
    var out = 0;
    var ch = 0;
    while (ch < 4) {
        var sh = ch * 8;
        var e0 = (c0 >> sh) & 0xFF;
        var e1 = (c1 >> sh) & 0xFF;
        var sc = (e0 * (den - y) + e1 * y + den / 2) / den;
        var dc = (dst >> sh) & 0xFF;
        var q = (sc * 255 + dc * ia + 127) / 255;
        if (q > 255) { q = 255; }
        out = out | (q << sh);
        ch = ch + 1;
    }
    return out;
}

# gpu_shader_grad_test — S9: vertical linear gradient, generated with NO source buffer, composited src-over.
#
# Both endpoint colours are SGPRs and the varying quantity is the row index the SPI already provides, so a
# full-screen gradient reads ZERO source bytes. On the CPU this is the worst primitive of the set: per-pixel
# interpolate AND per-pixel blend, with no memcpy-shaped loop to lean on.
#
# The ramp runs opaque magenta -> fully transparent over a dark/light split underlay, so BOTH ramps are
# visible at once: the colour fading and the underlay returning. A gradient that lerped straight-alpha
# instead of premultiplied colour would darken through the middle — visible against the light half.
#
# ⚠ Row 0 is asserted BIT-EXACT (t is exactly 0.0 and alpha0 is 255, so the row must be exactly C0).
# Elsewhere the bound is 2, not blend_cov's 1, because t comes from v_rcp_f32 — a hardware reciprocal
# APPROXIMATION, since GFX9 has neither an integer divide nor an exact f32 divide. The observed maximum is
# reported so the looser bound stays a measured fact rather than a convenient one.
fn gpu_shader_grad_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) { kprintln("gpu: skipping gradient (dispatch envelope unproven)", 51); return 0; }
    if (gpu_blit_arm() != 1) { kprintln("gpu: skipping gradient (no back buffer)", 39); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    var pitch = gpu_bb_pitch;
    if (pitch < (GPU_GRD_X + GPU_GRD_W) * 4) { kprintln("gpu: skipping gradient (surface too narrow)", 43); return 0; }

    var bb_phys = gpu_bb_a_phys;
    var bb_mc   = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { bb_phys = gpu_bb_b_phys; bb_mc = gpu_bb_b_mc; }

    var sh_phys = gpu_arena_phys + GPU_GRAD_SHADER_SUBOFF;
    var sh_mc   = gpu_arena_mc   + GPU_GRAD_SHADER_SUBOFF;
    var dn_phys = gpu_arena_phys + GPU_BLEND_DONE_SUBOFF;
    var dn_mc   = gpu_arena_mc   + GPU_BLEND_DONE_SUBOFF;
    grad_linear_write(sh_phys);

    var half = GPU_GRD_W / 2;
    var g_mc   = bb_mc   + GPU_GRD_Y * pitch + GPU_GRD_X * 4;
    var g_phys = bb_phys + GPU_GRD_Y * pitch + GPU_GRD_X * 4;
    if (gpu_cp_dma_fill_rect(g_mc, pitch, GPU_GRD_L, half * 4, GPU_GRD_H) != 1) {
        kprintln("gpu: gradient underlay fill failed", 34); return 0;
    }
    if (gpu_cp_dma_fill_rect(g_mc + half * 4, pitch, GPU_GRD_R, half * 4, GPU_GRD_H) != 1) {
        kprintln("gpu: gradient underlay fill failed", 34); return 0;
    }

    var gx = (GPU_GRD_W + 63) / 64;
    if (gpu_grid7_run(sh_mc,
    g_mc & 0xFFFFFFFF, (g_mc >> 32) & 0xFFFFFFFF,
    pitch, GPU_GRD_W, GPU_GRD_H, GPU_GRD_C0, GPU_GRD_C1,
    GPU_COMPUTE_PGM_RSRC1_GRAD, gx, GPU_GRD_H, dn_mc, dn_phys) != 1) {
        kprintln("gpu: gradient dispatch did not complete", 39);
        return 0;
    }

    var den = GPU_GRD_H - 1;
    var row0_bad = 0; var maxdev = 0; var bx = 0; var by = 0;
    var vy = 0;
    while (vy < GPU_GRD_H) {
        var vx = 0;
        while (vx < GPU_GRD_W) {
            var od = GPU_GRD_L;
            if (vx >= half) { od = GPU_GRD_R; }
            var got = load32(g_phys + vy * pitch + (vx << 2)) & 0xFFFFFFFF;
            var ref = grad_ref_px(GPU_GRD_C0, GPU_GRD_C1, vy, den, od) & 0xFFFFFFFF;
            if (got != ref) {
                if (vy == 0) { if (row0_bad == 0) { bx = vx; by = vy; } row0_bad = row0_bad + 1; }
                var ch = 0;
                while (ch < 4) {
                    var sh8 = ch * 8;
                    var d = ((got >> sh8) & 0xFF) - ((ref >> sh8) & 0xFF);
                    if (d < 0) { d = 0 - d; }
                    if (d > maxdev) { maxdev = d; }
                    ch = ch + 1;
                }
            }
            vx = vx + 1;
        }
        vy = vy + 1;
    }
    if (row0_bad != 0) {
        kprint("gpu: gradient ROW 0 NOT EXACT ", 30); kprint_num(row0_bad);
        kprint(" px, first at x=", 16); kprint_num(bx);
        kprintln("", 0);
        return 0;
    }
    if (maxdev > 2) {
        kprint("gpu: gradient DEVIATION too large, max ", 39); kprint_num(maxdev);
        kprintln("", 0);
        return 0;
    }

    var prev_back = gpu_bb_back;
    gpu_blit_present(0);
    var dh = 0;
    while (dh < 30000) { gpu_udelay(100); dh = dh + 1; }
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_display_surf >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_display_surf & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    gpu_bb_back = prev_back;

    gpu_grad_ok = 1;
    kprint("gpu: shader gradient online (row 0 exact, max dev ", 50); kprint_num(maxdev);
    kprintln(")", 1);
    return 1;
}

# gpu_glyph_arm / gpu_glyph_surface — the #94 runtime path. Same lazy-upload, own-slot discipline as
# gpu_blend_arm / gpu_cov_arm.
fn gpu_glyph_arm() {
    if (gpu_glyph_armed == 1) { return 1; }
    if (gpu_present == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    if (gpu_matmul_ok != 1) { return 0; }
    glyph_1bpp_write(gpu_arena_phys + GPU_GLYPH_SHADER_SUBOFF);
    gpu_mfence();
    gpu_glyph_armed = 1;
    return 1;
}

fn gpu_glyph_surface(bmp_mc, w, h, dx, dy, color) {
    if (gpu_glyph_arm() != 1) { return 0; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    var gx = (w + 63) / 64;
    var stride = (w + 7) / 8;                      # 1bpp: 8 px per byte, rows byte-aligned
    return gpu_blend_cov_run(gpu_arena_mc + GPU_GLYPH_SHADER_SUBOFF, bmp_mc, dst_mc,
    stride, gpu_bb_pitch, w, color, GPU_COMPUTE_PGM_RSRC1_GLYPH, gx, h,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF,
    gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
}

# gpu_shader_glyph_test — S8: expand a 1bpp bitmap to 32bpp with a transparent background.
#
# The bitmap is composed from kashi's real CP437 8x16 font, so the on-screen result is READABLE TEXT. That
# is deliberate and not decoration: the failure mode this kernel is most prone to — reading the bit order
# LSB-first instead of MSB-first — mirrors every glyph horizontally. A numeric test would still pass if the
# reference made the same mistake; mirrored words do not survive a glance.
#
# ⚠ This test asserts BIT-EXACTNESS with no tolerance, unlike the coverage test. There is no arithmetic on
# colour here: a pixel either becomes the colour or is untouched. Any deviation at all is a real bug.
fn gpu_shader_glyph_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) { kprintln("gpu: skipping glyph (dispatch envelope unproven)", 48); return 0; }
    if (gpu_blit_arm() != 1) { kprintln("gpu: skipping glyph (no back buffer)", 36); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    var pitch = gpu_bb_pitch;
    if (pitch < (GPU_GLY_X + GPU_GLY_W) * 4) { kprintln("gpu: skipping glyph (surface too narrow)", 40); return 0; }

    var bb_phys = gpu_bb_a_phys;
    var bb_mc   = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { bb_phys = gpu_bb_b_phys; bb_mc = gpu_bb_b_mc; }

    var sh_phys = gpu_arena_phys + GPU_GLYPH_SHADER_SUBOFF;
    var sh_mc   = gpu_arena_mc   + GPU_GLYPH_SHADER_SUBOFF;
    var bm_phys = gpu_arena_phys + GPU_GLYPH_BMP_SUBOFF;
    var bm_mc   = gpu_arena_mc   + GPU_GLYPH_BMP_SUBOFF;
    var dn_phys = gpu_arena_phys + GPU_BLEND_DONE_SUBOFF;
    var dn_mc   = gpu_arena_mc   + GPU_BLEND_DONE_SUBOFF;
    glyph_1bpp_write(sh_phys);

    # Compose the 1bpp bitmap straight out of kashi's font: one row byte per character per scanline, so a
    # 16-character line is exactly 16 bytes per row — 4 store32s, no bit shuffling at all. The font's
    # native layout IS the kernel's input format, which is the whole point of a 1bpp path.
    var msg = "AGNOS SHADER GPU";
    var r = 0;
    while (r < GPU_GLY_H) {
        var d = 0;
        while (d < 4) {
            var word = 0;
            var k = 0;
            while (k < 4) {
                var ch = load8(msg + d * 4 + k);
                word = word | ((kashi_glyph_row(KASHI_FONT_VGA_8X16, ch, r) & 0xFF) << (k * 8));
                k = k + 1;
            }
            store32(bm_phys + r * GPU_GLY_STRIDE + d * 4, word);
            d = d + 1;
        }
        r = r + 1;
    }
    gpu_mfence();

    var t_mc   = bb_mc   + GPU_GLY_Y * pitch + GPU_GLY_X * 4;
    var t_phys = bb_phys + GPU_GLY_Y * pitch + GPU_GLY_X * 4;
    if (gpu_cp_dma_fill_rect(t_mc, pitch, GPU_GLY_BG, GPU_GLY_W * 4, GPU_GLY_H) != 1) {
        kprintln("gpu: glyph underlay fill failed", 31); return 0;
    }
    var gx = (GPU_GLY_W + 63) / 64;
    if (gpu_blend_cov_run(sh_mc, bm_mc, t_mc, GPU_GLY_STRIDE, pitch, GPU_GLY_W, GPU_GLY_FG,
    GPU_COMPUTE_PGM_RSRC1_GLYPH, gx, GPU_GLY_H, dn_mc, dn_phys) != 1) {
        kprintln("gpu: glyph dispatch did not complete", 36);
        return 0;
    }

    # Verify exactly. `lit` counts pixels that were actually SET — a kernel whose EXEC mask killed every
    # lane would leave the underlay everywhere and still match on the background pixels, so "no mismatches"
    # alone is not evidence the glyphs drew (the 1.54.17-19 lesson, in its bitmap form).
    var bad = 0; var lit = 0; var bx = 0; var by = 0;
    var vy = 0;
    while (vy < GPU_GLY_H) {
        var vx = 0;
        while (vx < GPU_GLY_W) {
            var byt = load8(bm_phys + vy * GPU_GLY_STRIDE + (vx >> 3)) & 0xFF;
            var bit = (byt >> (7 - (vx & 7))) & 1;
            var want = GPU_GLY_BG;
            if (bit == 1) { want = GPU_GLY_FG; lit = lit + 1; }
            var got = load32(t_phys + vy * pitch + (vx << 2)) & 0xFFFFFFFF;
            if (got != (want & 0xFFFFFFFF)) {
                if (bad == 0) { bx = vx; by = vy; }
                bad = bad + 1;
            }
            vx = vx + 1;
        }
        vy = vy + 1;
    }
    if (bad != 0) {
        kprint("gpu: glyph MISMATCH ", 20); kprint_num(bad);
        kprint(" px, first at x=", 16); kprint_num(bx);
        kprint(" y=", 3); kprint_num(by);
        kprintln("", 0);
        return 0;
    }
    if (lit < 1) { kprintln("gpu: glyph NO PIXELS SET (empty font or exec mask?)", 51); return 0; }

    var prev_back = gpu_bb_back;
    gpu_blit_present(0);
    var dh = 0;
    while (dh < 30000) { gpu_udelay(100); dh = dh + 1; }
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_display_surf >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_display_surf & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    gpu_bb_back = prev_back;

    gpu_glyph_ok = 1;
    kprint("gpu: shader glyph expand online (1bpp text, bit-exact, ", 55); kprint_num(lit);
    kprintln(" px set)", 8);
    return 1;
}

# gpu_cov_arm — make blend_cov resident for the RUNTIME (#93) path. Idempotent; own arena slot, so #93
# works in a kernel built without SHADER_COV and depends on no boot-time ordering. Peer of gpu_blend_arm.
fn gpu_cov_arm() {
    if (gpu_cov_armed == 1) { return 1; }
    if (gpu_present == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    if (gpu_matmul_ok != 1) { return 0; }
    blend_cov_write(gpu_arena_phys + GPU_COV_SHADER_SUBOFF);
    gpu_mfence();
    gpu_cov_armed = 1;
    return 1;
}

# gpu_cov_surface — composite a uniform colour through an 8bpp coverage mask onto the back buffer.
# Kernel-side worker behind gpu_blend_cov_shm#93. Returns 1 / 0. Caller owns all bounds checking.
fn gpu_cov_surface(mask_mc, w, h, dx, dy, color) {
    if (gpu_cov_arm() != 1) { return 0; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    var gx = (w + 63) / 64;
    return gpu_blend_cov_run(gpu_arena_mc + GPU_COV_SHADER_SUBOFF, mask_mc, dst_mc,
    w, gpu_bb_pitch, w, color, GPU_COMPUTE_PGM_RSRC1_COV, gx, h,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF,
    gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
}

