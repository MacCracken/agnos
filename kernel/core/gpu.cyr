# perm_ref_px — the CPU oracle for v_perm_b32, single-source form (pool bytes 0..3 = px, 4..7 = 0).
# Selector byte k drives DESTINATION byte k, LSB to LSB — so a selector written as hex reads
# destination-MSB-first. 0..3 index the pixel's bytes; 12 is a constant 0x00; >= 13 is a constant 0xFF.
# Values 4..11 need the second source and are unreachable here by construction.
fn perm_ref_px(px, sel) {
    var out = 0;
    var k = 0;
    while (k < 4) {
        var sb = (sel >> (k * 8)) & 0xFF;
        var b = 0;
        if (sb < 4) { b = (px >> (sb * 8)) & 0xFF; }
        if (sb == 12) { b = 0; }
        if (sb > 12) { b = 0xFF; }
        out = out | (b << (k * 8));
        k = k + 1;
    }
    return out & 0xFFFFFFFF;
}

# gpu_shader_perm_test — plan-S4(i)+(ii): the v_perm_b32 BYTE CROSSBAR.
#
# Two proofs, one kernel, driven twice with different selectors:
#   (i)  unpack -> repack identity, the three fixed selectors 0x0c010c00 / 0x0c030c02 / 0x06040200
#   (ii) the ONE-INSTRUCTION RGBX<->BGRX permutation, selector 0x03000102
#
# (ii) is the item this arc opened by calling "an unhandled case, not just a slow one" — and it stayed that
# way through eleven bites. It is NOT the same capability as the DCN HUBP crossbar (bite D1): that crossbar
# is a property of the WHOLE SCANOUT, so it cannot swap one composited client surface while leaving its
# neighbours alone. This can.
#
# ⚠ The source pixels have all four bytes DISTINCT and NON-ZERO. A permutation proof on 0x11111111 passes
# for every selector ever written, which is worth exactly nothing.
#
# Run 1 uses the IDENTITY selector as a control: if the unpack/repack lane fails there, the swap run cannot
# tell you anything new, so the test stops rather than reporting a second derived failure.
fn gpu_shader_perm_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) { kprintln("gpu: skipping perm (dispatch envelope unproven)", 47); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_PERM_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_PERM_SHADER_SUBOFF;
    var src_phys    = gpu_arena_phys + GPU_PERM_SRC_SUBOFF;
    var src_mc      = gpu_arena_mc   + GPU_PERM_SRC_SUBOFF;
    var out_phys    = gpu_arena_phys + GPU_PERM_OUT_SUBOFF;
    var out_mc      = gpu_arena_mc   + GPU_PERM_OUT_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    perm_write(shader_phys);

    var i = 0;
    while (i < 64) {
        var b = i * 4 + 1;
        var g = i * 4 + 2;
        var r = i * 4 + 3;
        var a = i * 4 + 4;
        store32(src_phys + (i << 2), (a << 24) | (r << 16) | (g << 8) | b);
        i = i + 1;
    }
    var z = 0;
    while (z < 256) { store32(out_phys + (z << 2), GPU_MT_NOTYET); z = z + 1; }
    gpu_mfence();

    var pass = gpu_perm_run_one(shader_mc, src_mc, out_mc, done_mc, done_phys,
    src_phys, out_phys, 0x03020100, 1);
    if (pass != 1) { return 0; }

    var z2 = 0;
    while (z2 < 256) { store32(out_phys + (z2 << 2), GPU_MT_NOTYET); z2 = z2 + 1; }
    gpu_mfence();
    var pass2 = gpu_perm_run_one(shader_mc, src_mc, out_mc, done_mc, done_phys,
    src_phys, out_phys, 0x03000102, 0);
    if (pass2 != 1) { return 0; }

    gpu_perm_ok = 1;
    kprintln("gpu: perm byte crossbar online (identity and channel swap, 64 px)", 65);
    return 1;
}

# gpu_perm_run_one — one dispatch of perm.s plus its five checks, ordered so the FIRST failure is the most
# diagnostic: source witness (did the kernel read the right bytes at all) -> lanes stored (did every lane
# run) -> the selector result -> involution -> unpack/repack.
#
# ⚠ The involution check is valid ONLY because both driven selectors are involutions: identity trivially,
# and 0x03000102 because it is a transposition of bytes 0 and 2. If anyone later drives a ROTATE such as
# 0x02010003, slot +4 must be compared against a DOUBLE CPU shuffle, or correct hardware reads as broken.
fn gpu_perm_run_one(shader_mc, src_mc, out_mc, done_mc, done_phys, src_phys, out_phys, sel, is_ctrl) {
    if (is_ctrl == 1) { kprintln("gpu: perm control run, selector is identity", 43); }
    if (is_ctrl != 1) { kprintln("gpu: perm swap run, selector swaps red and blue", 47); }

    if (gpu_matmul_run(shader_mc, src_mc, out_mc, sel, done_mc, done_phys,
    GPU_COMPUTE_PGM_RSRC1_V12) != 1) {
        kprintln("gpu: perm dispatch did not complete", 35);
        return 0;
    }

    var stored = 0;
    var j = 0;
    while (j < 64) {
        if ((load32(out_phys + (j << 4) + 12) & 0xFFFFFFFF) != GPU_MT_NOTYET) { stored = stored + 1; }
        j = j + 1;
    }
    kprint("gpu: perm lanes stored ", 23); kprint_num(stored); kprintln(" of 64", 6);
    if (stored != 64) { kprintln("gpu: perm LANES MISSING (exec mask?)", 36); return 0; }

    var k = 0;
    while (k < 64) {
        var sp  = load32(src_phys + (k << 2)) & 0xFFFFFFFF;
        var wit = load32(out_phys + (k << 4) + 12) & 0xFFFFFFFF;
        if (wit != sp) {
            kprint("gpu: perm source witness wrong at lane ", 39); kprint_num(k);
            kprint(" got ", 5); kprint_num(wit); kprintln("", 0);
            return 0;
        }
        var got = load32(out_phys + (k << 4) + 0) & 0xFFFFFFFF;
        var exp = perm_ref_px(sp, sel);
        if (got != exp) {
            if (is_ctrl == 1) { kprint("gpu: perm identity wrong at lane ", 33); }
            if (is_ctrl != 1) { kprint("gpu: perm channel swap wrong at lane ", 37); }
            kprint_num(k); kprint(" got ", 5); kprint_num(got); kprintln("", 0);
            return 0;
        }
        var inv = load32(out_phys + (k << 4) + 4) & 0xFFFFFFFF;
        if (inv != sp) {
            kprint("gpu: perm involution wrong at lane ", 35); kprint_num(k); kprintln("", 0);
            return 0;
        }
        var rt = load32(out_phys + (k << 4) + 8) & 0xFFFFFFFF;
        if (rt != sp) {
            kprint("gpu: perm unpack repack wrong at lane ", 38); kprint_num(k); kprintln("", 0);
            return 0;
        }
        k = k + 1;
    }
    return 1;
}

# gpu_shader_blend_pk_test — plan-S4(iii): the VOP3P PACKED re-expression of the premultiplied blend.
#
# The claim is BIT-IDENTICAL to the shipped f32 kernel, and it is asserted with zero tolerance rather than
# the "<= 1, max printed" discipline blend_cov uses. That is not optimism: it was established exhaustively
# off-iron over all 8,421,376 premultiplied (src_c, dst_c, src_a) triples — 0 mismatches, max deviation 0 —
# so any deviation here is a real hardware or encoding fault, not rounding.
#
# ⚠ EVERY SEEDED LANE MUST SATISFY sc <= sa. On the FULL cube the two kernels genuinely diverge on
# 4,177,920 of 16,777,216 triples with max deviation 255, because f32 saturates where the packed path wraps
# and carries into the neighbouring byte lane. That is the premultiplied precondition firing, NOT a VOP3P
# defect — and seeding straight-alpha pixels would indict the wrong instruction. The seed loop below keeps
# sc = sa/2 and the four corner lanes are hand-checked against the same rule.
#
# The f32 kernel is the oracle, so it must have passed first — hence the gpu_blend_ok gate.
fn gpu_shader_blend_pk_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) { kprintln("gpu: skipping packed blend (envelope unproven)", 46); return 0; }
    if (gpu_blend_ok != 1) { kprintln("gpu: skipping packed blend (float blend unproven)", 49); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var pk_phys  = gpu_arena_phys + GPU_PK_SHADER_SUBOFF;
    var pk_mc    = gpu_arena_mc   + GPU_PK_SHADER_SUBOFF;
    var src_phys = gpu_arena_phys + GPU_MM_A_SUBOFF;
    var src_mc   = gpu_arena_mc   + GPU_MM_A_SUBOFF;
    var dst_phys = gpu_arena_phys + GPU_MM_B_SUBOFF;
    var dst_mc   = gpu_arena_mc   + GPU_MM_B_SUBOFF;
    var f_phys   = gpu_arena_phys + GPU_MM_C_SUBOFF;
    var f_mc     = gpu_arena_mc   + GPU_MM_C_SUBOFF;
    var p_phys   = gpu_arena_phys + GPU_PK_OUT_SUBOFF;
    var p_mc     = gpu_arena_mc   + GPU_PK_OUT_SUBOFF;
    var done_phys = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc   = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    blend_pk_write(pk_phys);
    blend_premul_write(gpu_arena_phys + GPU_SHADER_SUBOFF);

    # Sweep alpha 0..255, then overwrite four lanes with the corners that discriminate real failure modes.
    var i = 0;
    while (i < 64) {
        var sa = (i * 255) / 63;
        var sc = sa / 2;                              # premultiplied: sc <= sa, as the format requires
        var dc = 255 - i * 4;
        if (dc < 0) { dc = 0; }
        store32(src_phys + (i << 2), (sa << 24) | (sc << 16) | (sc << 8) | sc);
        store32(dst_phys + (i << 2), (255 << 24) | (dc << 16) | (dc << 8) | dc);
        i = i + 1;
    }
    store32(src_phys + 0,  0x00000000); store32(dst_phys + 0,  0xFF7F7F7F);   # sa=0   -> out == dst
    store32(src_phys + 4,  0xFFFFFFFF); store32(dst_phys + 4,  0xFF7F7F7F);   # sa=255 -> out == src
    # lane 2 — OPAQUE BLACK over grey. The f32 path hands v_cvt_pk_u8_f32 a strictly NEGATIVE value here
    # (min -1.508e-05), so the two kernels agree only if that convert clamps to 0 rather than converting
    # modularly. It is the one behaviour in this bite that cannot be settled off iron.
    store32(src_phys + 8,  0xFF000000); store32(dst_phys + 8,  0xFF7F7F7F);
    # lane 3 — the truncate-vs-round discriminator: a truncating convert gives 0 where a rounding one gives 1.
    store32(src_phys + 12, 0x01000000); store32(dst_phys + 12, 0xFF010101);
    var z = 0;
    while (z < 64) { store32(p_phys + (z << 2), GPU_MT_NOTYET); z = z + 1; }
    gpu_mfence();

    if (gpu_matmul_run(gpu_arena_mc + GPU_SHADER_SUBOFF, src_mc, dst_mc, f_mc, done_mc, done_phys,
    GPU_COMPUTE_PGM_RSRC1_V12) != 1) {
        kprintln("gpu: float blend dispatch did not complete", 42); return 0;
    }
    # ⚠ _PK, not _V12 — blend_pk needs 24 SGPRs where blend_premul needs 16. See GPU_COMPUTE_PGM_RSRC1_PK.
    if (gpu_matmul_run(pk_mc, src_mc, dst_mc, p_mc, done_mc, done_phys,
    GPU_COMPUTE_PGM_RSRC1_PK) != 1) {
        kprintln("gpu: packed blend dispatch did not complete", 43); return 0;
    }

    var stored = 0;
    var w = 0;
    while (w < 64) {
        if ((load32(p_phys + (w << 2)) & 0xFFFFFFFF) != GPU_MT_NOTYET) { stored = stored + 1; }
        w = w + 1;
    }
    kprint("gpu: packed blend lanes stored ", 31); kprint_num(stored); kprintln(" of 64", 6);
    if (stored != 64) { kprintln("gpu: packed blend LANES MISSING (exec mask?)", 44); return 0; }

    var j = 0;
    while (j < 64) {
        var pv = load32(p_phys + (j << 2)) & 0xFFFFFFFF;
        var fv = load32(f_phys + (j << 2)) & 0xFFFFFFFF;
        if (pv != fv) {
            # Bytes 1 and 3 wrong while 0 and 2 are right is the op_sel_hi SIGNATURE: with the modifier
            # omitted the shift's lane-1 input reads bits[31:16] = 0, so only the HIGH u16 lane (channels
            # G and A) is corrupted. It renders as a plausible image with a green/alpha cast, and it gets
            # its own line because a generic mismatch would send the burn hunting the wrong instruction.
            var lo_ok = 0;
            if ((pv & 0x00FF00FF) == (fv & 0x00FF00FF)) { lo_ok = 1; }
            if (lo_ok == 1) {
                kprintln("gpu: packed blend green or alpha wrong, check the packed shift lane select", 74);
            }
            kprint("gpu: packed blend differs from float blend at lane ", 51); kprint_num(j);
            kprint(" got ", 5); kprint_num(pv); kprintln("", 0);
            return 0;
        }
        j = j + 1;
    }

    # The VALU numbers are PRINTED rather than left in a comment — gpu_regs.cyr already carries one stale
    # instruction claim, and the deliverable of this sub-proof is the comparison, not the equality.
    kprint("gpu: packed blend valu per pixel ", 33); kprint_num(27);
    kprint(" float ", 7); kprint_num(31); kprintln("", 0);
    gpu_blend_pk_ok = 1;
    kprintln("gpu: packed blend bit-identical to float blend (64 px)", 54);
    return 1;
}

# ── plan-S12: the batched mock-frame oracle ───────────────────────────────────────────────────────────
#
# The arc's stated CLOSING CONDITION: a full mock frame composited in ONE submission and pixel-identical to
# the same frame composited op-by-op, with a real frame time.
#
# ⚠ THE PLAN'S HONEST CLAUSE APPLIES AND IS NOT A HEDGE: "a batched frame that is NOT faster means the
# fence was never the wall, and that finding is the deliverable." This path is MEMORY-bound by the arc's own
# calibration (12 B/pixel; a full-screen 1080p blend moves ~25 MB), so a large speedup is not the expected
# result and would itself be suspicious. What must hold unconditionally is PIXEL-IDENTITY — the batched
# frame is not allowed to be a different frame.
#
# ⚠ The timing is only meaningful because plan-S12a landed FIRST. Before it, every dispatch was quantised
# to a 100 us sleep, so a batch would have appeared ~5x better than it is purely by collapsing N sleeps
# into one. Measuring against that baseline would have made this number unfalsifiable.

# gpu_s12_frame — composite the mock frame once. batched=1 puts all six ops in ONE submission.
# The op mix is the plan's: translucent window chrome (x3) + an AA-text run + a gradient titlebar.
fn gpu_s12_frame(batched, src_mc, mask_mc, bmp_mc) {
    var done_phys = gpu_arena_phys + GPU_BLEND_DONE_SUBOFF;
    var done_mc   = gpu_arena_mc   + GPU_BLEND_DONE_SUBOFF;
    if (batched == 1) {
        store32(done_phys, GPU_MT_NOTYET);
        gpu_mfence();
        gpu_batch_active = 1;
    }

    var ok = 1;
    if (gpu_blend_surface(src_mc, 64, 48, GPU_S12_X + 8,   GPU_S12_Y + 16) != 1) { ok = 0; }
    if (gpu_blend_surface(src_mc, 64, 48, GPU_S12_X + 88,  GPU_S12_Y + 32) != 1) { ok = 0; }
    if (gpu_blend_surface(src_mc, 64, 48, GPU_S12_X + 168, GPU_S12_Y + 48) != 1) { ok = 0; }
    if (gpu_cov_surface(mask_mc, 64, 64, GPU_S12_X + 32, GPU_S12_Y + 56, 0xFF00C8FF) != 1) { ok = 0; }
    if (gpu_glyph_surface(bmp_mc, 128, 16, GPU_S12_X + 16, GPU_S12_Y + 4, 0xFFFFE060) != 1) { ok = 0; }
    if (gpu_grad_surface(192, 24, GPU_S12_X + 32, GPU_S12_Y + 100, 0xFFC000C0, 0x00000000) != 1) { ok = 0; }

    if (batched != 1) { return ok; }
    gpu_batch_active = 0;                      # restored before any early return below
    if (ok != 1) { return 0; }
    gpu_batch_tail(done_mc);
    gpu_mfence();
    return gpu_ring_kick_wait(done_phys, 100000);
}

fn gpu_shader_batch_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) { kprintln("gpu: skipping batch (dispatch envelope unproven)", 48); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    if (gpu_blit_arm() != 1) { kprintln("gpu: skipping batch (no back buffer)", 36); return 0; }

    var pitch = gpu_bb_pitch;
    if (pitch < (GPU_S12_X + GPU_S12_W) * 4) { kprintln("gpu: skipping batch (surface too narrow)", 40); return 0; }

    var bb_phys = gpu_bb_a_phys;
    var bb_mc   = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { bb_phys = gpu_bb_b_phys; bb_mc = gpu_bb_b_mc; }
    var reg_mc   = bb_mc   + GPU_S12_Y * pitch + GPU_S12_X * 4;
    var reg_phys = bb_phys + GPU_S12_Y * pitch + GPU_S12_X * 4;
    var snap_phys = gpu_arena_phys + GPU_S12_SNAP_SUBOFF;
    var snap_mc   = gpu_arena_mc   + GPU_S12_SNAP_SUBOFF;
    var rowb = GPU_S12_W * 4;

    # Sources: a premultiplied translucent grey window, a round coverage mask, a 1bpp text run.
    var src_phys = gpu_arena_phys + GPU_BR_SRC_SUBOFF;
    var src_mc   = gpu_arena_mc   + GPU_BR_SRC_SUBOFF;
    var i = 0;
    while (i < 64 * 48) { store32(src_phys + (i << 2), 0x80404040); i = i + 1; }
    var mask_phys = gpu_arena_phys + GPU_COV_MASK_SUBOFF;
    var mask_mc   = gpu_arena_mc   + GPU_COV_MASK_SUBOFF;
    var my = 0;
    while (my < 64) {
        var mx = 0;
        while (mx < 64) {
            var dx2 = mx - 32; var dy2 = my - 32;
            var c = 0;
            if (dx2 * dx2 + dy2 * dy2 < 900) { c = 255; }
            store8(mask_phys + my * 64 + mx, c);
            mx = mx + 1;
        }
        my = my + 1;
    }
    var bmp_phys = gpu_arena_phys + GPU_GLYPH_BMP_SUBOFF;
    var bmp_mc   = gpu_arena_mc   + GPU_GLYPH_BMP_SUBOFF;
    var b = 0;
    while (b < 16 * 16) { store8(bmp_phys + b, 0xA5); b = b + 1; }
    gpu_mfence();

    # ---- pass 1: OP-BY-OP, six submissions ----
    if (gpu_cp_dma_fill_rect(reg_mc, pitch, GPU_S12_BG, rowb, GPU_S12_H) != 1) {
        kprintln("gpu: batch underlay fill failed", 31); return 0;
    }
    var t0 = rdtsc();
    if (gpu_s12_frame(0, src_mc, mask_mc, bmp_mc) != 1) {
        kprintln("gpu: op-by-op frame failed", 26); return 0;
    }
    var seq_us = (rdtsc() - t0) / GPU_TSC_PER_US;

    # Snapshot it. CP-DMA is MC-direct and the frame's shader stores have each been written back by their
    # own tail, so this read is coherent — plan-S3 arm C is exactly what licenses it.
    if (gpu_cp_dma_blit(snap_mc, rowb, reg_mc, pitch, rowb, GPU_S12_H) != 1) {
        kprintln("gpu: batch snapshot blit failed", 31); return 0;
    }

    # ---- pass 2: BATCHED, one submission, from an identical underlay ----
    if (gpu_cp_dma_fill_rect(reg_mc, pitch, GPU_S12_BG, rowb, GPU_S12_H) != 1) {
        kprintln("gpu: batch underlay refill failed", 33); return 0;
    }
    var t1 = rdtsc();
    if (gpu_s12_frame(1, src_mc, mask_mc, bmp_mc) != 1) {
        kprintln("gpu: batched frame failed", 25); return 0;
    }
    var bat_us = (rdtsc() - t1) / GPU_TSC_PER_US;

    # ---- the gate: PIXEL-IDENTICAL ----
    var bad = 0;
    var y = 0;
    while (y < GPU_S12_H) {
        var x = 0;
        while (x < GPU_S12_W) {
            var a = load32(reg_phys + y * pitch + (x << 2)) & 0xFFFFFFFF;
            var c2 = load32(snap_phys + y * rowb + (x << 2)) & 0xFFFFFFFF;
            if (a != c2) { bad = bad + 1; }
            x = x + 1;
        }
        y = y + 1;
    }

    kprint("gpu: batch frame seq ", 21); kprint_num(seq_us);
    kprint(" us  batched ", 13); kprint_num(bat_us); kprintln(" us", 3);
    if (bad != 0) {
        kprint("gpu: batched frame DIFFERS at ", 30); kprint_num(bad);
        kprintln(" pixels", 7);
        return 0;
    }
    gpu_batch_ok = 1;
    kprintln("gpu: batched frame pixel-identical to op-by-op (6 ops, 1 submission)", 68);
    return 1;
}

# gpu_grad_arm — make grad_linear resident for the RUNTIME path. Idempotent; own arena slot, so the
# gradient op works in a kernel built without SHADER_GRAD and depends on no boot-time ordering.
# Peer of gpu_blend_arm / gpu_cov_arm / gpu_glyph_arm.
fn gpu_grad_arm() {
    if (gpu_grad_armed == 1) { return 1; }
    if (gpu_present == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    if (gpu_matmul_ok != 1) { return 0; }
    grad_linear_write(gpu_arena_phys + GPU_GRAD_SHADER_SUBOFF);
    gpu_mfence();
    gpu_grad_armed = 1;
    return 1;
}

# gpu_grad_surface — paint a two-stop vertical linear gradient src-over onto the back buffer.
# Kernel-side worker behind op GPU_OP_GRAD_LINEAR of gpu_shader_op#92. Returns 1 / 0.
# Caller owns all bounds checking.
#
# NO SOURCE BUFFER — both endpoints ride in as kernargs and the varying quantity is the row index the SPI
# already supplies in tgid_y, so a full-screen gradient reads ZERO source bytes. That is why this op takes
# no slot id: there is nothing to validate a slot against.
fn gpu_grad_surface(w, h, dx, dy, c0, c1) {
    if (gpu_grad_arm() != 1) { return 0; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    var gx = (w + 63) / 64;                    # CEILING — the shader's EXEC guard trims the last group
    return gpu_grid7_run(gpu_arena_mc + GPU_GRAD_SHADER_SUBOFF,
    dst_mc & 0xFFFFFFFF, (dst_mc >> 32) & 0xFFFFFFFF,
    gpu_bb_pitch, w, h, c0, c1,
    GPU_COMPUTE_PGM_RSRC1_GRAD, gx, h,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF,
    gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
}

# gpu_blend_arm — make blend_rect resident for the RUNTIME (#92) path. Idempotent.
#
# Separate from the boot self-tests on purpose: #92 must work in a kernel built WITHOUT SHADER_RECT, so it
# cannot depend on a test having uploaded the shader. It also uses its own arena slot, so no boot-time
# ordering assumption leaks into a syscall a compositor calls every frame.
#
# The dispatch envelope re-invalidates I$/K$ before every launch, so a shader resident at a fixed VA is safe
# to leave in place across dispatches — that was the C2g-1 lesson (a stale cached shader ran for 8 burns).
fn gpu_blend_arm() {
    if (gpu_blend_armed == 1) { return 1; }
    if (gpu_present == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }      # ring never came up (QEMU) → caller falls back
    if (gpu_matmul_ok != 1) { return 0; }      # dispatch envelope unproven on this boot
    blend_rect_write(gpu_arena_phys + GPU_BLEND_SHADER_SUBOFF);
    gpu_mfence();
    gpu_blend_armed = 1;
    return 1;
}

# gpu_blend_surface — alpha-composite a GPU-visible source rect onto the back buffer at (dx,dy).
# The kernel-side worker behind gpu_blend_shm#92. Returns 1 / 0. Caller owns all bounds checking.
fn gpu_blend_surface(src_mc, w, h, dx, dy) {
    if (gpu_blend_arm() != 1) { return 0; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    var gx = (w + 63) / 64;                    # CEILING — the shader's EXEC guard trims the last group
    return gpu_blend_rect_run(gpu_arena_mc + GPU_BLEND_SHADER_SUBOFF, src_mc, dst_mc,
    w * 4, gpu_bb_pitch, w, gx, h,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF,
    gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
}

# ── plan-S3: GL2 / scanout / CP-DMA coherence, characterised in ONE boot ──────────────────────────────
#
# WHY THIS EXISTS AND WHY IT IS LATE. The arc plan made S3 a GATE — "nothing writes to the back buffer ahead
# of S3" — and then execution consumed its label for the grid bite and never ran it. Shader stores have been
# reaching the panel since 1.56.1, so this can no longer gate anything; it is now RETROSPECTIVE
# CHARACTERISATION, and it still earns its slot twice:
#   1. If arm B passes, the 7-dword whole-cache write-back is NOT load-bearing for display visibility, and
#      S12's per-op envelope drops 7 dwords. If arm B fails, the packet is proven rather than assumed.
#   2. Arms C and D are S12's PRECONDITION. The arc's standing rule forbids batching a dispatch and a CP-DMA
#      into one submission without an intervening ACQUIRE_MEM "until S12 says otherwise" — and S12 cannot
#      say otherwise without this data, because CP-DMA is MC-direct while shader stores are GL2.
#
# The two coherence domains, stated plainly: CP-DMA bypasses GL2 entirely; shader loads/stores go through
# GL2. Today mixing them is safe ONLY because the CPU serialises on the done marker between operations.
#
# ⚠ SCORED SEPARATELY: CPU-readback visibility and PANEL visibility are different consumers on different
# paths (CPU reads the UC/WC mapping; DCN fetches through DCHUB → SDP → data fabric). A result that is
# visible to one and not the other is the single most useful thing this test can find, and collapsing them
# into one verdict would hide it.
#
# ⚠ HONEST LIMIT: a passing arm B does not prove the write-back is useless — it proves GL2 happened to have
# drained within the measurement window. Absence of a flush is not a guarantee of staleness. That is why the
# CPU readback happens IMMEDIATELY after the done marker retires (the marker rides a WRITE_DATA through the
# CP, not through GL2, so its arrival says nothing about the shader's stores).

fn gpu_s3_tile(i) { return GPU_S3_BASE_SUBOFF + i * GPU_S3_STRIDE; }

# gpu_cohere_run — THE ONLY place gpu_cohere_wb / gpu_cohere_inv are ever written. Sets them, runs one
# blend_rect dispatch, and restores BOTH on every exit path. A leaked 0 would re-create the C2g-1
# stale-shader class, so there is exactly one choke point rather than set/restore pairs at each call site.
fn gpu_cohere_run(wb, inv, src_mc, dst_mc, n) {
    gpu_cohere_wb = wb;
    gpu_cohere_inv = inv;
    var r = gpu_blend_rect_run(gpu_arena_mc + GPU_BLEND_SHADER_SUBOFF, src_mc, dst_mc,
    n * 4, n * 4, n, 1, n,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF,
    gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
    gpu_cohere_wb = 1;
    gpu_cohere_inv = 1;
    return r;
}

# gpu_s3_seed — fill a tile with a constant via the CPU. The arena is UC-mapped, so these stores go straight
# to DRAM with no CPU cache in the way — which is what makes it a valid starting point for a GPU-side
# coherence measurement rather than another cache to reason about.
fn gpu_s3_seed(phys, val, n) {
    var i = 0;
    var px = n * n;
    while (i < px) { store32(phys + (i << 2), val); i = i + 1; }
    gpu_mfence();
}

# gpu_s3_count_eq — how many of the tile's pixels equal `val`. Returning a COUNT rather than a bool is
# deliberate: "3 of 4096 pixels stale" and "4096 of 4096 stale" are different hardware facts, and a partial
# count would mean cache-line-granular drainage, which no boolean could express.
fn gpu_s3_count_eq(phys, val, n) {
    var i = 0;
    var px = n * n;
    var c = 0;
    while (i < px) {
        if ((load32(phys + (i << 2)) & 0xFFFFFFFF) == val) { c = c + 1; }
        i = i + 1;
    }
    return c;
}

fn gpu_s3_report(label, llen, got, total) {
    kprint(label, llen);
    kprint_num(got);
    kprint(" of ", 4);
    kprint_num(total);
    if (got == total) { kprintln("  COHERENT", 10); }
    if (got != total) { kprintln("  STALE", 7); }
    return 0;
}

fn gpu_shader_cohere_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    # Uses the RUNTIME arm, not a boot self-test, so this bite does not inherit SHADER_BLEND's ordering.
    if (gpu_blend_arm() != 1) { kprintln("gpu: skipping coherence (blend shader not resident)", 51); return 0; }
    if (gpu_blit_arm() != 1) { kprintln("gpu: skipping coherence (no back buffer)", 40); return 0; }

    var n     = GPU_S3_N;
    var tilep = n * n * 4;
    var pitch = gpu_bb_pitch;
    if (pitch < (GPU_S3_BX + n) * 4) { kprintln("gpu: skipping coherence (surface too narrow)", 44); return 0; }

    var bb_phys = gpu_bb_a_phys;
    var bb_mc   = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { bb_phys = gpu_bb_b_phys; bb_mc = gpu_bb_b_mc; }

    var src_phys = gpu_arena_phys + gpu_s3_tile(0);
    var src_mc   = gpu_arena_mc   + gpu_s3_tile(0);

    kprintln("gpu: --- plan-S3 coherence characterisation ---", 47);

    # Source: OPAQUE white (alpha 255, premultiplied). Blending opaque src over any dst yields exactly src,
    # so every arm's expected value is one constant and any deviation is a coherence fact, not blend error.
    gpu_s3_seed(src_phys, 0xFFFFFFFF, n);

    # ---- ARMS A and B: shader -> SCANOUT BACK BUFFER, with and without the write-back ----
    # Two tiles side by side so ONE photo scores both. The underlay is CP-DMA-painted near-black, so a tile
    # that did not reach the display stays visibly dark against a tile that did.
    if (gpu_cp_dma_fill_rect(bb_mc + GPU_S3_AY * pitch + GPU_S3_AX * 4, pitch, GPU_S3_UNDER, n * 4, n) != 1) {
        kprintln("gpu: coherence underlay A failed", 32); return 0;
    }
    if (gpu_cp_dma_fill_rect(bb_mc + GPU_S3_BY * pitch + GPU_S3_BX * 4, pitch, GPU_S3_UNDER, n * 4, n) != 1) {
        kprintln("gpu: coherence underlay B failed", 32); return 0;
    }

    var a_dst_mc   = bb_mc   + GPU_S3_AY * pitch + GPU_S3_AX * 4;
    var a_dst_phys = bb_phys + GPU_S3_AY * pitch + GPU_S3_AX * 4;
    gpu_cohere_wb = 1; gpu_cohere_inv = 1;
    var ra = gpu_blend_rect_run(gpu_arena_mc + GPU_BLEND_SHADER_SUBOFF, src_mc, a_dst_mc,
    n * 4, pitch, n, 1, n,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF, gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
    var a_cpu = 0;
    if (ra == 1) {
        var ay = 0;
        while (ay < n) {
            var ax = 0;
            while (ax < n) {
                if ((load32(a_dst_phys + ay * pitch + (ax << 2)) & 0xFFFFFFFF) == 0xFFFFFFFF) { a_cpu = a_cpu + 1; }
                ax = ax + 1;
            }
            ay = ay + 1;
        }
    }

    var b_dst_mc   = bb_mc   + GPU_S3_BY * pitch + GPU_S3_BX * 4;
    var b_dst_phys = bb_phys + GPU_S3_BY * pitch + GPU_S3_BX * 4;
    gpu_cohere_wb = 0; gpu_cohere_inv = 1;
    var rb = gpu_blend_rect_run(gpu_arena_mc + GPU_BLEND_SHADER_SUBOFF, src_mc, b_dst_mc,
    n * 4, pitch, n, 1, n,
    gpu_arena_mc + GPU_BLEND_DONE_SUBOFF, gpu_arena_phys + GPU_BLEND_DONE_SUBOFF);
    gpu_cohere_wb = 1;
    var b_cpu = 0;
    if (rb == 1) {
        var by = 0;
        while (by < n) {
            var bx = 0;
            while (bx < n) {
                if ((load32(b_dst_phys + by * pitch + (bx << 2)) & 0xFFFFFFFF) == 0xFFFFFFFF) { b_cpu = b_cpu + 1; }
                bx = bx + 1;
            }
            by = by + 1;
        }
    }

    var total = n * n;
    gpu_s3_report("gpu: S3-A shader->fb  WB=on  cpu-read ", 38, a_cpu, total);
    gpu_s3_report("gpu: S3-B shader->fb  WB=off cpu-read ", 38, b_cpu, total);

    # ⚠⚠ PRESENT HERE — BEFORE arms C and D, and NOT at the end of the test.
    # The first S3 burn (1.56.4) presented after every arm had run, so eight further dispatches — each
    # emitting a bit-18 write-back — had already drained arm B's dirty GL2 lines to DRAM by the time the
    # panel was scanned. The photo showed B white beside A and would have done so no matter what the
    # hardware did: invalid in the PERMISSIVE direction, which is the worst kind. That is precisely the
    # failure the "CPU-readback and PANEL scored SEPARATELY" rule exists to catch, and it still caught it —
    # B read 0 of 4096 on the CPU while the panel showed it lit.
    # Presenting here, with nothing between arm B's dispatch and the flip, is the only placement that makes
    # the panel an independent measurement rather than a restatement of the intervening flushes.
    gpu_blit_present(0);
    gpu_udelay(3000000);
    gpu_display_restore_console();

    # ---- ARM C: shader -> arena, then CP-DMA READS it. Does an MC-direct read see GL2-resident stores? ----
    var c1_dst_phys = gpu_arena_phys + gpu_s3_tile(1);
    var c1_dst_mc   = gpu_arena_mc   + gpu_s3_tile(1);
    var c1_cpy_phys = gpu_arena_phys + gpu_s3_tile(2);
    var c1_cpy_mc   = gpu_arena_mc   + gpu_s3_tile(2);
    gpu_s3_seed(c1_dst_phys, 0, n);                       # dst zeroed => opaque blend is an exact copy
    gpu_s3_seed(c1_cpy_phys, GPU_S3_SENTINEL, n);         # fresh, sentinel-seeded target
    var c1_ok = gpu_cohere_run(1, 1, src_mc, c1_dst_mc, n);
    if (c1_ok == 1) { gpu_cp_dma(c1_cpy_mc, c1_dst_mc, tilep); }
    var c1 = gpu_s3_count_eq(c1_cpy_phys, 0xFFFFFFFF, n);

    var c2_dst_phys = gpu_arena_phys + gpu_s3_tile(3);
    var c2_dst_mc   = gpu_arena_mc   + gpu_s3_tile(3);
    var c2_cpy_phys = gpu_arena_phys + gpu_s3_tile(4);
    var c2_cpy_mc   = gpu_arena_mc   + gpu_s3_tile(4);
    gpu_s3_seed(c2_dst_phys, 0, n);
    gpu_s3_seed(c2_cpy_phys, GPU_S3_SENTINEL, n);
    var c2_ok = gpu_cohere_run(0, 1, src_mc, c2_dst_mc, n);   # NO write-back
    if (c2_ok == 1) { gpu_cp_dma(c2_cpy_mc, c2_dst_mc, tilep); }
    var c2 = gpu_s3_count_eq(c2_cpy_phys, 0xFFFFFFFF, n);

    gpu_s3_report("gpu: S3-C shader->cpdma WB=on  read  ", 37, c1, total);
    gpu_s3_report("gpu: S3-C shader->cpdma WB=off read  ", 37, c2, total);

    # ---- ARM D: CP-DMA -> arena, then the SHADER reads it. Does a GL2 read see MC-direct writes? ----
    # A stale line has to EXIST before it can be measured, so each sub-arm primes GL2 first: the shader reads
    # tile 5 while it still holds PAT1, then CP-DMA overwrites tile 5 with PAT2 MC-direct, then the shader
    # reads tile 5 again into a FRESH destination. Reading back PAT1 means GL2 served a stale line.
    var d_src_phys = gpu_arena_phys + gpu_s3_tile(5);
    var d_src_mc   = gpu_arena_mc   + gpu_s3_tile(5);
    var d_p_phys   = gpu_arena_phys + gpu_s3_tile(6);
    var d_p_mc     = gpu_arena_mc   + gpu_s3_tile(6);
    var d1_phys    = gpu_arena_phys + gpu_s3_tile(7);
    var d1_mc      = gpu_arena_mc   + gpu_s3_tile(7);

    # ⚠⚠ THE PRIME MUST NOT WRITE BACK — this is what voided the first S3 burn (1.56.4, 2026-07-22).
    # GPU_CP_COHER_CNTL_TCWB = TC_WB_ACTION_ENA(1<<18) | TC_ACTION_ENA(1<<23), and bit 23 is the L2
    # INVALIDATE. That is settled independently of agnos's own comment, against a RADV IB decode captured on
    # this same Cezanne (mabda programs/diagnostics/radv_capture_triangle/radv-triangle.ib.txt): the decode
    # names exactly five =1 fields for 0x28C40000 — which has exactly five bits set, so the mapping is forced
    # — and CACHE_FLUSH_AND_INV_TS_EVENT there carries exactly {TC_WB=1, TC=1}, i.e. "flush" IS bit 18 and
    # "inv" IS bit 23. So a prime run with wb=1 emits a whole-L2 invalidate AFTER its own loads populated
    # GL2 and BEFORE the CP-DMA overwrite — destroying the stale line the arm exists to create. The measured
    # dispatch then takes a compulsory miss and reports "coherent" for both sub-arms, for any hardware.
    # Prime with wb=0. inv=1 on the prime is harmless: it fires BEFORE the loads that populate L2.
    var dp1 = gpu_cohere_run(0, 1, d_src_mc, d_p_mc, n);       # prime GL2 with PAT1 lines for tile 5
    gpu_cp_dma_fill(d_src_mc, GPU_S3_PAT2, tilep);             # MC-direct overwrite, bypassing GL2
    gpu_s3_seed(d1_phys, 0, n);
    gpu_cohere_run(1, 1, d_src_mc, d1_mc, n);                  # WITH the pre-dispatch invalidate
    var d1_new = gpu_s3_count_eq(d1_phys, GPU_S3_PAT2, n);
    var d1_old = gpu_s3_count_eq(d1_phys, GPU_S3_PAT1, n);

    # Same experiment with the invalidate suppressed. Re-prime first — the MEASURED dispatch above ran with
    # wb=1, so its own trailing packet invalidated L2 on the way out.
    gpu_s3_seed(d_src_phys, GPU_S3_PAT1, n);
    gpu_s3_seed(d_p_phys, 0, n);
    var dp2 = gpu_cohere_run(0, 1, d_src_mc, d_p_mc, n);
    gpu_cp_dma_fill(d_src_mc, GPU_S3_PAT2, tilep);
    gpu_s3_seed(c1_dst_phys, 0, n);                            # tile 1 reused as a scratch destination here
    gpu_cohere_run(1, 0, d_src_mc, c1_dst_mc, n);              # NO pre-dispatch invalidate
    var d2_new = gpu_s3_count_eq(c1_dst_phys, GPU_S3_PAT2, n);
    var d2_old = gpu_s3_count_eq(c1_dst_phys, GPU_S3_PAT1, n);

    # POSITIVE CONTROL — can this harness observe load-side staleness AT ALL? Identical to the sub-arm above
    # except the overwrite is a CPU store through the UC mapping instead of a CP-DMA fill. Both writers are
    # MC-direct and neither invalidates, so:
    #   control reads PAT1 (stale) + CP-DMA sub-arm reads PAT2  => CP-DMA writes probe/invalidate L2. A real
    #                                                              finding, and D-6's GL2 justification is wrong.
    #   control reads PAT2 (fresh)                              => the harness CANNOT see load-side staleness
    #                                                              on this part. Arm D needs redesign, NOT a
    #                                                              re-run, and the two rows above stay VOID.
    # Without this row a second "coherent" would again be unfalsifiable, which is exactly how the first burn
    # produced a confident-looking answer to a question it never asked.
    var d3_src_phys = gpu_arena_phys + gpu_s3_tile(8);
    var d3_src_mc   = gpu_arena_mc   + gpu_s3_tile(8);
    var d3_dst_phys = gpu_arena_phys + gpu_s3_tile(9);
    var d3_dst_mc   = gpu_arena_mc   + gpu_s3_tile(9);
    gpu_s3_seed(d3_src_phys, GPU_S3_PAT1, n);
    gpu_s3_seed(d_p_phys, 0, n);
    var dp3 = gpu_cohere_run(0, 1, d3_src_mc, d_p_mc, n);      # prime GL2 with PAT1 lines for tile 8
    gpu_s3_seed(d3_src_phys, GPU_S3_PAT2, n);                  # CPU UC overwrite, NOT CP-DMA
    gpu_s3_seed(d3_dst_phys, 0, n);
    gpu_cohere_run(1, 0, d3_src_mc, d3_dst_mc, n);             # NO pre-dispatch invalidate
    var d3_new = gpu_s3_count_eq(d3_dst_phys, GPU_S3_PAT2, n);
    var d3_old = gpu_s3_count_eq(d3_dst_phys, GPU_S3_PAT1, n);

    # PRIME WITNESSES. The first burn discarded these returns, so a silently timed-out prime produced the
    # same printed row as a successful one — a second, independent reason those rows could not be trusted.
    kprint("gpu: S3-D primes executed ", 26);
    kprint_num(dp1 + dp2 + dp3); kprintln(" of 3", 5);

    gpu_s3_report("gpu: S3-D cpdma->shader INV=on  new  ", 37, d1_new, total);
    kprint("gpu: S3-D cpdma->shader INV=on  stale ", 38); kprint_num(d1_old); kprintln("", 0);
    gpu_s3_report("gpu: S3-D cpdma->shader INV=off new  ", 37, d2_new, total);
    kprint("gpu: S3-D cpdma->shader INV=off stale ", 38); kprint_num(d2_old); kprintln("", 0);
    gpu_s3_report("gpu: S3-D CONTROL cpu-wr INV=off new ", 37, d3_new, total);
    kprint("gpu: S3-D CONTROL cpu-wr INV=off stale ", 39); kprint_num(d3_old); kprintln("", 0);

    # Belt-and-braces: both toggles MUST be 1 before anything else runs this boot.
    gpu_cohere_wb = 1;
    gpu_cohere_inv = 1;
    if (gpu_cohere_wb != 1) { kprintln("gpu: S3 FAILED TO RESTORE write-back", 36); return 0; }
    if (gpu_cohere_inv != 1) { kprintln("gpu: S3 FAILED TO RESTORE invalidate", 36); return 0; }

    kprintln("gpu: shader coherence characterised (see the S3-A..D table)", 59);
    return 1;
}

# gpu_shader_rect_test — S3: alpha-blend a real rect INTO THE SCANOUT BACK BUFFER over a 2-D grid, verify
# every pixel against the CPU reference, then PRESENT it so the result is visible.
#
# S2 proved the blend arithmetic on 64 pixels in the compute arena. This proves the three things S2 could
# not, and each has its own way of failing visibly:
#   (a) GRID — 256 workgroups instead of 1. tgid_x/tgid_y actually arrive and actually index.
#   (b) BACK-BUFFER ADDRESSING — a shader store and a CP-DMA blit agree on where a pixel lives. The whole
#       compositor depends on mixing the two; if their MC views differed, the rect would land skewed.
#   (c) SCANOUT VISIBILITY — the post-dispatch TC-writeback reaches memory the DISPLAY engine reads, not
#       just memory the CPU reads. S2 only ever proved the CPU side.
#
# The test is built so a pitch bug cannot hide. src alpha varies by ROW (a vertical gradient) and dst colour
# varies by COLUMN (left half vs right half), so a wrong src_pitch and a wrong dst_pitch each corrupt a
# different axis. A single constant-colour rect would have passed with both pitches wrong.
#
# dst is blended IN PLACE, so the original dst cannot be re-read for checking — the reference recomputes it
# from the same rule that painted it. That is stronger than re-reading, not weaker: it checks the pixel
# against what was INTENDED rather than against whatever is now in memory.
fn gpu_shader_rect_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_blend_ok != 1) { kprintln("gpu: skipping rect blend (blend math unproven)", 46); return 0; }
    if (gpu_blit_arm() != 1) { kprintln("gpu: skipping rect blend (no back buffer)", 41); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var pitch = gpu_bb_pitch;                       # back-buffer row stride in BYTES
    if (pitch < (GPU_BR_X + GPU_BR_W) * 4) { kprintln("gpu: skipping rect blend (surface too narrow)", 45); return 0; }

    var bb_phys = gpu_bb_a_phys;
    var bb_mc   = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { bb_phys = gpu_bb_b_phys; bb_mc = gpu_bb_b_mc; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var src_phys    = gpu_arena_phys + GPU_BR_SRC_SUBOFF;
    var src_mc      = gpu_arena_mc   + GPU_BR_SRC_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    blend_rect_write(shader_phys);

    # --- src: premultiplied translucent grey, alpha rising DOWN the rows (0, 4, 8 ... ) ---
    var src_pitch = GPU_BR_W * 4;
    var y = 0;
    while (y < GPU_BR_H) {
        var sa = y * 4;
        if (sa > 255) { sa = 255; }
        var sc = sa / 2;                            # premultiplied: sc <= sa, as the format requires
        var px = (sa << 24) | (sc << 16) | (sc << 8) | sc;
        var x = 0;
        while (x < GPU_BR_W) { store32(src_phys + y * src_pitch + (x << 2), px); x = x + 1; }
        y = y + 1;
    }
    gpu_mfence();

    # --- dst: GPU-paint the background and the two-tone rect underlay, all via CP-DMA ---
    if (gpu_cp_dma_fill(bb_mc, GPU_BR_BG, gpu_bb_fbsize) != 1) {
        kprintln("gpu: rect blend background fill failed", 38); return 0;
    }
    var rect_mc   = bb_mc   + GPU_BR_Y * pitch + GPU_BR_X * 4;
    var rect_phys = bb_phys + GPU_BR_Y * pitch + GPU_BR_X * 4;
    if (gpu_cp_dma_fill_rect(rect_mc, pitch, GPU_BR_DST_L, (GPU_BR_W / 2) * 4, GPU_BR_H) != 1) {
        kprintln("gpu: rect blend underlay fill failed", 36); return 0;
    }
    if (gpu_cp_dma_fill_rect(rect_mc + (GPU_BR_W / 2) * 4, pitch, GPU_BR_DST_R, (GPU_BR_W / 2) * 4, GPU_BR_H) != 1) {
        kprintln("gpu: rect blend underlay fill failed", 36); return 0;
    }

    # --- dispatch the grid: ceil(W/64) groups across, GPU_BR_H rows down ---
    var gx = (GPU_BR_W + 63) / 64;
    if (gpu_blend_rect_run(shader_mc, src_mc, rect_mc, src_pitch, pitch, GPU_BR_W, gx, GPU_BR_H, done_mc, done_phys) != 1) {
        kprintln("gpu: rect blend dispatch did not complete", 41);
        return 0;
    }

    # --- verify every pixel against the CPU reference ---
    var bad = 0; var bx = 0; var by = 0; var got0 = 0;
    var vy = 0;
    while (vy < GPU_BR_H) {
        var vx = 0;
        while (vx < GPU_BR_W) {
            var got = load32(rect_phys + vy * pitch + (vx << 2)) & 0xFFFFFFFF;
            var od  = GPU_BR_DST_L;
            if (vx >= GPU_BR_W / 2) { od = GPU_BR_DST_R; }
            var ref = blend_ref_px(load32(src_phys + vy * src_pitch + (vx << 2)) & 0xFFFFFFFF, od) & 0xFFFFFFFF;
            if (got != ref) {
                if (bad == 0) { bx = vx; by = vy; got0 = got; }
                bad = bad + 1;
            }
            vx = vx + 1;
        }
        vy = vy + 1;
    }
    if (bad != 0) {
        kprint("gpu: rect blend MISMATCH ", 25); kprint_num(bad);
        kprint(" px, first at x=", 16); kprint_num(bx);
        kprint(" y=", 3); kprint_num(by);
        kprint(" got ", 5); kprint_num(got0);
        kprintln("", 0);
        return 0;
    }

    # --- SECOND RECT: the BOUNDS-GUARD case, width 200 (NOT a multiple of 64) ---
    # The last of its 4 column groups is 56/64 masked off. Two things are checked and they are different
    # claims: that the 200 blended px are bit-exact (the guard did not corrupt the lanes it kept), and that
    # x = 200..255 still hold the untouched underlay (the guard actually stopped the lanes it dropped).
    # Only the second one can fail if s_and_saveexec_b64 is wrong, so it is the load-bearing check.
    var s2_phys = gpu_arena_phys + GPU_BR2_SRC_SUBOFF;
    var s2_mc   = gpu_arena_mc   + GPU_BR2_SRC_SUBOFF;
    var s2_pitch = GPU_BR2_W * 4;
    var gy2 = 0;
    while (gy2 < GPU_BR2_H) {
        var sa2 = gy2 * 5;
        if (sa2 > 255) { sa2 = 255; }
        var sc2 = sa2 / 2;
        var px2 = (sa2 << 24) | (sc2 << 16) | (sc2 << 8) | sc2;
        var gx2 = 0;
        while (gx2 < GPU_BR2_W) { store32(s2_phys + gy2 * s2_pitch + (gx2 << 2), px2); gx2 = gx2 + 1; }
        gy2 = gy2 + 1;
    }
    gpu_mfence();

    # Underlay is painted 256 px wide but only 200 px are blended — so the 56 px tail is a control strip
    # that MUST come back untouched.
    var r2_mc   = bb_mc   + GPU_BR2_Y * pitch + GPU_BR2_X * 4;
    var r2_phys = bb_phys + GPU_BR2_Y * pitch + GPU_BR2_X * 4;
    if (gpu_cp_dma_fill_rect(r2_mc, pitch, GPU_BR_DST_L, 256 * 4, GPU_BR2_H) != 1) {
        kprintln("gpu: guard underlay fill failed", 31); return 0;
    }
    var g2x = (GPU_BR2_W + 63) / 64;
    if (gpu_blend_rect_run(shader_mc, s2_mc, r2_mc, s2_pitch, pitch, GPU_BR2_W, g2x, GPU_BR2_H, done_mc, done_phys) != 1) {
        kprintln("gpu: guard blend dispatch did not complete", 42);
        return 0;
    }
    var gbad = 0; var gspill = 0; var sx = 0; var sy = 0;
    var wy = 0;
    while (wy < GPU_BR2_H) {
        var wx = 0;
        while (wx < 256) {
            var gv = load32(r2_phys + wy * pitch + (wx << 2)) & 0xFFFFFFFF;
            if (wx < GPU_BR2_W) {
                var gref = blend_ref_px(load32(s2_phys + wy * s2_pitch + (wx << 2)) & 0xFFFFFFFF, GPU_BR_DST_L) & 0xFFFFFFFF;
                if (gv != gref) { gbad = gbad + 1; }
            }
            if (wx >= GPU_BR2_W) {
                if (gv != GPU_BR_DST_L) {
                    if (gspill == 0) { sx = wx; sy = wy; }
                    gspill = gspill + 1;
                }
            }
            wx = wx + 1;
        }
        wy = wy + 1;
    }
    if (gspill != 0) {
        kprint("gpu: GUARD FAILED, blend spilled past the edge at x=", 52); kprint_num(sx);
        kprint(" y=", 3); kprint_num(sy);
        kprint(" count ", 7); kprint_num(gspill);
        kprintln("", 0);
        return 0;
    }
    if (gbad != 0) {
        kprint("gpu: guard rect MISMATCH ", 25); kprint_num(gbad);
        kprintln(" px", 3);
        return 0;
    }
    kprintln("gpu: shader blend width guard ok (200 px, 56 px tail untouched)", 63);

    # --- show it: flip the blended buffer in, HOLD, then put the console back ---
    # gpu_blit_present alone would strand scanout on the back buffer for the REST OF BOOT: fb_console keeps
    # writing to the console surface, which is no longer being scanned out, so the shell prompt would never
    # appear and the operator could not run klug to capture this very log. So the flip is bracketed —
    # show the blend for ~3 s, then restore the console surface with the same address-group-only write
    # gpu_blit_present uses (HIGH then LOW; cannot hang), and undo the front/back swap it performed.
    var prev_back = gpu_bb_back;
    gpu_blit_present(0);
    var d = 0;
    while (d < 30000) { gpu_udelay(100); d = d + 1; }        # ~3 s hold — bounded, never a spin on hardware
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_display_surf >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_display_surf & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    gpu_bb_back = prev_back;
    gpu_rect_ok = 1;
    kprintln("gpu: shader rect blend online (256x64 grid, bit-correct, presented)", 67);
    return 1;
}

# gpu_cp_dma_fill_rect — hardware RECT FILL: write the 32-bit `val` across `row_bytes` on each of `rows`
# rows, `dst_stride` apart (one CP-DMA constant-fill per row). The rect peer of gpu_cp_dma_fill, which only
# does one contiguous run. This is the primitive behind gpu_fill_rect#88 — window chrome is ~10 of these per
# window per frame (body, titlebar, focus accent, buttons), today a per-pixel CPU loop. Returns 1 / 0.
fn gpu_cp_dma_fill_rect(dst_mc, dst_stride, val, row_bytes, rows) {
    var y = 0;
    while (y < rows) {
        if (gpu_cp_dma_fill(dst_mc + y * dst_stride, val, row_bytes) != 1) { return 0; }
        y = y + 1;
    }
    return 1;
}
# gpu_cp_dma_blit — hardware 2D rect BLIT: copy `rows` rows of `row_bytes` from src_mc to dst_mc with
# independent source/dest row strides (one CP-DMA per row). The compositor substrate for moving a window or
# region FB->FB and for scrolling. Returns 1 on full success, 0 if any row fails. All MC addresses.
fn gpu_cp_dma_blit(dst_mc, dst_stride, src_mc, src_stride, row_bytes, rows) {
    var y = 0;
    while (y < rows) {
        if (gpu_cp_dma(dst_mc + y * dst_stride, src_mc + y * src_stride, row_bytes) != 1) { return 0; }
        y = y + 1;
    }
    return 1;
}
# gpu_cp_dma_copy — P9 boot SELF-TEST (the iron proof): seed a 4 KB src, copy it via gpu_cp_dma, verify
# dst==src byte-for-byte. Gated #ifdef CP_DMA_COPY; needs the ring coherence-proven (gpu_fence_ok).
fn gpu_cp_dma_copy() {
    if (gpu_present == 0) { return 0; }
    if (gpu_fence_ok == 0) { kprintln("gpu: cp-dma copy skipped (ring unverified)", 42); return 0; }
    if (gpu_arena_mc == 0) { return 0; }

    var src_phys = gpu_arena_phys + GPU_SDMA_SRC_SUBOFF;
    var dst_phys = gpu_arena_phys + GPU_SDMA_DST_SUBOFF;
    var src_mc   = gpu_arena_mc + GPU_SDMA_SRC_SUBOFF;
    var dst_mc   = gpu_arena_mc + GPU_SDMA_DST_SUBOFF;
    var ndw = 1024;                                      # 4096 bytes / 4

    var i = 0;
    while (i < ndw) {
        store32(src_phys + i * 4, i + 1);                # src = j+1 (nonzero, bit31-clear)
        store32(dst_phys + i * 4, GPU_C2E_NOTYET);       # dst = NOT-YET marker
        i = i + 1;
    }
    gpu_mfence();

    var r = gpu_cp_dma(dst_mc, src_mc, 4096);
    if (r != 1) { kprintln("gpu: cp-dma copy TIMEOUT or fault", 33); return 0; }

    var ok = 1;
    var j = 0;
    while (j < ndw) {
        if ((load32(dst_phys + j * 4) & 0xFFFFFFFF) != (j + 1)) { ok = 0; j = ndw; }
        else { j = j + 1; }
    }
    if (ok == 1) {
        kprintln("gpu: CP-DMA hardware copy verified (4KB, dst==src)", 50);
        return 1;
    }
    kprintln("gpu: cp-dma copy MISMATCH (marker fired, bytes wrong)", 53);
    return 0;
}
# gpu_cp_dma_fill_test — P9 fill SELF-TEST: hardware-fill a 4 KB slot with a constant via gpu_cp_dma_fill,
# verify every dword == the constant. Proves the DMA_DATA constant-fill (SRC_SEL=2) packet on iron. Gated
# #ifdef CP_DMA_COPY (runs alongside the copy test). Reuses the DST arena scratch slot.
fn gpu_cp_dma_fill_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_fence_ok == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }

    var dst_phys = gpu_arena_phys + GPU_SDMA_DST_SUBOFF;
    var dst_mc   = gpu_arena_mc + GPU_SDMA_DST_SUBOFF;
    var val      = 0x5A5A5A5A;                           # bit31-clear fill pattern (sign-safe compare)
    var ndw      = 1024;                                 # 4096 bytes / 4

    var i = 0;
    while (i < ndw) { store32(dst_phys + i * 4, GPU_C2E_NOTYET); i = i + 1; }   # pre-seed NOT-YET
    gpu_mfence();

    var r = gpu_cp_dma_fill(dst_mc, val, 4096);
    if (r != 1) { kprintln("gpu: cp-dma fill TIMEOUT or fault", 33); return 0; }

    var ok = 1;
    var j = 0;
    while (j < ndw) {
        if ((load32(dst_phys + j * 4) & 0xFFFFFFFF) != val) { ok = 0; j = ndw; }
        else { j = j + 1; }
    }
    if (ok == 1) {
        kprintln("gpu: CP-DMA hardware fill verified (4KB, all=pattern)", 53);
        return 1;
    }
    kprintln("gpu: cp-dma fill MISMATCH (marker fired, bytes wrong)", 53);
    return 0;
}
# gpu_cp_dma_blit_test — P9 blit SELF-TEST: a strided 2D rect copy. Copies an 8-row x 128-byte rect from a
# source whose rows are 256 B apart into a destination whose rows are 320 B apart (DIFFERENT strides, on
# purpose), then verifies BOTH that every copied row landed AND that the destination's inter-row padding was
# left UNTOUCHED. That second check is the one that matters: it proves real per-row stride addressing rather
# than one long linear copy (which would smear straight through the padding). Gated #ifdef CP_DMA_COPY.
fn gpu_cp_dma_blit_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_fence_ok == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }

    var src_phys  = gpu_arena_phys + GPU_SDMA_SRC_SUBOFF;
    var dst_phys  = gpu_arena_phys + GPU_SDMA_DST_SUBOFF;
    var src_mc    = gpu_arena_mc + GPU_SDMA_SRC_SUBOFF;
    var dst_mc    = gpu_arena_mc + GPU_SDMA_DST_SUBOFF;
    var rows      = 8;
    var row_bytes = 128;                 # 32 dwords of payload per row
    var src_str   = 256;                 # source row pitch (64 dw)
    var dst_str   = 320;                 # dest row pitch (80 dw) — deliberately NOT the source's
    var r = 0;
    var c = 0;
    var ok = 1;

    # Seed the source payload per (row, col); paint the WHOLE dest NOT-YET so untouched padding is detectable.
    while (r < rows) {
        c = 0;
        while (c < 32) { store32(src_phys + r * src_str + c * 4, r * 1000 + c + 1); c = c + 1; }
        r = r + 1;
    }
    r = 0;
    while (r < 640) { store32(dst_phys + r * 4, GPU_C2E_NOTYET); r = r + 1; }   # 640 dw = 2560 B = 8 x 320
    gpu_mfence();

    if (gpu_cp_dma_blit(dst_mc, dst_str, src_mc, src_str, row_bytes, rows) != 1) {
        kprintln("gpu: cp-dma blit TIMEOUT or fault", 33);
        return 0;
    }

    # (a) every copied row matches its source; (b) each row's trailing padding is STILL not-yet.
    r = 0;
    while (r < rows) {
        c = 0;
        while (c < 32) {
            if ((load32(dst_phys + r * dst_str + c * 4) & 0xFFFFFFFF) != (r * 1000 + c + 1)) { ok = 0; c = 32; }
            else { c = c + 1; }
        }
        c = 32;
        while (c < 80) {
            if ((load32(dst_phys + r * dst_str + c * 4) & 0xFFFFFFFF) != GPU_C2E_NOTYET) { ok = 0; c = 80; }
            else { c = c + 1; }
        }
        r = r + 1;
    }
    if (ok == 1) {
        kprintln("gpu: CP-DMA hardware blit verified (8 rows, strides differ)", 59);
        return 1;
    }
    kprintln("gpu: cp-dma blit MISMATCH (rows or padding wrong)", 49);
    return 0;
}
# ── C2g-1 — FIRST MULTI-THREAD compute dispatch (1 workgroup, 64 threads; out[tid]=tid) ──
# The first parallel dispatch: 64 lanes each write their workitem-id to out[tid], CPU verifies
# out[i]==i. Delta on C2f — NUM_THREAD_X flips 1->64 (DISPATCH_DIRECT DIM stays 1x1x1 => 64 threads
# in ONE workgroup) PLUS the EXEC fix: burns 1.54.17-19 showed the 64-lane wave RETIRED but stored
# nothing (nz=0) => all lanes EXEC-masked, so the shader now sets 's_mov_b64 exec,-1' first (C2f's
# 1-lane wave got SPI-auto EXEC=0x1; the full wave got EXEC=0 on the raw non-HWS HQD path). The
# shader then computes out[tid]=tid via v0(=workitem-id-X)<<2 folded into a 64-bit base
# (v_lshlrev + v_add_co/v_addc_co carry chain). ALL 12 shader dwords are llvm-mc(-mcpu=gfx90c)
# ground-truth. Output ARRAY is at +0x16000 (GPU_SHADER_OUT2_SUBOFF — a FRESH GPU-never-written
# slot, past the +0x15000 dummy fault-sink page, so no stale-L2 ghost can false-pass).
# WEDGE-SAFE: straight-line shader (no loops); bus-master off (cores reach only the FB aperture);
# a bad per-lane addr faults into the 0x1FFC dummy net (fault!=0); CPU runs a BOUNDED watchdog only.
fn gpu_shader_dispatch2() {
    gpu_mt_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_shader_ok != 1) {
        kprintln("gpu: skipping parallel test (shader unverified)", 47);
        return 0;
    }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var out_phys    = gpu_arena_phys + GPU_SHADER_OUT2_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var out_mc      = gpu_arena_mc   + GPU_SHADER_OUT2_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    # 1. C2g-1 shader (12 dwords): FIX = prepend 's_mov_b64 exec,-1' to unmask all 64 lanes, then
    #    each lane computes out[tid]=tid via v0(=workitem-id-X)<<2 folded into the 64-bit base
    #    (v_lshlrev + v_add_co/v_addc_co carry chain) and stores v0. ALL dwords are
    #    llvm-mc(-mcpu=gfx90c) ground-truth. Root cause of the 1.54.17-19 zero-store burns: the
    #    64-lane wave RETIRED (done fired, ACTIVE=1) but stored nothing (nz=0) => all lanes were
    #    EXEC-masked. C2f's 1-lane wave got SPI-auto EXEC=0x1 (lane0 stored); the full wave got
    #    EXEC=0 on this raw non-HWS HQD path, so the explicit set is what lights all 64.
    #    NOTE (forward-carry): 's_mov_b64 exec,-1' is correct ONLY for an EXACT full wave (64 =
    #    exact wave64). C2g-2+ grids with a PARTIAL last wave must replace this with a real lane
    #    mask (s_bfm / whole-wave-mode) or the surplus lanes do OOB stores.
    store32(shader_phys + 0x00, 0xBEFE01C1);              # s_mov_b64 exec, -1   (unmask all 64 lanes)
    store32(shader_phys + 0x04, 0x7E0202FF);              # v_mov_b32 v1, lit
    store32(shader_phys + 0x08, out_mc & 0xFFFFFFFF);     #   = out base lo
    store32(shader_phys + 0x0C, 0x7E0402FF);              # v_mov_b32 v2, lit
    store32(shader_phys + 0x10, (out_mc >> 32) & 0xFFFFFFFF); # = out base hi
    store32(shader_phys + 0x14, 0x24060082);              # v_lshlrev_b32 v3, 2, v0   (v3 = tid<<2)
    store32(shader_phys + 0x18, 0x32020701);              # v_add_co_u32 v1, vcc, v1, v3
    store32(shader_phys + 0x1C, 0x38040480);              # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x20, 0xDC718000);              # global_store_dword v[1:2],v0,off glc
    store32(shader_phys + 0x24, 0x007F0001);              #   (VADDR=v1, VDATA=v0=tid, SADDR=off)
    store32(shader_phys + 0x28, 0xBF8C0F70);              # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x2C, 0xBF810000);              # s_endpgm

    # 2. Pre-seed all 64 output dwords + done with a NOT-YET marker (!= any tid 0..63, != done).
    var s = 0;
    while (s < GPU_MT_N) { store32(out_phys + (s << 2), GPU_MT_NOTYET); s = s + 1; }
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    # 3. Pulse-clear + re-arm the fault-net so a post-dispatch fault!=0 blames C2g-1.
    var fc0 = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0 | 0x1);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0);

    # 4. Append the 39-dword ring program at gpu_ring_wptr (== 52 after C2f). ONLY delta vs C2f:
    #    NUM_THREAD_X = 64 instead of 1.
    var pgm_lo = (shader_mc >> 8)  & 0xFFFFFFFF;
    var pgm_hi = (shader_mc >> 40) & 0xFF;
    # PRE-dispatch I$/K$ invalidate (mabda-proven, MANDATORY on gfx9) — the shader is rewritten in place at
    # a FIXED VA (0x14000) every dispatch, so without this the SQ runs a STALE cached shader (a prior
    # dispatch's baked store-address) => the store lands in the wrong slot. THE fix for the C2g-1
    # intermittent-launch bug (burns 1-8): C2f worked only by cold-cache luck; every later dispatch ran stale.
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_INV);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_LO); gpu_ring_put(pgm_lo); gpu_ring_put(pgm_hi);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_RSRC1); gpu_ring_put(GPU_COMPUTE_PGM_RSRC1_MIN); gpu_ring_put(0);
    # C2g-1 zero-wave FIX (burn 5): clear the stale threadgroup-origin + dispatch-resume SH state
    # tinygrad/radv zero on EVERY dispatch and our raw MQD path uniquely left stale — a full
    # 64-thread workgroup launched ZERO executing waves at 1.54.20 (even with exec,-1 first),
    # which is neither a shader-EXEC nor a NUM_THREAD-field bug. START latches with NUM_THREAD.
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_START_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_NUM_THREAD_X); gpu_ring_put(GPU_MT_NUM_THREAD_X); gpu_ring_put(1); gpu_ring_put(1);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_RESTART_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE0); gpu_ring_put(GPU_CU_MASK_ALL); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE2); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N1); gpu_ring_put(GPU_SH_COMPUTE_RESOURCE_LIMITS); gpu_ring_put(GPU_COMPUTE_RESLIM);
    gpu_ring_put(GPU_PM4_DISPATCH_DIRECT_HDR); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(GPU_DISPATCH_INITIATOR);
    gpu_ring_put(GPU_PM4_EVENT_WRITE_HDR); gpu_ring_put(GPU_EVENT_CS_PARTIAL_FLUSH);
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_TCWB);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_WRITE_DATA_HDR); gpu_ring_put(GPU_PM4_WRITE_DATA_CTL);
    gpu_ring_put(done_mc & 0xFFFFFFFF); gpu_ring_put((done_mc >> 32) & 0xFFFFFFFF); gpu_ring_put(GPU_C2F_DONE);
    gpu_mfence();

    # 5. Register-wptr submit (LO before HI — the CP latches the 64-bit wptr on the HI write).
    var new_wptr = gpu_ring_wptr;
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, GPU_GRBM_SEL_MEC1_P0_Q0);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_LO, new_wptr);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_HI, 0);
    gpu_mfence();

    # 6. BOUNDED watchdog on the done-marker (100 ms cap; NEVER an unbounded spin).
    # plan-S12a: tight spin, not a 100 us sleep quantum. See gpu_wait_done.
    var ok = gpu_wait_done(done_phys, GPU_C2F_DONE, 100000);
    # Read per-queue state WHILE STILL GRBM-SELECTED (deselected reads hit the default queue).
    var rreg    = gpu_reg32(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_RPTR)    & 0xFFFFFFFF;
    var wptr_rb = gpu_reg32(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_LO) & 0xFFFFFFFF;
    var active  = gpu_reg32(GPU_BASE_GC_0, GPU_R_CP_HQD_ACTIVE)     & 0xFFFFFFFF;
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, 0);
    gpu_mfence();

    # 7. VERIFY out[i]==i for all 64; count correct + first-bad index + how many changed from
    #    the pre-seed (nz). nz distinguishes "no store landed" (nz=0 => waves didn't run / all
    #    stores missed the array) from "wrote wrong value/addr" (nz>0 => decode o0/o1/o2).
    var okcount  = 0;
    var firstbad = 0 - 1;
    var nz = 0;
    var j = 0;
    while (j < GPU_MT_N) {
        var v = load32(out_phys + (j << 2)) & 0xFFFFFFFF;
        if (v == j) { okcount = okcount + 1; }
        else { if (firstbad < 0) { firstbad = j; } }
        if (v != GPU_MT_NOTYET) { nz = nz + 1; }
        j = j + 1;
    }
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);
    gpu_ring_wptr = new_wptr;


    if (fault != 0) {
        gpu_mt_ok = 0 - 3;
        kprintln("gpu: parallel compute store faulted", 35);
        return 0;
    }
    if (ok != 0) {
        if (okcount == GPU_MT_N) {
            gpu_mt_ok = 1;
            kprintln("gpu: parallel compute online (64 threads)", 41);
            return 1;
        }
        gpu_mt_ok = 0 - 2;
        kprintln("gpu: parallel compute incomplete", 32);
        return 0;
    }
    gpu_mt_ok = 0 - 1;
    kprintln("gpu: parallel dispatch did not complete", 39);
    return 0;
}

# ── C2g-2 — compute KERNARGS: read an operand through a pointer passed in COMPUTE_USER_DATA ──────
# The last primitive before matmul. C2g-1 baked the output address into the shader as a literal; C2g-2
# passes BOTH an input and an output base pointer via COMPUTE_USER_DATA_0..3 (RSRC2 USER_SGPR=4 makes the
# SPI preload s[0:1]=input, s[2:3]=output before shader entry), and the shader does out[tid] = in[tid] —
# proving per-lane operand reads through kernarg pointers. mabda-proven ABI; all 17 shader dwords are
# llvm-mc(-mcpu=gfx90c) ground-truth. Gated on C2g-1 (multi-thread proven). WEDGE-SAFE: same bounded
# envelope as C2g-1; a bad per-lane load/store addr faults into the 0x1FFC dummy net (fault!=0, bounded).
fn gpu_shader_dispatch3() {
    gpu_kernarg_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_mt_ok != 1) {
        kprintln("gpu: skipping kernarg test (parallel compute unverified)", 56);
        return 0;
    }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var in_phys     = gpu_arena_phys + GPU_KERNARG_IN_SUBOFF;
    var in_mc       = gpu_arena_mc   + GPU_KERNARG_IN_SUBOFF;
    var out_phys    = gpu_arena_phys + GPU_KERNARG_OUT_SUBOFF;
    var out_mc      = gpu_arena_mc   + GPU_KERNARG_OUT_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    # 1. Shader (17 dwords): s[0:1]=input base, s[2:3]=output base (SPI-preloaded from USER_DATA).
    #    off = tid*4; v3 = in[off] (load via s[0:1]); out[off] = v3 (store via s[2:3]).
    store32(shader_phys + 0x00, 0xBEFE01C1);   # s_mov_b64 exec, -1   (unmask all 64 lanes; exact-64)
    store32(shader_phys + 0x04, 0x24000082);   # v_lshlrev_b32 v0, 2, v0        (v0 = tid*4)
    store32(shader_phys + 0x08, 0x7E020200);   # v_mov_b32 v1, s0               (in base lo)
    store32(shader_phys + 0x0C, 0x7E040201);   # v_mov_b32 v2, s1               (in base hi)
    store32(shader_phys + 0x10, 0x32020101);   # v_add_co_u32 v1, vcc, v1, v0
    store32(shader_phys + 0x14, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x18, 0xDC508000);   # global_load_dword v3, v[1:2], off
    store32(shader_phys + 0x1C, 0x037F0001);   #   (VDATA=v3, VADDR=v1, SADDR=off)
    store32(shader_phys + 0x20, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x24, 0x7E020202);   # v_mov_b32 v1, s2               (out base lo)
    store32(shader_phys + 0x28, 0x7E040203);   # v_mov_b32 v2, s3               (out base hi)
    store32(shader_phys + 0x2C, 0x32020101);   # v_add_co_u32 v1, vcc, v1, v0
    store32(shader_phys + 0x30, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x34, 0xDC718000);   # global_store_dword v[1:2], v3, off glc
    store32(shader_phys + 0x38, 0x007F0301);   #   (VADDR=v1, VDATA=v3, SADDR=off)
    store32(shader_phys + 0x3C, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x40, 0xBF810000);   # s_endpgm

    # 2. Pre-seed the INPUT buffer (in[i] = i*7+1, a distinct != NOTYET pattern) + the OUTPUT + done.
    var s = 0;
    while (s < GPU_MT_N) {
        store32(in_phys  + (s << 2), s * 7 + 1);
        store32(out_phys + (s << 2), GPU_MT_NOTYET);
        s = s + 1;
    }
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    # 3. Re-arm the fault-net.
    var fc0 = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0 | 0x1);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0);

    # 4. Ring program. Deltas vs C2g-1: RSRC2 = USER_SGPR=4 (0x08) so the SPI preloads s0..s3, and a
    #    COMPUTE_USER_DATA_0..3 = (in_lo, in_hi, out_lo, out_hi) write. Everything else is the proven path
    #    (pre-dispatch I$ invalidate, START/RESTART, STATIC, RESLIM, post-dispatch TC-writeback, done).
    var pgm_lo = (shader_mc >> 8)  & 0xFFFFFFFF;
    var pgm_hi = (shader_mc >> 40) & 0xFF;
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_INV);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_LO); gpu_ring_put(pgm_lo); gpu_ring_put(pgm_hi);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_RSRC1); gpu_ring_put(GPU_COMPUTE_PGM_RSRC1_MIN); gpu_ring_put(GPU_COMPUTE_RSRC2_KERNARG);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N4); gpu_ring_put(GPU_SH_COMPUTE_USER_DATA_0);
    gpu_ring_put(in_mc & 0xFFFFFFFF); gpu_ring_put((in_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(out_mc & 0xFFFFFFFF); gpu_ring_put((out_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_START_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_NUM_THREAD_X); gpu_ring_put(GPU_MT_NUM_THREAD_X); gpu_ring_put(1); gpu_ring_put(1);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_RESTART_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE0); gpu_ring_put(GPU_CU_MASK_ALL); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE2); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N1); gpu_ring_put(GPU_SH_COMPUTE_RESOURCE_LIMITS); gpu_ring_put(GPU_COMPUTE_RESLIM);
    gpu_ring_put(GPU_PM4_DISPATCH_DIRECT_HDR); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(GPU_DISPATCH_INITIATOR);
    gpu_ring_put(GPU_PM4_EVENT_WRITE_HDR); gpu_ring_put(GPU_EVENT_CS_PARTIAL_FLUSH);
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_TCWB);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_WRITE_DATA_HDR); gpu_ring_put(GPU_PM4_WRITE_DATA_CTL);
    gpu_ring_put(done_mc & 0xFFFFFFFF); gpu_ring_put((done_mc >> 32) & 0xFFFFFFFF); gpu_ring_put(GPU_C2F_DONE);
    gpu_mfence();

    # 5. Register-wptr submit (LO before HI).
    var new_wptr = gpu_ring_wptr;
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, GPU_GRBM_SEL_MEC1_P0_Q0);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_LO, new_wptr);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_HI, 0);
    gpu_mfence();

    # 6. Bounded watchdog on the done-marker.
    # plan-S12a: tight spin, not a 100 us sleep quantum. See gpu_wait_done.
    var ok = gpu_wait_done(done_phys, GPU_C2F_DONE, 100000);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, 0);
    gpu_mfence();
    gpu_ring_wptr = new_wptr;

    # 7. VERIFY out[i] == in[i] (== i*7+1) for all 64 — proves each lane read its operand + wrote it back.
    var okcount = 0;
    var j = 0;
    while (j < GPU_MT_N) {
        var v = load32(out_phys + (j << 2)) & 0xFFFFFFFF;
        if (v == (j * 7 + 1)) { okcount = okcount + 1; }
        j = j + 1;
    }
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);

    if (fault != 0) {
        gpu_kernarg_ok = 0 - 3;
        kprintln("gpu: kernarg compute faulted", 28);
        return 0;
    }
    if (ok != 0) {
        if (okcount == GPU_MT_N) {
            gpu_kernarg_ok = 1;
            kprintln("gpu: kernarg compute online (64 operand reads)", 46);
            return 1;
        }
        gpu_kernarg_ok = 0 - 2;
        kprintln("gpu: kernarg compute incomplete", 31);
        return 0;
    }
    gpu_kernarg_ok = 0 - 1;
    kprintln("gpu: kernarg dispatch did not complete", 38);
    return 0;
}

# ── C2g-3 — ALU + REDUCTION LOOP: each lane runs matmul's inner loop (per-lane integer dot product) ──
# out[tid] = sum_{k=0..K-1} a[tid*K+k] * b[tid*K+k], K=4, via a REAL branch loop (s_cbranch) with
# v_mul_lo_u32 / v_add_u32 accumulate. 3 kernargs (a,b,out) preloaded into s[0:1]/s[2:3]/s[4:5] (RSRC2
# USER_SGPR=6). All 38 shader dwords are llvm-mc(-mcpu=gfx90c) ground-truth (incl. the loop branch
# 0xBF85FFEF = -17 dwords). Pre-seeds a[i]=i+1, b[i]=i+2; verifies each of the 64 dot products vs the CPU.
# This is the last primitive before rosnet matmul (C2g-4). Gated on C2g-2 (kernargs proven).
fn gpu_shader_dispatch4() {
    gpu_reduce_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_kernarg_ok != 1) {
        kprintln("gpu: skipping reduction test (kernargs unverified)", 50);
        return 0;
    }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var a_phys      = gpu_arena_phys + GPU_DOT_A_SUBOFF;
    var a_mc        = gpu_arena_mc   + GPU_DOT_A_SUBOFF;
    var b_phys      = gpu_arena_phys + GPU_DOT_B_SUBOFF;
    var b_mc        = gpu_arena_mc   + GPU_DOT_B_SUBOFF;
    var out_phys    = gpu_arena_phys + GPU_DOT_OUT_SUBOFF;
    var out_mc      = gpu_arena_mc   + GPU_DOT_OUT_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    # 1. Shader (38 dwords): s[0:1]=a, s[2:3]=b, s[4:5]=out. Per lane: acc=0; loop K times over
    #    v3=a[k]*b[k] accumulating into v8; store v8 -> out[tid]. Loop counter is the uniform SGPR s6.
    store32(shader_phys + 0x00, 0xBEFE01C1);   # s_mov_b64 exec, -1
    store32(shader_phys + 0x04, 0x24120084);   # v_lshlrev_b32 v9, 4, v0    (v9 = tid*16 = a/b slice off)
    store32(shader_phys + 0x08, 0x24140082);   # v_lshlrev_b32 v10, 2, v0   (v10 = tid*4 = out off)
    store32(shader_phys + 0x0C, 0x7E020200);   # v_mov_b32 v1, s0
    store32(shader_phys + 0x10, 0x7E040201);   # v_mov_b32 v2, s1
    store32(shader_phys + 0x14, 0x32021301);   # v_add_co_u32 v1, vcc, v1, v9   (addr_a = a + slice)
    store32(shader_phys + 0x18, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x1C, 0x7E060202);   # v_mov_b32 v3, s2
    store32(shader_phys + 0x20, 0x7E080203);   # v_mov_b32 v4, s3
    store32(shader_phys + 0x24, 0x32061303);   # v_add_co_u32 v3, vcc, v3, v9   (addr_b = b + slice)
    store32(shader_phys + 0x28, 0x38080880);   # v_addc_co_u32 v4, vcc, 0, v4, vcc
    store32(shader_phys + 0x2C, 0x7E100280);   # v_mov_b32 v8, 0                (acc = 0)
    store32(shader_phys + 0x30, 0xB0060004);   # s_movk_i32 s6, 4              (K = loop count)
    store32(shader_phys + 0x34, 0xDC508000);   # loop: global_load_dword v5, v[1:2], off
    store32(shader_phys + 0x38, 0x057F0001);   #   (a[k])
    store32(shader_phys + 0x3C, 0xDC508000);   # global_load_dword v6, v[3:4], off
    store32(shader_phys + 0x40, 0x067F0003);   #   (b[k])
    store32(shader_phys + 0x44, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x48, 0xD2850007);   # v_mul_lo_u32 v7, v5, v6       (a[k]*b[k])
    store32(shader_phys + 0x4C, 0x00020D05);   #   (VOP3 lo dword)
    store32(shader_phys + 0x50, 0x68100F08);   # v_add_u32 v8, v8, v7          (acc += a[k]*b[k])
    store32(shader_phys + 0x54, 0xD1196A01);   # v_add_co_u32 v1, vcc, v1, 4   (addr_a += 4)
    store32(shader_phys + 0x58, 0x00010901);   #   (VOP3 lo dword)
    store32(shader_phys + 0x5C, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x60, 0xD1196A03);   # v_add_co_u32 v3, vcc, v3, 4   (addr_b += 4)
    store32(shader_phys + 0x64, 0x00010903);   #   (VOP3 lo dword)
    store32(shader_phys + 0x68, 0x38080880);   # v_addc_co_u32 v4, vcc, 0, v4, vcc
    store32(shader_phys + 0x6C, 0x81868106);   # s_sub_i32 s6, s6, 1           (K--)
    store32(shader_phys + 0x70, 0xBF018006);   # s_cmp_lg_i32 s6, 0
    store32(shader_phys + 0x74, 0xBF85FFEF);   # s_cbranch_scc1 loop           (offset -17 dwords)
    store32(shader_phys + 0x78, 0x7E020204);   # v_mov_b32 v1, s4
    store32(shader_phys + 0x7C, 0x7E040205);   # v_mov_b32 v2, s5
    store32(shader_phys + 0x80, 0x32021501);   # v_add_co_u32 v1, vcc, v1, v10 (addr_out = out + tid*4)
    store32(shader_phys + 0x84, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x88, 0xDC718000);   # global_store_dword v[1:2], v8, off glc
    store32(shader_phys + 0x8C, 0x007F0801);   #   (out[tid] = acc)
    store32(shader_phys + 0x90, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x94, 0xBF810000);   # s_endpgm

    # 2. Pre-seed a[i]=i+1, b[i]=i+2 (256 each), out[64]=NOTYET, done=NOTYET.
    var s = 0;
    while (s < GPU_DOT_N) {
        store32(a_phys + (s << 2), s + 1);
        store32(b_phys + (s << 2), s + 2);
        s = s + 1;
    }
    s = 0;
    while (s < GPU_MT_N) { store32(out_phys + (s << 2), GPU_MT_NOTYET); s = s + 1; }
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    # 3. Re-arm the fault-net.
    var fc0 = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0 | 0x1);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0);

    # 4. Ring program. Deltas vs C2g-2: RSRC1 = 12-VGPR (loop shader), RSRC2 = USER_SGPR=6 (0x0C), and
    #    USER_DATA_0..5 = (a_lo, a_hi, b_lo, b_hi, out_lo, out_hi). Rest is the proven envelope.
    var pgm_lo = (shader_mc >> 8)  & 0xFFFFFFFF;
    var pgm_hi = (shader_mc >> 40) & 0xFF;
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_INV);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_LO); gpu_ring_put(pgm_lo); gpu_ring_put(pgm_hi);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_RSRC1); gpu_ring_put(GPU_COMPUTE_PGM_RSRC1_V12); gpu_ring_put(GPU_COMPUTE_RSRC2_KERNARG3);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N6); gpu_ring_put(GPU_SH_COMPUTE_USER_DATA_0);
    gpu_ring_put(a_mc & 0xFFFFFFFF); gpu_ring_put((a_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(b_mc & 0xFFFFFFFF); gpu_ring_put((b_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(out_mc & 0xFFFFFFFF); gpu_ring_put((out_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_START_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_NUM_THREAD_X); gpu_ring_put(GPU_MT_NUM_THREAD_X); gpu_ring_put(1); gpu_ring_put(1);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_RESTART_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE0); gpu_ring_put(GPU_CU_MASK_ALL); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE2); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N1); gpu_ring_put(GPU_SH_COMPUTE_RESOURCE_LIMITS); gpu_ring_put(GPU_COMPUTE_RESLIM);
    gpu_ring_put(GPU_PM4_DISPATCH_DIRECT_HDR); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(GPU_DISPATCH_INITIATOR);
    gpu_ring_put(GPU_PM4_EVENT_WRITE_HDR); gpu_ring_put(GPU_EVENT_CS_PARTIAL_FLUSH);
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_TCWB);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_WRITE_DATA_HDR); gpu_ring_put(GPU_PM4_WRITE_DATA_CTL);
    gpu_ring_put(done_mc & 0xFFFFFFFF); gpu_ring_put((done_mc >> 32) & 0xFFFFFFFF); gpu_ring_put(GPU_C2F_DONE);
    gpu_mfence();

    # 5. Register-wptr submit.
    var new_wptr = gpu_ring_wptr;
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, GPU_GRBM_SEL_MEC1_P0_Q0);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_LO, new_wptr);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_HI, 0);
    gpu_mfence();

    # 6. Bounded watchdog.
    # plan-S12a: tight spin, not a 100 us sleep quantum. See gpu_wait_done.
    var ok = gpu_wait_done(done_phys, GPU_C2F_DONE, 100000);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, 0);
    gpu_mfence();
    gpu_ring_wptr = new_wptr;

    # 7. VERIFY out[j] == sum_{k=0..K-1} a[j*K+k]*b[j*K+k] (a[i]=i+1, b[i]=i+2) for all 64.
    var okcount = 0;
    var j = 0;
    while (j < GPU_MT_N) {
        var expected = 0;
        var k = 0;
        while (k < GPU_DOT_K) {
            var idx = j * GPU_DOT_K + k;
            expected = expected + (idx + 1) * (idx + 2);
            k = k + 1;
        }
        var v = load32(out_phys + (j << 2)) & 0xFFFFFFFF;
        if (v == expected) { okcount = okcount + 1; }
        j = j + 1;
    }
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);

    if (fault != 0) {
        gpu_reduce_ok = 0 - 3;
        kprintln("gpu: reduction-loop compute faulted", 35);
        return 0;
    }
    if (ok != 0) {
        if (okcount == GPU_MT_N) {
            gpu_reduce_ok = 1;
            kprintln("gpu: reduction-loop compute online (64 dot products)", 52);
            return 1;
        }
        gpu_reduce_ok = 0 - 2;
        kprintln("gpu: reduction-loop compute incomplete", 38);
        return 0;
    }
    gpu_reduce_ok = 0 - 1;
    kprintln("gpu: reduction-loop dispatch did not complete", 45);
    return 0;
}

# ── C2g-4 — THE CROWN: real integer tiled matmul C[8x8] = A[8x8] * B[8x8] on the shader cores ──────
# Each of 64 lanes computes ONE output element C[i][j] = sum_{k=0..7} A[i*8+k] * B[k*8+j]. tid -> i=tid>>3,
# j=tid&7; the lane walks row i of A (+4 per k) and column j of B (+32 per k = N*4), accumulating in a real
# branch loop. Bit-correct vs the CPU reference. Same kernarg ABI as C2g-3 (3 pointers, RSRC2=0x0C, 12 VGPRs).
# All 41 shader dwords llvm-mc(-mcpu=gfx90c) ground-truth. THIS is the matmul that attn11/tentib ML layers
# ride onto the GPU (C2h wires the ring-3 gpu_* band next). Gated on C2g-3 (loop+MAC proven).
# === C2h: shared integer-matmul primitives (factored from gpu_shader_dispatch5) ===
# gpu_matmul_write_shader — emit the 41-dword gfx90c 8x8 integer-matmul kernel at
# shader_phys. tid->(i,j); walk A row (i*32, +4/k) x B col (j*4, +32/k); loop K=8
# with v_mul_lo_u32 + v_add_u32 MAC; store C[tid]. The C2g-4 shader, one source of truth.
fn gpu_matmul_write_shader(shader_phys) {
    store32(shader_phys + 0x00, 0xBEFE01C1);   # s_mov_b64 exec, -1
    store32(shader_phys + 0x04, 0x20120083);   # v_lshrrev_b32 v9, 3, v0     (i = tid>>3)
    store32(shader_phys + 0x08, 0x26140087);   # v_and_b32 v10, 7, v0        (j = tid&7)
    store32(shader_phys + 0x0C, 0x24121285);   # v_lshlrev_b32 v9, 5, v9     (v9 = i*32 = A row off)
    store32(shader_phys + 0x10, 0x24141482);   # v_lshlrev_b32 v10, 2, v10   (v10 = j*4 = B col off)
    store32(shader_phys + 0x14, 0x24160082);   # v_lshlrev_b32 v11, 2, v0    (v11 = tid*4 = C off)
    store32(shader_phys + 0x18, 0x7E020200);   # v_mov_b32 v1, s0
    store32(shader_phys + 0x1C, 0x7E040201);   # v_mov_b32 v2, s1
    store32(shader_phys + 0x20, 0x32021301);   # v_add_co_u32 v1, vcc, v1, v9   (addr_a = A + i*32)
    store32(shader_phys + 0x24, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x28, 0x7E060202);   # v_mov_b32 v3, s2
    store32(shader_phys + 0x2C, 0x7E080203);   # v_mov_b32 v4, s3
    store32(shader_phys + 0x30, 0x32061503);   # v_add_co_u32 v3, vcc, v3, v10  (addr_b = B + j*4)
    store32(shader_phys + 0x34, 0x38080880);   # v_addc_co_u32 v4, vcc, 0, v4, vcc
    store32(shader_phys + 0x38, 0x7E100280);   # v_mov_b32 v8, 0                (acc = 0)
    store32(shader_phys + 0x3C, 0xB0060008);   # s_movk_i32 s6, 8              (K)
    store32(shader_phys + 0x40, 0xDC508000);   # loop: global_load_dword v5, v[1:2], off  (A[i][k])
    store32(shader_phys + 0x44, 0x057F0001);
    store32(shader_phys + 0x48, 0xDC508000);   # global_load_dword v6, v[3:4], off         (B[k][j])
    store32(shader_phys + 0x4C, 0x067F0003);
    store32(shader_phys + 0x50, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x54, 0xD2850007);   # v_mul_lo_u32 v7, v5, v6
    store32(shader_phys + 0x58, 0x00020D05);
    store32(shader_phys + 0x5C, 0x68100F08);   # v_add_u32 v8, v8, v7          (acc += A*B)
    store32(shader_phys + 0x60, 0xD1196A01);   # v_add_co_u32 v1, vcc, v1, 4   (addr_a += 4, next col of A)
    store32(shader_phys + 0x64, 0x00010901);
    store32(shader_phys + 0x68, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x6C, 0xD1196A03);   # v_add_co_u32 v3, vcc, v3, 32  (addr_b += 32, next row of B)
    store32(shader_phys + 0x70, 0x00014103);
    store32(shader_phys + 0x74, 0x38080880);   # v_addc_co_u32 v4, vcc, 0, v4, vcc
    store32(shader_phys + 0x78, 0x81868106);   # s_sub_i32 s6, s6, 1
    store32(shader_phys + 0x7C, 0xBF018006);   # s_cmp_lg_i32 s6, 0
    store32(shader_phys + 0x80, 0xBF85FFEF);   # s_cbranch_scc1 loop
    store32(shader_phys + 0x84, 0x7E020204);   # v_mov_b32 v1, s4
    store32(shader_phys + 0x88, 0x7E040205);   # v_mov_b32 v2, s5
    store32(shader_phys + 0x8C, 0x32021701);   # v_add_co_u32 v1, vcc, v1, v11 (addr_c = C + tid*4)
    store32(shader_phys + 0x90, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x94, 0xDC718000);   # global_store_dword v[1:2], v8, off glc  (C[i][j] = acc)
    store32(shader_phys + 0x98, 0x007F0801);
    store32(shader_phys + 0x9C, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0xA0, 0xBF810000);   # s_endpgm
    return 0;
}

# gpu_matmul_run — with A,B already in the carveout and the shader resident, emit the
# proven PM4 dispatch envelope (I-cache invalidate -> SET_SH_REG USER_DATA=A,B,C ->
# DISPATCH_DIRECT -> CS flush -> TCWB -> fence WRITE_DATA), submit via register-wptr,
# and spin the watchdog. Returns 1 = fence fired, 0 = timeout. Leaves C[tid] in the
# carveout. Shared by the C2g-4 boot proof and the C2h dispatch syscall.
fn gpu_matmul_run(shader_mc, a_mc, b_mc, c_mc, done_mc, done_phys, rsrc1) {
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    # Re-arm the fault-net.
    var fc0 = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0 | 0x1);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0);

    # Ring program (USER_DATA_0..5 = A, B, C).
    var pgm_lo = (shader_mc >> 8)  & 0xFFFFFFFF;
    var pgm_hi = (shader_mc >> 40) & 0xFF;
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_INV);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_LO); gpu_ring_put(pgm_lo); gpu_ring_put(pgm_hi);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_RSRC1); gpu_ring_put(rsrc1); gpu_ring_put(GPU_COMPUTE_RSRC2_KERNARG3);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N6); gpu_ring_put(GPU_SH_COMPUTE_USER_DATA_0);
    gpu_ring_put(a_mc & 0xFFFFFFFF); gpu_ring_put((a_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(b_mc & 0xFFFFFFFF); gpu_ring_put((b_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(c_mc & 0xFFFFFFFF); gpu_ring_put((c_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_START_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_NUM_THREAD_X); gpu_ring_put(GPU_MT_NUM_THREAD_X); gpu_ring_put(1); gpu_ring_put(1);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_RESTART_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE0); gpu_ring_put(GPU_CU_MASK_ALL); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE2); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N1); gpu_ring_put(GPU_SH_COMPUTE_RESOURCE_LIMITS); gpu_ring_put(GPU_COMPUTE_RESLIM);
    gpu_ring_put(GPU_PM4_DISPATCH_DIRECT_HDR); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(1); gpu_ring_put(GPU_DISPATCH_INITIATOR);
    gpu_ring_put(GPU_PM4_EVENT_WRITE_HDR); gpu_ring_put(GPU_EVENT_CS_PARTIAL_FLUSH);
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_TCWB);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_WRITE_DATA_HDR); gpu_ring_put(GPU_PM4_WRITE_DATA_CTL);
    gpu_ring_put(done_mc & 0xFFFFFFFF); gpu_ring_put((done_mc >> 32) & 0xFFFFFFFF); gpu_ring_put(GPU_C2F_DONE);
    gpu_mfence();

    # Register-wptr submit.
    var new_wptr = gpu_ring_wptr;
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, GPU_GRBM_SEL_MEC1_P0_Q0);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_LO, new_wptr);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_HI, 0);
    gpu_mfence();

    # Bounded watchdog.
    # plan-S12a: tight spin, not a 100 us sleep quantum. See gpu_wait_done.
    var ok = gpu_wait_done(done_phys, GPU_C2F_DONE, 100000);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, 0);
    gpu_mfence();
    gpu_ring_wptr = new_wptr;
    return ok;
}

fn gpu_shader_dispatch5() {
    gpu_matmul_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_reduce_ok != 1) {
        kprintln("gpu: skipping matmul (reduction loop unverified)", 48);
        return 0;
    }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var a_phys      = gpu_arena_phys + GPU_MM_A_SUBOFF;
    var a_mc        = gpu_arena_mc   + GPU_MM_A_SUBOFF;
    var b_phys      = gpu_arena_phys + GPU_MM_B_SUBOFF;
    var b_mc        = gpu_arena_mc   + GPU_MM_B_SUBOFF;
    var c_phys      = gpu_arena_phys + GPU_MM_C_SUBOFF;
    var c_mc        = gpu_arena_mc   + GPU_MM_C_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    # 1. Shader — the C2g-4 8x8 integer-matmul kernel (factored to gpu_matmul_write_shader).
    gpu_matmul_write_shader(shader_phys);

    # 2. Pre-seed A[i]=i+1, B[i]=i+1 (64 each), C[64]=NOTYET.
    var n = GPU_MM_DIM * GPU_MM_DIM;
    var s = 0;
    while (s < n) {
        store32(a_phys + (s << 2), s + 1);
        store32(b_phys + (s << 2), s + 1);
        store32(c_phys + (s << 2), GPU_MT_NOTYET);
        s = s + 1;
    }
    gpu_mfence();

    # 3-6. Dispatch envelope + submit + watchdog (factored to gpu_matmul_run).
    var ok = gpu_matmul_run(shader_mc, a_mc, b_mc, c_mc, done_mc, done_phys, GPU_COMPUTE_PGM_RSRC1_V12);

    # 7. VERIFY C[i*8+j] == sum_{k=0..7} A[i*8+k]*B[k*8+j] (A[x]=B[x]=x+1) — bit-correct vs the CPU matmul.
    var okcount = 0;
    var tid = 0;
    while (tid < n) {
        var ii = tid >> 3;
        var jj = tid & 7;
        var expected = 0;
        var k = 0;
        while (k < GPU_MM_DIM) {
            var av = ii * 8 + k + 1;      # A[ii*8+k]
            var bv = k * 8 + jj + 1;      # B[k*8+jj]
            expected = expected + av * bv;
            k = k + 1;
        }
        var v = load32(c_phys + (tid << 2)) & 0xFFFFFFFF;
        if (v == expected) { okcount = okcount + 1; }
        tid = tid + 1;
    }
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);

    if (fault != 0) {
        gpu_matmul_ok = 0 - 3;
        kprintln("gpu: matmul faulted", 19);
        return 0;
    }
    if (ok != 0) {
        if (okcount == n) {
            gpu_matmul_ok = 1;
            kprintln("gpu: integer matmul online (8x8, bit-correct vs CPU)", 52);
            return 1;
        }
        gpu_matmul_ok = 0 - 2;
        kprintln("gpu: matmul incomplete (result mismatch)", 40);
        return 0;
    }
    gpu_matmul_ok = 0 - 1;
    kprintln("gpu: matmul dispatch did not complete", 37);
    return 0;
}

# === C2h: ring-3 GPU-compute dispatch (syscall #82) ===
# gpu_dispatch(a_uva, b_uva, c_uva): run the proven 8x8 integer matmul on the
# userspace-supplied A,B (64 i32 each, row-major) and write C (64 i32, C=A*B) to
# c_uva. This is the ring-3 seam the sovereign GPU compute libraries (mabda /
# tentib) consume — the SAME PM4 envelope as the C2g-4 boot proof, driven by
# caller data instead of a kernel-baked pattern. Returns 0 ok; -1 GPU not ready;
# -2 dispatch did not complete; -3 VM fault.
#
# Runs in ring 0 under the CALLER's CR3: the carveout lives in the shared kernel
# PDPT (proc CR3s mirror entries [1..511], so it is reachable), and a_uva/b_uva/
# c_uva are the caller's own user pages (present under its CR3). Pointer sanity is
# the caller's responsibility for now (matches the other simple syscall handlers);
# a proc_copy_from_user hardening pass is tracked as follow-on.
fn gpu_dispatch_sys(a_uva, b_uva, c_uva) {
    if (gpu_present == 0)   { return 0 - 1; }
    if (gpu_matmul_ok != 1) { return 0 - 1; }   # engines + shader proven at boot
    if (gpu_arena_mc == 0)  { return 0 - 1; }
    if (gpu_ring_wptr == 0) { return 0 - 1; }

    # Pointer hardening: A,B,C each hold 64 i32 = 256 bytes. Reject out-of-range pointers (kernel
    # addresses, wrap, above the 1 GB user ceiling) — the readdir#81/uname#34 norm — so a wild ring-3
    # pointer can never steer the copy into kernel memory.
    var nbytes = GPU_MM_DIM * GPU_MM_DIM * 4;   # 256
    if (is_user_range(a_uva, nbytes) == 0) { return 0 - 4; }
    if (is_user_range(b_uva, nbytes) == 0) { return 0 - 4; }
    if (is_user_range(c_uva, nbytes) == 0) { return 0 - 4; }
    var cr3 = proc_get_cr3(proc_current_get());

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var a_phys      = gpu_arena_phys + GPU_MM_A_SUBOFF;
    var a_mc        = gpu_arena_mc   + GPU_MM_A_SUBOFF;
    var b_phys      = gpu_arena_phys + GPU_MM_B_SUBOFF;
    var b_mc        = gpu_arena_mc   + GPU_MM_B_SUBOFF;
    var c_phys      = gpu_arena_phys + GPU_MM_C_SUBOFF;
    var c_mc        = gpu_arena_mc   + GPU_MM_C_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    # Fault-proof copy A,B from userspace into the carveout: proc_copy_from_user page-walks the caller's
    # CR3 and refuses any not-present / non-user page (returns 0) instead of a blind deref that could #PF
    # the kernel on a wild-but-in-range pointer.
    if (proc_copy_from_user(cr3, a_phys, a_uva, nbytes) == 0) { return 0 - 5; }
    if (proc_copy_from_user(cr3, b_phys, b_uva, nbytes) == 0) { return 0 - 5; }
    var n = GPU_MM_DIM * GPU_MM_DIM;
    var s = 0;
    while (s < n) { store32(c_phys + (s << 2), GPU_MT_NOTYET); s = s + 1; }

    gpu_matmul_write_shader(shader_phys);
    gpu_mfence();

    var ok = gpu_matmul_run(shader_mc, a_mc, b_mc, c_mc, done_mc, done_phys, GPU_COMPUTE_PGM_RSRC1_V12);
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);
    if (fault != 0) { return 0 - 3; }
    if (ok != 1)    { return 0 - 2; }

    # Fault-proof the write-back: no proc_copy_TO_user primitive exists, so confirm C's user pages are
    # present+user first (page-walk into a_phys, now free — its A copy was already consumed by the
    # dispatch), then the direct store32 loop cannot #PF.
    if (proc_copy_from_user(cr3, a_phys, c_uva, nbytes) == 0) { return 0 - 5; }
    s = 0;
    while (s < n) {
        store32(c_uva + (s << 2), load32(c_phys + (s << 2)) & 0xFFFFFFFF);
        s = s + 1;
    }
    return 0;
}

# === f64 full-precision matmul (attn11's path) ===
# u64_to_f64_bits — the IEEE-754 double bit pattern of a non-negative integer, computed in pure i64
# (no kernel FPU). For n in [1, 2^53): sign=0, exponent = e+1023 (e = index of the highest set bit),
# mantissa = the bits below the leading 1, left-justified into [51:0]. Used both to SEED the f64 test
# data (A[i]=B[i]=(i+1).0) and to VERIFY the GPU result against the CPU reference, since every expected
# C[i][j] is an exact integer < 2^15 (exactly representable, so no rounding — FMA == mul+add here).
fn u64_to_f64_bits(n) {
    if (n == 0) { return 0; }
    var e = 63;
    while (((n >> e) & 1) == 0) { e = e - 1; }
    var mant = 0;
    if (e <= 52) { mant = (n << (52 - e)) & 0xFFFFFFFFFFFFF; }
    else { mant = (n >> (e - 52)) & 0xFFFFFFFFFFFFF; }
    var expf = e + 1023;
    return (expf << 52) | mant;
}

# gpu_matmul_write_shader_f64 — the 43-dword gfx90c f64 8x8 matmul kernel. Same tiled structure as the
# integer crown, but f64 (8-byte) elements: global_load/store_dwordx2 into register pairs and doubled
# address strides (A row i*64, +8/k; B col j*8, +64/k; C tid*8). The MAC is SEPARATE v_mul_f64 then
# v_add_f64 (product in the free pair v[14:15]) — NOT a fused v_fma_f64 — because rosnet accumulates as
# mul-then-add (its f64v_fmadd lowers to mulpd+addpd; the scalar path is f64_add(y, f64_mul(x,W))). Two
# roundings per step, same k-ascending order => bit-identical to rosnet's f64_mul/f64_add. All dwords
# llvm-mc -mcpu=gfx90c verified. Uses v0..v15 (16 VGPRs -> RSRC1 VGPRS=3).
fn gpu_matmul_write_shader_f64(shader_phys) {
    store32(shader_phys + 0x00, 0xBEFE01C1);   # s_mov_b64 exec, -1
    store32(shader_phys + 0x04, 0x200A0083);   # v_lshrrev_b32 v5, 3, v0     (i = tid>>3)
    store32(shader_phys + 0x08, 0x260C0087);   # v_and_b32 v6, 7, v0         (j = tid&7)
    store32(shader_phys + 0x0C, 0x240A0A86);   # v_lshlrev_b32 v5, 6, v5     (v5 = i*64 = A row off, f64)
    store32(shader_phys + 0x10, 0x240C0C83);   # v_lshlrev_b32 v6, 3, v6     (v6 = j*8  = B col off)
    store32(shader_phys + 0x14, 0x240E0083);   # v_lshlrev_b32 v7, 3, v0     (v7 = tid*8 = C off)
    store32(shader_phys + 0x18, 0x7E020200);   # v_mov_b32 v1, s0
    store32(shader_phys + 0x1C, 0x7E040201);   # v_mov_b32 v2, s1
    store32(shader_phys + 0x20, 0x32020B01);   # v_add_co_u32 v1, vcc, v1, v5   (addr_a = A + i*64)
    store32(shader_phys + 0x24, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x28, 0x7E060202);   # v_mov_b32 v3, s2
    store32(shader_phys + 0x2C, 0x7E080203);   # v_mov_b32 v4, s3
    store32(shader_phys + 0x30, 0x32060D03);   # v_add_co_u32 v3, vcc, v3, v6   (addr_b = B + j*8)
    store32(shader_phys + 0x34, 0x38080880);   # v_addc_co_u32 v4, vcc, 0, v4, vcc
    store32(shader_phys + 0x38, 0x7E180280);   # v_mov_b32 v12, 0               (acc lo = 0.0)
    store32(shader_phys + 0x3C, 0x7E1A0280);   # v_mov_b32 v13, 0               (acc hi = 0.0)
    store32(shader_phys + 0x40, 0xB0060008);   # s_movk_i32 s6, 8              (K)
    store32(shader_phys + 0x44, 0xDC548000);   # loop: global_load_dwordx2 v[8:9], v[1:2], off  (A[i][k])
    store32(shader_phys + 0x48, 0x087F0001);
    store32(shader_phys + 0x4C, 0xDC548000);   # global_load_dwordx2 v[10:11], v[3:4], off      (B[k][j])
    store32(shader_phys + 0x50, 0x0A7F0003);
    store32(shader_phys + 0x54, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0x58, 0xD281000E);   # v_mul_f64 v[14:15], v[8:9], v[10:11]   (prod = A*B, round 1)
    store32(shader_phys + 0x5C, 0x00021508);
    store32(shader_phys + 0x60, 0xD280000C);   # v_add_f64 v[12:13], v[12:13], v[14:15] (acc = acc + prod, round 2 = rosnet mul+add)
    store32(shader_phys + 0x64, 0x00021D0C);
    store32(shader_phys + 0x68, 0xD1196A01);   # v_add_co_u32 v1, vcc, v1, 8   (addr_a += 8, next col of A)
    store32(shader_phys + 0x6C, 0x00011101);
    store32(shader_phys + 0x70, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x74, 0xD1196A03);   # v_add_co_u32 v3, vcc, v3, 64  (addr_b += 64, next row of B, N*8)
    store32(shader_phys + 0x78, 0x00018103);
    store32(shader_phys + 0x7C, 0x38080880);   # v_addc_co_u32 v4, vcc, 0, v4, vcc
    store32(shader_phys + 0x80, 0x81868106);   # s_sub_i32 s6, s6, 1
    store32(shader_phys + 0x84, 0xBF018006);   # s_cmp_lg_i32 s6, 0
    store32(shader_phys + 0x88, 0xBF85FFEE);   # s_cbranch_scc1 loop           (offset -18 dwords)
    store32(shader_phys + 0x8C, 0x7E020204);   # v_mov_b32 v1, s4
    store32(shader_phys + 0x90, 0x7E040205);   # v_mov_b32 v2, s5
    store32(shader_phys + 0x94, 0x32020F01);   # v_add_co_u32 v1, vcc, v1, v7  (addr_c = C + tid*8)
    store32(shader_phys + 0x98, 0x38040480);   # v_addc_co_u32 v2, vcc, 0, v2, vcc
    store32(shader_phys + 0x9C, 0xDC758000);   # global_store_dwordx2 v[1:2], v[12:13], off glc  (C[tid] = acc)
    store32(shader_phys + 0xA0, 0x007F0C01);
    store32(shader_phys + 0xA4, 0xBF8C0F70);   # s_waitcnt vmcnt(0)
    store32(shader_phys + 0xA8, 0xBF810000);   # s_endpgm
    return 0;
}

# gpu_shader_dispatch_f64 — the f64 matmul BOOT PROOF (analog of the C2g-4 integer crown). Seeds
# A[i]=B[i]=(i+1).0 as f64, runs the f64 shader through the proven dispatch envelope (RSRC1_F64 = 16
# VGPRs), and verifies each C[tid] bit-for-bit against the CPU integer reference converted to f64 bits.
# PASS proves f64 matmul EXECUTES on the shader cores + is bit-correct for exact-integer data; the
# FMA-vs-rosnet fidelity test (non-exact data) is a follow-on. Gated on the integer matmul (engines up).
fn gpu_shader_dispatch_f64() {
    gpu_matmul_f64_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) {
        kprintln("gpu: skipping f64 matmul (integer matmul unverified)", 52);
        return 0;
    }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var a_phys      = gpu_arena_phys + GPU_MMF_A_SUBOFF;
    var a_mc        = gpu_arena_mc   + GPU_MMF_A_SUBOFF;
    var b_phys      = gpu_arena_phys + GPU_MMF_B_SUBOFF;
    var b_mc        = gpu_arena_mc   + GPU_MMF_B_SUBOFF;
    var c_phys      = gpu_arena_phys + GPU_MMF_C_SUBOFF;
    var c_mc        = gpu_arena_mc   + GPU_MMF_C_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    gpu_matmul_write_shader_f64(shader_phys);

    # Seed A[i]=B[i]=(i+1).0 as f64 (8-byte doubles); clear C.
    var n = GPU_MM_DIM * GPU_MM_DIM;
    var s = 0;
    while (s < n) {
        var vbits = u64_to_f64_bits(s + 1);
        store64(a_phys + (s << 3), vbits);
        store64(b_phys + (s << 3), vbits);
        store64(c_phys + (s << 3), 0);
        s = s + 1;
    }
    gpu_mfence();

    var ok = gpu_matmul_run(shader_mc, a_mc, b_mc, c_mc, done_mc, done_phys, GPU_COMPUTE_PGM_RSRC1_F64);

    # VERIFY C[i*8+j] == sum_{k=0..7} A[i*8+k]*B[k*8+j] (A[x]=B[x]=x+1) — the expected integer, converted
    # to its f64 bit pattern, must bit-match the 8 bytes the GPU wrote (exact-integer data => no rounding).
    var okcount = 0;
    var tid = 0;
    while (tid < n) {
        var ii = tid >> 3;
        var jj = tid & 7;
        var expected = 0;
        var k = 0;
        while (k < GPU_MM_DIM) {
            var av = ii * 8 + k + 1;      # A[ii*8+k]
            var bv = k * 8 + jj + 1;      # B[k*8+jj]
            expected = expected + av * bv;
            k = k + 1;
        }
        if (load64(c_phys + (tid << 3)) == u64_to_f64_bits(expected)) { okcount = okcount + 1; }
        tid = tid + 1;
    }
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);

    if (fault != 0) {
        gpu_matmul_f64_ok = 0 - 3;
        kprintln("gpu: f64 matmul faulted", 23);
        return 0;
    }
    if (ok != 0) {
        if (okcount == n) {
            gpu_matmul_f64_ok = 1;
            kprintln("gpu: f64 matmul online (8x8, bit-correct vs CPU)", 48);
            return 1;
        }
        gpu_matmul_f64_ok = 0 - 2;
        kprintln("gpu: f64 matmul incomplete (result mismatch)", 44);
        return 0;
    }
    gpu_matmul_f64_ok = 0 - 1;
    kprintln("gpu: f64 matmul dispatch did not complete", 41);
    return 0;
}

# gpu_shader_dispatch_f64_fidelity — the ROSNET-BIT-CORRECT proof. Runs the SAME mul+add f64 shader on
# NON-EXACT data (A[i]=B[i]=(i+1)*0x1234567 — exact inputs, but products (…)*0x1234567^2 exceed 2^53 so
# the multiply ROUNDS), then verifies each C[tid] bit-for-bit against an IN-KERNEL reference computed
# with the SAME f64_mul/f64_add builtins rosnet uses, in the SAME k-ascending order. A PASS on rounding data
# proves the GPU's v_mul_f64/v_add_f64 == rosnet's mul+add bit-for-bit (a fused v_fma_f64 would DIVERGE
# here) => rosnet-bit-correct. Seeding stays FP-free (u64_to_f64_bits of exact scaled integers); the
# reference is the only f64 arithmetic (native SSE mulsd/addsd, RNE — identical to rosnet). Gated on the
# exact-int f64 proof (engines + f64 pipeline up).
fn gpu_shader_dispatch_f64_fidelity() {
    gpu_f64_fidelity_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_f64_ok != 1) {
        kprintln("gpu: skipping f64 fidelity (f64 matmul unverified)", 50);
        return 0;
    }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var a_phys      = gpu_arena_phys + GPU_MMF_A_SUBOFF;
    var a_mc        = gpu_arena_mc   + GPU_MMF_A_SUBOFF;
    var b_phys      = gpu_arena_phys + GPU_MMF_B_SUBOFF;
    var b_mc        = gpu_arena_mc   + GPU_MMF_B_SUBOFF;
    var c_phys      = gpu_arena_phys + GPU_MMF_C_SUBOFF;
    var c_mc        = gpu_arena_mc   + GPU_MMF_C_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    gpu_matmul_write_shader_f64(shader_phys);

    # Seed A[i]=B[i]=((i+1) * 0x1234567).0 — exact integer inputs (<2^31, u64_to_f64_bits-seedable) chosen
    # so the f64 PRODUCTS A[i][k]*B[k][j] = (…)*0x1234567^2 exceed 2^53 and ROUND. Host-verified: fma vs
    # mul+add diverge on 29/64 outputs with this data, so a PASS genuinely proves the GPU does mul+add.
    var n = GPU_MM_DIM * GPU_MM_DIM;
    var s = 0;
    while (s < n) {
        var vbits = u64_to_f64_bits((s + 1) * 0x1234567);
        store64(a_phys + (s << 3), vbits);
        store64(b_phys + (s << 3), vbits);
        store64(c_phys + (s << 3), 0);
        s = s + 1;
    }
    gpu_mfence();

    var ok = gpu_matmul_run(shader_mc, a_mc, b_mc, c_mc, done_mc, done_phys, GPU_COMPUTE_PGM_RSRC1_F64);

    # VERIFY: in-kernel reference using the SAME f64_mul/f64_add builtins rosnet uses (mul then add, two
    # roundings) over k ascending — must bit-match the 8 bytes the GPU wrote.
    var okcount = 0;
    var tid = 0;
    while (tid < n) {
        var ii = tid >> 3;
        var jj = tid & 7;
        var acc = 0;                    # +0.0 bits
        var k = 0;
        while (k < GPU_MM_DIM) {
            var prod = f64_mul(load64(a_phys + ((ii * 8 + k) << 3)), load64(b_phys + ((k * 8 + jj) << 3)));
            acc = f64_add(acc, prod);
            k = k + 1;
        }
        if (load64(c_phys + (tid << 3)) == acc) { okcount = okcount + 1; }
        tid = tid + 1;
    }
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);

    if (fault != 0) {
        gpu_f64_fidelity_ok = 0 - 3;
        kprintln("gpu: f64 fidelity faulted", 25);
        return 0;
    }
    if (ok != 0) {
        if (okcount == n) {
            gpu_f64_fidelity_ok = 1;
            kprintln("gpu: f64 matmul rosnet-bit-correct (8x8, rounding)", 50);
            return 1;
        }
        gpu_f64_fidelity_ok = 0 - 2;
        kprintln("gpu: f64 fidelity mismatch (fma vs mul+add?)", 44);
        return 0;
    }
    gpu_f64_fidelity_ok = 0 - 1;
    kprintln("gpu: f64 fidelity dispatch did not complete", 43);
    return 0;
}

# === f64 ring-3 GPU-compute dispatch (syscall #83) ===
# gpu_dispatch_f64(a_uva, b_uva, c_uva): the FULL-PRECISION ring-3 seam. Same as #82 but f64 — A,B are 64
# f64 (512 bytes each), runs the rosnet-matching mul+add f64 shader (RSRC1_F64 = 16 VGPRs), writes C = A·B
# (64 f64) back. This is attn11's path to the GPU from userspace: a ring-3 program gets rosnet-bit-correct
# f64 matmul on the shader cores. Same pointer hardening as #82. Returns 0 ok; -1 GPU/f64 not ready;
# -2 dispatch did not complete; -3 VM fault; -4 pointer out of user range; -5 user page not mapped.
fn gpu_dispatch_f64_sys(a_uva, b_uva, c_uva) {
    if (gpu_present == 0)       { return 0 - 1; }
    if (gpu_matmul_f64_ok != 1) { return 0 - 1; }   # f64 pipeline proven at boot
    if (gpu_arena_mc == 0)      { return 0 - 1; }
    if (gpu_ring_wptr == 0)     { return 0 - 1; }

    var nbytes = GPU_MM_DIM * GPU_MM_DIM * 8;   # 512 (64 f64)
    if (is_user_range(a_uva, nbytes) == 0) { return 0 - 4; }
    if (is_user_range(b_uva, nbytes) == 0) { return 0 - 4; }
    if (is_user_range(c_uva, nbytes) == 0) { return 0 - 4; }
    var cr3 = proc_get_cr3(proc_current_get());

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var a_phys      = gpu_arena_phys + GPU_MMF_A_SUBOFF;
    var a_mc        = gpu_arena_mc   + GPU_MMF_A_SUBOFF;
    var b_phys      = gpu_arena_phys + GPU_MMF_B_SUBOFF;
    var b_mc        = gpu_arena_mc   + GPU_MMF_B_SUBOFF;
    var c_phys      = gpu_arena_phys + GPU_MMF_C_SUBOFF;
    var c_mc        = gpu_arena_mc   + GPU_MMF_C_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    if (proc_copy_from_user(cr3, a_phys, a_uva, nbytes) == 0) { return 0 - 5; }
    if (proc_copy_from_user(cr3, b_phys, b_uva, nbytes) == 0) { return 0 - 5; }
    var n = GPU_MM_DIM * GPU_MM_DIM;
    var s = 0;
    while (s < n) { store64(c_phys + (s << 3), 0); s = s + 1; }

    gpu_matmul_write_shader_f64(shader_phys);
    gpu_mfence();

    var ok = gpu_matmul_run(shader_mc, a_mc, b_mc, c_mc, done_mc, done_phys, GPU_COMPUTE_PGM_RSRC1_F64);
    var fault = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_STATUS);
    if (fault != 0) { return 0 - 3; }
    if (ok != 1)    { return 0 - 2; }

    # Fault-proof the write-back (present+user check into a_phys, now free), then store.
    if (proc_copy_from_user(cr3, a_phys, c_uva, nbytes) == 0) { return 0 - 5; }
    s = 0;
    while (s < n) {
        store64(c_uva + (s << 3), load64(c_phys + (s << 3)));
        s = s + 1;
    }
    return 0;
}

# === 1.55.x display arc (Thrust P) — P0: read-only DCN 2.1 live-pipe probe ===
# gpu_display_probe — the display-arc opening bite. STRICTLY READ-ONLY (no writes). Walks the OTG/OPTC
# instances to find the GOP-lit pipe, then scans the HUBP instances for the one whose scanout surface
# address equals the kernel's framebuffer (fb_phys, or its MC-aperture image) — that HUBP is by definition
# the pipe driving our console, and it is exactly the surface register P1's page-flip will re-point. Prints
# a plain-kernel line on match. Zero-hang-risk: OTG reads are safe on a lit DCN; the 0xFFFFFFFF guard skips
# gated pipes; a HUBP mismatch simply fails the gate. No-ops if the GPU is absent or the FB isn't GOP-lit.
# DCN registers live at BASE_IDX 2 (GPU_BASE_DCN_2 = 0x34C0), NOT the seg1 0xC0 (DCE_VERSION only).
fn gpu_display_probe() {
    gpu_display_ok = 0;
    if (gpu_present == 0) { return 0; }

    # Framebuffer physical base from the gnoboot/GOP handoff (boot_info + 0x48).
    var bi = load64(&boot_info_ptr);
    if (bi == 0) { return 0; }
    var fb_phys = load64(bi + 0x48);
    if (fb_phys == 0) { return 0; }   # no GOP FB → nothing to match

    # CPU→MC transform for the scanout address. The GOP framebuffer is addressed by the CPU through the
    # GPU's **BAR0 VRAM aperture** — NOT the DRAM carveout's CPU-phys base. So the framebuffer's offset
    # within VRAM is (fb_phys - BAR0), and the HUBP — which holds the GPU/MC-domain address of the same
    # pixels — sees it at fb_base + that offset.
    #
    # IRON 1.55.1 proved this: fb_phys read 0xD0000000 (~3.25 GB = the BAR0 window) while the carveout's
    # CPU-phys base is 0xF70000000 (~62 GB), so subtracting fb_off was the 1.55.0 no-match bug (it produced
    # 0xE560000000). The real pipe-0 surface read 0xF400000000 == fb_base exactly, i.e. the console sits at
    # VRAM offset 0 — which this BAR0-relative transform reproduces.
    var r_base = gpu_reg32(GPU_BASE_GC_0, GPU_R_MC_VM_FB_LOC_BASE) & GPU_FB_LOC_MASK;
    var fb_base = r_base << 24;          # carveout MC base = where VRAM offset 0 lives in the GPU's view
    var bar0 = pci_bar0_64(gpu_pci_idx); # VRAM aperture: the CPU's window onto the same memory
    var expected_mc = 0;
    if (bar0 != 0) {
        if (fb_phys >= bar0) { expected_mc = fb_base + (fb_phys - bar0); }
    }

    # OTG liveness walk (safe on all 4 pipes; corroboration + pipe id). 0xFFFFFFFF = gated → skip.
    var lit_otg = 0 - 1;
    var n = 0;
    while (n < GPU_DCN_PIPES) {
        var ctl = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_CONTROL + n * GPU_DCN_OTG_STRIDE);
        if (ctl != 0xFFFFFFFF) {
            if ((ctl & GPU_OTG_MASTER_EN) != 0) { if (lit_otg < 0) { lit_otg = n; } }
        }
        n = n + 1;
    }

    # HUBP surface scan — the authoritative match: the HUBP whose scanout surface == the framebuffer.
    var pipe = 0 - 1;
    n = 0;
    while (n < GPU_DCN_PIPES) {
        var lo = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR    + n * GPU_DCN_HUBP_STRIDE) & 0xFFFFFFFF;
        var hi = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR_HI + n * GPU_DCN_HUBP_STRIDE) & 0xFFFF;
        var surf = (hi << 32) | lo;
        var blank = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_CNTL + n * GPU_DCN_HUBP_STRIDE) & GPU_HUBP_BLANK_EN;
        if (blank == 0) {
            if (surf == fb_phys) { if (pipe < 0) { pipe = n; } }
            else { if (surf == expected_mc) { if (pipe < 0) { pipe = n; } } }
        }
        n = n + 1;
    }

    if (pipe >= 0) {
        if (lit_otg >= 0) {
            gpu_display_ok = 1;
            gpu_display_pipe = pipe;        # the HUBP whose scanout is our console — P1 re-points THIS one
            gpu_display_surf = expected_mc; # its current (front) surface address, for the P1 restore
            kprint("gpu: display pipe ", 18);
            kprint_num(pipe);
            kprintln(" live (scanout matches framebuffer)", 35);
            # P4 (2026-07-20, regdump-confirmed): report the REAL scanout surface geometry. The firmware scans a
            # small surface (this box: 800x600, pitch 832px) that DCN upscales to the 2560x1440 link; boot_info
            # reports the OUTPUT, so gpu_scanout_matchgeom overrides fb_console to render at THIS. HW-confirmed
            # offsets: viewport 0x5EA (w[15:0], h[31:16]), pitch 0x607 (px), pixfmt 0x5E5. Read-only.
            var d = pipe * GPU_DCN_HUBP_STRIDE;
            var vp  = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_VIEWPORT_DIM + d);
            var vw  = vp & 0xFFFF;
            var vh  = (vp >> 16) & 0xFFFF;
            var ppx = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_PITCH + d) & 0x3FFF;
            var pixfmt = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_CONFIG + d) & 0x7F;
            kprint("gpu: scanout surface ", 21);   kprint_num(vw);
            kprint("x", 1);                          kprint_num(vh);
            kprint(" pitch ", 7);                    kprint_num(ppx);
            kprint("px pixfmt ", 10);                kprint_num(pixfmt);
            kprintln("", 0);
            return 1;
        }
        gpu_display_ok = 0 - 2;
        kprintln("gpu: display surface matched but no OTG lit", 43);
        return 0;
    }
    gpu_display_ok = 0 - 1;
    kprintln("gpu: display pipe surface not matched", 37);
    return 0;
}

# ══ 1.56.x D lane — the two DCN one-register levers ═══════════════════════════════════════════════════
#
# ⚠ THESE ARE WRITES TO THE LIVE CONSOLE PIPE. That is the highest-risk thing in this arc, and the arc has
# already paid for it once: SCANOUT_LINEAR (v3) wrote the WRONG register under the OTG lock and BLACKED the
# box on iron. It is retired to a hard no-op and its flag must never be built again.
#
# Every bite here therefore obeys the same three rules:
#   1. READ AND SAVE FIRST. The value restored is the one the GOP actually left, never a reconstructed
#      "default" — this pipe was initialised by firmware agnos did not write and cannot re-derive.
#   2. DEAD-MAN RESTORE. The restore is UNCONDITIONAL and not gated on the apply having worked, on a
#      readback, or on an ack. There is no operator input during a boot selftest, so anything conditional
#      is a way to leave the console wedged with no keyboard to recover it.
#   3. VERIFY AFTER. Read the register back and compare against the saved value, and confirm OPTC underflow
#      is still 0 — an underflow means the pipe missed its fetch deadline, which is how a "successful"
#      register poke corrupts scanout without blanking it.
#
# Both are anchored on D0, which read every one of these offsets and got 5-of-5 constraints agreeing
# ([[reference_agnos_dcn_hubp_reg_offsets_derived]]: anchor reads, never trust a derived write).

# ⚠⚠ DCN REGISTERS ARE VUPDATE DOUBLE-BUFFERED. A bare write lands in the SHADOW copy; the pipe keeps
# scanning with the previously-latched ACTIVE values until a VUPDATE event swaps them. The readback returns
# the shadow, so a write can look perfectly applied and change nothing on screen — which is exactly what the
# first D-lane burn produced (2026-07-22): D1 read back 0x00E40000 -> 0x00B40000 and D2 swept global alpha
# 255 -> 63, both latched in shadow, and the panel never changed. gpu_regs.cyr:192 already said this; the
# first version of these bites simply did not use the lock the plan's D2 row named explicitly.
#
# The commit sequence, lifted from the (retired) gpu_scanout_clear_tiling_dead and from amdgpu
# optc1_lock/unlock:
#   1. point OTG_GLOBAL_CONTROL0's lock-select at this pipe, take OTG_MASTER_UPDATE_LOCK, poll the ack
#   2. write the target registers (they go to shadow)
#   3. RE-ARM THE SURFACE ADDRESS, HIGH then LOW — the LOW write is the flip trigger, and without it there
#      is no VUPDATE and nothing commits. This is the step the first burn was missing.
#   4. release the lock; the whole change latches atomically at the next VUPDATE
# ⚠ The unlock MUST run on every exit path or the pipe freezes on its last frame. Both polls are bounded.

# gpu_otg_lock — take the master update lock for `pipe`. Bounded; proceeds on timeout exactly as amdgpu's
# REG_WAIT does, because a stuck poll must never wedge boot.
fn gpu_otg_lock(pipe) {
    var o = pipe * GPU_DCN_OTG_STRIDE;
    var gc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_GLOBAL_CONTROL0 + o);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_OTG_GLOBAL_CONTROL0 + o,
    (gc & (0 - 1 - GPU_OTG_LOCK_SEL_MASK)) | ((pipe << 25) & GPU_OTG_LOCK_SEL_MASK));
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_OTG_MASTER_UPDATE_LOCK + o, 0x1);
    # ⚠ WALL-CLOCK bounded, not iteration bounded (1.56.x). 100 000 iterations of a UC MMIO read has an
    # unknowable duration — each one is a round trip to the device — so the old bound was a number of reads,
    # not a length of time, and nothing could say how long the pipe might sit locked. 20 ms is ~1.2 frames
    # at 60 Hz: comfortably longer than any real ack, comfortably shorter than anything a caller could
    # notice. Matters more than it looks, because a lock left held freezes the pipe on its last frame —
    # which looks exactly like a successful hold.
    var t0 = rdtsc();
    var lim = 20 * 1000 * GPU_TSC_PER_US;
    var acked = 0;
    while ((rdtsc() - t0) < lim) {
        if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_MASTER_UPDATE_LOCK + o) & GPU_OTG_UPDATE_LOCK_STATUS) != 0) {
            acked = 1;
            break;
        }
    }
    # ⚠ RETURNS THE ACK, and callers must report it. Burn 2 added this lock and printed NOTHING about it, so
    # "the write was committed under the lock" stayed an ASSUMPTION through a whole wasted iron burn — the
    # poll is bounded and proceeds on timeout, so an unacked lock is indistinguishable from a taken one.
    gpu_otg_lock_acked = acked;
    return acked;
}

# gpu_otg_commit_unlock — re-arm the LIVE surface address to trigger VUPDATE, release the lock, wait a frame.
# ⚠ Re-arms whatever address is CURRENTLY programmed rather than a remembered one: during a boot self-test
# the console owns scanout, but a present may have swapped to a back buffer, and re-arming a stale base
# would flip the display to the wrong buffer as a side effect of a register poke that has nothing to do with
# scanout addressing.
fn gpu_otg_commit_unlock(pipe) {
    var o = pipe * GPU_DCN_OTG_STRIDE;
    var h = pipe * GPU_DCN_HUBP_STRIDE;
    var lo = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR + h)    & 0xFFFFFFFF;
    var hi = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR_HI + h) & 0xFFFF;
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR_HI + h, hi);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR + h, lo);   # LOW is the flip trigger
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_OTG_MASTER_UPDATE_LOCK + o, 0);   # UNLOCK — must always run
    gpu_mfence();
    gpu_display_wait_vblank(pipe);
    return 1;
}

# gpu_dcn_write_committed — the whole lock -> write -> trigger -> unlock cycle for ONE register.
fn gpu_dcn_write_committed(pipe, off, val) {
    gpu_otg_lock(pipe);
    gpu_reg32_write(GPU_BASE_DCN_2, off, val);
    gpu_otg_commit_unlock(pipe);
    return gpu_reg32(GPU_BASE_DCN_2, off) & 0xFFFFFFFF;
}

# gpu_dcn_hold — hold a state for n frames so it is photographable, paced by the display's own clock rather
# than a spin. Bounded per frame, so a stopped pipe cannot wedge the hold.
fn gpu_dcn_hold(frames) {
    var i = 0;
    while (i < frames) {
        if (gpu_display_wait_vblank(gpu_display_pipe) != 1) { return 0; }
        i = i + 1;
    }
    return 1;
}

# gpu_dcn_hold_ms — hold for a WALL-CLOCK duration. Cannot collapse.
#
# ⚠ gpu_dcn_hold above aborts the WHOLE hold the moment one gpu_display_wait_vblank times out, so a hold
# that looks like "4 seconds" in the source can silently become ~50 ms. That is exactly what happened on
# burn 5: the operator could not photograph any phase and had to shoot video to catch the states flashing
# past. A photographable hold must not depend on a bounded poll succeeding 240 times in a row.
# Reports the ACTUAL elapsed time, because a hold that claims 8 s and delivers 0.05 s is worse than no hold.
fn gpu_dcn_hold_ms(ms) {
    var t0 = rdtsc();
    var limit = ms * 1000 * GPU_TSC_PER_US;
    while ((rdtsc() - t0) < limit) { }
    return (rdtsc() - t0) / GPU_TSC_PER_US / 1000;
}

# === 1.56.x D LANE — RETIRED 2026-07-23, code and flag ===================================================
#
# gpu_hubp_crossbar_test / gpu_mpc_galpha_test / gpu_d1_paint_bars lived here as BOOT SELF-TESTS. THE LANE
# IS FINISHED: it cost five iron burns and it produced its answer — D2 closed once the test was made
# maximally loud (alpha to zero against a deliberately-set blue background), and D1 closed with the
# A/B/C/D/E phase burn that put the HUBPRET crossbar and SURFACE_PIXEL_FORMAT in ONE boot instead of one
# hypothesis per flash. There is nothing left to run, so the tests are deleted rather than re-homed.
#
# Three things are worth carrying even though the code is not:
#
#   1. THE HARNESS COST FOUR OF THE FIVE BURNS, not the register work. A hold built on a bounded vblank
#      poll silently collapsed from 4 s to ~50 ms so nothing could be photographed; two burns used a
#      white-on-black console as the stimulus, where every pixel has R == G == B and ANY permutation of the
#      colour crossbar is therefore the IDENTITY, by arithmetic; and one register value was decoded by eye.
#      A test whose oracle is a human looking at the screen cannot live in a boot self-test, because boot
#      cannot ask a human anything. See [[feedback_dlane_five_burns_what_went_wrong]].
#
#   2. THE OFFSETS WERE UNINDEXED. Both tests read and wrote GPU_R_HUBPRET0_CONTROL, GPU_R_MPCC0_* and
#      GPU_R_OPTC0_UNDERFLOW as bare offsets — those constants name INSTANCE 0 — while correctly indexing
#      GPU_R_HUBP_SURF_CONFIG by gpu_display_pipe two lines away. Harmless on a pipe-0 boot, wrong on any
#      other. Any future DCN write must index by gpu_display_pipe (and MPCC by MPC_OUT<pipe>_MUX).
#
#   3. THE COMMIT PRIMITIVES SURVIVE, and are the only thing left of this lane: gpu_otg_lock /
#      gpu_otg_commit_unlock / gpu_dcn_write_committed below. They have NO CALLERS today. They are kept
#      because they encode a fact that cost a burn to learn — a bare write to a DCN register lands in the
#      SHADOW copy and reads back as if it applied, while the pipe keeps scanning the old value; it latches
#      only under the OTG master update lock with a surface-address re-arm to trigger VUPDATE. The DCN
#      plane arc will want them. If they are still callerless when that arc opens, delete them then.

# === 1.55.x display arc — P2: vblank pacing ===
# gpu_display_wait_vblank — THE pacing primitive: block until the pipe crosses a frame boundary. The OTG
# frame counter increments once per vsync, so a change means a full frame was scanned and we are now in (or
# just past) the blank interval. This is what a present loop waits on: after a flip, this returns once the
# hardware has ACTUALLY taken the new surface, so the previous front buffer is free to render into.
# Bounded (~50 ms ≥ 3 frames at 60 Hz) so a stopped pipe can never wedge the boot. 1 = boundary crossed.
fn gpu_display_wait_vblank(pipe) {
    var fc_off = GPU_R_OTG_FRAME_COUNT + pipe * GPU_DCN_OTG_STRIDE;
    var f0 = gpu_reg32(GPU_BASE_DCN_2, fc_off) & GPU_OTG_FRAME_COUNT_MASK;
    var i = 0;
    while (i < 5000) {
        if ((gpu_reg32(GPU_BASE_DCN_2, fc_off) & GPU_OTG_FRAME_COUNT_MASK) != f0) { return 1; }
        gpu_udelay(10);
        i = i + 1;
    }
    return 0;
}

# gpu_display_vblank — P2 proof: the pacing SIGNAL exists and is observable. (1) the frame counter advances
# => the pipe is really scanning and we can see frame boundaries; (2) OTG_STATUS shows BOTH the blank and
# the active phase => we can tell where in the scan we are. Together these are what P1's flip is paced on
# and what the double-buffered blit will pace on. Strictly read-only. Gated on P0 (we know the lit pipe).
fn gpu_display_vblank() {
    gpu_vblank_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_display_pipe < 0) { return 0; }
    var pipe = gpu_display_pipe;

    # 1. Frame boundaries must be observable.
    if (gpu_display_wait_vblank(pipe) != 1) {
        gpu_vblank_ok = 0 - 1;
        kprintln("gpu: display frame counter not advancing", 40);
        return 0;
    }

    # 2. Both scan phases must be observable — poll OTG_STATUS across at least one frame.
    var st_off = GPU_R_OTG_STATUS + pipe * GPU_DCN_OTG_STRIDE;
    var saw_blank  = 0;
    var saw_active = 0;
    var i = 0;
    while (i < 200000) {
        var st = gpu_reg32(GPU_BASE_DCN_2, st_off);
        if ((st & GPU_OTG_V_BLANK)  != 0) { saw_blank  = 1; }
        if ((st & GPU_OTG_V_ACTIVE) != 0) { saw_active = 1; }
        if (saw_blank != 0) { if (saw_active != 0) { i = 200000; } }
        i = i + 1;
    }
    if (saw_blank == 0) {
        gpu_vblank_ok = 0 - 2;
        kprintln("gpu: display blank interval not observed", 40);
        return 0;
    }
    if (saw_active == 0) {
        gpu_vblank_ok = 0 - 3;
        kprintln("gpu: display active phase not observed", 38);
        return 0;
    }
    gpu_vblank_ok = 1;
    kprintln("gpu: display vblank pacing online (frame counter + blank)", 57);
    return 1;
}


# === 1.55.x display arc — blit#39 double-buffering (the payoff: tear-free full-screen apps) ===
# blit#39 is the graphical-TAKEOVER path (doom/fbtest draw full-screen and never interleave with console
# text). Wiring it here makes those apps tear-free with NO app change: the blit renders into a back buffer
# and the present swaps it in during blank. Two consequences worth naming:
#   * OWNERSHIP — while an app presents, the scanout is on ITS buffers, so console text (which still lands
#     in the console's own framebuffer) is not visible. `gpu_display_restore_console` hands the screen back
#     when the owning process exits, so a full-screen app quitting doesn't leave a blank console. A
#     long-running compositor simply keeps the screen, which is correct.
#   * PACING — the present blocks until the pipe takes the surface, so a blit is vsync-paced (≤ refresh).
#     That is the point (tear-free), but it does mean a blit can block up to one frame.
# Falls back to the direct live-FB path whenever the GPU/DCN isn't usable (e.g. QEMU) or P0 never found a
# pipe, so existing behaviour is byte-identical off-iron.

# gpu_blit_arm — lazily stand up the double-buffer: two VRAM buffers with the console FB's exact geometry
# and pitch, WC-mapped and CLEARED. Clearing matters: an app that only paints part of the screen (a
# letterboxed viewport) leaves black in the margins rather than stale pixels from two frames ago.
fn gpu_blit_arm() {
    if (gpu_bb_armed == 1) { return 1; }
    if (gpu_present == 0) { return 0; }
    if (gpu_display_ok != 1) { return 0; }     # no pipe identified (P0) → direct path
    if (gpu_display_pipe < 0) { return 0; }
    if (gpu_display_surf == 0) { return 0; }
    var bi = load64(&boot_info_ptr);
    if (bi == 0) { return 0; }
    var pitch  = load32(bi + 0x50) & 0xFFFFFFFF;
    var height = load32(bi + 0x58) & 0xFFFFFFFF;
    if (pitch == 0) { return 0; }
    if (height == 0) { return 0; }
    var fb_size = pitch * height;
    var span = ((fb_size + 0x1FFFFF) >> 21) << 21;
    # HARD BOUND: both buffers must end before the PSP TMR (GPU_FB_BACK_LIMIT). A quirky/hostile GOP
    # geometry falls back to the direct FB rather than scribbling over the TMR or the compute arena.
    if (GPU_FB_BACK_OFF + span + span > GPU_FB_BACK_LIMIT) { return 0; }
    var r_off  = gpu_reg32(GPU_BASE_GC_0, GPU_R_MC_VM_FB_OFFSET)   & GPU_FB_LOC_MASK;
    var r_base = gpu_reg32(GPU_BASE_GC_0, GPU_R_MC_VM_FB_LOC_BASE) & GPU_FB_LOC_MASK;
    gpu_bb_a_phys = (r_off  << 24) + GPU_FB_BACK_OFF;
    gpu_bb_a_mc   = (r_base << 24) + GPU_FB_BACK_OFF;
    gpu_bb_b_phys = gpu_bb_a_phys + span;
    gpu_bb_b_mc   = gpu_bb_a_mc   + span;
    var p = 0;
    while (p < span) {
        vmm_remap_wc_2mb(gpu_bb_a_phys + p);
        vmm_remap_wc_2mb(gpu_bb_b_phys + p);
        p = p + 0x200000;
    }
    var q = 0;
    while (q < fb_size) { store64(gpu_bb_a_phys + q, 0); store64(gpu_bb_b_phys + q, 0); q = q + 8; }
    gpu_mfence();
    gpu_bb_back   = 0;
    gpu_bb_fbsize = fb_size;                 # remember the fill span for gpu_fill_sys (CP-DMA clear)
    gpu_bb_pitch  = pitch;                   # and the row stride for gpu_blit_shm_sys (CP-DMA rect blit)
    gpu_bb_armed  = 1;
    return 1;
}

# P4 — scanout-residue clear. If the GOP left the console surface TILED (SW_MODE != 0), fb_console's LINEAR
# byte writes get de-swizzled by the HUBP → banded glyphs. The data on the surface IS linear (fb_console wrote
# it); only the HUBP's interpretation is wrong. So clear SW_MODE to 0 (linear) and re-latch by re-pointing the
# surface address (HIGH-then-LOW, the P1 latch idiom) so the HUBP re-reads its tiling config at the next blank.
# Display-safe: cannot hang (same HUBP block agnos already writes for flips); worst case is a mis-drawn screen
# that a reboot clears. Gated for the first iron test — promote to default-on once the residue is confirmed
# gone. Uses the lit pipe found by P0; no-op if the surface is already linear or the pipe was never matched.
# ⚠ REWRITTEN after the first iron attempt FAILED (bands persisted). Two mistakes, both now fixed (registers
# derived + cross-checked vs dcn_2_1_0_offset.h / amdgpu hubp2.c, 2026-07-20):
#   (1) it cleared SW_MODE but NEVER cleared DCC — the GOP left DCSURF_SURFACE_CONTROL.PRIMARY_SURFACE_DCC_EN
#       set, so the HUBP still decompressed fb_console's linear bytes into garbage. agnos had never touched 0x61A.
#   (2) it relied on an ADDRESS FLIP to latch tiling/DCC — but the flip only auto-latches the ADDRESS group;
#       tiling + DCC are VUPDATE double-buffered and latch ONLY under the OTG master update lock (amdgpu
#       programs them inside optc1_lock/unlock, never on a bare flip).
# The fix: lock the OTG, clear DCC + set linear tiling, re-arm the address, unlock, settle. All registers are in
# the always-clocked HUBP/OTG block agnos already touches for flips — no gated-clock hang, no OTG_MASTER_EN /
# HUBP_BLANK write, so the worst case is a torn frame that self-clears or reboots away, never a dead pipe.
# ⚠ The lock MUST be cleared on every exit path or the pipe freezes on its last frame; the status poll is bounded.
fn gpu_scanout_clear_tiling() {
    # ⚠⚠ RETIRED 2026-07-20 — DO NOT RE-ARM. Register-truth (HIGH confidence) proved this whole path is
    # mis-targeted: 0x607 is EARLIEST_INUSE_C (read-only in-use STATUS), NOT DCSURF_SURFACE_PITCH (real =
    # 0x603), and 0x60B is SECONDARY_ADDR_HIGH not primary. Writing 2560→0x607 + the address split, committed
    # atomically under the OTG master update lock, poisoned the surface descriptor → HUBP underflow → BLACK
    # BOX + wedge on iron (burn #3). The banding was never a pitch fault; the replacement path is the
    # address-flip pattern probe (gpu_scanout_pattern_probe) which touches ONLY the P0-verified 0x60A/0x60B.
    # Left as a hard no-op so a stale #ifdef SCANOUT_LINEAR build can never black the box again.
    kprintln("gpu: scanout_clear_tiling RETIRED (0x607 was wrong reg) -- no-op", 64);
    return 0;
}

fn gpu_scanout_clear_tiling_dead() {
    if (gpu_display_ok != 1) { return 0; }

    var h = gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var o = gpu_display_pipe * GPU_DCN_OTG_STRIDE;
    var lock_off = GPU_R_OTG_MASTER_UPDATE_LOCK + o;

    # 1. Point the master update lock at this pipe, then take it. Bounded poll on the ack — proceed on timeout
    #    exactly as amdgpu's REG_WAIT does (a stuck poll must never wedge boot).
    var gc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_GLOBAL_CONTROL0 + o);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_OTG_GLOBAL_CONTROL0 + o,
    (gc & (0 - 1 - GPU_OTG_LOCK_SEL_MASK)) | ((gpu_display_pipe << 25) & GPU_OTG_LOCK_SEL_MASK));
    gpu_reg32_write(GPU_BASE_DCN_2, lock_off, 0x1);
    var spins = 0;
    while (spins < 100000) {
        if ((gpu_reg32(GPU_BASE_DCN_2, lock_off) & GPU_OTG_UPDATE_LOCK_STATUS) != 0) { spins = 100000; }
        else { spins = spins + 1; }
    }

    # 2. Clear DCC (full-write 0 = DCC off + TMZ off) and set a plain linear tiling config (SW_MODE=0, META_LINEAR).
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_SURFACE_CONTROL + h, 0);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_TILING_CONFIG + h, GPU_HUBP_META_LINEAR);

    # 2b. PITCH — the burn-2 lead. The surface is already LINEAR, yet the console still shears, which on a linear
    #     surface means the HUBP scans a DIFFERENT stride than fb_console writes. fb_console lays glyphs out at
    #     fb_pitch() BYTES/row; the HUBP must scan exactly fb_pitch()/4 PIXELS/row over that same memory. Force
    #     the HUBP's DCSURF_SURFACE_PITCH to match the console's actual layout so every row lands where the next
    #     one begins. (No-op if they already agree; if they don't, this is the fix.)
    var want_pitch = fb_pitch() / 4;
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_PITCH + h, want_pitch & 0x3FFF);
    kprint("gpu: scanout pitch -> ", 22); kprint_num(want_pitch); kprintln(" px (= fb stride)", 17);

    # 3. Re-arm the surface address (HIGH then LOW; LOW is the flip trigger) so the new config commits with a
    #    fresh scanout base, then release the lock — the whole change latches atomically at the next VUPDATE.
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR_HI + h, (gpu_display_surf >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_ADDR + h, gpu_display_surf & 0xFFFFFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, lock_off, 0);       # UNLOCK — must always run
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    kprintln("gpu: scanout tiling+dcc cleared to linear (residue fix)", 55);
    return 1;
}

# gpu_scanout_pattern_probe — the SAFE, DECISIVE P4 bisector (replaces the retired pitch-write path). Paints a
# test pattern into an agnos-OWNED linear buffer (gpu_bb_a, full console geometry, cleared) and flips scanout
# to it using ONLY the two P0-verified address registers (0x60A/0x60B) — byte-identical to gpu_blit_present,
# the proven DOOM/blit flip. NO pitch/tiling/DCC write, NO OTG lock, NO VUPDATE latch → it cannot black the
# pipe (worst case a torn frame a reboot clears). Three zones so ONE photo names the fault family:
#   top    1/3 : 64px horizontal R/G/B bars       — gross vertical stride: wrong pitch ⟹ diagonal shear/repeat.
#   middle 1/3 : 2px vertical white/black stripes  — high HORIZONTAL freq (glyph-stroke proxy): a tiling/format
#                fault garbles the fine stripes even when solid bars look clean.
#   bottom 1/3 : 4px checkerboard                  — 2D high freq.
# Crisp everywhere ⟹ HUBP scans an agnos linear buffer perfectly ⟹ banding is surface-content (the redirect is
# the fix, and DOOM/blit#39 ARE band-free on this iron). Sheared/garbled ⟹ a real per-pipe scan-geometry fault
# an address flip can never fix (then fix the VERIFIED 0x603, never 0x607).
fn gpu_scanout_pattern_probe() {
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_display_pipe < 0) { return 0; }
    if (gpu_blit_arm() != 1) { return 0; }
    var pitch = fb_pitch();
    var height = fb_height();
    var stride_u64 = pitch / 8;
    var third = height / 3;
    var two_third = third + third;
    var y = 0;
    while (y < height) {
        var band = 0;
        if (y >= third) { band = 1; }
        if (y >= two_third) { band = 2; }
        var row = gpu_bb_a_phys + y * pitch;
        var xi = 0;
        while (xi < stride_u64) {
            var c = 0;
            if (band == 0) {
                c = 0x00FF0000;                                   # red
                if ((y / 64) % 3 == 1) { c = 0x0000FF00; }        # green
                if ((y / 64) % 3 == 2) { c = 0x000000FF; }        # blue
            }
            if (band == 1) {
                if (xi % 2 == 0) { c = 0x00FFFFFF; }              # 2px white / 2px black vertical stripes
            }
            if (band == 2) {
                if (((xi / 2) + (y / 4)) % 2 == 0) { c = 0x00FFFFFF; }  # 4x4 checker
            }
            store64(row + xi * 8, (c << 32) | c);
            xi = xi + 1;
        }
        y = y + 1;
    }
    gpu_mfence();
    # Flip scanout to the pattern buffer — ONLY the P0-verified address group (identical to gpu_blit_present).
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_bb_a_mc >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_bb_a_mc & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    kprintln("gpu: scanout pattern armed -- read the bars/stripes/checker", 59);
    return 1;
}

# gpu_scanout_matchgeom — THE P4 FIX (2026-07-20, regdump-confirmed). The banding is a SCALE mismatch: the
# firmware scans a small surface (iron: 800x600, pitch 832px) that DCN upscales to the 2560x1440 link, while
# boot_info reports 2560x1440/10240 — so fb_console writes 2560-wide into an 800-wide surface and every row
# smears. Fix: READ the real geometry from the HW viewport (0x5EA) + pitch (0x607) — both offsets confirmed by
# the regdump — override fb_console's geometry to match, and redraw. NO hardware writes (pure reads + a software
# geometry switch + a console clear) → cannot hang, cannot black. fb_console then renders at the surface's true
# 800x600 and the scaler upsizes it → clean (blocky but legible). No-op safe: if the viewport already matches
# boot_info (quiet-boot OFF / native), the override is the same value.
fn gpu_scanout_matchgeom() {
    if (fb_geom_active() == 1) { return 0; }    # already matched (idempotent — the earlier call site won)
    # Runs from TWO sites: an EARLY one in gpu_probe (right after the aperture maps, so the boot log renders at
    # the right geometry from there on) and a LATE fallback after gpu_display_probe. Early call precedes the
    # display probe, so gpu_display_pipe is still -1 → assume pipe 0 (the only lit pipe on this SoC). The
    # plausibility guards below reject a not-yet-valid viewport, so the early call simply no-ops and the late
    # fallback fixes it — never a regression.
    var pipe = gpu_display_pipe;
    if (pipe < 0) { pipe = 0; }
    var p = pipe * GPU_DCN_HUBP_STRIDE;
    var vp = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_VIEWPORT_DIM + p);
    var vw = vp & 0xFFFF;
    var vh = (vp >> 16) & 0xFFFF;
    var ppx = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HUBP_SURF_PITCH + p) & 0x3FFF;
    # Guards: only act on a plausible viewport + pitch (never override to garbage).
    if (vw == 0) { return 0; }
    if (vh == 0) { return 0; }
    if (vw > 4096) { return 0; }
    if (vh > 4096) { return 0; }
    if (ppx < vw) { return 0; }             # pitch must be >= width
    fb_set_geom(vw, vh, ppx * 4);           # bytes/row = pitch-px * 4 (ARGB8888)
    fb_console_clear();                      # redraw at the new geometry (also resets cursor + shadow)
    kprint("gpu: console geometry matched to surface ", 41); kprint_num(vw);
    kprint("x", 1); kprint_num(vh);
    kprint(" pitch ", 7); kprint_num(ppx * 4);
    kprintln(" bytes", 6);
    return 1;
}

# gpu_scanout_regdump — READ-ONLY ground-truth dump (2026-07-20). The derived HUBP offsets kept lying (0x607
# and the register-truth "corrections" 0x603/0x609 all read garbage/0; only 0x60A/0x60B are trustworthy). The
# pattern-probe thirds proved the real surface is SCALED (~800x600 → 2560x1440), so the pitch/viewport live in
# HUBP regs at offsets we don't reliably know. Dump the whole HUBP/HUBPREQ block for the live pipe as
# "rd <offset_dec> <value_dec>" so the values can be matched to the known geometry (2560=0xA00, 1440=0x5A0,
# 800=0x320, 600=0x258, pitch 10240=0x2800 / 3200=0xC80) and the block RE-ANCHORED for real. Pure reads, safe.
fn gpu_scanout_regdump() {
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_display_pipe < 0) { return 0; }
    var p = gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    kprintln("gpu: --- HUBP regdump begin (rd offset value, both decimal) ---", 63);
    var off = 0x5A0;
    while (off <= 0x640) {
        var v = gpu_reg32(GPU_BASE_DCN_2, off + p);
        if (v != 0) {                       # skip zeros to keep the klug ring small; nonzero regs carry the geometry
            kprint("rd ", 3); kprint_num(off); kprint(" ", 1); kprint_num(v); kprintln("", 0);
        }
        off = off + 1;
    }
    kprintln("gpu: --- HUBP regdump end ---", 29);
    return 0;
}

# gpu_sdma_probe — P9.0 READ-ONLY SDMA0 discovery dump (2026-07-20). SDMA is a genuine NEW engine ring: the
# ONLY existing reference is GPU_BASE_SDMA0_0=0x1260 (the IP base), with NO register offsets and NO code. Per
# the hard P4 lesson (never WRITE a derived GPU offset — anchor it read-only first; see
# reference_agnos_dcn_hubp_reg_offsets_derived), this dumps the SDMA0 block to klug so the REAL ring/status/
# ucode offsets can be anchored against known values (a ucode-version word, an idle STATUS bit, RB_CNTL≈0 while
# unconfigured) BEFORE any SDMA write. It also answers the C0-style prerequisite: is SDMA ucode resident? —
# gpu_fw_load_set loads CP/MEC only, NOT SDMA (gpu.cyr:599-614), so it may not be. Read-only; runs after
# gpu_vm_setup brought L2/the fabric up (best chance the SDMA block is clocked). ⚠ Small residual hang risk if
# SDMA's clock domain is gated — a bounded first burn: if it hangs, THAT is the finding (SDMA gated → the next
# bite ungates it before reading), and a reboot recovers. Gated #ifdef SDMA_PROBE (opt-in, off by default).
fn gpu_sdma_probe() {
    if (gpu_present == 0) { return 0; }
    kprintln("gpu: --- SDMA0 regdump begin (sdma offset value, decimal) ---", 61);
    var off = 0x00;
    while (off <= 0x100) {
        var v = gpu_reg32(GPU_BASE_SDMA0_0, off);
        if (v != 0) {                       # skip zeros to keep the klug ring small; nonzero regs carry the state
            kprint("sdma ", 5); kprint_num(off); kprint(" ", 1); kprint_num(v); kprintln("", 0);
        }
        off = off + 1;
    }
    kprintln("gpu: --- SDMA0 regdump end ---", 30);
    return 0;
}

# gpu_sdma_route_doorbell — P9.2c: program the NBIO to ROUTE SDMA0's doorbell byte-range (0x780) to the engine.
# The GOP never uses SDMA so it never set this up (the MEC's analog, CP_MEC_DOORBELL_RANGE, IS set — that's why
# the compute doorbell works). Written to GDC0_BIF_SDMA0_DOORBELL_RANGE via the BIF RSMU indirect port
# (INDEX←target*4, then DATA). ⚠ THE ONE RISKY WRITE OF THE ARC — a wrong NBIO base could hit an unrelated BIF
# register — so PROBE READ-ONLY FIRST and ABORT if the address looks wrong. Bases are header-verified (anchored
# by the working SEG2=0xD20). Interrupts are OFF during GPU bringup, so the INDEX→DATA pair is atomic (no other
# RSMU user). Full recipe adversarially verified vs renoir_ip_offset.h + nbio_v7_2.c + nbio_7_2_0_sh_mask.h.
fn gpu_sdma_route_doorbell() {
    # PROBE (read-only): arm INDEX at the doorbell-range reg, read DATA. Only OFFSET[11:2]/SIZE[20:16] bits may
    # be set on the real register; any foreign bit ⟹ wrong address ⟹ ABORT before the destructive write.
    gpu_reg32_write(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_INDEX, GPU_NBIO_SDMA0_DBR_IDX);
    gpu_reg32(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_INDEX);
    var cur = gpu_reg32(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_DATA) & 0xFFFFFFFF;
    kprint("gpu: sdma doorbell-range cur ", 29); kprint_num(cur); kprintln("", 0);
    if ((cur & GPU_NBIO_DBR_FOREIGN) != 0) {
        kprintln("gpu: sdma doorbell-range addressing SUSPECT -- route NOT written", 64);
        return 0;
    }
    # WRITE the route (RMW preserves foreign bits; = 0x40780 when cur is clean). Re-arm INDEX before DATA.
    var newv = (cur & GPU_NBIO_DBR_FOREIGN) | GPU_NBIO_SDMA0_DBR_VAL;
    gpu_reg32_write(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_INDEX, GPU_NBIO_SDMA0_DBR_IDX);
    gpu_reg32(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_INDEX);
    gpu_reg32_write(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_DATA, newv);
    gpu_reg32(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_DATA);
    # VERIFY (re-read through the indirect port).
    gpu_reg32_write(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_INDEX, GPU_NBIO_SDMA0_DBR_IDX);
    gpu_reg32(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_INDEX);
    var rb = gpu_reg32(GPU_BASE_NBIO_1, GPU_R_NBIO_RSMU_DATA) & 0xFFFFFFFF;
    kprint("gpu: sdma doorbell-range routed ", 32); kprint_num(rb); kprintln("", 0);
    return 1;
}

# gpu_sdma_bringup — P9.1: bring up the SDMA0 GFX ring (the hardware fill/copy engine for 2D). Mirrors the
# proven MEC ring bring-up (gpu_queue_setup): (P9.0.5) PSP-load the SDMA ucode — the F32 is HALTED at boot and
# agnos loads only CP/MEC, so it is NOT resident — then un-halt the F32 and program the GFX ring registers
# (regdump-anchored offsets), and read back the ANSWER registers (HALT→0, STATUS.IDLE). NO packet, NO wptr bump,
# NO doorbell kick — that is P9.2. Configured with RB DISABLED, RB_ENABLE set LAST, so the engine cannot fetch
# during setup. Gated #ifdef SDMA_RING; runs after gpu_vm_setup armed the 2 MB-UC-mapped arena the ring lives in.
fn gpu_sdma_bringup() {
    if (gpu_present == 0) { return 0; }
    if (gpu_psp_ring2 == 0) { return 0; }
    if (gpu_arena_mc == 0) { return 0; }

    # P9.0.5 — PSP-load SDMA0 ucode (same validated path as CP/MEC; needs /fw/sdma.bin on the agnos-fs).
    var fw = gpu_fw_load_one("/fw/sdma.bin", 12, GPU_FW_TYPE_SDMA0, 0);
    if (fw != 1) { kprintln("gpu: SDMA firmware load failed (/fw/sdma.bin)", 45); return 0; }
    kprintln("gpu: SDMA firmware loaded (PSP-validated)", 41);

    var ring_mc      = gpu_arena_mc   + GPU_SDMA_RING_SUBOFF;
    var rptr_mc      = gpu_arena_mc   + GPU_SDMA_RPTR_SUBOFF;
    var rptr_phys    = gpu_arena_phys + GPU_SDMA_RPTR_SUBOFF;
    var wptr_poll_mc = rptr_mc + 0x100;             # a zeroed slot; if the F32 polls it, it reads 0 == rptr (no work)

    # Zero the rptr-report + wptr-poll page (CPU UC) so no poll sees phantom work.
    var z = 0;
    while (z < 512) { store64(rptr_phys + z * 8, 0); z = z + 1; }
    gpu_mfence();

    # Un-halt the F32 (clear HALT bit0 via RMW). RB still disabled → no fetch. Verify it took (answer register).
    var fc = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_F32_CNTL);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_F32_CNTL, fc & (0 - 1 - GPU_SDMA0_HALT));
    if ((gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_F32_CNTL) & GPU_SDMA0_HALT) != 0) {
        kprintln("gpu: SDMA un-halt refused (engine gated?)", 41);
        return 0;
    }

    # Start-sequence steps P9.1 omitted (sdma_v4_0_start): AUTO_CTXSW so the microcode SCHEDULES the GFX queue
    # (un-halt + RB_ENABLE alone don't — the strongest fetch suspect), and zero the semaphore-fail timer. UTC_L1
    # is left OFF on purpose: agnos fetches from FLAT FB-aperture MC addrs with paging disabled (no VMID0 page
    # table), so enabling VA translation here would fault the fetch, not fix it. RMW (answer reg, preserve bits).
    var cl = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_CNTL);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_CNTL, cl | GPU_SDMA0_AUTO_CTXSW);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_SEM_FAIL_TIMER, 0);

    # Program the GFX ring (RB_ENABLE NOT set yet). RB_CNTL = size + rptr-writeback, preserving the reset
    # default (bit18) via RMW — do NOT blind-write.
    var cnt = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_CNTL);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_CNTL, cnt | GPU_SDMA0_RB_SIZE_64K | GPU_SDMA0_RPTR_WB_EN);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_RPTR, 0);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_RPTR_HI, 0);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_WPTR, 0);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_WPTR_HI, 0);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_RPTR_ADDR_HI, (rptr_mc >> 32) & 0xFFFFFFFF); # ⚠ HI at LOWER off
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_RPTR_ADDR_LO, rptr_mc & 0xFFFFFFFC);          # ⚠ LO at HIGHER off
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_WPTR_POLL_ADDR_HI, (wptr_poll_mc >> 32) & 0xFFFFFFFF);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_WPTR_POLL_ADDR_LO, wptr_poll_mc & 0xFFFFFFFC);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_BASE, (ring_mc >> 8) & 0xFFFFFFFF);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_BASE_HI, (ring_mc >> 40) & 0xFFFFFFFF);
    # Release the atomic wptr-commit gate: gfx_resume leaves MINOR_PTR_UPDATE=0 after programming wptr. If PSP/HW
    # left it latched at 1, every wptr update (register OR doorbell) is HELD → rptr stuck at 0 (our exact symptom).
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_MINOR_PTR_UPDATE, 0);
    # DISABLE the doorbell. archaemenid's doorbell aperture does NOT deliver (P9.2f: SDMA GFX_DOORBELL.CAPTURED
    # read 0 after a routed kick; AND the MEC compute doorbell fails identically — agnos submits compute via a
    # direct CP_HQD_PQ_WPTR_LO register write, its own code says "doorbell did NOT advance wptr; a direct
    # CP_HQD_PQ_WPTR_LO write DID"). So submit via the RB_WPTR register (direct MMIO — the one wptr channel proven
    # to work on this box), mirroring the MEC fallback. Doorbell OFF ⟹ the F32 takes its wptr from the RB_WPTR reg.
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_GFX_DOORBELL, 0);
    gpu_mfence();
    # Enable the ring (RB last), then the IB path.
    var cnt2 = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_CNTL);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_CNTL, cnt2 | GPU_SDMA0_RB_ENABLE);
    var ib = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_IB_CNTL);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_IB_CNTL, ib | GPU_SDMA0_IB_ENABLE);
    gpu_mfence();

    # Verdict — ANSWER registers only (HALT must read 0, STATUS.IDLE must read 1); rptr/wptr must still be 0.
    var halt = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_F32_CNTL) & GPU_SDMA0_HALT;
    var idle = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_STATUS_REG) & GPU_SDMA0_IDLE;
    var rp = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_RPTR);
    var wp = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_WPTR);
    var cf = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_CNTL) & 0xFFFFFFFF;
    kprint("gpu: sdma halt ", 15); kprint_num(halt);
    kprint(" idle ", 6);           kprint_num(idle);
    kprint(" rptr ", 6);           kprint_num(rp);
    kprint(" wptr ", 6);           kprint_num(wp);
    kprint(" cntl ", 6);           kprint_num(cf);
    kprintln("", 0);
    if (halt == 0) {
        if (idle == GPU_SDMA0_IDLE) {
            gpu_sdma_ready = 1;
            kprintln("gpu: sdma ring ready (F32 running, idle)", 40);
            return 1;
        }
    }
    kprintln("gpu: sdma ring setup incomplete", 31);
    return 0;
}

# gpu_sdma_copy_test — P9.2: the first SDMA PACKET. Proves the ring FETCHES + EXECUTES + the result is
# CPU-visible — the first hardware 2D on sovereign agnos. Writes ONE COPY_LINEAR (4 KB carveout→carveout) plus a
# FENCE (SDMA_OP_FENCE) into the ring, kicks via the RB_WPTR register (amdgpu non-doorbell path; wptr in BYTES),
# and gates completion on the FENCE SENTINEL going CPU-visible — NOT on rptr (agnos already hit the GPU→DRAM
# GL2-coherence strand on this iron, so an rptr-only gate could false-GREEN with stale dst; the fence is ordered
# after the copy's writes on the same engine, so sentinel-visible ⟹ copy committed, else an honest TIMEOUT).
# Addresses are FLAT FB-aperture MC (gpu_arena_mc + suboff) — VMID0 paging is disabled, same domain the compute
# path proved; no page tables. Gated #ifdef SDMA_COPY; needs the ring up (gpu_sdma_ready from P9.1).
fn gpu_sdma_copy_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_sdma_ready != 1) { kprintln("gpu: sdma copy skipped (ring not ready)", 39); return 0; }

    var src_phys   = gpu_arena_phys + GPU_SDMA_SRC_SUBOFF;
    var dst_phys   = gpu_arena_phys + GPU_SDMA_DST_SUBOFF;
    var fence_phys = gpu_arena_phys + GPU_SDMA_FENCE_SUBOFF;
    var src_mc     = gpu_arena_mc + GPU_SDMA_SRC_SUBOFF;
    var dst_mc     = gpu_arena_mc + GPU_SDMA_DST_SUBOFF;
    var fence_mc   = gpu_arena_mc + GPU_SDMA_FENCE_SUBOFF;
    var ring_phys  = gpu_arena_phys + GPU_SDMA_RING_SUBOFF;
    var seq        = 0x00C0FFEE;                     # bit31-clear so the load32 compare is sign-safe
    var ndw        = 1024;                           # 4096 bytes / 4

    # S0 — seed src (distinct per-dword: j+1, nonzero + bit31-clear), zero dst, clear the fence sentinel.
    var i = 0;
    while (i < ndw) {
        store32(src_phys + i * 4, i + 1);
        store32(dst_phys + i * 4, 0);
        i = i + 1;
    }
    store32(fence_phys, 0);
    gpu_mfence();

    # S1 — build the 11-dword ring packet at ring offset 0 (COPY_LINEAR 7dw + FENCE 4dw). No NOP pad (IB-only).
    store32(ring_phys + 0,  0x00000001);                    # dw0  COPY(1) | LINEAR(0<<8)
    store32(ring_phys + 4,  4095);                          # dw1  count = byte_count-1 (4096-1)
    store32(ring_phys + 8,  0);                             # dw2  params
    store32(ring_phys + 12, src_mc & 0xFFFFFFFF);           # dw3  src lo
    store32(ring_phys + 16, (src_mc >> 32) & 0xFFFFFFFF);   # dw4  src hi
    store32(ring_phys + 20, dst_mc & 0xFFFFFFFF);           # dw5  dst lo
    store32(ring_phys + 24, (dst_mc >> 32) & 0xFFFFFFFF);   # dw6  dst hi
    store32(ring_phys + 28, 0x00000005);                    # dw7  FENCE (SDMA_OP_FENCE=5)
    store32(ring_phys + 32, fence_mc & 0xFFFFFFFF);         # dw8  fence lo (dword-aligned)
    store32(ring_phys + 36, (fence_mc >> 32) & 0xFFFFFFFF); # dw9  fence hi
    store32(ring_phys + 40, seq);                           # dw10 sentinel value
    gpu_mfence();

    # S3 — KICK via the RB_WPTR register (direct MMIO; the doorbell is disabled in bring-up because it doesn't
    #      deliver on this box). wptr in BYTES: 11 dw = 44. This is the exact channel agnos's MEC compute ring uses
    #      (CP_HQD_PQ_WPTR_LO) after its own doorbell failed; AUTO_CTXSW (set in bring-up) lets the F32 schedule
    #      the queue and act on the register wptr.
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_WPTR, 44);
    gpu_reg32_write(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_WPTR_HI, 0);
    gpu_mfence();

    # S4 — bounded poll on the FENCE SENTINEL (coherence-honest completion; never spins unbounded).
    var done  = 0;
    var spins = 0;
    while (spins < 1000000) {
        if ((load32(fence_phys) & 0xFFFFFFFF) == seq) { done = 1; spins = 1000000; }
        else { spins = spins + 1; }
    }
    var rptr = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_RPTR) & 0xFFFFFFFF;
    if (done != 1) {
        # Localize the never-fetched cause: did RB_WPTR take my 44? is RB_ENABLE (RB_CNTL bit0) set? RB_BASE ok?
        var wr = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_WPTR) & 0xFFFFFFFF;
        var cn = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_CNTL) & 0xFFFFFFFF;
        var ba = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_RB_BASE) & 0xFFFFFFFF;
        var ha = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_F32_CNTL) & GPU_SDMA0_HALT;
        # CAPTURED (GFX_DOORBELL b30) is THE localizer: set ⟹ the doorbell reached the engine (route OK, gate is
        # engine-side); clear ⟹ it never arrived (route still wrong). cntl confirms AUTO_CTXSW (b18) actually took.
        var cap = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_GFX_DOORBELL) & GPU_SDMA0_CAPTURED;
        var cnl = gpu_reg32(GPU_BASE_SDMA0_0, GPU_R_SDMA0_CNTL) & 0xFFFFFFFF;
        kprint("gpu: sdma copy TIMEOUT rptr ", 28); kprint_num(rptr);
        kprint(" wptr ", 6);                        kprint_num(wr);
        kprint(" cnt ", 5);                         kprint_num(cn);
        kprint(" base ", 6);                        kprint_num(ba);
        kprint(" halt ", 6);                        kprint_num(ha);
        kprint(" cap ", 5);                         kprint_num(cap);
        kprint(" cntl ", 6);                        kprint_num(cnl);
        kprintln("", 0);
        return 0;
    }

    # S5 — verify dst == src byte-for-byte (the self-validating oracle).
    var ok = 1;
    var j = 0;
    while (j < ndw) {
        if ((load32(dst_phys + j * 4) & 0xFFFFFFFF) != (j + 1)) { ok = 0; j = ndw; }
        else { j = j + 1; }
    }
    kprint("gpu: sdma copy fence fired, rptr ", 33); kprint_num(rptr); kprintln("", 0);
    if (ok == 1) {
        kprintln("gpu: sdma HARDWARE COPY verified (4KB, dst==src)", 48);
        return 1;
    }
    kprintln("gpu: sdma copy MISMATCH (fence fired, bytes wrong)", 50);
    return 0;
}

# gpu_scanout_redirect — THE P4 FIX (2026-07-20). The pattern probe proved an agnos-owned linear buffer scans
# BAND-FREE while the GOP's own console surface bands (surface-specific, not scan-geometry). So: copy the boot
# log painted so far into gpu_bb_a, flip scanout to it (address group ONLY — the P0/blit#39-proven flip, zero
# hang risk), then point fb_console's paint base at gpu_bb_a so ALL further console output lands on the clean,
# agnos-owned, scanned buffer. No pitch/tiling/DCC write, no OTG lock. The console text itself is the oracle:
# legible ⟹ P4 closed. ⚠ FIRST-CUT shares gpu_bb_a (fine at boot, before any app); shipping needs a dedicated
# console slot (gpu_blit_target hands gpu_bb_a/b to full-screen apps) + gpu_display_restore_console re-pointed.
fn gpu_scanout_redirect() {
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_display_pipe < 0) { return 0; }
    if (gpu_display_surf == 0) { return 0; }
    if (gpu_blit_arm() != 1) { return 0; }
    # 1. Seed gpu_bb_a with the console content painted so far (so the redirect doesn't blank the boot log).
    var src = fb_fb_phys();
    var bytes = fb_pitch() * fb_height();
    var q = 0;
    while (q < bytes) { store64(gpu_bb_a_phys + q, load64(src + q)); q = q + 8; }
    gpu_mfence();
    # 2. Flip scanout to the agnos buffer — identical to gpu_blit_present (address group only, cannot hang).
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_bb_a_mc >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_bb_a_mc & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    # 3. Redirect fb_console's paint base — every subsequent glyph lands on the clean scanned buffer.
    fb_set_scanout_base(gpu_bb_a_phys);
    gpu_scanout_pid = 0 - 1;                 # console owns the scanout
    kprintln("gpu: console redirected to agnos scanout buffer (pitch-free P4 fix)", 67);
    return 1;
}

# gpu_blit_target — where a blit should RENDER: the back buffer when double-buffering is available, else
# the caller's direct live-FB base (unchanged legacy path).
fn gpu_blit_target(fb_direct) {
    if (gpu_blit_arm() != 1) { return fb_direct; }
    if (gpu_bb_back == 0) { return gpu_bb_a_phys; }
    return gpu_bb_b_phys;
}

# gpu_blit_present — swap the freshly-rendered back buffer in: flip (HIGH then LOW) → block until the pipe
# takes it at the next blank (tear-free, and vsync-paces the caller) → the other buffer becomes the render
# target. Records the owning pid so exit() can hand the screen back.
fn gpu_blit_present(pid) {
    if (gpu_bb_armed != 1) { return 0; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (tgt >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, tgt & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    if (gpu_bb_back == 0) { gpu_bb_back = 1; } else { gpu_bb_back = 0; }
    gpu_scanout_pid = pid;
    return 1;
}

# gpu_fill_sys — SYSCALL #85 handler: GPU-clear the current blit back-buffer to `color` (xRGB8888) with a
# CP-DMA fill (replacing the CPU store-loop), then userland presents (#84) to show it. Arms the double-buffer
# lazily. Ring-3 names only the color — the kernel targets the back buffer, so no MC address crosses the
# boundary (same discipline as blit #39). The fill is scanout-visible (MC-direct, no ACQUIRE_MEM). Returns 0
# on success, -1 if the GPU/display isn't usable (QEMU, no pipe) or the fill failed.
fn gpu_fill_sys(color) {
    if (gpu_present == 0) { return 0 - 1; }
    if (gpu_blit_arm() != 1) { return 0 - 1; }           # stand up the back buffers (idempotent)
    if (gpu_bb_fbsize == 0) { return 0 - 1; }
    var tgt_mc = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt_mc = gpu_bb_b_mc; }
    if (gpu_cp_dma_fill(tgt_mc, color, gpu_bb_fbsize) != 1) { return 0 - 1; }
    return 0;
}

# gpu_display_restore_console — hand the screen back to the console by re-pointing the scanout at the
# console's own framebuffer. Called when the process owning the scanout exits: without this, a full-screen
# app quitting would leave its last frame on the panel while console text scrolled invisibly into a buffer
# nothing is scanning.
fn gpu_display_restore_console() {
    if (gpu_scanout_pid < 0) { return 0; }     # console already owns it
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_display_pipe < 0) { return 0; }
    if (gpu_display_surf == 0) { return 0; }
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_display_surf >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_display_surf & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    gpu_scanout_pid = 0 - 1;
    gpu_bb_back = 0;
    return 1;
}

# === 1.55.x P3a — display-audio state probe (READ-ONLY) ===
# The 1.53.5 HDA work reaches the codec on the GPU's audio function (04:00.1) and streams a tone, but the
# tone is SILENT because the DISPLAY side of the audio path was never programmed. Before writing a single
# audio register, this probe answers every open question for the cost of a klug dump:
#   1. DP or HDMI? — the PRIMARY discriminator is DCCG OTGn_PIXEL_RATE_CNTL.DP_DTOn_ENABLE (bit4), NOT the
#      "HDMI audio" backlog name. It decides everything: DP uses DTO1 with a CONSTANT module (DPREFCLK/100),
#      HDMI uses DTO0 with the actual pixel clock — which we would otherwise have to reconstruct.
#   2. The pixel clock + DPREFCLK, for free: DP_DTO_PHASE holds the live pixel clock in Hz and DP_DTO_MODULO
#      holds DPREFCLK as VBIOS programmed it. Reading MODULO also MEASURES any spread-spectrum downspread
#      (the nominal 600 MHz is a driver-side constant, not a hardware read), so it settles that question too.
#   3. Which DIG carries the lit stream (DIG_ENABLE + SYMCLK_FE_ON; SOURCE_SELECT alone is a trap — its
#      reset default is also 0), and its DIG_MODE (3 == HDMI).
#   4. Is the Azalia endpoint awake, or in D3? If endpoint reads come back all-ones/zero we need the SMU
#      PME workaround (VBIOSSMC_MSG_UpdatePmeRestore — an SMU mailbox, NOT DMCUB). Detected for free here
#      rather than implemented preemptively.
#   5. Did the GOP already program the audio DTO, and is AFMT audio already enabled (AFMT_STATUS bit4)?
# Strictly read-only apart from the Azalia index/data window select (a read mechanism, not a config write).
# Labeled-hex discovery dump — removed once P3b lands, same disposal as the P0 diagnostic.
fn gpu_audio_probe() {
    if (gpu_present == 0) { return 0; }
    if (gpu_display_ok != 1) { return 0; }      # need the lit pipe (P0)
    var pipe = gpu_display_pipe;

    # --- DCCG (seg1!) — the DP/HDMI discriminator + the clocks, for free ---
    var prc  = gpu_reg32(GPU_BASE_DCN_1, GPU_R_OTG_PIXEL_RATE_CNTL + pipe * GPU_DCN_PIXRATE_STRIDE);
    var pixc = gpu_reg32(GPU_BASE_DCN_1, GPU_R_DP_DTO_PHASE        + pipe * GPU_DCN_PIXRATE_STRIDE);
    var dpref= gpu_reg32(GPU_BASE_DCN_1, GPU_R_DP_DTO_MODULO       + pipe * GPU_DCN_PIXRATE_STRIDE);
    var is_dp = 0;
    if ((prc & GPU_DP_DTO_ENABLE) != 0) { is_dp = 1; }
    kprint("gpu: audio probe rate=", 22); kprint_hex(prc);
    kprint(" pixclk=", 8); kprint_hex(pixc);
    kprint(" dpref=", 7); kprint_hex(dpref); kprintln("", 0);

    var dsrc = gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO_SRC);
    kprint("gpu: audio probe dtosrc=", 24); kprint_hex(dsrc);
    kprint(" dto0=", 6); kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_PHASE));
    kprint("/", 1);     kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_MODULE));
    kprint(" dto1=", 6); kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO1_PHASE));
    kprint("/", 1);     kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO1_MODULE));
    kprintln("", 0);

    # --- DIG walk (seg2): find the LIVE stream encoder. SOURCE_SELECT alone is a trap (reset default 0),
    #     so gate on DIG_ENABLE && SYMCLK_FE_ON.
    var live_dig = 0 - 1;
    var d = 0;
    while (d < GPU_DCN_DIGS) {
        var fe = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL    + d * GPU_DCN_DIG_STRIDE);
        var be = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d * GPU_DCN_DIG_STRIDE);
        var bc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL    + d * GPU_DCN_DIG_STRIDE);
        var dv = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DP_VID_STREAM_CNTL + d * GPU_DCN_DIG_STRIDE);
        var af = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_STATUS    + d * GPU_DCN_DIG_STRIDE);
        kprint("gpu: audio probe dig", 20); kprint_num(d);
        kprint(" fe=", 4); kprint_hex(fe);
        kprint(" be=", 4); kprint_hex(be);
        kprint(" mode=", 6); kprint_hex((bc >> 16) & 0x7);
        kprint(" dpvid=", 7); kprint_hex(dv);
        kprint(" afmt=", 6); kprint_hex(af);
        kprintln("", 0);
        if ((be & GPU_DIG_ENABLE) != 0) {
            if ((fe & GPU_DIG_SYMCLK_FE_ON) != 0) { if (live_dig < 0) { live_dig = d; } }
        }
        d = d + 1;
    }

    # --- Azalia endpoints 0..3 (ONLY 0..3 exist on Renoir). DISCRIMINATOR ---
    # 1.55.8 read hpc=0 on all four, which is EITHER (a) the AZ block is in D3 (writes dropped, reads 0 =>
    # needs the SMU PME wake, VBIOSSMC_MSG_UpdatePmeRestore) OR (b) our F0 index-window offsets/ordinals are
    # wrong. Implementing an SMU mailbox to fix a typo would be an expensive mistake, so distinguish first:
    # WRITE the index register, then READ IT BACK.
    #   back == what we wrote  => the window is powered + reachable  => NOT D3; a zero DATA read means the
    #                             endpoint register really is 0, or the ix ordinal is wrong.
    #   back == 0 / all-ones   => the write was dropped => D3 (or a bad offset).
    # Also read two more ordinals: RESPONSE_CONFIGURATION_DEFAULT (a real endpoint's PORT_CONNECTIVITY is not
    # all-zero) and CONVERTER_CONTROL_CHANNEL_STREAM_ID (should echo agnos's HDA stream tag if bound) — if
    # every ordinal reads 0 on a live window, the ordinals are the suspect, not the power state.
    var az_alive = 0;
    var k = 0;
    while (k < GPU_DCN_AZ_ENDPOINTS) {
        var ir = GPU_R_AZ_ENDPOINT_INDEX + k * GPU_DCN_AZ_STRIDE;
        var dr = GPU_R_AZ_ENDPOINT_DATA  + k * GPU_DCN_AZ_STRIDE;
        var pre = gpu_reg32(GPU_BASE_DCN_2, ir);                       # reset state before we touch it
        gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
        var back = gpu_reg32(GPU_BASE_DCN_2, ir);                      # THE discriminator
        var hpc = gpu_reg32(GPU_BASE_DCN_2, dr);
        gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_RESPONSE_CFG_DEF);
        var rcd = gpu_reg32(GPU_BASE_DCN_2, dr);
        gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_CONV_STREAM_ID);
        var csi = gpu_reg32(GPU_BASE_DCN_2, dr);
        kprint("gpu: audio probe az", 19); kprint_num(k);
        kprint(" pre=", 5); kprint_hex(pre);
        kprint(" back=", 6); kprint_hex(back);
        kprint(" hpc=", 5); kprint_hex(hpc);
        kprint(" rcd=", 5); kprint_hex(rcd);
        kprint(" csi=", 5); kprint_hex(csi);
        kprintln("", 0);
        if (back == GPU_AZ_IX_HOT_PLUG_CONTROL) { az_alive = az_alive + 1; }
        k = k + 1;
    }
    if (az_alive == 0) {
        kprintln("gpu: audio endpoint window dead (D3 or wrong offset)", 52);
    }
    if (az_alive != 0) {
        kprint("gpu: audio endpoint window alive on ", 36); kprint_num(az_alive); kprintln(" of 4", 5);
    }

    # --- Verdict: which signal, which DIG ---
    if (live_dig < 0) {
        kprintln("gpu: display audio: no live stream encoder found", 48);
        return 0;
    }
    if (is_dp != 0) {
        gpu_audio_dp = 1;
        gpu_audio_dig = live_dig;
        kprint("gpu: display audio path is DP on dig ", 37); kprint_num(live_dig); kprintln("", 0);
        return 1;
    }
    gpu_audio_dp = 0;
    gpu_audio_dig = live_dig;
    kprint("gpu: display audio path is HDMI on dig ", 39); kprint_num(live_dig); kprintln("", 0);
    return 1;
}

# === 1.55.x P3b prerequisite — pixel-clock discovery ===
# The HDMI audio DTO needs the pixel clock in 100 Hz units, and the DCCG register that would hold it is only
# populated on a DP-driven pipe (this link is HDMI, so it reads 0). Derive it instead:
#     pixel clock = h_total x v_total x refresh
# with the totals read exactly from the OTG and the refresh measured against PIT ch0. The measured value IS
# the answer — nothing is snapped to a "standard" value. That corrects 1.55.10, and the reasoning matters
# because the instinct to snap is strong and wrong:
#
#   * 1.55.10 snapped the REFRESH to a table of standard rates. Iron falsified it. This link is CVT-RB
#     2560x1440, whose refresh is 59.9506 Hz — a LEFTOVER, not a round number: VESA CVT quantises the PIXEL
#     CLOCK to a 0.25 MHz step (241.6992 -> 241.50), and the odd refresh is what falls out. The table's
#     nearest entry was 59.94, a TELEVISION rate, which turned a 7.5 ppm measurement into a 176 ppm answer.
#     The snap did not protect the value; it corrupted it.
#   * Snapping the PIXEL CLOCK to the 0.25 MHz step instead is WORSE, not better. On this very link the
#     WRONG totals decode (raw 2719x1480, no -1) lands 0.08 ppm from a step, while the CORRECT decode lands
#     7.5 ppm from one — the wrong answer fits the grid 75x better. A grid cannot tell correct from
#     plausible, so it would launder a register-decode bug into a confident exact number.
#   * There is no PLL to read either: amdgpu has no PHY-PLL read-back on the HDMI path (its
#     get_pixel_clk_frequency_100hz reads the DP DTO, which is exactly the register that reads 0 here), and
#     a divider computation would return the un-spread CENTRE while the frame-count measurement returns the
#     AVERAGE — and the average is what the audio DTO actually wants.
#
# Accuracy is not the constraint people assume. The DTO module and the ACR CTS are derived from the SAME
# believed pixel clock, so any error is self-consistent: the sink recovers the source's actual rate with no
# drift and no under/overrun, leaving only an absolute pitch offset. Even 1.55.10's 176 ppm was 0.3 cents
# (inaudible; ~5 cents is the JND) and passes IEC 60958-3 Level II's +/-1000 ppm with margin. The snap was
# deleted because it can be CATASTROPHICALLY wrong on a mode that is not in the table, not because its error
# was audible.

# gpu_pixclk_ticks — the measurement primitive: PIT ch0 ticks spanned by exactly `frames` vsync boundaries.
# Both endpoints are detected the same way through the same poll loop, so their detection latency largely
# cancels and only the jitter survives. Interrupts mid-window are irrelevant — they delay the polling, not
# the two clocks being compared — which is why this needs no cli/sti window. Returns 0 if the pipe stalls.
fn gpu_pixclk_ticks(pipe, frames) {
    var fc_off = GPU_R_OTG_FRAME_COUNT + pipe * GPU_DCN_OTG_STRIDE;

    # Open the window ON a frame boundary rather than wherever we happened to arrive.
    var f0 = gpu_reg32(GPU_BASE_DCN_2, fc_off) & GPU_OTG_FRAME_COUNT_MASK;
    var guard = 0;
    while ((gpu_reg32(GPU_BASE_DCN_2, fc_off) & GPU_OTG_FRAME_COUNT_MASK) == f0) {
        guard = guard + 1;
        if (guard >= GPU_PIXCLK_GUARD) { return 0; }
    }

    var pstart = pit_ch0_read();
    var prev   = pstart;
    var wraps  = 0;
    var fprev  = gpu_reg32(GPU_BASE_DCN_2, fc_off) & GPU_OTG_FRAME_COUNT_MASK;
    var seen   = 0;
    guard = 0;
    while (seen < frames) {
        var pc = pit_ch0_read();
        if (pc > prev) { wraps = wraps + 1; }   # ch0 counts DOWN, so a RISE is a reload
        prev = pc;
        var fc = gpu_reg32(GPU_BASE_DCN_2, fc_off) & GPU_OTG_FRAME_COUNT_MASK;
        if (fc != fprev) { fprev = fc; seen = seen + 1; }
        guard = guard + 1;
        if (guard >= GPU_PIXCLK_GUARD) { return 0; }
    }
    # Elapsed = the drop within the current period + one full period per reload. The loop polls every few
    # microseconds against a 10 ms period, so a wrap cannot be missed short of a multi-millisecond stall —
    # and such a stall would land ~3% low, far outside the snap tolerance, so it is refused rather than taken.
    return (pstart - prev) + wraps * GPU_PIT_CH0_DIV;
}

fn gpu_pixclk_discover() {
    gpu_pixclk_100hz = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_display_pipe < 0) { return 0; }
    var pipe = gpu_display_pipe;

    # Refuse the two timing modes that break pixel clock = h_total x v_total x refresh, rather than assume
    # a desktop link clears both.
    var il = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_INTERLACE_CONTROL + pipe * GPU_DCN_OTG_STRIDE);
    if ((il & GPU_OTG_INTERLACE_ENABLE) != 0) {
        kprintln("gpu: display timing is interlaced, pixel clock not derived", 58);
        return 0;
    }
    var hd = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_H_TIMING_CNTL + pipe * GPU_DCN_OTG_STRIDE);
    if ((hd & GPU_OTG_H_TIMING_DIV_BY2) != 0) {
        kprintln("gpu: display timing runs at half pixel rate, clock not derived", 62);
        return 0;
    }

    # Both totals hold total-1 (see gpu_regs.cyr). Confirmed on iron three independent ways at 1.55.10 —
    # raw 2719x1480 -> 2720x1481, which is exactly CVT-RB 2560x1440 (hblank 160, vblank 41); the measured
    # refresh matches that decode to 7.5 ppm while a raw decode would be 1036 ppm out; and it is what
    # amdgpu's optc1_program_timing writes. Do NOT revisit it.
    var hraw = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_H_TOTAL + pipe * GPU_DCN_OTG_STRIDE) & GPU_OTG_TOTAL_MASK;
    var vraw = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_V_TOTAL + pipe * GPU_DCN_OTG_STRIDE) & GPU_OTG_TOTAL_MASK;
    var htotal = hraw + 1;
    var vtotal = vraw + 1;
    gpu_h_total = htotal;
    gpu_v_total = vtotal;

    # The LINK's active size — NOT fb_width()/fb_height(). Those describe the GOP's surface, which the DCN
    # pipe scaler may be stretching into a completely different raster: on archaemenid the firmware left an
    # 800x600 surface on a 2560x1440 link, so 1.55.10's `htotal <= fb_width()` guard was comparing a link
    # total against a surface width — the wrong plane of the pipe, and it passed only by luck. The blank
    # registers are the right operand and are convention-free: dcn10_optc.c programs them with NO -1, and
    # asic_blank_end = asic_blank_start - h_addressable, so the difference IS the active size.
    var hbl = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_H_BLANK_START_END + pipe * GPU_DCN_OTG_STRIDE);
    var vbl = gpu_reg32(GPU_BASE_DCN_2, GPU_R_OTG_V_BLANK_START_END + pipe * GPU_DCN_OTG_STRIDE);
    var hact = (hbl & GPU_OTG_BLANK_MASK) - ((hbl >> GPU_OTG_BLANK_END_SHIFT) & GPU_OTG_BLANK_MASK);
    var vact = (vbl & GPU_OTG_BLANK_MASK) - ((vbl >> GPU_OTG_BLANK_END_SHIFT) & GPU_OTG_BLANK_MASK);
    gpu_h_active = hact;

    kprint("gpu: display link ", 18); kprint_num(hact); kprint("x", 1); kprint_num(vact);
    kprint(" total ", 7); kprint_num(htotal); kprint("x", 1); kprint_num(vtotal);
    kprint(" blanking ", 10); kprint_num(htotal - hact); kprint("x", 1); kprint_num(vtotal - vact);
    kprintln("", 0);
    # Geometry must close: a total that does not exceed a positive active size is not a total, and the
    # offsets or the mode are then wrong. This is the check fb_width() could never actually perform.
    if (hact <= 0) {
        kprintln("gpu: display active width not readable, clock not derived", 57);
        return 0;
    }
    if (vact <= 0) {
        kprintln("gpu: display active height not readable, clock not derived", 58);
        return 0;
    }
    if (htotal <= hact) {
        kprintln("gpu: display horizontal total below active, clock not derived", 61);
        return 0;
    }
    if (vtotal <= vact) {
        kprintln("gpu: display vertical total below active, clock not derived", 59);
        return 0;
    }

    # Measure: several short windows, keep the shortest (an SMI can only add time).
    var best = 0;
    var worst = 0;
    var t = 0;
    while (t < GPU_PIXCLK_TRIALS) {
        var tk = gpu_pixclk_ticks(pipe, GPU_PIXCLK_FRAMES);
        if (tk > 0) {
            if (best == 0) { best = tk; worst = tk; }
            if (tk < best) { best = tk; }
            if (tk > worst) { worst = tk; }
        }
        t = t + 1;
    }
    if (best == 0) {
        kprintln("gpu: display refresh not measurable", 35);
        return 0;
    }

    # The windows must AGREE. This replaces 1.55.10's snap-tolerance gate, which was unreachable across
    # [59.94, 60] by construction (candidates ~1000 ppm apart, gate at the 500 ppm half-spacing, so something
    # always "matched"). Disagreement between windows is an axis where a gate can actually fire: it catches a
    # missed PIT wrap (~3%) or a pipe whose rate is moving under us. Iron spread at 1.55.10 was ~17 ppm.
    var spread_ppm = (worst - best) * 1000000 / best;
    # milliHz keeps a fractional rate readable (59.94 Hz = 59940) without leaving integer arithmetic. This is
    # for the log ONLY — the pixel clock below is computed from the raw tick count, never from this rounded
    # value, whose +/-0.5 mHz print quantum is itself ~8 ppm at 60 Hz.
    var refresh = GPU_PIXCLK_FRAMES * GPU_PIT_HZ * 1000 / best;
    kprint("gpu: display refresh ", 21); kprint_num(refresh);
    kprint(" mHz, windows agree within ", 27); kprint_num(spread_ppm); kprintln(" ppm", 4);
    if (spread_ppm > GPU_PIXCLK_SPREAD_PPM) {
        kprintln("gpu: display refresh unstable across windows, clock not derived", 63);
        return 0;
    }

    # THE value: measured, not snapped, and computed straight from the tick count so no rounded intermediate
    # gets between the measurement and the DTO.
    var pixclk = htotal * vtotal * GPU_PIXCLK_FRAMES * GPU_PIT_HZ / best;
    # A plausibility band, deliberately WIDE. Note it does not gate at single-link DVI's 165 MHz ceiling:
    # this link legitimately runs 241.5 MHz while reporting DIG_MODE=2 (DVI signalling on an HDMI wire).
    if (pixclk < GPU_PIXCLK_MIN_HZ) {
        kprintln("gpu: display pixel clock implausibly low, not derived", 53);
        return 0;
    }
    if (pixclk > GPU_PIXCLK_MAX_HZ) {
        kprintln("gpu: display pixel clock implausibly high, not derived", 54);
        return 0;
    }
    gpu_pixclk_100hz = pixclk / 100;

    # Canary: how far the derived clock sits from the nearest VESA 0.25 MHz clock step. DIAGNOSTIC ONLY —
    # NEVER apply it. A grid fit does not mean the value is right: on this very link the WRONG totals decode
    # lands 0.08 ppm from a step while the CORRECT one lands 7.5 ppm from one, so snapping would actively
    # prefer the bug. It is logged because a gross mis-derivation lands thousands of ppm from any step and
    # says so, while a healthy read lands within tens of ppm and corroborates the totals, the PIT and the
    # absence of spread-spectrum on the pixel clock in a single line.
    var grid = (pixclk + GPU_PIXCLK_GRID_HZ / 2) / GPU_PIXCLK_GRID_HZ * GPU_PIXCLK_GRID_HZ;
    var gd = pixclk - grid;
    if (gd < 0) { gd = 0 - gd; }
    kprint("gpu: display pixel clock ", 25); kprint_num(pixclk / 1000);
    kprint(" kHz, ", 6); kprint_num(gd * 1000000 / grid);
    kprint(" ppm from the ", 14); kprint_num(grid / 1000); kprintln(" kHz step", 9);
    return 1;
}

# === 1.55.x P3b-ii pre-flight — is the DVI->HDMI flip safe on THIS link? (READ-ONLY) ===
# Audio cannot be reached without DIG_MODE=3: DVI's TMDS link has no data-island period to carry samples in,
# amdgpu gates the whole AFMT/HDMI path on the signal type, and its DVI attribute setter writes no audio
# register at all. So the flip is not optional and this bite makes it answerable instead of a leap.
#
# The flip itself is one field, and it is inert on its own: with every HDMI_*_SEND bit clear the encoder emits
# no data islands, and a sink infers DVI-vs-HDMI from the PRESENCE of data islands rather than from any
# source-side bit — so the picture is expected to survive unchanged. What can black the console is not the
# mode bit but what the GOP happened to leave in registers DVI mode ignores. Those defaults are unconstrained
# precisely BECAUSE they are inert, and they go live the instant the mode lands. Every one is readable now.
#
# This probe reads them and returns a verdict. It writes nothing.
# Send one VBIOSSMC message to the SMU and wait for its response. Transcribed from
# rn_vbios_smu_send_msg_with_param() (rn_clk_mgr_vbios_smu.c) — the order is the protocol:
#   1. wait until the response register is not BUSY (a prior message may still be in flight)
#   2. clear the response register to BUSY, so we can tell OUR completion from a stale one
#   3. write the parameter
#   4. write the message id LAST — that write is what triggers the transaction
#   5. wait for the response, and read the result back out of the parameter register
# amdgpu polls at 10 us x 200000 (2 s worst case); a shorter bound is fine here because a wedged SMU must
# not be able to hang the boot — this is an audio nicety, not a boot-critical path.
fn gpu_smu_msg(msg, param) {
    var i = 0;
    while (i < GPU_SMU_POLL_MAX) {
        if (gpu_reg32(GPU_BASE_MP1_0, GPU_R_SMU_RESP) != GPU_SMU_BUSY) { break; }
        gpu_udelay(10);
        i = i + 1;
    }
    gpu_reg32_write(GPU_BASE_MP1_0, GPU_R_SMU_RESP, GPU_SMU_BUSY);
    gpu_reg32_write(GPU_BASE_MP1_0, GPU_R_SMU_PARAM, param);
    gpu_reg32_write(GPU_BASE_MP1_0, GPU_R_SMU_MSG, msg);
    i = 0;
    while (i < GPU_SMU_POLL_MAX) {
        var r = gpu_reg32(GPU_BASE_MP1_0, GPU_R_SMU_RESP);
        if (r != GPU_SMU_BUSY) { return r; }
        gpu_udelay(10);
        i = i + 1;
    }
    return GPU_SMU_BUSY;
}

fn gpu_hdmi_preflight() {
    gpu_hdmi_flip_ok = 0;
    if (gpu_present == 0) { return 0; }
    if (gpu_display_ok != 1) { return 0; }
    if (gpu_audio_dp != 0) { return 0; }        # DP link: the HDMI block is not the path
    if (gpu_audio_dig < 0) { return 0; }        # P3a never found a live encoder
    # Derive the DIG offset from the probed instance rather than hard-coding the iron's DIG1: the global IS
    # the single source of truth, and a literal would encode the same fact twice.
    var d = gpu_audio_dig * GPU_DCN_DIG_STRIDE;

    var fe   = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL   + d);
    var ctl  = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_CONTROL  + d);
    var gc   = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC       + d);

    # --- The three black-screen gates. Each is a hard refusal, not a warning. ---
    var bad = 0;
    if ((ctl & GPU_HDMI_CONTROL_RATE_HAZARD) != 0) {
        # Deep colour or scrambling would rescale the TMDS character rate away from the running PLL.
        kprintln("gpu: hdmi flip unsafe: deep colour or scrambling armed", 54);
        bad = 1;
    }
    if ((gc & GPU_HDMI_GC_AVMUTE) != 0) {
        kprintln("gpu: hdmi flip unsafe: AVMUTE armed", 35);
        bad = 1;
    }
    if ((fe & GPU_DIG_FE_FORMAT_HAZARD) != 0) {
        kprintln("gpu: hdmi flip unsafe: pixel format is not 24bpp RGB", 52);
        bad = 1;
    }
    if (bad != 0) { return 0; }
    gpu_hdmi_flip_ok = 1;
    kprintln("gpu: hdmi flip preconditions met", 32);
    return 1;
}

# === 1.55.x P3b-ii + P3b-iii — take the live DVI link to HDMI and open the audio path ===
# This is the write bite: it closes the 1.53.5 backlog where the HDA codec streams samples that nothing
# embeds. gpu_hdmi_preflight() runs INLINE as this function's gate — the hazard reads and the writes belong in
# the same boot, because a read that only reports is a burn spent on something the writer could decide itself.
#
# ORDER IS LOAD-BEARING AND EVERY VIOLATION FAILS SILENTLY (no fault, no log, just no sound):
#   1. Stage the HDMI block while DIG_MODE is still 2 — every HDMI_* register is INERT in DVI mode, so this
#      part is free. Staging first means the flip commits an already-correct context rather than a moment of
#      half-configured HDMI.
#   2. Flip DIG_MODE 2->3 by READ-MODIFY-WRITE. Never a blind write: DIG_FE_SOURCE_SELECT is 7 bits in this
#      same register and zeroing it would unbind the front end from the back end and take the console down
#      for a reason unrelated to HDMI.
#   3. DCCG audio DTO — SOURCE/SEL strictly BEFORE module/phase (hardware-enforced; AMD warns in dce_audio.c).
#      MODULE-before-PHASE is AMD's observed order but NOT a documented constraint: match it, never debug
#      against it as if it were one.
#   4. Azalia: configure (speaker/channel allocation, clock gating) BEFORE enable, per dce110_enable_stream.
#   5. AFMT: the audio CLOCK first (nothing downstream ticks without it), then source/channels, then the tap.
# One AZ indexed ordinal, written and read back. The index window has NO MEMORY: `dr` returns whatever `ir`
# last named, so every access re-selects. 1.55.15 fixed that by hand at four sites after it destroyed its
# own slot-map write; this makes it impossible to get wrong again.
fn gpu_az_write_ord(ir, dr, ordinal, val) {
    gpu_reg32_write(GPU_BASE_DCN_2, ir, ordinal);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, val);
    return 0;
}

fn gpu_hdmi_audio_enable() {
    gpu_hdmi_audio_on = 0;
    if (gpu_hdmi_preflight() != 1) {
        kprintln("gpu: hdmi audio not enabled (preflight refused)", 47);
        return 0;
    }
    if (gpu_pixclk_100hz == 0) {
        # The DTO module IS the pixel clock; without it we would be guessing at the audio wall clock.
        kprintln("gpu: hdmi audio not enabled (no pixel clock)", 44);
        return 0;
    }
    var d    = gpu_audio_dig * GPU_DCN_DIG_STRIDE;
    var pipe = gpu_display_pipe;
    # WHICH Azalia endpoint? THE ONE WHOSE INDEX MATCHES THE ENCODER'S. amdgpu's find_first_free_audio()
    # (dc_resource.c) walks the audio pool and skips every instance whose index is not the stream encoder's
    # engine id ("if (id != i) continue;"), so DIG1 / ENGINE_ID_DIGB takes audio endpoint 1. The pairing is
    # fixed by the hardware's wiring, not discovered by a search.
    #
    # 1.55.8-1.55.13 searched instead — for the endpoint whose CONVERTER_CONTROL_CHANNEL_STREAM_ID echoed a
    # non-zero tag. hda_codec_route() binds EVERY converter to the same tag, so that search could only ever
    # return endpoint 0, and six burns aimed the audio at a pin with nothing plugged into it. Every other
    # register those burns programmed was already byte-correct.
    #
    # Confirmed three independent ways against this iron running amdgpu with sound playing: the live DIG1
    # reads AFMT_AUDIO_SRC_SELECT=1; endpoint 1 is the only one with AUDIO_ENABLED set in HOT_PLUG_CONTROL;
    # and the sink's ELD reports the monitor on codec pin 0x5, the second pin, with the other three pins
    # reading monitor_present=0.
    var az = gpu_audio_dig;
    if (az >= GPU_DCN_AZ_ENDPOINTS) {
        # Renoir carries five DIGs but only four audio endpoints, so a high-numbered encoder has none.
        kprintln("gpu: hdmi audio not enabled (encoder has no audio endpoint)", 59);
        return 0;
    }
    var ir = GPU_R_AZ_ENDPOINT_INDEX + az * GPU_DCN_AZ_STRIDE;
    var dr = GPU_R_AZ_ENDPOINT_DATA  + az * GPU_DCN_AZ_STRIDE;

    # DRAIN-BEFORE-FEED (2026-07-16, THE root cause): stop the HDMI codec DMA NOW so all the encoder-audio
    # setup below runs against a QUIESCED AFMT FIFO. hda_stream_arm set SD_RUN on this stream during the HDA
    # block, so the codec has been free-running PCM into the FIFO for seconds with the read side closed —
    # which is why AFMT_STATUS bit24 is chronically set and the AFMT formatter (CRC tap1) drains NULL cells
    # while tap0 is full. The feed is restarted as the TERMINAL op of this function (hda_hdmi_feed_start),
    # into a freshly-drained FIFO with the read pointer armed — amdgpu's prepare(drain)->trigger(feed) order.
    if (gpu_audio_quiet == 0) { hda_hdmi_feed_stop(); }

    # --- 1. Stage the HDMI block (inert while DIG_MODE==2, so this cannot disturb the console) ---
    var ctl = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_CONTROL + d,
    (ctl & (0 - 1 - GPU_HDMI_CONTROL_KEEP)) | GPU_HDMI_CONTROL_SET);
    var gc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, gc & (0 - 1 - GPU_HDMI_GC_AVMUTE));
    var vbi = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_VBI_PACKET_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_VBI_PACKET_CONTROL + d, vbi | GPU_HDMI_VBI_SET);

    # --- 2. THE COMMIT: DIG_MODE 2 -> 3, read-modify-write ---
    var be = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d,
    (be & (0 - 1 - GPU_DIG_MODE_MASK)) | (GPU_DIG_MODE_HDMI << GPU_DIG_MODE_SHIFT));
    var back = (gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d) & GPU_DIG_MODE_MASK) >> GPU_DIG_MODE_SHIFT;
    if (back != GPU_DIG_MODE_HDMI) {
        kprintln("gpu: hdmi mode did not take", 27);
        return 0;
    }
    kprintln("gpu: display link switched to HDMI signalling", 45);

    # --- 3. DCCG audio DTO (seg1). Source/select FIRST — hardware-enforced. ---
    # DTO_SEL must be 0: 0 selects the DTO0/HDMI path, 1 selects DTO1/DP. A GOP that left it at 1 would give
    # silence with every other register perfect.
    var src = gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO_SRC);
    src = src & (0 - 1 - GPU_DCCG_AUDIO_DTO_SEL_MASK) & (0 - 1 - 0x7);
    gpu_reg32_write(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO_SRC, src | (pipe & 0x7));
    # MODULE = the live pixel clock in 100 Hz units (this is what P3b-i derived); PHASE = a constant 24 MHz.
    # The sample rate NEVER enters either: Fs comes from the HDA converter format, and 128*Fs is derived
    # downstream. An Fs-scaled DTO would be a regression.
    # MODULE: use amdgpu's LITERAL, not our live-derived pixel clock. agnos derives
    # gpu_pixclk_100hz from the OTG and lands 0x24d9b2 where the audibly-playing
    # amdgpu link reads 0x24d998 — about 10.8 ppm off. Almost certainly inaudible on
    # its own, but it is the one remaining unexplained delta in the whole DCN audio
    # register file, and "byte-matched to the working path" is worth more than a
    # derivation we like better. Display-safe: audio DTO only.
    gpu_reg32_write(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_MODULE, 0x24D998);
    gpu_reg32_write(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_PHASE,  GPU_DCCG_AUDIO_DTO_PHASE_VAL);

    # --- 3b. ⚠⚠ MISIDENTIFIED REGISTERS — RETRACTED 2026-07-19. THIS BLOCK IS NOT "SYMCLK".
    # abs 0x159-0x15C are DPPCLK0..3_DTO_PARAM and abs 0x176 is DPPCLK_DTO_CTRL — display-pipe clock DTO
    # parameters, NOT symbol-clock enables. The real SYMCLKA_CLOCK_ENABLE is abs 0x160, and amdgpu writes
    # ZERO SYMCLK registers anywhere in the modeset capture this block claimed to be derived from. So the
    # comment below was wrong twice over: wrong register identity, and wrong about amdgpu doing it at all.
    # The in-boot A/B at 1.55.24 had already falsified the block BEHAVIOURALLY (writes land, sound unchanged);
    # this is the register-identity half of the same retraction. The block is retained only because it is
    # harmless and #ifdef'd off by default — it is NOT a lead and must not be revived.
    # --- superseded comment follows ---
    # DCCG symbol-clock re-prime (HDMI_DCCG) — the host-visible DCCG writes amdgpu makes for HDMI that
    # agnos omitted. GROUND TRUTH: agnosticos/docs/development/prior-art/amdgpu-hdmi-modeset-writes-0717.txt,
    # replug window t=33338.x. SYMCLKA (abs dword 0x159) is DIG1's PHY symbol clock: DIG1 routes to UNIPHYA
    # (phyid=0, A1-confirmed), and amdgpu set 0x159 ACTIVE with its own HDMI on the SAME DIG1 (its AVI infoframe
    # 0x80885e8f landed at abs 0x564d = agnos's DIG1 AFMT_GENERIC_0; its DIG_FE writes hit 0x5628 = DIG1). So
    # the mapping is confirmed, not guessed. These are DCCG writes — host-visible, NO PHY power-cycle — so far
    # safer than the transmitter (which blanks the pipe). This may be the missing symbol clock that carries
    # audio to the sink without the transmitter enable. base_seg 0 => absolute dword index. Single-display box,
    # so SYMCLKB/C/D are already idle (the idle writes are faithful no-ops).
    # ⚠ ATTRIBUTION STATUS (2026-07-19): this block is a CANDIDATE WITH NO SURVIVING EVIDENCE, not a fix.
    # It is now INSTRUMENTED rather than blind — read the five registers BEFORE and AFTER. If the "before"
    # line already shows 000d000d / 000d000a / 00001111, the block never changed anything and the 1.55.24
    # "breakthrough" is closed as a no-op. Reading first also costs nothing: gpu_reg32 is a pure load.
    #ifdef HDMI_DCCG
    gpu_symclk_capture();
    kprintln("gpu: hdmi DCCG symclk BEFORE", 28);
    gpu_symclk_report();
    gpu_symclk_apply();
    kprintln("gpu: hdmi DCCG symclk re-prime (SYMCLKA on)", 43);
    gpu_symclk_report();
    #endif

    # --- 4. Azalia endpoint: configure, then enable ---
    # Un-gate the endpoint clock FIRST — before any other endpoint write. dce_aud_az_configure brackets its
    # whole sequence this way (open at dce_audio.c:685, close at :1013), and the order matters: a register
    # write into a gated clock is dropped SILENTLY. 1.55.12 set this bit after the CHANNEL_SPEAKER write, so
    # that write may never have landed at all.
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    var hpc = gpu_reg32(GPU_BASE_DCN_2, dr);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc | GPU_AZ_CLOCK_GATING_DISABLE);

    # CHANNEL_SPEAKER is not just speaker allocation — it is the SOURCE the hardware builds the Audio
    # InfoFrame from, so HDMI_CONNECTION must say "this pin is HDMI" or the HW has nothing to build. 1.55.12
    # masked only [6:0] and left bit16 at the GOP's DVI-era 0.
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_CHANNEL_SPEAKER);
    var spk = gpu_reg32(GPU_BASE_DCN_2, dr);
    spk = spk & (0 - 1 - GPU_AZ_SPEAKER_ALLOC_MASK) & (0 - 1 - GPU_AZ_DP_CONNECTION)
    & (0 - 1 - GPU_AZ_EXTRA_CONN_INFO_LSB);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, spk | GPU_AZ_SPEAKER_FL_FR | GPU_AZ_HDMI_CONNECTION);

    # Now enable the endpoint, then close the clock-gating bracket (amdgpu re-writes with the bit cleared).
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    var hpc1 = gpu_reg32(GPU_BASE_DCN_2, dr);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc1 | GPU_AZ_AUDIO_ENABLED);

    # THE SLOT MAP — written AFTER AUDIO_ENABLED, and read back, because writing it BEFORE did not stick.
    # Iron, 1.55.14 dump: agnos read AZ_MULTICHANNEL_ENABLE = 0 where amdgpu reads 1, while CHANNEL_SPEAKER
    # (written in the same window, moments earlier) landed fine at 0x10001. So the window works and the
    # ordinal is right — the endpoint clears this register across the AUDIO_ENABLED transition. That matters
    # because MULTICHANNEL01_ENABLE is bit 0: at 0, NO slot pair is enabled, the AFMT has nowhere to drain
    # samples, and the FIFO backs up — which is exactly the AFMT_AUDIO_FIFO_OVERFLOW (bit 24) that the same
    # dump caught set on agnos and clear on amdgpu. Two registers, one bug.
    # Never assume a write stuck: read it back and say so.
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_MULTICHANNEL_ENABLE);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, GPU_AZ_MULTICHANNEL_STEREO);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_MULTICHANNEL_ENABLE);
    if ((gpu_reg32(GPU_BASE_DCN_2, dr) & 0x1) == 0) {
        kprintln("gpu: hdmi endpoint slot map did not take", 40);
    }
    # --- dce_aud_az_configure: THE BLOCK AGNOS NEVER PORTED ------------------------------------------
    # agnos's audio path was hand-derived down to a minimum: HOT_PLUG_CONTROL, a hardcoded CHANNEL_SPEAKER,
    # MULTICHANNEL_ENABLE, stop. amdgpu programs the endpoint from the sink's ELD — descriptors (what the
    # sink accepts), sink info (who it is), lipsync, and the multichannel MODE. Sixteen burns hunted a wrong
    # VALUE in the registers agnos does write, and every one of them is byte-identical to amdgpu. The
    # registers agnos does NOT write were never in the diff at all.
    #
    # The perturbation test that appeared to clear these was ASYMMETRIC: it forced agnos's values onto a
    # path amdgpu had ALREADY configured correctly, where the hardware had latched good state, so a late bad
    # write did nothing. That cannot exonerate a write that never happens. Port them and let the burn judge
    # — the method that carried the whole 1.54.x GPU arc.
    #
    # PANEL-SPECIFIC, DELIBERATELY AND TEMPORARILY: these are amdgpu's measured values for the XB323U
    # (prior-art capture 2026-07-15). The general form is an ELD read, which agnos does not have. If this
    # burn makes sound, the ELD parse is the follow-up and these constants die. If it does not, they cost
    # nothing. Do not ship them past that decision.
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_AUDIO_DESCRIPTOR0, GPU_AZ_AUDIO_DESCRIPTOR0_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_AUDIO_DESCRIPTOR1, 0);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_AUDIO_DESCRIPTOR2, 0);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_RESPONSE_LIPSYNC,  0);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO0, GPU_AZ_SINK_INFO0_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO1, GPU_AZ_SINK_INFO1_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO2, GPU_AZ_SINK_INFO2_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO3, GPU_AZ_SINK_INFO3_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO4, GPU_AZ_SINK_INFO4_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO5, GPU_AZ_SINK_INFO5_VAL);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO6, 0);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO7, 0);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_SINK_INFO8, 0);
    gpu_az_write_ord(ir, dr, GPU_AZ_IX_MULTICHANNEL_MODE, GPU_AZ_MULTICHANNEL_MODE_SINGLE);

    # RE-SELECT THE INDEX. Everything below reads and writes HOT_PLUG_CONTROL, and `dr` is a WINDOW: it
    # returns whatever ordinal `ir` last named. Inserting the slot-map write above without re-selecting left
    # the window on 0x36, so the reads below reported the slot map as "hotplug" (printing a fake
    # `hotplug 0` / `clock OFF`) and the clock-gating write below then stored 0 straight back into the slot
    # map — destroying the very write it was meant to protect. Iron, 1.55.14: `hotplug 0` in the sequence
    # while the end-of-boot dump read the same register as 0x80000011.
    # Any write between an `ir` select and its `dr` use must re-select. This window has no memory.
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    # CLOCK_ON_STATE is a READ-ONLY status, so unlike AUDIO_ENABLED it cannot echo our own write: 1 means the
    # audio wall clock genuinely reached the endpoint.
    var hpc2 = gpu_reg32(GPU_BASE_DCN_2, dr);
    if (gpu_audio_quiet == 0) {
        kprint("gpu: hdmi endpoint clock ", 25);
        if ((hpc2 & GPU_AZ_CLOCK_ON_STATE) != 0) { kprint("on", 2); } else { kprint("OFF", 3); }
        kprint(" (hotplug ", 10); kprint_hex(hpc2); kprintln(")", 1);
    }
    gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc2 & (0 - 1 - GPU_AZ_CLOCK_GATING_DISABLE));

    # THE PME WORKAROUND — wake the Azalia block out of D3. This goes exactly where amdgpu puts it:
    # dce110_enable_audio_stream() calls az_enable() and then, unconditionally (num_audio starts at 1),
    # clk_mgr->funcs->enable_pme_wa() — before enable_audio_packet() opens the tap.
    # It is the ONE function in amdgpu's audio-enable chain agnos never had. 1.55.9 ruled it out because the
    # AZ index window answered reads and writes, but a reachable window is not a woken block: everything
    # configures, the endpoint reports itself enabled and passing, the DMA runs — and nothing drains.
    var smu = gpu_smu_msg(GPU_SMU_MSG_PME_RESTORE, 0);
    if (smu != GPU_SMU_OK) {
        # Not fatal: report and continue. If the block was already awake the message is redundant, and a
        # sulking SMU must not take the audio path down with it.
        kprint("gpu: hdmi azalia wake declined (smu ", 36); kprint_hex(smu); kprintln(")", 1);
    }

    # --- 5. AFMT. The audio CLOCK first: without it the whole block is inert and reports nothing wrong. ---
    # AFMT_AUDIO_CLOCK_ON (bit8) is the hardware's ack, and amdgpu reads 0x101 here — both bits — with sound
    # playing on this iron. But NEVER GATE ON IT. amdgpu polls this bit nowhere: enc1_se_enable_audio_clock
    # carries the REG_WAIT commented out, under "wait for clock_on does not work well ... audio seems work
    # normally even without wait for clock_on status change", and its own expectation was 1-2 reads. We read
    # once, immediately. Report the ack; never let an unreliable status bit abort the eight writes below.
    var ac = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d, ac | GPU_AFMT_AUDIO_CLOCK_EN);
    if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d) & GPU_AFMT_AUDIO_CLOCK_ON) == 0) {
        kprintln("gpu: hdmi audio clock ack did not arrive", 40);
    }

    # HDMI_DB_CONTROL — the LAST unexplained CONTROL-register difference on the 16-bit path. Measured against
    # amdgpu audibly playing on this exact link (dcn-audio-live-amdgpu-known-good, DIG1): amdgpu = 0x00001000,
    # agnos = 0x00010010 — the GOP's DVI-bring-up value, because agnos never wrote this register at all.
    # It governs the HDMI DATA-ISLAND packet buffer, and agnos's AFMT audio FIFO is OVERFLOWING (AFMT_STATUS
    # bit24 SET on agnos, CLEAR on amdgpu even after the ack below): the signature of audio samples that enter
    # the FIFO but never drain into HDMI audio sample packets. A live DIG_MODE flip (what agnos does) never
    # triggers the buffer swap a full modeset would, so a stale GOP data-island buffer config is a coherent
    # cause for "every register reads back correct yet the sink is silent". Write amdgpu's exact value —
    # absolute, not RMW, to also clear the GOP's bit4/bit16 that the working path does not set.
    # HYPOTHESIS, not diagnosis: the mechanism is unproven, but it is safe (a packet-buffer control, not the
    # scanout) and reversible, and it is the one register on the working path agnos has never touched.
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_DB_CONTROL + d, GPU_HDMI_DB_CONTROL_VAL);

    # THE AVI INFOFRAME — generic packet slot 0. This must follow the AFMT clock write above:
    # enc1_update_generic_info_packet opens by turning the audio clock on, under "we need turn on clock
    # before programming AFMT block". The sequence is enc1_update_generic_info_packet followed by
    # enc2_update_hdmi_info_packet case 0, in order. Without this the sink never sees an AVI, never treats
    # the link as HDMI, and ignores every audio data island we send — with all our registers reading back
    # exactly as written.
    var vp = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_VBI_PACKET_CONTROL + d);
    vp = (vp & (0 - 1 - GPU_AFMT_GENERIC_INDEX_MASK)) | GPU_AFMT_GENERIC_CONFLICT_CLR;
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_VBI_PACKET_CONTROL + d, vp);
    # The PAYLOAD. 1.55.14 originally sent an all-zero body with checksum 0x6F, arguing an empty AVI was "a
    # legal minimum". The header was derived correctly (0xD0282 == amdgpu byte-for-byte) and then the body
    # was INVENTED — a self-consistent packet describing nothing. Measured against amdgpu playing sound on
    # this link: GENERIC_0 = 0x80885E8F, GENERIC_2 = 0x05CA, GENERIC_3 = 0x0AA1. It describes the raster.
    #   sb[0] = 0x8F checksum · DB1 = 0x5E · DB2 = 0x88 · DB3 = 0x80
    #   DB1 0x5E: A0=1 (active-format valid), B=3 (BOTH bars valid), S=2 — agnos sent 0x00, declaring no
    #             bar info and no active format, then pointed at bars it never sent.
    #   bottom bar = v_total + 1, right bar = h_total + 1 (1482 / 2721 on this 2720x1481 link) — derived
    #             from the totals gpu_pixclk_discover already reads, NOT hardcoded to one panel.
    # The checksum is computed here for the same reason: a copied constant would silently lie the moment the
    # raster changes. 0x100 - (HB0 + HB1 + HB2 + sum(DB1..DB13)), which reproduces amdgpu's 0x8F exactly on
    # this link (verified arithmetically before this was written).
    var bar_b = gpu_v_total + 1;
    var bar_r = gpu_h_total + 1;
    var g2 = bar_b & 0xFFFF;
    var g3 = bar_r & 0xFFFF;
    var sum = 0x82 + 0x02 + 0x0D + GPU_AVI_DB1 + GPU_AVI_DB2 + GPU_AVI_DB3;
    sum = sum + (g2 & 0xFF) + ((g2 >> 8) & 0xFF) + (g3 & 0xFF) + ((g3 >> 8) & 0xFF);
    var cks = (0x100 - (sum & 0xFF)) & 0xFF;
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_HDR + d, GPU_AVI_HDR);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_0 + d,
    cks | (GPU_AVI_DB1 << 8) | (GPU_AVI_DB2 << 16) | (GPU_AVI_DB3 << 24));
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_1 + d, 0);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_2 + d, g2);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_3 + d, g3);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_4 + d, 0);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_5 + d, 0);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_6 + d, 0);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_7 + d, 0);
    var vp1 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_VBI_PACKET_CONTROL1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_VBI_PACKET_CONTROL1 + d,
    vp1 | GPU_AFMT_GENERIC0_IMMEDIATE_UPDATE);
    # GENERIC0_LINE is in CONTROL1, not CONTROL0 — dcn20 split enc1's fused write because DCN2 moved it.
    var gl = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL1 + d,
    (gl & (0 - 1 - GPU_HDMI_GENERIC0_LINE_MASK)) | GPU_HDMI_GENERIC0_LINE_VAL);
    var gp = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL0 + d,
    gp | GPU_HDMI_GENERIC0_SEND | GPU_HDMI_GENERIC0_CONT);

    # ACR: hardware-measured CTS (SOURCE=0) + AUTO_SEND, but N is a per-Fs constant and must be written.
    var acr = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_PACKET_CONTROL + d);
    acr = acr & (0 - 1 - GPU_HDMI_ACR_SOURCE) & (0 - 1 - GPU_HDMI_ACR_SELECT_MASK);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_PACKET_CONTROL + d, acr | GPU_HDMI_ACR_AUTO_SEND);
    var n48 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_1 + d,
    (n48 & (0 - 1 - GPU_HDMI_ACR_N_48_MASK)) | GPU_HDMI_ACR_N_48_VAL);
    # ACR_SELECT is cleared above, which is hardware rate auto-select: the hardware picks the N/CTS pair from
    # the incoming Fs. tonegen is locked to 48 kHz so the 48 pair is the live one and it is correct — but the
    # 32 and 44.1 pairs are silence the moment anything plays at those rates. amdgpu writes all six. All three
    # N fields share the same [19:0] mask.
    #
    # THE CTS REGISTERS (HDMI_ACR_CTS_48/44/32_0): the ONE real register-value delta in the whole 40-register
    # agnos-vs-amdgpu diff (2026-07-20). agnos left them 0; the amdgpu-playing capture writes 0x3AF5C000 to all
    # three. The old reasoning for leaving them 0 was "inert under HDMI_ACR_SOURCE=0, and our measured 241502
    # would diverge from the known-good 241500" — but that has a hole: amdgpu programs 0x3AF5C000 (241500) WITH
    # SOURCE=0, so (a) the divergence argument dies if we write amdgpu's LITERAL rather than our measurement,
    # and (b) "inert per spec" was never tested on THIS silicon. The CTS/N ratio is exactly what a sink uses to
    # regenerate its audio clock — the precise mechanism between "amp armed + receiving stream" and "decodes as
    # clean silence" (a sink that cannot lock its audio clock outputs silence, not hash). This is the untested
    # register in the exact failure path. Gated so it is a clean single-variable burn.
    #ifdef HDMI_ACR_CTS
    var cts48 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_0 + d,
    (cts48 & 0xFFF) | GPU_HDMI_ACR_CTS_48_VAL);
    var cts44 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_0 + d,
    (cts44 & 0xFFF) | GPU_HDMI_ACR_CTS_48_VAL);
    var cts32 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_0 + d,
    (cts32 & 0xFFF) | GPU_HDMI_ACR_CTS_48_VAL);
    kprintln("gpu: hdmi acr cts programmed (241500, amdgpu-match)", 51);
    #endif
    var n32 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_1 + d,
    (n32 & (0 - 1 - GPU_HDMI_ACR_N_48_MASK)) | GPU_HDMI_ACR_N_32_VAL);
    var n44 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_1 + d,
    (n44 & (0 - 1 - GPU_HDMI_ACR_N_48_MASK)) | GPU_HDMI_ACR_N_44_VAL);

    # HDMI_AUDIO_PACKETS_PER_LINE ([20:16]) — tested and FALSIFIED as a cause (2026-07-16). The DCE-formula
    # ppl=3 was burned on iron (HDMI_AUDIO_PKT_CONTROL 0x30010): still silent. The full amdgpu-while-playing
    # capture then showed the working path runs **ppl = 0** (0x00000010 — the hardware schedules packets
    # itself when the field is 0; the DCE-era explicit budget does not apply to DCN 2.1). Field cleared to
    # match the known-good byte-for-byte; DELAY_EN (bit4) is the only bit the working path sets here.
    var hap = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d,
    (hap & (0 - 1 - GPU_HDMI_AUDIO_DELAY_MASK) & (0 - 1 - 0x1F0000)) | GPU_HDMI_AUDIO_DELAY_SET);

    # Source select binds this DIG's AFMT to the Azalia endpoint; channel-enable is 8 bits and zero of them
    # is silence, so stereo must be spelled out.
    var sc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_SRC_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_SRC_CONTROL + d,
    (sc & (0 - 1 - GPU_AFMT_AUDIO_SRC_SELECT_MASK)) | az);
    # Clearing AUDIO_LAYOUT_OVRD (bit0) and 60958_OSF_OVRD (bit28) alongside the channel enable matches
    # dcn10_stream_encoder.c; known-good reads 0x300, with both overrides at 0. LAYOUT_SELECT, HBR_ENABLE_OVRD
    # and DP_AUDIO_STREAM_ID are deliberately left alone — amdgpu never writes them.
    var pc2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL2 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL2 + d,
    (pc2 & (0 - 1 - GPU_AFMT_CHANNEL_ENABLE_MASK) & (0 - 1 - GPU_AFMT_AUDIO_LAYOUT_OVRD)
    & (0 - 1 - GPU_AFMT_60958_OSF_OVRD)) | GPU_AFMT_CHANNEL_ENABLE_STEREO);

    # IEC 60958 channel status. These MUST be populated before CS_UPDATE latches them: L/R = 0/0 is invalid
    # channel status and a strict sink rejects the substream. 1.55.12 set the latch over untouched registers
    # and therefore latched zeros. (AFMT_60958_2 is at 0x20A7, NOT adjacent to _0/_1 — see gpu_regs.cyr.)
    var cs0 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_60958_0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_60958_0 + d,
    (cs0 & (0 - 1 - GPU_AFMT_CS_CHANNEL_MASK) & (0 - 1 - GPU_AFMT_CS_CLOCK_ACCURACY_MASK))
    | GPU_AFMT_CS_CHANNEL_L);
    var cs1 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_60958_1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_60958_1 + d,
    (cs1 & (0 - 1 - GPU_AFMT_CS_CHANNEL_MASK)) | GPU_AFMT_CS_CHANNEL_R);
    var cs2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_60958_2 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_60958_2 + d,
    (cs2 & (0 - 1 - 0xFFFFFF)) | GPU_AFMT_60958_2_CHANNELS);

    # THE AUDIO INFOFRAME. This is what 1.55.12 missed and it is why the sink stayed silent through a
    # perfect-looking display side: the encoder was sending sample packets and ACR packets with NO Audio
    # InfoFrame, and a conformant sink mutes without one.
    #   * HDMI_AUDIO_INFO_SEND (INFOFRAME_CONTROL0 bit4) is the TRANSMIT ENABLE — the missing write.
    #   * HDMI_AUDIO_INFO_LINE (INFOFRAME_CONTROL1 [13:8]) is the scanline it goes out on; SEND with LINE=0
    #     has no slot to use, so they are a pair.
    #   * AFMT_AUDIO_INFO_UPDATE (AFMT_INFOFRAME_CONTROL0 bit7) is only the UPDATE LATCH. 1.55.12 set the
    #     latch and left the enable clear — one register apart. The content itself is HW-generated from the
    #     endpoint's CHANNEL_SPEAKER (set above), which is why amdgpu never writes AFMT_AUDIO_INFO0/1 at all;
    #     1.55.12's writes there were the wrong lever entirely and are gone.
    var il = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL1 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL1 + d,
    (il & (0 - 1 - GPU_HDMI_AUDIO_INFO_LINE_MASK)) | GPU_HDMI_AUDIO_INFO_LINE_VAL);
    var hif = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d, hif | GPU_HDMI_AUDIO_INFO_SEND);
    var ifc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d, ifc | GPU_AFMT_AUDIO_INFO_UPDATE);

    # THE RAMP ENVELOPE — tested and FALSIFIED (2026-07-16, full known-good capture). The hypothesis: all four
    # AFMT_RAMP_CONTROL regs read 0 on agnos, and a zero output-attenuator would deliver a valid stream of
    # exact silence. The radeon-lineage values (0xFFFFFF/0x7FFFFF/1/1, r600/evergreen) were burned on iron:
    # still silent, AND the shutdown-release pop the previous burn produced DISAPPEARED — the non-zero values
    # made the output measurably worse. The full amdgpu-while-audibly-playing capture then settled it:
    # **amdgpu plays with all four at 0** (dcn-audio-known-good-full-0716.txt, DIG1). Zero IS the working
    # value on DCN 2.1; the radeon-era programming does not transfer. DO NOT write these registers — the
    # dump rows keep reading them for the record.

    # LAST: latch channel status and open the sample tap.
    var apc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d,
    apc | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);

    # The hardware's own Audio InfoFrame, read back. Non-zero here means the AIF generator actually ran on
    # the CHANNEL_SPEAKER we wrote — the one end-to-end check this block gives us for free, and a real answer
    # rather than an echo, since we never write this register and neither does amdgpu.
    if (gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_INFO0 + d) != GPU_AFMT_AUDIO_INFO0_STEREO) {
        kprintln("gpu: hdmi audio infoframe not generated", 39);
    }

    # AFMT_AUDIO_FIFO_OVERFLOW (AFMT_STATUS bit 24) is a STICKY status: it latches on the first overrun and
    # stays set, so a bit read long after setup cannot distinguish "overflowing right now" from "overran once
    # while the path was being built". The 1.55.14 dump caught it SET on agnos and CLEAR on amdgpu. Clear it
    # here, now that the drain path is fully armed, and read it back: if it re-arms after the ack, samples
    # genuinely cannot drain and the FIFO is still backing up; if it stays clear, the earlier read was a
    # setup artifact and the overflow is not the fault. Ack is bit 23 of AFMT_AUDIO_PACKET_CONTROL.
    var ao = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, ao | GPU_AFMT_FIFO_OVERFLOW_ACK);
    if (gpu_audio_quiet == 0) {
        if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_STATUS + d) & GPU_AFMT_FIFO_OVERFLOW) != 0) {
            kprintln("gpu: hdmi audio fifo overflowing", 32);
        }
    }

    gpu_hdmi_audio_on = 1;
    if (gpu_audio_quiet == 0) {
        kprint("gpu: hdmi audio online (endpoint ", 33); kprint_num(az);
        kprint(" on dig ", 8); kprint_num(gpu_audio_dig); kprintln(")", 1);
    }

    # The only unexplained causal difference the known-good capture found. 30 registers compared against
    # amdgpu audibly playing on this silicon: 26 identical, two deliberate/benign, one the overflow symptom
    # — and this bit. amdgpu sets it (enc1_setup_stereo_sync writes !stereo_enable, and stereo is always off
    # here); the GOP left it clear and agnos never touched this register. Matching amdgpu is safe and
    # reversible; the MECHANISM is unproven and this is a hypothesis, not a diagnosis.
    var fec = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL + d, fec | GPU_DIG_STEREOSYNC_GATE_EN);

    # === STAGE 1 — the two DYNAMIC EDGES a live DIG_MODE flip skips (2026-07-16 first-principles plan) ===
    # Every audio register above is BYTE-IDENTICAL to amdgpu audibly playing on this exact panel, and it is
    # still silent — so the fault is NOT a register value. HDMI audio is data-island packets the sink accepts
    # only after two DYNAMIC events that a COLD modeset produces and agnos's LIVE DIG_MODE flip never has:
    #   (1) a DIG_ENABLE output-enable EDGE — the MMIO equivalent of ATOM TransmitterControl(ENABLE,HDMI); a
    #       real TMDS-loss/re-lock the sink treats as a link event and re-arms its audio receiver on.
    #   (2) an AVMUTE SET->CLEAR EDGE in the GCP data island — many sinks unmute only on the transition, not on
    #       a steady-cleared AVMUTE (the vc4_hdmi upstream fix; corroborated by i915's "audio only after the
    #       port is enabled and link-trained" rule and the ADV7511/IT66121 reset-then-release pattern).
    # Sweep profiles 14/15 toggled DIG_ENABLE but the window was MICROSECONDS (no sink link event) and never
    # produced the AVMUTE edge, so islands moved and the sink still ignored them. This does it PROPERLY. All
    # MMIO, no DMUB/ATOM (pre-DMUB DCE did HDMI audio 100% via MMIO — this is the same enc1_se_* class + the
    # output-enable edge). The DIG_ENABLE toggle is iron-proven recoverable (14/15 booted through it). Skipped
    # on a quiet sweep re-apply so the harness does not blink the console 28 times.
    if (gpu_audio_quiet == 0) {
        # SET AVMUTE (the SET half of the edge) and close the sample tap, then take the link DOWN.
        var e_gc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, e_gc | GPU_HDMI_GC_AVMUTE);
        var e_ap = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, e_ap & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        var e_en = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d, e_en & (0 - 1 - GPU_DIG_ENABLE));
        # Hold the link DOWN ~120 ms so the sink registers a real TMDS-loss event (14/15 held only microseconds).
        gpu_udelay(120000);
        # Bring it back UP with HDMI framing latched; poll the back-end symbol clock re-assert.
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d, e_en | GPU_DIG_ENABLE);
        var e_pi = 0;
        while (e_pi < 20000) {
            if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d) & GPU_DIG_SYMCLK_BE_ON) != 0) { break; }
            e_pi = e_pi + 1;
        }
        # Link re-locked, clocks stable, DIG up, SAMPLE_SEND still 0 (FIFO held in reset via
        # AFMT_RESET_FIFO_WHEN_AUDIO_DIS), and the codec FEED is STILL STOPPED (hda_hdmi_feed_stop, top).
        gpu_udelay(20000);
        # Clear the sticky overflow accumulated during setup — the FIFO is empty and the feed is stopped, so
        # this ack finally sticks (bit24 has nothing to re-arm it).
        var e_ov = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, e_ov | GPU_AFMT_FIFO_OVERFLOW_ACK);
        # AVMUTE SET->CLEAR unmute edge.
        var e_gc2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, e_gc2 & (0 - 1 - GPU_HDMI_GC_AVMUTE));
        # ARM THE DRAIN: latch channel status + open the sample tap (SAMPLE_SEND 0->1) on the EMPTY FIFO.
        # The codec FEED stays STOPPED here — it is started LAST, in main.cyr AFTER hda_hdmi_bind_single()
        # runs (bind-single re-issues SET_STREAM_FMT on the converter, which would re-glitch the pointer phase
        # if the feed were already running). So feed-start is the true terminal op of the whole HDMI-audio
        # bring-up: hda_hdmi_feed_start() at main.cyr, after the sink is fully bound.
        var e_re = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, e_re | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
        kprintln("gpu: hdmi audio drain armed on empty FIFO (feed starts after bind)", 66);
    }

    # THE ONE QUESTION EVERY LINE ABOVE BEGS. Everything printed so far is an echo of a write: the endpoint
    # says it is enabled because we enabled it. This asks the hardware something it has to answer for itself.
    # Skipped on a quiet sweep re-apply — the ~120 ms two-tap probe would dominate the harness's cadence.
    if (gpu_audio_quiet == 0) {
        gpu_hdmi_audio_crc_probe(d);
        # HDMI_STATUS is READ-ONLY and cannot echo anything we wrote. Two bits, two answers this arc has only
        # ever inferred: is the packet engine rejecting our audio, and is the sink being told to mute.
        var hs = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_STATUS + d);
        if ((hs & GPU_HDMI_AUDIO_PACKET_ERROR) != 0) {
            kprintln("gpu: hdmi encoder reports an audio packet error", 47);
        }
        if ((hs & GPU_HDMI_ACTIVE_AVMUTE) != 0) {
            kprintln("gpu: hdmi link is muted (AVMUTE active on the wire)", 51);
        }
    }
    return 1;
}

# === HDMI_AUDIO_SWEEP — in-boot fix-profile matrix ==========================================
# The register-value class is exhausted (every DCN register matches amdgpu, still silent, FIFO overflowing),
# so instead of one hypothesis per reflash this cycles a matrix of candidate STRUCTURAL/SEQUENCING/CLOCK
# fixes in a single boot. Each profile re-establishes the 1.55.18 baseline (a quiet gpu_hdmi_audio_enable),
# then applies ONE delta to the live encoder while the HDA tone streams to the HDMI sink, then ACKs the FIFO
# overflow and reads AFMT_STATUS bit24 back — the built-in oracle: bit24 re-arming = still not draining.
# The operator watches this log and LISTENS; the profile whose name is on screen when sound appears is it.
# gpu_hdmi_audio_profile(-1) returns the profile count. All profiles are safe or console-recoverable.
var GPU_HDMI_SWEEP_COUNT = 16;
fn gpu_hdmi_audio_profile(n) {
    if (n < 0) { return GPU_HDMI_SWEEP_COUNT; }
    # 1. Reset to the shipped 1.55.18 baseline, quietly, so each profile is an independent single-variable test.
    gpu_audio_quiet = 1;
    gpu_hdmi_audio_enable();
    gpu_audio_quiet = 0;
    var d  = gpu_audio_dig * GPU_DCN_DIG_STRIDE;
    var az = gpu_audio_dig;
    var ir = GPU_R_AZ_ENDPOINT_INDEX + az * GPU_DCN_AZ_STRIDE;
    var dr = GPU_R_AZ_ENDPOINT_DATA  + az * GPU_DCN_AZ_STRIDE;
    # Cyrius `var` is function-scoped, so scratch registers reused across the mutually-exclusive branches
    # below are declared once here and assigned (not re-declared) per profile.
    var v = 0; var c = 0; var c2 = 0; var r = 0; var h0 = 0; var ic = 0; var ap = 0; var hap = 0;
    var been = 0; var bc = 0; var pi = 0;   # cold-bringup scratch (profiles 14/15)

    kprint("hdmi-sweep: profile ", 20); kprint_num(n); kprint(" = ", 3);

    # 2. Apply the delta for profile n.
    if (n == 0) {
        kprintln("baseline (no delta)", 19);
    } elif (n == 1) {
        # E1 — fire the RESET_FIFO_WHEN_AUDIO_DIS edge amdgpu gets from az_disable->az_enable and agnos never does.
        kprintln("E1 AZ audio-enable off-on", 25);
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
        var hpc = gpu_reg32(GPU_BASE_DCN_2, dr);
        gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc & (0 - 1 - GPU_AZ_AUDIO_ENABLED));
        gpu_udelay(2000);
        gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
        var hpc2 = gpu_reg32(GPU_BASE_DCN_2, dr);
        gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc2 | GPU_AZ_AUDIO_ENABLED);
        gpu_udelay(2000);
        c = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, c | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
    } elif (n == 2) {
        # E3 — re-latch the AFMT audio clock (agnos raised it DURING the live DIG flip; re-latch a clean one).
        kprintln("E3 AFMT audio-clock off-on", 26);
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        c = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d, c & (0 - 1 - GPU_AFMT_AUDIO_CLOCK_EN));
        gpu_udelay(1000);
        c2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d, c2 | GPU_AFMT_AUDIO_CLOCK_EN);
        r = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, r | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
    } elif (n == 3) {
        # E4 — open SAMPLE_SEND strictly LAST, after CS latches and the packet stream settles (agnos fuses them).
        kprintln("E4 sample-send opened last", 26);
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        c = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, c | GPU_AFMT_60958_CS_UPDATE);
        gpu_udelay(2000);
        var s = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, s | GPU_AFMT_AUDIO_SAMPLE_SEND);
    } elif (n == 4) {
        # A — close, reset, re-open the sample tap so the packetizer re-syncs from an empty FIFO.
        kprintln("A relatch AFMT sample tap", 25);
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        gpu_udelay(1000);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
    } elif (n == 5) {
        # A — pulse the AVI + Audio-InfoFrame SEND enables off then on (stale DVI-context latch hypothesis).
        kprintln("A rearm data-island packets", 27);
        var g0 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL0 + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL0 + d, g0 & (0 - 1 - GPU_HDMI_GENERIC0_SEND) & (0 - 1 - GPU_HDMI_GENERIC0_CONT));
        h0 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d, h0 & (0 - 1 - GPU_HDMI_AUDIO_INFO_SEND));
        gpu_udelay(1000);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL0 + d, g0 | GPU_HDMI_GENERIC0_SEND | GPU_HDMI_GENERIC0_CONT);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d, h0 | GPU_HDMI_AUDIO_INFO_SEND);
        ic = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d, ic | GPU_AFMT_AUDIO_INFO_UPDATE);
    } elif (n == 6) {
        # F1 — HW-measured CTS may be stale after the live DVI->HDMI flip; force software CTS = amdgpu's 241500.
        kprintln("F1 software CTS 241500", 22);
        ap = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_PACKET_CONTROL + d, (ap & (0 - 1 - GPU_HDMI_ACR_SELECT_MASK)) | GPU_HDMI_ACR_SOURCE | GPU_HDMI_ACR_AUTO_SEND);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_0 + d, GPU_HDMI_ACR_CTS_48_VAL);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_0 + d, GPU_HDMI_ACR_CTS_48_VAL);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_0 + d, GPU_HDMI_ACR_CTS_48_VAL);
    } elif (n == 7) {
        # F3 — software CTS AND explicit continuous ACR send (bypass AUTO_SEND's modeset-timing dependence).
        kprintln("F3 software CTS + manual send", 29);
        ap = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_PACKET_CONTROL + d, (ap & (0 - 1 - GPU_HDMI_ACR_AUTO_SEND) & (0 - 1 - GPU_HDMI_ACR_SELECT_MASK)) | GPU_HDMI_ACR_SOURCE | GPU_HDMI_ACR_SEND | GPU_HDMI_ACR_CONT);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_0 + d, GPU_HDMI_ACR_CTS_48_VAL);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_0 + d, GPU_HDMI_ACR_CTS_48_VAL);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_0 + d, GPU_HDMI_ACR_CTS_48_VAL);
    } elif (n == 8) {
        # D1 — PACKETS_PER_LINE=0 may mean "schedule zero" not "auto"; force the DCE-computed count (3 here).
        kprintln("D1 packets-per-line explicit", 28);
        hap = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d, (hap & (0 - 1 - GPU_HDMI_AUDIO_DELAY_MASK) & (0 - 1 - 0x1F0000)) | GPU_HDMI_AUDIO_DELAY_SET | 0x30000);
    } elif (n == 9) {
        # D2 — force SEND_MAX_PACKETS so the packetizer packs the line instead of throttling to zero.
        kprintln("D2 send-max-packets", 19);
        hap = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d, (hap & (0 - 1 - GPU_HDMI_AUDIO_DELAY_MASK)) | GPU_HDMI_AUDIO_DELAY_SET | 0x100);
    } elif (n == 10) {
        # D4 — pin stereo layout-0; the packetizer may be auto-deriving 8ch and stalling on channels 3-8.
        kprintln("D4 audio-layout-0 override", 26);
        var pc2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL2 + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL2 + d, (pc2 & (0 - 1 - GPU_AFMT_CHANNEL_ENABLE_MASK) & (0 - 1 - 0x2) & (0 - 1 - GPU_AFMT_60958_OSF_OVRD)) | GPU_AFMT_CHANNEL_ENABLE_STEREO | GPU_AFMT_AUDIO_LAYOUT_OVRD);
    } elif (n == 11) {
        # C — re-latch the audio DTO to source 0 with amdgpu's exact MODULE, then re-cycle the AFMT clock so
        #     the codec feed and the AFMT drain lock to ONE wall clock (the live flip may have stale-locked it).
        kprintln("C DTO source0 + clock relatch", 29);
        gpu_reg32_write(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO_SRC, 0);
        gpu_reg32_write(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_MODULE, 0x24d998);
        gpu_reg32_write(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_PHASE, 0x3a980);
        c = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d, c & (0 - 1 - GPU_AFMT_AUDIO_CLOCK_EN));
        gpu_udelay(1000);
        c2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d, c2 | GPU_AFMT_AUDIO_CLOCK_EN);
        r = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, r | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
    } elif (n == 12) {
        # A — a live-flipped link may drop the one-shot Audio InfoFrame before the sink locks; force CONT.
        kprintln("A audio-infoframe CONT", 22);
        h0 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d, h0 | GPU_HDMI_AUDIO_INFO_SEND | GPU_HDMI_AUDIO_INFO_CONT);
        ic = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d, ic | GPU_AFMT_AUDIO_INFO_UPDATE);
    } elif (n == 13) {
        # A — re-ENTER HDMI mode (3->2->3) to re-run the back-end HDMI packet latch. Brief screen flicker at
        #     the DVI dip is expected (mode 2 is a lit state; the RMW preserves FE_SOURCE_SELECT so it recovers).
        kprintln("A dig-mode bounce 3-2-3", 23);
        var be = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d, (be & (0 - 1 - GPU_DIG_MODE_MASK)) | (GPU_DIG_MODE_DVI << GPU_DIG_MODE_SHIFT));
        gpu_udelay(2000);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d, (be & (0 - 1 - GPU_DIG_MODE_MASK)) | (GPU_DIG_MODE_HDMI << GPU_DIG_MODE_SHIFT));
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
    } elif (n == 14) {
        # RISK — the register-reachable proxy for ATOM TransmitterControl(ENABLE,HDMI): a DIG_ENABLE edge
        #        (1->0->1) with DIG_MODE already 3 — the HDMI-enable edge agnos's live DIG_MODE flip never
        #        produced. DIG_BE_EN_CNTL is the one liveness register agnos has only ever READ, never written.
        #        The picture blanks for the toggle window then restores (DIG_ENABLE re-asserted). The CRC probe
        #        after shows whether audio ISLANDS finally leave the encoder (tap1 non-zero).
        kprintln("RISK cold DIG-enable re-latch", 29);
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        been = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d, been & (0 - 1 - GPU_DIG_ENABLE));
        bc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d, (bc & (0 - 1 - GPU_DIG_MODE_MASK)) | (GPU_DIG_MODE_HDMI << GPU_DIG_MODE_SHIFT));
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d, been | GPU_DIG_ENABLE);
        pi = 0;
        while (pi < 10000) {
            if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d) & GPU_DIG_SYMCLK_BE_ON) != 0) { break; }
            pi = pi + 1;
        }
        r = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, r | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
        gpu_hdmi_audio_crc_probe(d);
    } else {
        # RISK — the ordered cold replica: DIG_ENABLE DOWN, re-stage the FE/HDMI datapath while output is off
        #        (the ATOM EncoderControl SETUP equivalent), THEN raise DIG_ENABLE so the encoder latches HDMI
        #        framing on the rising edge with the FE fully staged — as close to amdgpu's cold bring-up order
        #        as agnos gets without ATOM. Blanks then restores; CRC probe after.
        kprintln("RISK cold FE+BE re-stage", 24);
        v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
        been = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d, been & (0 - 1 - GPU_DIG_ENABLE));
        bc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d, (bc & (0 - 1 - GPU_DIG_MODE_MASK)) | (GPU_DIG_MODE_HDMI << GPU_DIG_MODE_SHIFT));
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_CONTROL + d, GPU_HDMI_CONTROL_SET);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_VBI_PACKET_CONTROL + d, GPU_HDMI_VBI_SET);
        c = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, c & (0 - 1 - GPU_HDMI_GC_AVMUTE));
        c2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL + d, c2 | GPU_DIG_STEREOSYNC_GATE_EN);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_DB_CONTROL + d, GPU_HDMI_DB_CONTROL_VAL);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d, been | GPU_DIG_ENABLE);
        pi = 0;
        while (pi < 10000) {
            if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_EN_CNTL + d) & GPU_DIG_SYMCLK_BE_ON) != 0) { break; }
            pi = pi + 1;
        }
        r = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
        gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, r | GPU_AFMT_60958_CS_UPDATE | GPU_AFMT_AUDIO_SAMPLE_SEND);
        gpu_hdmi_audio_crc_probe(d);
    }

    # 3. The built-in oracle: clear the sticky overflow, let it re-arm (or not), read AFMT_STATUS bit24.
    var oa = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d, oa | GPU_AFMT_FIFO_OVERFLOW_ACK);
    gpu_udelay(150000);
    if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_STATUS + d) & GPU_AFMT_FIFO_OVERFLOW) != 0) {
        kprintln("  drain: STILL OVERFLOWING (bit24 set)", 38);
    } else {
        kprintln("  drain: OK -- bit24 CLEAR (listen now)", 39);
    }
    return 0;
}

# Measure whether audio samples PHYSICALLY traverse this encoder, by checksumming them in hardware.
#
# This exists because twelve burns could not distinguish "the encoder is transmitting our tone and the sink
# ignores it" from "nothing ever reaches the encoder and it is faithfully transmitting silence". Both look
# exactly like the register state agnos already has. The CRC block tells them apart: it counts and
# checksums the samples that actually go through, so DONE is a fact about the hardware rather than about
# our configuration.
#
# HOW TO READ THE RESULT — this is the whole point, so it is spelled out. The one rule that governs all of
# it: this CRC is CONTENT-SENSITIVE but AMPLITUDE-BLIND. It checksums the sample words; any stream that is
# not all-zeros produces a non-zero CRC, at ANY level. So a non-zero CRC proves samples TRAVERSED — it does
# NOT prove the samples are CORRECT, or even audible.
#   "samples reaching the encoder (crc N)"  ⟹ non-zero samples are traversing this tap. That is ALL it
#       proves. It does NOT clear the codec-side data path: a wrong-amplitude or sign-mangled PCM stream
#       reads exactly like a correct one here. This is not hypothetical — 1.55.17's s16->24-bit packing bug
#       (sample parked at container [23:8] instead of [31:8]) made a ~-48 dB, sign-folded, all-positive DC
#       remnant that was DEAD SILENT on the sink yet lit this tap at crc 0x71539c. So on a non-zero CRC,
#       look BOTH ways: UPSTREAM at the PCM the ring actually contains (hda.cyr hda_refill_half /
#       snd_copy_frames — is it the right level and sign?) AND downstream at the link/sink. Do not read
#       "crc N" as "the codec half works".
#   crc N == 0 with DONE set ⟹ samples arrive but they are DIGITAL SILENCE (genuinely all-zero words). The
#       pipe is correct and the PCM is empty — a ring/refill/sink-select bug on the codec side.
#   "crc did not complete" ⟹ either nothing is arriving, OR this counter is inert on this silicon. It is
#       reported as UNCONFIRMED and not as proof of no samples, because amdgpu never reads this register
#       back and so nothing validates the DONE semantics on DCN 2.1. Do not turn a non-answer into a
#       verdict; that is how the last twelve burns were spent.
fn gpu_hdmi_audio_crc_probe(d) {
    # BOTH TAPS. AFMT_AUDIO_CRC_SOURCE is a 1-bit field and no source says whether 0 is the FIFO input or
    # the packetized output — so a single reading cannot tell "samples arrive" from "samples egress", and
    # 1.55.15 over-read exactly that. The control run on amdgpu settled what it could: on an AUDIBLY WORKING
    # path BOTH taps complete, with different CRCs (source 0 = 0x7fe228, source 1 = 0x525ae0), so both are
    # real and distinct. That means the discriminator is HERE, on the broken path:
    #   both complete  ⟹ non-zero samples reach both taps. Because this CRC is amplitude-blind (see the
    #                    HOW-TO-READ block above), this does NOT localize the fault past the encoder — it is
    #                    equally consistent with correct samples that the sink drops AND with garbage-level
    #                    samples that traverse fine (the 1.55.17 packing bug read exactly this way). Rule the
    #                    PCM level/sign UPSTREAM (hda.cyr) in or out before concluding the fault is link/sink.
    #   0 completes, 1 does not ⟹ the fault sits BETWEEN the taps — the bisection is proven, and whichever
    #                             tap 1 is, agnos does not reach it.
    #   neither ⟹ nothing arrives at all and the codec half is back in scope.
    gpu_hdmi_audio_crc_one(d, 0);
    gpu_hdmi_audio_crc_one(d, 1);
    return 1;
}

# gpu_hdmi_avmute_pulse — a fresh GCP AVMUTE SET->CLEAR edge issued WITH the codec feed already running.
#
# WHY THIS EXISTS. gpu_hdmi_audio_enable() clears AVMUTE (its unmute edge) at the END of the enable — but that
# is BEFORE hda_hdmi_bind_single() and BEFORE hda_hdmi_feed_start(), i.e. while the AFMT FIFO is still EMPTY
# and no PCM is moving. amdgpu unmutes in the opposite order: the audio stream is already live (trigger START
# after prepare), THEN the AV path unmutes. Many sinks latch their audio receiver ON the AVMUTE SET->CLEAR
# transition (the vc4_hdmi unmute-edge rule; the ADV7511/IT66121 reset-then-release pattern), and sample the
# stream state at that instant — an unmute edge over an empty FIFO can leave the receiver disarmed even though
# every register reads correct and samples start flowing a beat later. This re-issues the edge as the terminal
# op, from main.cyr AFTER the feed is primed, so the sink sees the transition with real audio in the pipe.
#
# A brief (~one-frame) SET before the CLEAR is a momentary AV-mute — a quick black flash on the HDMI console,
# already visually indistinguishable from the DIG down/up the enable does. Gated on gpu_hdmi_audio_on so it is
# inert unless the HDMI audio path actually came up, and on gpu_audio_quiet so a sweep re-apply does not blink.
fn gpu_hdmi_avmute_pulse() {
    if (gpu_hdmi_audio_on == 0) { return 0; }
    if (gpu_audio_quiet != 0) { return 0; }
    var d = gpu_audio_dig * GPU_DCN_DIG_STRIDE;
    var gc = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, gc | GPU_HDMI_GC_AVMUTE);             # SET (mute)
    gpu_udelay(48000);                                                                       # ~3 frames of samples flow into the muted sink
    var gc2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, gc2 & (0 - 1 - GPU_HDMI_GC_AVMUTE));  # CLEAR (unmute edge, audio present)
    return 0;
}

# One CRC measurement at one tap. Returns 1 if it completed.
fn gpu_hdmi_audio_crc_one(d, source) {
    # Disarm first: the counter is free-running once enabled, and re-arming a live one races its own DONE.
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_CONTROL + d, 0);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_CONTROL + d,
    (GPU_AFMT_AUDIO_CRC_SAMPLES << GPU_AFMT_AUDIO_CRC_COUNT_SHIFT)
    | ((source & 0x1) << GPU_AFMT_AUDIO_CRC_SOURCE_SHIFT) | GPU_AFMT_AUDIO_CRC_EN);

    # 2048 samples at 48 kHz is 42.7 ms, so 60 ms is the honest bound — the old 300 ms was 7x that, and with
    # TWO taps it put up to 600 ms of busy-wait into every burn kernel's boot BEFORE interrupts are enabled.
    # DHCP started failing on exactly the burns that added it (5/5 ACK at 1.55.14 -> 0/3 by 1.55.16); the
    # correlation is not proof, but a diagnostic has no business costing half a second of boot to find out.
    var waited = 0;
    var done = 0;
    while (waited < 60) {
        gpu_udelay(1000);
        waited = waited + 1;
        if ((gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_RESULT + d) & GPU_AFMT_AUDIO_CRC_DONE) != 0) {
            done = 1;
            break;
        }
    }
    var res = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_RESULT + d);
    # Leave the block as we found it — a free-running CRC serves no purpose past this measurement.
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_CONTROL + d, 0);

    if (done == 0) {
        kprint("gpu: hdmi audio tap ", 20); kprint_num(source);
        kprintln(" saw no samples (crc did not complete)", 38);
        return 0;
    }
    var crc = (res >> 8) & 0xFFFFFF;
    if (crc == 0) {
        kprint("gpu: hdmi audio tap ", 20); kprint_num(source);
        kprintln(" saw samples, but they are silence", 34);
        return 1;
    }
    kprint("gpu: hdmi audio tap ", 20); kprint_num(source);
    kprint(" saw samples (crc ", 18); kprint_hex(crc); kprintln(")", 1);
    return 1;
}

# NOTE ON PLACEMENT: these live OUTSIDE #ifdef HDMI_AUDIO_DUMP on purpose. Their consumers are the
# HDMI_DCCG boot path and the HDMI_SYMCLK_AB in-boot A/B, both of which can be built without the dump.
# They were briefly declared inside the dump guard — a narrower #ifdef than the consumer — which built
# clean only because both burn profiles happen to set HDMI_AUDIO_DUMP too, and emitted
# 'undefined function gpu_symclk_capture' with a REACHABLE call site the moment HDMI_DCCG was built
# alone. See [[reference_cyrius_control_flow_idioms]]: a shared decl must never sit behind a narrower
# guard than the code that calls it.
# === Shutdown arc bite 11 — HDMI audio teardown, as a METERED LADDER ========================
#
# TWO JOBS, and the second is why this is gated OFF by default.
#
# (1) It is the anti-pop step. The monitor's amp releases with an audible pop when
#     agnos cuts power with the audio path still live — Linux does not pop because
#     it tears the path down first. Muting and unwinding in order fixes that.
#
# (2) ⚠ IT IS ALSO AN A4 DIAGNOSTIC, and that is worth more than the fix right now.
#     The shutdown pop is currently the arc's ONLY sink-side instrument — the single
#     piece of evidence that the monitor's amp is armed and driven by agnos's stream
#     at all. Every other instrument in this arc is source-side. Shipping a silent
#     unconditional teardown would DESTROY that instrument before A4 closes.
#
# So each rung prints a label and holds ~1 s. THE OPERATOR NOTES WHICH RUNG PRODUCES
# THE POP, and that answers a question 20+ burns could not:
#   - pop at the SD_RUN clear (rung 3)  ⟹ the amp follows sample CONTENT, which
#     FALSIFIES "the payload is digital silence" and moves A4 to level/scale in hda.cyr;
#   - pop only at SAMPLE_SEND (rung 2)  ⟹ the amp follows data-island presence;
#   - pop only at the very end          ⟹ "amp armed by our stream" is overstated.
#
# Answer-registers to read alongside, both content-sensitive rather than echoes:
# AZ_LPIB must FREEZE once SD_RUN clears, and AZ_AUDIO_ENABLE_STATUS must go 1 -> 0.
# ⚠ Do NOT score AFMT_STATUS bit4 — the tree already documents it as "what the
# hardware was TOLD", not what it did.
#
# ⚠ DOES NOT reuse gpu_hdmi_avmute_pulse(): that is an UNMUTE-edge generator which
# clears AVMUTE ~48 ms later, so the amp would be live again exactly when power drops
# and the pop would return. Here AVMUTE is asserted and HELD.
# ⚠ NEVER touches DIG_BE_CNTL / DIG_MODE — the console rides this DIG.
#ifdef BURN_AUDIO_TEARDOWN
fn gpu_hdmi_audio_disable() {
    var d = 0;
    var az = 0;
    var ir = 0;
    var dr = 0;
    var v = 0;
    var hpc = 0;

    if (gpu_present == 0) { return 0; }
    if (gpu_audio_dig < 0) { return 0; }
    d  = gpu_audio_dig * GPU_DCN_DIG_STRIDE;
    az = gpu_audio_dig;
    ir = GPU_R_AZ_ENDPOINT_INDEX + az * GPU_DCN_AZ_STRIDE;
    dr = GPU_R_AZ_ENDPOINT_DATA  + az * GPU_DCN_AZ_STRIDE;

    kprintln("audio teardown: rung 1 assert avmute", 36);
    v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d, v | GPU_HDMI_GC_AVMUTE);
    v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_STATUS + d);
    if ((v & GPU_HDMI_ACTIVE_AVMUTE) != 0) {
        kprintln("audio teardown: sink is being told to mute", 42);
    }
    gpu_udelay(1000000);

    kprintln("audio teardown: rung 2 stop sample send", 39);
    v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d,
    v & (0 - 1 - GPU_AFMT_AUDIO_SAMPLE_SEND));
    gpu_udelay(1000000);

    kprintln("audio teardown: rung 3 stop the codec feed", 42);
    hda_hdmi_feed_stop();
    gpu_udelay(1000000);

    # The endpoint disable MUST be bracketed by clock-gating-disable. A write into a
    # gated clock is dropped SILENTLY — the sweep code elsewhere clears AUDIO_ENABLED
    # without the bracket, so that write may never have landed at all.
    kprintln("audio teardown: rung 4 disable the endpoint", 43);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    hpc = gpu_reg32(GPU_BASE_DCN_2, dr);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc | GPU_AZ_CLOCK_GATING_DISABLE);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    hpc = gpu_reg32(GPU_BASE_DCN_2, dr);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc & (0 - 1 - GPU_AZ_AUDIO_ENABLED));
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    hpc = gpu_reg32(GPU_BASE_DCN_2, dr);
    gpu_reg32_write(GPU_BASE_DCN_2, dr, hpc & (0 - 1 - GPU_AZ_CLOCK_GATING_DISABLE));
    gpu_udelay(1000000);

    kprintln("audio teardown: rung 5 stop the packet generators", 49);
    v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_INFOFRAME_CONTROL0 + d,
    v & (0 - 1 - GPU_HDMI_AUDIO_INFO_SEND));
    gpu_udelay(1000000);

    # LAST. Dropping the audio clock first would gate every preceding write into a
    # dead clock, so this rung has to come after all of them.
    kprintln("audio teardown: rung 6 drop the audio clock", 43);
    v = gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d);
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d, v & (0 - 1 - GPU_AFMT_AUDIO_CLOCK_EN));

    kprintln("audio teardown: done -- which rung made the pop?", 48);
    return 1;
}
#endif

# === Shutdown arc bite 6 — quiesce the GPU compute engines ==================================
#
# THE CONCRETE HAZARD THIS CLOSES: CP_HQD_ACTIVE is written to 1 exactly once, when
# the compute queue is mapped (see the 20-write HQD block above), and is cleared
# NOWHERE else in this tree. A warm reset does not power-cycle the iGPU. So a MEC
# queue with a live doorbell and a PQ base pointing into DRAM survives the reset into
# a next boot that has since reallocated that memory — the GPU keeps fetching packets
# from pages the new kernel is using for something else. That is the worst class of
# corruption available here, because it is invisible until it isn't.
#
# ORDER IS LOAD-BEARING, and it is the mirror of bring-up (RLC -> CP-gfx -> CP-MEC):
# deactivate the QUEUE first, then halt the MEC that would service it, then halt the
# gfx pipe. Halting MEC while its queue is still marked active leaves the engine
# holding a mapped queue it can no longer drain.
#
# DELIBERATELY NOT TOUCHED: the PSP/TMR (there is no un-load path — the firmware
# stays resident by design), the VM L2 cache-enable, the DIG/display block, and the
# scanout. Powering down the display here would black the console before the
# operator can read the final lines, and the display half is a separate bite.
fn gpu_quiesce() {
    var active = 0;
    var mec = 0;
    var me = 0;

    if (gpu_present == 0) { return 0; }

    # 1. Deactivate the compute queue. The HQD registers are behind the GRBM queue
    #    mux, so select MEC1/pipe0/queue0 exactly as the mapping path does, and put
    #    the mux back to 0 afterwards — leaving it selected would misdirect every
    #    later GC register access.
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, GPU_GRBM_SEL_MEC1_P0_Q0);
    active = gpu_reg32(GPU_BASE_GC_0, GPU_R_CP_HQD_ACTIVE);
    if ((active & 0x1) != 0) {
        gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_ACTIVE, 0);
    }
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, 0);

    # 2. Halt MEC1, then the gfx pipe (ME|PFP|CE).
    mec = gpu_reg32(GPU_BASE_GC_0, GPU_R_CP_MEC_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_MEC_CNTL, mec | GPU_CP_MEC_ME1_HALT);
    me = gpu_reg32(GPU_BASE_GC_0, GPU_R_CP_ME_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_ME_CNTL, me | GPU_CP_GFX_HALT_MASK);

    kprintln("gpu: compute engines halted", 27);
    return 1;
}

# === A4 SYMCLK attribution instrument =======================================================
# WHY THIS EXISTS: 1.55.24 wrote five blind absolute stores (0x159/15A/15B/15C/176) and the burn was written
# up as "the DCCG symclk re-prime ARMED THE SINK". The re-audit killed that: the symbol clock reads ALREADY ON
# in every silent burn (`audio probe dig1 fe=1000000 be=101` — both DIG_SYMCLK_*_ON acks SET, byte-identical
# across all eight logs); the shutdown pop predates the write by five burns (first heard at audio_re_5 /
# 1.55.20); the operator reports the noise floor recurred on several burns in the cycle; and NOT ONE dumped
# register differs between the silent burn 8 and the "armed" burn 10. The write had no pre-read, no readback
# and no dump row, so there is no evidence any bit ever changed. These helpers close that hole: capture the
# pre-write values, apply, restore, and report — so the block can be PROVEN a no-op rather than argued about.
var gpu_symclk_s159 = 0;
var gpu_symclk_s15a = 0;
var gpu_symclk_s15b = 0;
var gpu_symclk_s15c = 0;
var gpu_symclk_s176 = 0;
var gpu_symclk_have = 0;

# Snapshot the pre-write state ONCE. Idempotent: a second call is a no-op, so the A/B loop can never
# overwrite the pristine values with its own applied ones.
fn gpu_symclk_capture() {
    if (gpu_symclk_have == 1) { return 0; }
    gpu_symclk_s159 = gpu_reg32(0, 0x159);
    gpu_symclk_s15a = gpu_reg32(0, 0x15A);
    gpu_symclk_s15b = gpu_reg32(0, 0x15B);
    gpu_symclk_s15c = gpu_reg32(0, 0x15C);
    gpu_symclk_s176 = gpu_reg32(0, 0x176);
    gpu_symclk_have = 1;
    return 0;
}

# One line, five live reads. THE decisive readout: if these already equal amdgpu's values BEFORE the write,
# the whole block is a no-op and the attribution collapses with no further burn.
fn gpu_symclk_report() {
    kprint("gpu: symclk 159=", 16); kprint_hex(gpu_reg32(0, 0x159));
    kprint(" 15a=", 5);             kprint_hex(gpu_reg32(0, 0x15A));
    kprint(" 15b=", 5);             kprint_hex(gpu_reg32(0, 0x15B));
    kprint(" 15c=", 5);             kprint_hex(gpu_reg32(0, 0x15C));
    kprint(" 176=", 5);             kprint_hex(gpu_reg32(0, 0x176));
    kprintln("", 0);
    return 0;
}

# The five amdgpu values. Host DCCG only — no PHY power-cycle, so display-safe (burn 10 ran them and finished
# to a shell with a live 2560x1440 scanout).
fn gpu_symclk_apply() {
    gpu_symclk_capture();
    gpu_reg32_write(0, 0x159, 0x000D000D);
    gpu_reg32_write(0, 0x15A, 0x000D000A);
    gpu_reg32_write(0, 0x15B, 0x000D000A);
    gpu_reg32_write(0, 0x15C, 0x000D000A);
    gpu_reg32_write(0, 0x176, 0x00001111);
    return 0;
}

# Put back exactly what the GOP left. Without this the A/B has no "off" window.
fn gpu_symclk_restore() {
    if (gpu_symclk_have == 0) { return 0; }
    gpu_reg32_write(0, 0x159, gpu_symclk_s159);
    gpu_reg32_write(0, 0x15A, gpu_symclk_s15a);
    gpu_reg32_write(0, 0x15B, gpu_symclk_s15b);
    gpu_reg32_write(0, 0x15C, gpu_symclk_s15c);
    gpu_reg32_write(0, 0x176, gpu_symclk_s176);
    return 0;
}

# === ACR N-scale discriminator ==============================================================
# HDMI_ACR_STATUS_0 is the one register in this block that demonstrably MOVES: CTS reads 241502/241503/241504
# across burns (dead DIGs read 0), agnos never writes those values, and ACR_SOURCE=0 means HW-measured. But at
# N=6144 / Fs=48kHz, CTS = f_TMDS*N/(128*Fs) reduces to exactly f_pixel in kHz — so "measured against the
# audio clock" and "just counting pixels" predict the SAME number. Doubling N separates them: if the audio
# clock is genuinely in the measurement loop, CTS doubles. Display-safe — ACR affects only the audio
# clock-regeneration packet, never TMDS timing. N is restored before returning.
fn gpu_hdmi_acr_nscale() {
    if (gpu_present == 0) { return 0; }
    if (gpu_audio_dig < 0) { return 0; }
    var d = gpu_audio_dig * GPU_DCN_DIG_STRIDE;
    var n0 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_1 + d);
    var c0 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_STATUS_0 + d) >> GPU_HDMI_ACR_CTS_48_SHIFT;
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_1 + d,
    (n0 & (0 - 1 - GPU_HDMI_ACR_N_48_MASK)) | (GPU_HDMI_ACR_N_48_VAL * 2));
    gpu_udelay(200000);
    var c1 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_STATUS_0 + d) >> GPU_HDMI_ACR_CTS_48_SHIFT;
    gpu_reg32_write(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_1 + d, n0);
    gpu_udelay(200000);
    var c2 = gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_STATUS_0 + d) >> GPU_HDMI_ACR_CTS_48_SHIFT;
    kprint("gpu: acr cts ", 13);   kprint_num(c0);
    kprint(" -> ", 4);             kprint_num(c1);
    kprint(" -> ", 4);             kprint_num(c2);
    kprintln(" (n doubled then restored)", 26);
    # The verdict, stated so the log reads it out instead of the operator deriving it.
    if (c1 > (c0 + (c0 >> 1))) {
        kprintln("gpu: acr cts scaled with n -- audio clock is in the measurement loop", 68);
    } else {
        kprintln("gpu: acr cts did not scale with n -- pixel-only counter, says nothing about audio", 81);
    }
    return 0;
}


#ifdef HDMI_AUDIO_DUMP
# Dump the display-audio block AFTER the enable path has run, in the exact register order and naming of
# agnosticos/scripts/dump-dcn-audio.py, so agnos's state can be diffed mechanically against the known-good
# captured off amdgpu playing sound on this same silicon. Every claim made about agnos's registers so far
# has been INFERRED FROM THE SOURCE and several were wrong; this reads the hardware.
#
# Diagnostic-only, gated out of every normal build: it is a raw hex dump, which the kernel-log rule forbids
# in the production path. Capture with `run /bin/klug > dump.txt`.
fn gpu_audio_dump() {
    if (gpu_present == 0) { return 0; }
    if (gpu_audio_dig < 0) { return 0; }
    var d = gpu_audio_dig * GPU_DCN_DIG_STRIDE;
    var az = gpu_audio_dig;
    var ir = GPU_R_AZ_ENDPOINT_INDEX + az * GPU_DCN_AZ_STRIDE;
    var dr = GPU_R_AZ_ENDPOINT_DATA  + az * GPU_DCN_AZ_STRIDE;

    kprintln("== agnos display-audio dump ==", 30);
    kprint("DCCG_AUDIO_DTO_SOURCE  ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO_SRC)); kprintln("", 0);
    kprint("DCCG_AUDIO_DTO0_PHASE  ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_PHASE)); kprintln("", 0);
    kprint("DCCG_AUDIO_DTO0_MODULE ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_1, GPU_R_DCCG_AUDIO_DTO0_MODULE)); kprintln("", 0);
    kprint("DIG_FE_CNTL            ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_FE_CNTL + d)); kprintln("", 0);
    kprint("HDMI_CONTROL           ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_CONTROL + d)); kprintln("", 0);
    kprint("HDMI_STATUS            ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_STATUS + d)); kprintln("", 0);
    kprint("HDMI_DB_CONTROL        ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_DB_CONTROL + d)); kprintln("", 0);
    kprint("HDMI_ACR_STATUS_0      ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_STATUS_0 + d)); kprintln("", 0);
    kprint("HDMI_ACR_STATUS_1      ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_STATUS_1 + d)); kprintln("", 0);
    # The three programmed CTS registers, never dumped before. FREE ECHO TEST: agnos declines to write CTS
    # (ACR_SOURCE=0 = HW-measured) and its only CTS constant is 0x3AF5C000 (241500). If these read anything
    # other than ~241502, ACR_STATUS_0 is not echoing a programmed value and it is a real instrument.
    kprint("HDMI_ACR_48_0          ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_0 + d)); kprintln("", 0);
    kprint("HDMI_ACR_44_0          ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_44_0 + d)); kprintln("", 0);
    kprint("HDMI_ACR_32_0          ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_32_0 + d)); kprintln("", 0);
    # The five DCCG symbol-clock registers the 1.55.24 write touched blind. Permanent rows now, so no future
    # session has to argue about whether that block changed anything.
    kprint("DCCG_SYMCLKA (0x159)   ", 23);
    kprint_hex(gpu_reg32(0, 0x159)); kprintln("", 0);
    kprint("DCCG_SYMCLKB (0x15a)   ", 23);
    kprint_hex(gpu_reg32(0, 0x15A)); kprintln("", 0);
    kprint("DCCG_SYMCLKC (0x15b)   ", 23);
    kprint_hex(gpu_reg32(0, 0x15B)); kprintln("", 0);
    kprint("DCCG_SYMCLKD (0x15c)   ", 23);
    kprint_hex(gpu_reg32(0, 0x15C)); kprintln("", 0);
    kprint("DCCG_COMPANION (0x176) ", 23);
    kprint_hex(gpu_reg32(0, 0x176)); kprintln("", 0);
    kprint("HDMI_AUDIO_PKT_CONTROL ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_AUDIO_PACKET_CONTROL + d)); kprintln("", 0);
    kprint("HDMI_ACR_PKT_CONTROL   ", 23);
