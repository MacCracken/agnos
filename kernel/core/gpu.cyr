    kprint("HDMI_GENERIC_PKT_CNTL1 ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GENERIC_PACKET_CONTROL1 + d)); kprintln("", 0);
    kprint("HDMI_GC                ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_GC + d)); kprintln("", 0);
    kprint("AFMT_GENERIC_HDR       ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_HDR + d)); kprintln("", 0);
    kprint("AFMT_GENERIC_0         ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_0 + d)); kprintln("", 0);
    kprint("AFMT_GENERIC_2         ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_2 + d)); kprintln("", 0);
    kprint("AFMT_GENERIC_3         ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_GENERIC_3 + d)); kprintln("", 0);
    kprint("AFMT_VBI_PKT_CONTROL   ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_VBI_PACKET_CONTROL + d)); kprintln("", 0);
    kprint("AFMT_AUDIO_PKT_CONTROL ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL + d)); kprintln("", 0);
    kprint("AFMT_AUDIO_PKT_CNTL2   ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_PACKET_CONTROL2 + d)); kprintln("", 0);
    kprint("AFMT_AUDIO_SRC_CONTROL ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_SRC_CONTROL + d)); kprintln("", 0);
    kprint("AFMT_INFOFRAME_CNTL0   ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_INFOFRAME_CONTROL0 + d)); kprintln("", 0);
    kprint("AFMT_AUDIO_INFO0       ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_INFO0 + d)); kprintln("", 0);
    kprint("AFMT_60958_0           ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_60958_0 + d)); kprintln("", 0);
    kprint("AFMT_60958_1           ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_60958_1 + d)); kprintln("", 0);
    kprint("AFMT_60958_2           ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_60958_2 + d)); kprintln("", 0);
    kprint("AFMT_STATUS            ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_STATUS + d)); kprintln("", 0);
    kprint("AFMT_CNTL              ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_CNTL + d)); kprintln("", 0);
    # The CRC pair. gpu_hdmi_audio_crc_probe disarms CONTROL when it finishes, so CONTROL reads 0 here by
    # design and RESULT still holds the last measurement — the value the probe's line above reported.
    kprint("AFMT_RAMP_CONTROL0     ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_RAMP_CONTROL0 + d)); kprintln("", 0);
    kprint("AFMT_RAMP_CONTROL1     ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_RAMP_CONTROL1 + d)); kprintln("", 0);
    kprint("AFMT_RAMP_CONTROL2     ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_RAMP_CONTROL2 + d)); kprintln("", 0);
    kprint("AFMT_RAMP_CONTROL3     ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_RAMP_CONTROL3 + d)); kprintln("", 0);
    kprint("AFMT_INTERRUPT_STATUS  ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_INTERRUPT_STATUS + d)); kprintln("", 0);
    kprint("AFMT_AUDIO_CRC_CONTROL ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_CONTROL + d)); kprintln("", 0);
    kprint("AFMT_AUDIO_CRC_RESULT  ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_AFMT_AUDIO_CRC_RESULT + d)); kprintln("", 0);
    kprint("HDMI_ACR_48_1          ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_HDMI_ACR_48_1 + d)); kprintln("", 0);
    kprint("DIG_BE_CNTL            ", 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, GPU_R_DIG_BE_CNTL + d)); kprintln("", 0);
    # The AZ endpoint the AFMT is bound to — indexed window, same ordinals as the python dump.
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_CONV_FORMAT);
    kprint("AZ_CONVERTER_FORMAT    ", 23); kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr)); kprintln("", 0);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_CONV_STREAM_ID);
    kprint("AZ_CHANNEL_STREAM_ID   ", 23); kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr)); kprintln("", 0);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_CHANNEL_SPEAKER);
    kprint("AZ_CHANNEL_SPEAKER     ", 23); kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr)); kprintln("", 0);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_MULTICHANNEL_ENABLE);
    kprint("AZ_MULTICHANNEL_ENABLE ", 23); kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr)); kprintln("", 0);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_HOT_PLUG_CONTROL);
    kprint("AZ_HOT_PLUG_CONTROL    ", 23); kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr)); kprintln("", 0);
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_AUDIO_ENABLE_STATUS);
    kprint("AZ_AUDIO_ENABLE_STATUS ", 23); kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr)); kprintln("", 0);

    # --- The ordinals agnos has never read, now that a known-good exists for every one of them ---
    #
    # The six above were the whole AZ picture for fourteen burns. The amdgpu capture has THIRTY-FOUR, and
    # the two that matter most were never among ours:
    #
    #   DIGITAL_OUTPUT_STATUS (0x63) — OUTPUT_ACTIVE bit0, READ-ONLY. The direct answer to "is this pin
    #     transmitting?". amdgpu reads 1 while audibly playing. If agnos reads 0, the drain is dead AT THE
    #     PIN and the whole search collapses onto the encoder.
    #   LPIB (0x65) — the endpoint's own link position. Previously rejected as an instrument because amdgpu
    #     reads it NOWHERE in the entire amd tree, so nothing proved it was implemented rather than dead
    #     silicon. MEASUREMENT OVERRULED THAT: amdgpu's reads 0x00019128 — live and non-zero. It is real,
    #     and it now has a known-good. Sampled twice so a frozen counter is distinguishable from a moving
    #     one; a static value is still uninformative, never a verdict.
    #
    # The rest are read for the corpus: one burn closes the entire AZ diff instead of one register per burn.
    # All read-only or already-owned; nothing here changes hardware behaviour.
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_DIGITAL_OUTPUT_STATUS, "AZ_DIGITAL_OUT_STATUS  ");
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_LPIB);
    var lp0 = gpu_reg32(GPU_BASE_DCN_2, dr);
    gpu_udelay(5000);   # 5 ms is enough to see LPIB move; 50 ms was gratuitous boot cost
    gpu_reg32_write(GPU_BASE_DCN_2, ir, GPU_AZ_IX_LPIB);
    var lp1 = gpu_reg32(GPU_BASE_DCN_2, dr);
    kprint("AZ_LPIB                ", 23); kprint_hex(lp0);
    kprint(" then ", 6); kprint_hex(lp1); kprintln("", 0);
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_CONV_DIGITAL_CONVERTER, "AZ_DIGITAL_CONVERTER   ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_CONV_WIDGET_CAPS,       "AZ_CONV_WIDGET_CAPS    ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_PIN_WIDGET_CONTROL,     "AZ_PIN_WIDGET_CONTROL  ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_PIN_CAPS,               "AZ_PIN_CAPS            ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_PIN_SENSE,              "AZ_PIN_SENSE           ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_AUDIO_DESCRIPTOR0,      "AZ_AUDIO_DESCRIPTOR0   ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_MULTICHANNEL_MODE,      "AZ_MULTICHANNEL_MODE   ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_RESPONSE_HBR,           "AZ_RESPONSE_HBR        ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_SINK_INFO0,             "AZ_SINK_INFO0          ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_CODING_TYPE,            "AZ_CODING_TYPE         ");
    gpu_az_dump_ord(ir, dr, GPU_AZ_IX_FORMAT_CHANGED,         "AZ_FORMAT_CHANGED      ");
    gpu_dmcub_probe();
    gpu_vbios_acquire();
    kprintln("== end dump ==", 14);
    return 1;
}
#endif
# --- VBIOS acquisition (A2) is ALWAYS compiled: the ATOM interpreter (core/atom.cyr,
# always included) consumes gpu_vbios_va. The dump-block gate above only controls the
# read-only probes; acquisition itself is a safe ACPI walk + one alloc + a word copy. ---

var gpu_vbios_va = 0;    # A2: CPU VA of the copied VBIOS ATOM image (0 = not acquired)
var gpu_vbios_len = 0;   # A2: length of the VBIOS ATOM image in bytes

# A2 (gpu.md) — acquire the VBIOS ATOM image from the ACPI VFCT table. Renoir/Cezanne is an
# APU with NO discrete flash ROM; the integrated IGP VBIOS ships inside the system UEFI, published as the ACPI
# VFCT table. Layout (amdgpu_bios.c amdgpu_acpi_vfct_bios): ACPI header(36) + TableUUID[16] +
# VBIOSImageOffset:u32 @52. At (vfct + VBIOSImageOffset) sits VFCT_IMAGE_HEADER { PCIBus/Dev/Fn u32 (12) ·
# VendorID u16 @12 · DeviceID u16 @14 · SSVID/SSID (4) · Revision u32 @20 · ImageLength u32 @24 } then the raw
# VbiosContent[] @28. Read-only ACPI walk + one 2 MB alloc + a word copy. Safe. Sets gpu_vbios_va/len for A3.
fn gpu_vbios_acquire() {
    var vfct = 0;
    if (acpi_xsdt_addr != 0) { vfct = acpi_xsdt_find(acpi_xsdt_addr, 0x56, 0x46, 0x43, 0x54); }
    if (vfct == 0 && acpi_rsdt_addr != 0) { vfct = acpi_rsdt_find(acpi_rsdt_addr, 0x56, 0x46, 0x43, 0x54); }
    if (vfct == 0) { kprintln("gpu: vbios VFCT not found", 25); return 0; }
    var vbase = vfct + acpi_load32(vfct + 52);
    var vendor = acpi_load16(vbase + 12);
    var device = acpi_load16(vbase + 14);
    var len    = acpi_load32(vbase + 24);
    kprint("gpu: vbios VFCT vid=", 20); kprint_hex(vendor);
    kprint(" did=", 5); kprint_hex(device);
    kprint(" len=", 5); kprint_num(len); kprintln("", 0);
    if (vendor != 0x1002) { kprintln("gpu: vbios vendor mismatch", 26); return 0; }
    if (len < 512 || len > 0x100000) { kprintln("gpu: vbios length insane", 24); return 0; }
    var buf = pmm_alloc_2mb();
    if (buf == 0) { kprintln("gpu: vbios buf alloc failed", 27); return 0; }
    var bva = DIRECTMAP_BASE + buf;
    var content = vbase + 28;
    var words = (len + 3) / 4;
    var i = 0;
    while (i < words) { store32(bva + i * 4, acpi_load32(content + i * 4)); i = i + 1; }
    var sig = load8(bva) | (load8(bva + 1) << 8);
    var atomhdr = load8(bva + 0x48) | (load8(bva + 0x49) << 8);
    kprint("gpu: vbios copied, sig=", 23); kprint_hex(sig);
    kprint(" atomhdr=", 9); kprint_hex(atomhdr); kprintln("", 0);
    if (sig != 0xAA55) { kprintln("gpu: vbios sig NOT 55aa", 23); return 0; }
    gpu_vbios_va = bva;
    gpu_vbios_len = len;
    kprintln("gpu: vbios ATOM image acquired OK", 33);
    return 1;
}

#ifdef HDMI_AUDIO_DUMP
# T2 (gpu.md) — READ-ONLY DMCUB attach probe. Reads only the always-on DMU-domain
# CNTL/SCRATCH/CC_DC_PIPE_DIS + inbox pointers (SAFE on a live GOP-lit DMCUB: amdgpu's cold
# dmub_dcn20_is_hw_init/get_fw_boot_status read exactly these with no power sequencing, unlike the gate-able
# pipe blocks that hung the blind scan). Decides Path A (attach the GOP's live inbox ring, effort M) vs
# Path B (PSP-load renoir_dmcub.bin ourselves, L/XL). WRITES NOTHING.
fn gpu_dmcub_probe() {
    if (gpu_present == 0) { return 0; }
    var pipe_dis = gpu_reg32(GPU_BASE_DCN_2, GPU_R_CC_DC_PIPE_DIS);
    var cntl     = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DMCUB_CNTL);
    var scr0     = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DMCUB_SCRATCH0);
    var ibase    = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DMCUB_INBOX1_BASE);
    var isize    = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DMCUB_INBOX1_SIZE);
    var iwptr    = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DMCUB_INBOX1_WPTR);
    var irptr    = gpu_reg32(GPU_BASE_DCN_2, GPU_R_DMCUB_INBOX1_RPTR);
    kprint("dmcub: CC_DC_PIPE_DIS ", 22); kprint_hex(pipe_dis); kprintln("", 0);
    kprint("dmcub: CNTL ", 12); kprint_hex(cntl); kprintln("", 0);
    kprint("dmcub: SCRATCH0 ", 16); kprint_hex(scr0); kprintln("", 0);
    kprint("dmcub: INBOX1 base ", 19); kprint_hex(ibase);
    kprint(" size ", 6); kprint_hex(isize);
    kprint(" wptr ", 6); kprint_hex(iwptr);
    kprint(" rptr ", 6); kprint_hex(irptr); kprintln("", 0);
    var enabled = (cntl & GPU_DMCUB_ENABLE);
    var mbrdy   = (scr0 & GPU_DMCUB_FW_MAILBOX_RDY);
    var dalfw   = (scr0 & GPU_DMCUB_FW_DAL);
    if (enabled != 0 && mbrdy != 0 && dalfw != 0) {
        kprintln("dmcub: ATTACHABLE -> Path A (attach live ring)", 46);
    } else {
        kprintln("dmcub: NOT attach-ready -> Path B (PSP-load fw)", 47);
    }
    return 1;
}

# One AZ indexed ordinal, named and printed. The index window has NO MEMORY — it returns whatever `ir` last
# selected — so every read re-selects. That is the bug 1.55.15 fixed by hand at four sites; this makes it
# structurally impossible to repeat.

fn gpu_az_dump_ord(ir, dr, ordinal, label) {
    gpu_reg32_write(GPU_BASE_DCN_2, ir, ordinal);
    kprint(label, 23);
    kprint_hex(gpu_reg32(GPU_BASE_DCN_2, dr));
    kprintln("", 0);
    return 0;
}
#endif

# gpu_release_pid — the display half of the per-pid release chain (cf. flock_release_pid / snd_release_pid):
# if this process owned the scanout, hand the screen back to the console as it exits. A process that never
# presented is a no-op, and a long-running compositor simply never exits — so it keeps the screen.
fn gpu_release_pid(pid) {
    if (gpu_scanout_pid != pid) { return 0; }
    return gpu_display_restore_console();
}
