# gpu_blend_cov_run — the shared 8-KERNARG 2-D grid dispatcher. Peer of gpu_blend_rect_run.
#
# Used by BOTH blend_cov and glyph_1bpp: their kernarg layouts are identical in shape (two pointers, two
# pitches, a width and a uniform colour) and they share RSRC2 (USER_SGPR=8 | TGID_X | TGID_Y), so only
# RSRC1 differs — hence it is a parameter. One dispatcher rather than two near-identical copies means the
# ring program has a single place to be wrong.
fn gpu_blend_cov_run(shader_mc, mask_mc, dst_mc, mask_pitch, dst_pitch, width, color, rsrc1, gx, gy, done_mc, done_phys) {
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    var fc0 = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0 | 0x1);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0);

    var pgm_lo = (shader_mc >> 8) & 0xFFFFFFFF;
    var pgm_hi = (shader_mc >> 40) & 0xFF;
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_INV);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_LO); gpu_ring_put(pgm_lo); gpu_ring_put(pgm_hi);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_RSRC1); gpu_ring_put(rsrc1); gpu_ring_put(GPU_COMPUTE_RSRC2_COV);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N8); gpu_ring_put(GPU_SH_COMPUTE_USER_DATA_0);
    gpu_ring_put(mask_mc & 0xFFFFFFFF); gpu_ring_put((mask_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(dst_mc & 0xFFFFFFFF); gpu_ring_put((dst_mc >> 32) & 0xFFFFFFFF);
    gpu_ring_put(mask_pitch); gpu_ring_put(dst_pitch); gpu_ring_put(width); gpu_ring_put(color);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_START_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_NUM_THREAD_X); gpu_ring_put(GPU_MT_NUM_THREAD_X); gpu_ring_put(1); gpu_ring_put(1);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_RESTART_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE0); gpu_ring_put(GPU_CU_MASK_ALL); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE2); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N1); gpu_ring_put(GPU_SH_COMPUTE_RESOURCE_LIMITS); gpu_ring_put(GPU_COMPUTE_RESLIM);
    gpu_ring_put(GPU_PM4_DISPATCH_DIRECT_HDR); gpu_ring_put(gx); gpu_ring_put(gy); gpu_ring_put(1); gpu_ring_put(GPU_DISPATCH_INITIATOR);
    gpu_ring_put(GPU_PM4_EVENT_WRITE_HDR); gpu_ring_put(GPU_EVENT_CS_PARTIAL_FLUSH);
    gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_TCWB);
    gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
    gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    if (gpu_batch_active != 0) { return 1; }   # batched: the driver emits ONE tail for the whole array
    gpu_batch_tail(done_mc);
    gpu_mfence();
    return gpu_ring_kick_wait(done_phys, 100000);
}

# cov_ref_px — EXACT rational reference for the coverage blend, rounded once at the end:
#   out_c = round( (colour_c*cov*255 + dst_c*(65025 - colour_a*cov)) / 65025 )
# Deriving it as one integer quotient (rather than mirroring the shader's float steps) is deliberate: it
# measures the shader against the RIGHT ANSWER, not against a re-implementation of the shader's own
# rounding. That is what makes the reported deviation meaningful.
# Widest intermediate is 255*255*255 + 255*65025 ~ 33.2M, doubled for the round-half-up ~ 66.4M — far inside i64.
fn cov_ref_px(color, cv, dst) {
    var ca = (color >> 24) & 0xFF;
    var out = 0;
    var ch = 0;
    while (ch < 4) {
        var sh = ch * 8;
        var cc = (color >> sh) & 0xFF;
        var dc = (dst >> sh) & 0xFF;
        var num = cc * cv * 255 + dc * (65025 - ca * cv);
        var q = (num * 2 + 65025) / 130050;
        if (q > 255) { q = 255; }
        out = out | (q << sh);
        ch = ch + 1;
    }
    return out;
}

# gpu_shader_cov_test — S7: COVERAGE blending, the anti-aliased text/shape path.
#
# Renders a circle with a soft edge. That choice is the point: CP-DMA fills rectangles, blend_rect
# composites rectangular images, and NEITHER can make a round shape with a smooth boundary, because both
# are blind to partial pixel coverage. A clean circle edge is therefore self-evidently a coverage blend.
#
# The circle straddles a dark/light underlay split, so one arc is light-on-dark and the other dark-on-light
# — the two cases where a wrong blend direction or an inverted mask looks obviously wrong to the eye.
#
# ⚠ PRECISION, STATED HONESTLY. This test does NOT claim bit-exactness, because the kernel has two rounding
# sites (the coverage multiply and the final pack) and 1/255 is not representable in binary floating point.
# It asserts what is genuinely exact and MEASURES the rest:
#   - cov = 0   MUST be bit-exact (the pixel must be untouched — any deviation is a real bug, not rounding)
#   - cov = 255 MUST be bit-exact (it reduces to the blend already proven bit-correct at S2/S3)
#   - everywhere else: deviation bounded at <= 1, and the OBSERVED MAXIMUM is printed.
# Reporting the number rather than just passing means drift shows up as a changed digit instead of hiding
# inside a tolerance.
fn gpu_shader_cov_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_blend_ok != 1) { kprintln("gpu: skipping coverage (blend math unproven)", 44); return 0; }
    if (gpu_blit_arm() != 1) { kprintln("gpu: skipping coverage (no back buffer)", 39); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }
    var pitch = gpu_bb_pitch;
    if (pitch < (GPU_COV_X + GPU_COV_N) * 4) { kprintln("gpu: skipping coverage (surface too narrow)", 43); return 0; }

    var bb_phys = gpu_bb_a_phys;
    var bb_mc   = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { bb_phys = gpu_bb_b_phys; bb_mc = gpu_bb_b_mc; }

    var sh_phys = gpu_arena_phys + GPU_COV_SHADER_SUBOFF;
    var sh_mc   = gpu_arena_mc   + GPU_COV_SHADER_SUBOFF;
    var mk_phys = gpu_arena_phys + GPU_COV_MASK_SUBOFF;
    var mk_mc   = gpu_arena_mc   + GPU_COV_MASK_SUBOFF;
    var dn_phys = gpu_arena_phys + GPU_BLEND_DONE_SUBOFF;
    var dn_mc   = gpu_arena_mc   + GPU_BLEND_DONE_SUBOFF;
    blend_cov_write(sh_phys);

    # --- rasterise the circle's coverage. Analytic, no sqrt: compare the squared distance against an inner
    # and an outer radius and interpolate between them, giving a ~2 px soft edge. Packed 4 bytes per store32
    # (the mask is 8bpp and N is a multiple of 4).
    var half = GPU_COV_N / 2;
    var ri = GPU_COV_R - 1;
    var ro = GPU_COV_R + 1;
    var ri2 = ri * ri;
    var ro2 = ro * ro;
    var span = ro2 - ri2;
    var y = 0;
    while (y < GPU_COV_N) {
        var dy = y - half;
        var dy2 = dy * dy;
        var x = 0;
        while (x < GPU_COV_N) {
            var word = 0;
            var k = 0;
            while (k < 4) {
                var dx = (x + k) - half;
                var d2 = dx * dx + dy2;
                var cov = 0;
                if (d2 <= ri2) { cov = 255; }
                if (d2 > ri2) {
                    if (d2 < ro2) { cov = (255 * (ro2 - d2)) / span; }
                }
                word = word | (cov << (k * 8));
                k = k + 1;
            }
            store32(mk_phys + y * GPU_COV_N + x, word);
            x = x + 4;
        }
        y = y + 1;
    }
    gpu_mfence();

    # --- underlay: dark left half, light right half, so the circle crosses both ---
    var r_mc   = bb_mc   + GPU_COV_Y * pitch + GPU_COV_X * 4;
    var r_phys = bb_phys + GPU_COV_Y * pitch + GPU_COV_X * 4;
    if (gpu_cp_dma_fill_rect(r_mc, pitch, GPU_COV_DST_L, half * 4, GPU_COV_N) != 1) {
        kprintln("gpu: coverage underlay fill failed", 34); return 0;
    }
    if (gpu_cp_dma_fill_rect(r_mc + half * 4, pitch, GPU_COV_DST_R, half * 4, GPU_COV_N) != 1) {
        kprintln("gpu: coverage underlay fill failed", 34); return 0;
    }

    var gx = (GPU_COV_N + 63) / 64;
    if (gpu_blend_cov_run(sh_mc, mk_mc, r_mc, GPU_COV_N, pitch, GPU_COV_N, GPU_COV_COLOR,
    GPU_COMPUTE_PGM_RSRC1_COV, gx, GPU_COV_N, dn_mc, dn_phys) != 1) {
        kprintln("gpu: coverage dispatch did not complete", 39);
        return 0;
    }

    # --- verify: exact at both coverage endpoints, bounded and MEASURED in between ---
    var edge_bad = 0; var maxdev = 0; var bx = 0; var by = 0; var gotb = 0;
    var vy = 0;
    while (vy < GPU_COV_N) {
        var vx = 0;
        while (vx < GPU_COV_N) {
            var mw = load32(mk_phys + vy * GPU_COV_N + ((vx >> 2) << 2)) & 0xFFFFFFFF;
            var cv = (mw >> ((vx & 3) * 8)) & 0xFF;
            var od = GPU_COV_DST_L;
            if (vx >= half) { od = GPU_COV_DST_R; }
            var got = load32(r_phys + vy * pitch + (vx << 2)) & 0xFFFFFFFF;
            var ref = cov_ref_px(GPU_COV_COLOR, cv, od) & 0xFFFFFFFF;
            if (got != ref) {
                # The two exact cases are HARD failures; anything else is measured, not tolerated silently.
                if (cv == 0)   { if (edge_bad == 0) { bx = vx; by = vy; gotb = got; } edge_bad = edge_bad + 1; }
                if (cv == 255) { if (edge_bad == 0) { bx = vx; by = vy; gotb = got; } edge_bad = edge_bad + 1; }
                var ch = 0;
                while (ch < 4) {
                    var sh8 = ch * 8;
                    var a = (got >> sh8) & 0xFF;
                    var b = (ref >> sh8) & 0xFF;
                    var d = a - b;
                    if (d < 0) { d = 0 - d; }
                    if (d > maxdev) { maxdev = d; }
                    ch = ch + 1;
                }
            }
            vx = vx + 1;
        }
        vy = vy + 1;
    }
    if (edge_bad != 0) {
        kprint("gpu: coverage ENDPOINT MISMATCH ", 32); kprint_num(edge_bad);
        kprint(" px, first at x=", 16); kprint_num(bx);
        kprint(" y=", 3); kprint_num(by);
        kprint(" got ", 5); kprint_num(gotb);
        kprintln("", 0);
        return 0;
    }
    if (maxdev > 1) {
        kprint("gpu: coverage DEVIATION too large, max ", 39); kprint_num(maxdev);
        kprintln("", 0);
        return 0;
    }

    # --- show it, then hand the console back (same bracket as the rect test) ---
    var prev_back = gpu_bb_back;
    gpu_blit_present(0);
    var d2h = 0;
    while (d2h < 30000) { gpu_udelay(100); d2h = d2h + 1; }
    var slo = GPU_R_HUBP_SURF_ADDR    + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    var shi = GPU_R_HUBP_SURF_ADDR_HI + gpu_display_pipe * GPU_DCN_HUBP_STRIDE;
    gpu_reg32_write(GPU_BASE_DCN_2, shi, (gpu_display_surf >> 32) & 0xFFFF);
    gpu_reg32_write(GPU_BASE_DCN_2, slo, gpu_display_surf & 0xFFFFFFFF);
    gpu_mfence();
    gpu_display_wait_vblank(gpu_display_pipe);
    gpu_bb_back = prev_back;

    gpu_cov_ok = 1;
    kprint("gpu: shader coverage blend online (AA circle, endpoints exact, max dev ", 71);
    kprint_num(maxdev);
    kprintln(")", 1);
    return 1;
}

# glyph_1bpp — GENERATED by scripts/gfx9-asm.sh from kernel/shaders/glyph_1bpp.s. DO NOT HAND-EDIT.
# Regenerate: sh scripts/gfx9-asm.sh kernel/shaders/glyph_1bpp.s glyph_1bpp
fn glyph_1bpp_write(dst_phys) {
    store32(dst_phys + 0,   0x8e0a8608);
    store32(dst_phys + 4,   0x6804000a);
