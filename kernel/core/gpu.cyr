# gpu_blend_rect_run — dispatch blend_rect over a 2-D GRID of (gx, gy) workgroups, 64 threads each.
#
# The grid peer of gpu_matmul_run. Envelope is byte-identical to that iron-proven path — same pre-dispatch
# I$/K$ invalidate, same START/RESTART/STATIC/RESLIM, same CS_PARTIAL_FLUSH + TC-writeback, same WRITE_DATA
# done-marker, same register-wptr submit. THREE deltas, all of them the point of the bite:
#   1. DISPATCH_DIRECT is (gx, gy, 1) instead of (1, 1, 1) — the first real grid agnos has ever launched.
#   2. RSRC2 = GPU_COMPUTE_RSRC2_GRID2D sets TGID_X_EN|TGID_Y_EN so the SPI delivers the workgroup id.
#   3. USER_DATA_4/5/6 carry the two PITCHES and the WIDTH, so one kernel serves any stride and any width.
# `width` is what the shader's EXEC guard compares against — `gx` must be the CEILING of width/64, and the
# surplus lanes of the final workgroup mask themselves off. Passing floor() instead would silently drop the
# rect's right edge rather than fault, so the caller computes it once, here.
# gpu_grid7_run — the shared 7-KERNARG 2-D grid dispatcher, taking RAW kernarg dwords.
#
# Factored out when grad_linear arrived: blend_rect and grad_linear share RSRC2 (USER_SGPR=7 | TGID_X |
# TGID_Y) but have completely different kernarg MEANINGS (two pointers + three scalars vs one pointer +
# five). Rather than a third near-identical copy of the ring program — the one place a typo is silent and
# expensive — the emitter takes seven opaque dwords and the callers name them.
fn gpu_grid7_run(shader_mc, k0, k1, k2, k3, k4, k5, k6, rsrc1, gx, gy, done_mc, done_phys) {
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    var fc0 = gpu_reg32(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0 | 0x1);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_VM_L2_PROT_FAULT_CNTL, fc0);

    var pgm_lo = (shader_mc >> 8)  & 0xFFFFFFFF;
    var pgm_hi = (shader_mc >> 40) & 0xFF;
    # PRE-dispatch invalidate. gpu_cohere_inv is 1 in production and decision D-6 keeps it that way; only
    # gpu_shader_cohere_test (plan-S3 arm D) ever clears it, for exactly one dispatch, via gpu_cohere_run.
    if (gpu_cohere_inv != 0) {
        gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_INV);
        gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
        gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    }
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_LO); gpu_ring_put(pgm_lo); gpu_ring_put(pgm_hi);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_PGM_RSRC1); gpu_ring_put(rsrc1); gpu_ring_put(GPU_COMPUTE_RSRC2_GRID2D);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N7); gpu_ring_put(GPU_SH_COMPUTE_USER_DATA_0);
    gpu_ring_put(k0); gpu_ring_put(k1); gpu_ring_put(k2); gpu_ring_put(k3);
    gpu_ring_put(k4); gpu_ring_put(k5); gpu_ring_put(k6);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_START_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_NUM_THREAD_X); gpu_ring_put(GPU_MT_NUM_THREAD_X); gpu_ring_put(1); gpu_ring_put(1);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N3); gpu_ring_put(GPU_SH_COMPUTE_RESTART_X); gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE0); gpu_ring_put(GPU_CU_MASK_ALL); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N2); gpu_ring_put(GPU_SH_COMPUTE_STATIC_SE2); gpu_ring_put(0); gpu_ring_put(0);
    gpu_ring_put(GPU_PM4_SET_SH_REG_N1); gpu_ring_put(GPU_SH_COMPUTE_RESOURCE_LIMITS); gpu_ring_put(GPU_COMPUTE_RESLIM);
    gpu_ring_put(GPU_PM4_DISPATCH_DIRECT_HDR); gpu_ring_put(gx); gpu_ring_put(gy); gpu_ring_put(1); gpu_ring_put(GPU_DISPATCH_INITIATOR);
    gpu_ring_put(GPU_PM4_EVENT_WRITE_HDR); gpu_ring_put(GPU_EVENT_CS_PARTIAL_FLUSH);
    if (gpu_batch_active != 0) { return 1; }   # batched: the driver emits ONE tail for the whole array
    gpu_batch_tail(done_mc);
    gpu_mfence();
    return gpu_ring_kick_wait(done_phys, 100000);
}

# ── plan-S12: the batch seam ───────────────────────────────────────────────────────────────────────────
#
# gpu_grid7_run above is now emit + tail + kick, and the tail and kick are separable so that N dispatches
# can share ONE of each. That is the whole of S12's throughput claim, and it is deliberately NOT a rewrite
# of the proven dispatch program: every existing caller goes through the same three steps in the same order
# and puts the same dwords in the ring.
#
# WHAT A BATCH ACTUALLY SAVES, per op after the first: the 7-dword TC write-back, the 5-dword WRITE_DATA
# fence, and — the one that matters — a whole CPU round-trip (register submit + spin until the marker
# retires). It does NOT save the pre-dispatch invalidate or the CS_PARTIAL_FLUSH; both stay per-dispatch.
#
# WHY THE INVALIDATE STAYS PER-DISPATCH. Decision D-6, now EVIDENCED rather than assumed: plan-S3 measured
# 4096-of-4096 stale reads without it. Hoisting one invalidate to the head of a batch is a plausible
# optimisation — inside an all-shader batch the sources are GL2-coherent with each other, and each kernel
# now has its own resident slot so the I-cache argument is weaker than it was at C2g-1 — but it is exactly
# the kind of "obviously safe" removal that cost eight burns once already. It is a MEASURABLE follow-up,
# not something to fold into the bite that first makes batching work.
#
# ⚠ NO ENGINE-DOMAIN TRANSITIONS ARISE YET. Every #92 op code implemented today (0x01 blend, 0x02 coverage,
# 0x03 glyph, 0x04 gradient) is a SHADER dispatch; the CP-DMA-domain codes 0x10/0x11 are reserved and still
# return E_BADOP. So a batch is uniformly `dispatch x N -> ACQUIRE_MEM -> fence`, which is precisely the
# shape plan-S3 blessed. The moment 0x10/0x11 are minted, this function needs the domain state machine that
# emits BOTH packets at every transition in either direction — S3 measured that CP-DMA neither snoops GL2 on
# read nor invalidates it on write, so neither direction is free.

# gpu_batch_tail — the once-per-submission tail: TC write-back, then the completion fence.
fn gpu_batch_tail(done_mc) {
    if (gpu_cohere_wb != 0) {
        gpu_ring_put(GPU_PM4_ACQUIRE_MEM_HDR); gpu_ring_put(GPU_CP_COHER_CNTL_TCWB);
        gpu_ring_put(GPU_ACQUIRE_COHER_SIZE); gpu_ring_put(GPU_ACQUIRE_COHER_SIZE_HI);
        gpu_ring_put(0); gpu_ring_put(0); gpu_ring_put(GPU_ACQUIRE_POLL);
    }
    gpu_ring_put(GPU_PM4_WRITE_DATA_HDR); gpu_ring_put(GPU_PM4_WRITE_DATA_CTL);
    gpu_ring_put(done_mc & 0xFFFFFFFF); gpu_ring_put((done_mc >> 32) & 0xFFFFFFFF); gpu_ring_put(GPU_C2F_DONE);
    return 0;
}

# gpu_ring_kick_wait — register-wptr submit (LO before HI; the CP latches on the HI write), then spin for
# the marker, then deselect. Bounded; NEVER unbounded. Leaves gpu_last_wait_us set for the caller to print.
fn gpu_ring_kick_wait(done_phys, timeout_us) {
    var new_wptr = gpu_ring_wptr;
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, GPU_GRBM_SEL_MEC1_P0_Q0);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_LO, new_wptr);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_CP_HQD_PQ_WPTR_HI, 0);
    gpu_mfence();
    var ok = gpu_wait_done(done_phys, GPU_C2F_DONE, timeout_us);
    gpu_reg32_write(GPU_BASE_GC_0, GPU_R_GRBM_GFX_CNTL, 0);
    gpu_mfence();
    gpu_ring_wptr = new_wptr;
    return ok;
}

# gpu_blend_rect_run — blend_rect's kernarg layout over gpu_grid7_run. Kept as a named wrapper so the two
# existing call sites read as (src, dst, pitches, width) rather than as seven anonymous dwords.
fn gpu_blend_rect_run(shader_mc, src_mc, dst_mc, src_pitch, dst_pitch, width, gx, gy, done_mc, done_phys) {
    return gpu_grid7_run(shader_mc,
    src_mc & 0xFFFFFFFF, (src_mc >> 32) & 0xFFFFFFFF,
    dst_mc & 0xFFFFFFFF, (dst_mc >> 32) & 0xFFFFFFFF,
    src_pitch, dst_pitch, width,
    GPU_COMPUTE_PGM_RSRC1_GRID, gx, gy, done_mc, done_phys);
}

