    store32(dst_phys + 108, 0xd1ed000a);
    store32(dst_phys + 112, 0x00220704);
    store32(dst_phys + 116, 0x7e160302);
    store32(dst_phys + 120, 0xdc7d8000);
    store32(dst_phys + 124, 0x007f0805);
    store32(dst_phys + 128, 0xbf8c0f70);
    store32(dst_phys + 132, 0xbf810000);
    return 34;
}

