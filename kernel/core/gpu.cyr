# ── S2 (1.56.x SHADER arc) — THE FIRST BLEND. Per-pixel src-over alpha executed on the CUs.
# PREMULTIPLIED f32: out = src + dst*(1 - src_a). Chosen by measurement, not preference — on this ISA
# premultiplied f32 is 20-22 VALU/pixel vs 31-33 for packed-int16-with-div255 and 43-45 for packed f16,
# because GFX9 unpacks bytes ONLY to float (v_cvt_f32_ubyteN) and packs ONLY from float (v_cvt_pk_u8_f32).
# Premultiplying also drops the src*a term AND makes the result provably <= 255, so no clamp is needed.
# The kernel is AUTHORED IN ASSEMBLY (kernel/shaders/blend_premul.s) and machine-assembled by
# scripts/gfx9-asm.sh — no hand-typed ISA hex, and RSRC1 is harvested from llvm-mc, not hand-counted.
# Reuses gpu_matmul_run's proven dispatch envelope verbatim (3 kernargs = src/dst/out, 64 threads).
# The CPU here does exactly two things: seed the inputs and check the answer. Every blend is on the GPU.
fn blend_ref_px(src, dst) {
    var sa = (src >> 24) & 0xFF;
    var ia = 255 - sa;
    var out = 0;
    var b = 0;
    while (b < 4) {
        var sc = (src >> (b * 8)) & 0xFF;
        var dc = (dst >> (b * 8)) & 0xFF;
        # round-to-nearest of dc*ia/255 — matches v_cvt_pk_u8_f32, which iron proved ROUNDS (it does not
        # truncate; burn 1's +0.5 double-rounded and came out +1 everywhere). Exact .5 never occurs here
        # (t = 255k + 127.5 is not an integer), so the tie rule is unreachable and half-up == to-nearest.
        var r = sc + ((dc * ia) * 2 + 255) / 510;
        if (r > 255) { r = 255; }
        out = out | (r << (b * 8));
        b = b + 1;
    }
    return out;
}
fn gpu_shader_blend_test() {
    if (gpu_present == 0) { return 0; }
    if (gpu_matmul_ok != 1) { kprintln("gpu: skipping blend (dispatch envelope unproven)", 48); return 0; }
    if (gpu_arena_mc == 0) { return 0; }
    if (gpu_ring_wptr == 0) { return 0; }

    var shader_phys = gpu_arena_phys + GPU_SHADER_SUBOFF;
    var shader_mc   = gpu_arena_mc   + GPU_SHADER_SUBOFF;
    var src_phys    = gpu_arena_phys + GPU_MM_A_SUBOFF;
    var src_mc      = gpu_arena_mc   + GPU_MM_A_SUBOFF;
    var dst_phys    = gpu_arena_phys + GPU_MM_B_SUBOFF;
    var dst_mc      = gpu_arena_mc   + GPU_MM_B_SUBOFF;
    var out_phys    = gpu_arena_phys + GPU_MM_C_SUBOFF;
    var out_mc      = gpu_arena_mc   + GPU_MM_C_SUBOFF;
    var done_phys   = gpu_arena_phys + GPU_SHADER_DONE_SUBOFF;
    var done_mc     = gpu_arena_mc   + GPU_SHADER_DONE_SUBOFF;

    blend_premul_write(shader_phys);

    # Seed 64 pixels sweeping alpha 0..255. src is PREMULTIPLIED (sc <= sa, which the format requires).
    # i=0 gives sa=0 (out must equal dst) and i=63 gives sa=255 (out must equal src) — both endpoints get
    # exercised, and they are the two cases a broken blend is most likely to still pass by accident.
    var i = 0;
    while (i < 64) {
        var sa = (i * 255) / 63;
        var sc = sa / 2;
        var dc = 255 - i * 4;
        store32(src_phys + (i << 2), (sa << 24) | (sc << 16) | (sc << 8) | sc);
        store32(dst_phys + (i << 2), (255 << 24) | (dc << 16) | (dc << 8) | dc);
        store32(out_phys + (i << 2), GPU_MT_NOTYET);
        i = i + 1;
    }
    gpu_mfence();

    # RSRC1 0x002c0042 is HARVESTED from llvm-mc via the .amdhsa_kernel descriptor, not hand-counted.
    if (gpu_matmul_run(shader_mc, src_mc, dst_mc, out_mc, done_mc, done_phys, GPU_COMPUTE_PGM_RSRC1_V12) != 1) {
        kprintln("gpu: shader blend dispatch did not complete", 43);
        return 0;
    }

    # Verify vs the CPU reference. Also count lanes that actually STORED: a dispatch can retire having
    # written nothing if every lane was EXEC-masked (that is exactly what happened at 1.54.17-19), so
    # "retired" is not evidence and the witness is reported separately.
    var stored = 0;
    var ok = 1;
    var bad = 0;
    var j = 0;
    while (j < 64) {
        var got = load32(out_phys + (j << 2)) & 0xFFFFFFFF;
        var ref = blend_ref_px(load32(src_phys + (j << 2)) & 0xFFFFFFFF,
        load32(dst_phys + (j << 2)) & 0xFFFFFFFF) & 0xFFFFFFFF;
        if (got != GPU_MT_NOTYET) { stored = stored + 1; }
        if (got != ref) { if (ok == 1) { bad = j; } ok = 0; }
        j = j + 1;
    }
    kprint("gpu: shader blend lanes stored ", 31); kprint_num(stored);
    kprintln(" of 64", 6);
    if (stored != 64) { kprintln("gpu: shader blend LANES MISSING (exec mask?)", 44); return 0; }
    if (ok != 1) {
        kprint("gpu: shader blend MISMATCH at lane ", 35); kprint_num(bad);
        kprint(" got ", 5);  kprint_num(load32(out_phys + (bad << 2)) & 0xFFFFFFFF);
        kprintln("", 0);
        return 0;
    }
    gpu_blend_ok = 1;
    kprintln("gpu: shader alpha blend online (64 px, bit-correct vs CPU)", 58);
    return 1;
}
