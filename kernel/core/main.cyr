# === CMOS kernel checkpoint 12 (VFS up) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0C; 0xE6; 0x71; }

var h1 = kmalloc(16);
var h2 = kmalloc(100);
var h3 = kmalloc(4096);
kprint("Heap: ", 6);
kprint_num(h1);
kprint(" ", 1);
kprint_num(h2);
kprint(" ", 1);
kprint_num(h3);
kprintln("", 0);
kfree_sized(h2, 100);

# Initialize SYSCALL/SYSRET
syscall_init();
kprintln("SYSCALL/SYSRET initialized", 26);

# Initialize stack canary secret (S13)
stack_canary_init();
kprintln("Stack canary initialized", 24);

# === CMOS kernel checkpoint 13 (SYSCALL + stack canary) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0D; 0xE6; 0x71; }

#ifdef KTEST
# Syscall test (direct call — still works)
kernel_return_rsp = 0;
kernel_return_rip = 0;
proc_count = 0;
proc_current = 0;
var p0 = proc_create(0x100000);
proc_set_state(0, 2);  # kernel "process" is running

var pid = ksyscall(2, 0, 0, 0);
kprint("Syscall getpid=", 15);
kprint_num(pid);
kprintln("", 0);

ksyscall(1, 0, "Syscall write works!\n", 21);

ksyscall(0, 42, 0, 0);
kprint("Exit code: ", 11);
kprint_num(sys_exit_code);
kprintln("", 0);

# Hardware SYSCALL test (from kernel mode — same privilege, tests the plumbing).
# test_hw_syscall() prints intermediate detail to serial; one bare digit (the
# getpid result) lands on the kprint channel inside the call, so we close the
# "HW syscall test: " prefix with an explicit kprintln. Without this the next
# kprintln collides on the same FB row producing "0Creating test...".
kprint("HW syscall test: ", 17);
test_hw_syscall();
kprintln("", 0);
#endif

#ifdef KTEST
# === Context Switch Test ===
# Create two test processes with dedicated stacks.
# Process stacks at 0x800000 + pid * 0x10000, 64KB apart.
# Stack grows down, so stack_top is base + size.
kprintln("Creating test processes...", 26);

proc_count = 0;
proc_current = 0;

# Process 0: kernel idle (the code running right now)
var kern_pid = proc_create(0);
proc_set_state(0, 2);  # running

# Process 1: test_proc_a
var stack_a = 0x800000 + 1 * 0x10000;
if (vmm_is_mapped(stack_a) == 0) { vmm_alloc_at(stack_a); }
var pa = proc_create_full(&test_proc_a, stack_a + 0x4000);
kprint("Process A (pid=", 15);
kprint_num(pa);
kprintln(") created", 9);

# Process 2: test_proc_b
var stack_b = 0x800000 + 2 * 0x10000;
if (vmm_is_mapped(stack_b) == 0) { vmm_alloc_at(stack_b); }
var pb = proc_create_full(&test_proc_b, stack_b + 0x4000);
kprint("Process B (pid=", 15);
kprint_num(pb);
kprintln(") created", 9);

kprint("Processes: ", 11);
kprint_num(proc_count);
kprint(" total, ", 8);
kprint_num(proc_count_by_state(1));
kprintln(" ready", 6);

# === CMOS kernel checkpoint 14 (test procs created) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0E; 0xE6; 0x71; }
#endif

# Enable interrupts and activate scheduler
asm { sti; }
kprintln("Interrupts enabled", 18);

# === CMOS kernel checkpoint 15 (interrupts enabled — sti executed) ===
# CP 15 reached but CP 16 not = scheduler activation faulted, or a flood
# of interrupts post-sti is preventing forward progress.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0F; 0xE6; 0x71; }

# Wait a few ticks before activating scheduler
arch_wait();
arch_wait();
kprint("Timer ticks before sched: ", 26);
kprint_num(timer_ticks);
kprintln("", 0);

# 1.44.18 — wake + park the APs (see smp.cyr). HERE because: pt_init has run (the
# trampoline's CR3 0x1000 = the kernel PML4, identity 0-4 GB incl. the APIC), IF=1
# windows exist (smp_wait_ticks' real SDM delays), and sched_active is still 0 (the
# wait's ticks no-op in do_context_switch). APs report in and PARK (IF=0 hlt) — the
# single-core invariant is untouched; "smp: cpus online: N" is the proof line.
#
# GATED OFF (iron multi-verb keyboard-death bisect). The "keyboard dies after the
# first command" regression is IRON-ONLY — it does NOT reproduce in QEMU even over
# the exact IRQ1/kb_isr keystroke path with -smp 4 + a 30 s dwell (see
# scripts/agnsh-irq1-repro.py) — and bisects to THIS wake: multi-verb typing worked
# on archaemenid at 14115 (1.41.15) and 1439 (DOOM, 1.43.8), both PRE-1.44.18, the
# only sessions where AGNOS never woke the other Zen cores. Hypothesis: a woken-but-
# parked AP (LAPIC enabled in ap_entry, but its LVT LINT0/timer left at the INIT
# reset state, never explicitly masked) competes for / swallows the BSP's 8259 IRQ1
# (keyboard) on real Zen. SMP buys NOTHING for cooperative-agnsh boot-to-shell (the
# MVP gate), so gating the wake OFF is BOTH the discriminator AND — if confirmed —
# the MVP fix. Flip smp_wake_enabled back to 1 to restore the wake (the documented
# 1.44.18 one-line fallback; everything downstream is inert without it).
var smp_wake_enabled = 0;
if (smp_wake_enabled != 0) {
    smp_start_aps();
} else {
    kprintln("smp: AP wake gated (MVP single-core)", 36);
}

kprintln("Activating scheduler...", 23);

# 1.40.10 — register the kernel main thread + an idle thread as real procs
# before activating preemption (production path; KTEST builds set up their own
# proc_a/proc_b above). The exec-from-disk selftest leaves dead exec procs in
# slots 0..N with proc_current on the last one; without a valid runnable proc
# the first timer tick after sched_active=1 (the DHCP DISCOVER hlt-wait on iron)
# fell back to a dead exec proc, cr3_load'd its stale per-process CR3 and
# iretq'd into a ring-3 RIP in ring 0 → triple-fault reset. Build proc 0 = this
# kernel main thread (already running) + proc 1 = the hlt idle thread, both on
# the boot CR3 (0x1000, where kernel_resume left us post-exec) so the equal-CR3
# guard in do_context_switch skips cr3_load entirely — preemption is pure
# register save/restore in one shared address space. See sched.cyr kernel_idle_loop.
#ifdef THREAD_SELFTEST
# === 1.44.x THREAD_SELFTEST — preemptive kernel-thread time-slicing (opening bite) ===
# Two kernel threads tight-loop bumping their own counters; they NEVER yield, so if
# BOTH counters advance, the TIMER preempted + round-robined them — preemptive
# time-slicing on the shared kernel AS via kthread_create. Then verify the preempt
# gate: under preempt_disable() the counters must FREEZE (do_context_switch no-ops).
# Compile-gated: `THREAD_SELFTEST=1 ./scripts/build.sh`.
var thr_counter_a = 0;
var thr_counter_b = 0;
var thr_pid_a = 0;
var thr_pid_b = 0;
fn thread_test_a() { while (1 == 1) { thr_counter_a = thr_counter_a + 1; } return 0; }
fn thread_test_b() { while (1 == 1) { thr_counter_b = thr_counter_b + 1; } return 0; }
fn thread_selftest_verify() {
    var i = 0;
    while (i < 40) { arch_wait(); i = i + 1; }   # yield: timer round-robins kmain->A->B->kmain
    kprint("thr: A=", 7); kprint_num(thr_counter_a);
    kprint(" B=", 3); kprint_num(thr_counter_b); kprintln("", 0);
    if (thr_counter_a > 0) { if (thr_counter_b > 0) { kprintln("thr: preempt OK", 15); } }
    if (thr_counter_a == 0) { kprintln("thr: A starved", 14); }
    if (thr_counter_b == 0) { kprintln("thr: B starved", 14); }
    # Preempt gate: counters must NOT advance while preemption is disabled.
    var snap_a = thr_counter_a;
    preempt_disable();
    var g = 0;
    while (g < 20) { arch_wait(); g = g + 1; }    # timer wakes the hlt but must NOT switch
    preempt_enable();
    if (thr_counter_a == snap_a) { kprintln("thr: gate held", 14); }
    else { kprintln("thr: gate LEAK", 14); }
    proc_set_state(thr_pid_a, 0);                 # retire the test threads (skip-on-dead)
    proc_set_state(thr_pid_b, 0);
    kprintln("thr: done", 9);
    return 0;
}
#endif

#ifdef RING3_SELFTEST
# === RING3_SELFTEST — preemptive ring-3 (1.44.4 one proc · 1.44.5 two procs · 1.44.6 syscalls) ===
# Spawn TWO ring-3 procs, each with its OWN per-process CR3 + IF=1, each running the SAME
# raw-machine-code loop: a getpid SYSCALL (1.44.6) then increment a u64 at user VA 0x2000000.
# Because each proc has a distinct CR3, that one user VA maps to a DIFFERENT physical
# counter per proc — so two advancing counters proves (a) the scheduler round-robins
# ring-3 <-> ring-3 across two DIFFERENT per-proc CR3s (cr3_load A->B->A every slice),
# (b) per-proc address-space isolation (same VA, separate memory), and (c) a PREEMPTIBLE
# ring-3 proc can SYSCALL safely. The timer preempts each under its own CR3 and the
# scheduler iretq's back into ring 3 (CS=0x23 — the 1.44.3 table-driven restore + the
# 1.44.4 proc_set_ring3). preempt_disable() must FREEZE both.
#
# 1.44.6 dissolved the supposed "shared-kstack wall": syscall handlers run IF=0 (SFMASK
# clears IF on SYSCALL entry) and the few sti-window syscalls are preempt-gated (1.44.1),
# so NO syscall is ever preempted mid-handler — the shared syscall kstack (0x3F0000) is
# serial, and no per-proc kernel stack is needed.
#
# The payload is RAW machine code in a byte array, NOT a Cyrius fn: a compiled fn's
# prologue does a relocate-sensitive access (CR2=0 #PF at the entry) once spawn_user_proc
# memcpy's it to the user code page at a different VA. Raw bytes have no prologue and the
# only address they touch is the absolute imm64 0x2000000, so they survive the relocation.
var ring3_counter_a = 0;
var ring3_counter_b = 0;
var ring3_pid_a = 0;
var ring3_pid_b = 0;
var ring3_payload[16];          # raw ring-3 code (proc A, getpid loop); first 22 bytes used
var ring3_elf[24];              # a minimal in-memory ELF64 for proc B (159 bytes used)
fn ring3_payload_fill() {
    # 1.44.6: each loop iteration makes a getpid SYSCALL (#2), THEN increments the
    # counter — proving a PREEMPTIBLE ring-3 proc can syscall safely. The handler runs
    # IF=0 (SFMASK clears IF on SYSCALL entry) so it is never preempted mid-syscall, and
    # the few sti-window syscalls are preempt-gated (1.44.1) — so the shared syscall
    # kstack (0x3F0000) stays serial, no per-proc kstack needed. The body re-loads the
    # counter addr each iteration because the syscall clobbers rax/rcx/r11 (rbx is
    # reloaded too, so it does not depend on the handler preserving callee-saved regs):
    #   mov eax,2 ; syscall ; movabs rbx,0x2000000 ; inc qword [rbx] ; jmp -22
    store8(&ring3_payload + 0, 0xB8);  store8(&ring3_payload + 1, 0x02);   # mov eax, 2 (getpid)
    store8(&ring3_payload + 2, 0x00);  store8(&ring3_payload + 3, 0x00);  store8(&ring3_payload + 4, 0x00);
    store8(&ring3_payload + 5, 0x0F);  store8(&ring3_payload + 6, 0x05);   # syscall
    store8(&ring3_payload + 7, 0x48);  store8(&ring3_payload + 8, 0xBB);   # movabs rbx, 0x2000000
    store8(&ring3_payload + 9, 0x00);  store8(&ring3_payload + 10, 0x00); store8(&ring3_payload + 11, 0x00); store8(&ring3_payload + 12, 0x02);
    store8(&ring3_payload + 13, 0x00); store8(&ring3_payload + 14, 0x00); store8(&ring3_payload + 15, 0x00); store8(&ring3_payload + 16, 0x00);
    store8(&ring3_payload + 17, 0x48); store8(&ring3_payload + 18, 0xFF); store8(&ring3_payload + 19, 0x03);   # inc qword [rbx]
    store8(&ring3_payload + 20, 0xEB); store8(&ring3_payload + 21, 0xEA);  # jmp -22 (back to mov eax,2)
    return 0;
}
# 1.44.8: build a minimal in-memory ELF64 for proc B — a real ELF that elf_load (the
# spawn #3 loader) parses, so this exercises the actual ELF-spawn path, not a raw memcpy.
# One PT_LOAD segment covers the whole 159-byte image at vaddr 0x400000 (header+phdr+code);
# e_entry = 0x400078 (the code, at file offset 120 = 64-byte ehdr + 56-byte phdr). The code
# is the same finite payload: count the counter to N=0x1000000, exit (#0), spin.
#   movabs rbx,0x2000000 ; movabs rcx,0x1000000 ; .L: inc [rbx]; dec rcx; jnz .L
#   ; mov eax,0 ; xor edi,edi ; syscall(exit) ; jmp -2 (spin)
fn ring3_elf_fill() {
    memset(&ring3_elf, 0, 192);
    # --- ELF64 header (64 bytes) ---
    store8(&ring3_elf + 0, 0x7F); store8(&ring3_elf + 1, 0x45); store8(&ring3_elf + 2, 0x4C); store8(&ring3_elf + 3, 0x46);  # \x7FELF
    store8(&ring3_elf + 4, 0x02);   # EI_CLASS = ELFCLASS64
    store8(&ring3_elf + 5, 0x01);   # EI_DATA = little-endian
    store8(&ring3_elf + 6, 0x01);   # EI_VERSION
    store8(&ring3_elf + 16, 0x02);  # e_type = ET_EXEC
    store8(&ring3_elf + 18, 0x3E);  # e_machine = x86-64
    store8(&ring3_elf + 20, 0x01);  # e_version
    store8(&ring3_elf + 24, 0x78); store8(&ring3_elf + 25, 0x00); store8(&ring3_elf + 26, 0x40);  # e_entry = 0x400078
    store8(&ring3_elf + 32, 0x40);  # e_phoff = 64
    store8(&ring3_elf + 52, 0x40);  # e_ehsize = 64
    store8(&ring3_elf + 54, 0x38);  # e_phentsize = 56
    store8(&ring3_elf + 56, 0x01);  # e_phnum = 1
    # --- Program header PT_LOAD (56 bytes at offset 64) ---
    store8(&ring3_elf + 64, 0x01);  # p_type = PT_LOAD
    store8(&ring3_elf + 68, 0x07);  # p_flags = R|W|X
    # p_offset = 0 (offset 72, already zero)
    store8(&ring3_elf + 82, 0x40);  # p_vaddr  = 0x400000  (byte 80+2)
    store8(&ring3_elf + 90, 0x40);  # p_paddr  = 0x400000  (byte 88+2)
    store8(&ring3_elf + 96, 0x9F);  # p_filesz = 159 (0x9F)
    store8(&ring3_elf + 104, 0x9F); # p_memsz  = 159
    store8(&ring3_elf + 113, 0x10); # p_align  = 0x1000   (byte 112+1)
    # --- code @ file offset 120 → vaddr 0x400078: count to N then exit ---
    store8(&ring3_elf + 120, 0x48); store8(&ring3_elf + 121, 0xBB);  # movabs rbx, 0x2000000
    store8(&ring3_elf + 122, 0x00); store8(&ring3_elf + 123, 0x00); store8(&ring3_elf + 124, 0x00); store8(&ring3_elf + 125, 0x02);
    store8(&ring3_elf + 126, 0x00); store8(&ring3_elf + 127, 0x00); store8(&ring3_elf + 128, 0x00); store8(&ring3_elf + 129, 0x00);
    store8(&ring3_elf + 130, 0x48); store8(&ring3_elf + 131, 0xB9);  # movabs rcx, 0x1000000
    store8(&ring3_elf + 132, 0x00); store8(&ring3_elf + 133, 0x00); store8(&ring3_elf + 134, 0x00); store8(&ring3_elf + 135, 0x01);
    store8(&ring3_elf + 136, 0x00); store8(&ring3_elf + 137, 0x00); store8(&ring3_elf + 138, 0x00); store8(&ring3_elf + 139, 0x00);
    store8(&ring3_elf + 140, 0x48); store8(&ring3_elf + 141, 0xFF); store8(&ring3_elf + 142, 0x03);  # inc qword [rbx]
    store8(&ring3_elf + 143, 0x48); store8(&ring3_elf + 144, 0xFF); store8(&ring3_elf + 145, 0xC9);  # dec rcx
    store8(&ring3_elf + 146, 0x75); store8(&ring3_elf + 147, 0xF8);  # jnz -8 (back to inc)
    store8(&ring3_elf + 148, 0xB8); store8(&ring3_elf + 149, 0x00); store8(&ring3_elf + 150, 0x00); store8(&ring3_elf + 151, 0x00); store8(&ring3_elf + 152, 0x00);  # mov eax, 0 (exit)
    store8(&ring3_elf + 153, 0x31); store8(&ring3_elf + 154, 0xFF);  # xor edi, edi (exit code 0)
    store8(&ring3_elf + 155, 0x0F); store8(&ring3_elf + 156, 0x05);  # syscall
    store8(&ring3_elf + 157, 0xEB); store8(&ring3_elf + 158, 0xFE);  # jmp -2 (spin until descheduled)
    return 0;
}
# 1.44.10: a ring-3 PARENT (proc P) that drives spawn(#3) + poll-waitpid(#4) entirely
# from RING 3 — the proof that the spawn#3 kernel-CR3 fix (syscall.cyr) lets elf_load,
# run under the PARENT's CR3, reach the child's page tables. Previously this triple-
# faulted on the child (#UD at entry) because the parent CR3 has a 256 MB-1 GB mirror gap.
#
# The parent payload is RIP-relative (position-independent): it `lea`s the embedded child
# ELF off RIP, so it needs no knowledge of the pid-dependent code_va. The child is a
# MINIMAL exit-only ELF (no memory writes → no per-child mapping needed). The parent writes
# the sentinel 0xABCD to its 0x2000000 ONLY after a SUCCESSFUL waitpid (rax>=0) — i.e. only
# if the child actually ran to exit AND the parent observed it via waitpid from ring 3.
#
#   lea  rdi, [rip+0xF9]      ; &child_elf (payload+256)
#   mov  esi, 0x83           ; child size = 131
#   mov  eax, 3 ; syscall    ; spawn -> rax = child pid (or -1)
#   test rax, rax ; js .fail  ; bail on spawn failure (no sentinel)
#   mov  rbx, rax
# .poll:
#   mov  eax, 4 ; mov rdi, rbx ; syscall   ; waitpid -> rax = exit code or -2 (WOULD_BLOCK)
#   cmp  rax, -2 ; je .poll                 ; spin in ring 3 until the child exits
#   movabs rbx, 0x2000000 ; mov dword [rbx], 0xABCD   ; sentinel = "saw child exit"
# .fail:
#   mov  eax, 0 ; xor edi, edi ; syscall    ; exit(0)
#   jmp  $
# ONE array only — the child ELF is built INLINE at offset 256 of this same array (an earlier
# two-array layout with a separate spawn_child_elf clobbered this buffer; building inline
# sidesteps any inter-global layout assumption). CAUTION: a module-global `var X[N]` reserves
# N×u64 = 8N BYTES — the codebase-wide rule (CLAUDE.md), empirically confirmed on cyrius 6.0.56
# AND 6.1.34 (`&b - &a == 80` for `var a[10]`). An earlier revision of THIS comment asserted the
# opposite ("~N bytes, NOT N×u64") — that was WRONG; do not size a buffer from it (the original
# two-array clobber had a different cause). So [4096] reserves 32 KB — ample for the parent's
# used region [0,387) and for spawn_user_proc's 4096-byte memcpy.
var spawn_parent_payload[4096];   # parent code @0, child ELF @256 (one 4 KB code page)
var spawn_parent_pid = 0;
fn spawn_parent_fill() {
    memset(&spawn_parent_payload, 0, 4096);
    # memset zeroed the page, so store ONLY the non-zero bytes, ONE store8 per line.
    # (A line packing many store8;-statements had trailing stores silently dropped by
    # the parser — P0/P2 came back wrong while a re-stored P1 on its own line was right.)
    # Success is signalled via the parent's EXIT CODE (kernel-side, read by the verify with
    # proc_get_exit_code) — NOT a user-memory counter, because the FB and an arbitrary user
    # page mapping are both unreliable under the parent CR3. The parent exit(0xABCD) ONLY
    # after a successful waitpid (child ran + exited); exit(1) if spawn itself failed.
    # lea rdi, [rip+0xF9]  (child ELF @256; disp = 256-7 = 249 = 0xF9)
    store8(&spawn_parent_payload + 0, 0x48);
    store8(&spawn_parent_payload + 1, 0x8D);
    store8(&spawn_parent_payload + 2, 0x3D);
    store8(&spawn_parent_payload + 3, 0xF9);
    # mov esi, 131
    store8(&spawn_parent_payload + 7, 0xBE);
    store8(&spawn_parent_payload + 8, 0x83);
    # mov eax, 3 (spawn)
    store8(&spawn_parent_payload + 12, 0xB8);
    store8(&spawn_parent_payload + 13, 0x03);
    # syscall
    store8(&spawn_parent_payload + 17, 0x0F);
    store8(&spawn_parent_payload + 18, 0x05);
    # mov rbx, rax (save child pid; rbx survives the waitpid syscalls)
    store8(&spawn_parent_payload + 19, 0x48);
    store8(&spawn_parent_payload + 20, 0x89);
    store8(&spawn_parent_payload + 21, 0xC3);
    # test ebx, ebx  (32-bit: spawn failed if negative)
    store8(&spawn_parent_payload + 22, 0x85);
    store8(&spawn_parent_payload + 23, 0xDB);
    # js .fail (rel +0x1D -> off 55)
    store8(&spawn_parent_payload + 24, 0x78);
    store8(&spawn_parent_payload + 25, 0x1D);
    # .poll @ off 26: mov eax, 4 (waitpid)
    store8(&spawn_parent_payload + 26, 0xB8);
    store8(&spawn_parent_payload + 27, 0x04);
    # mov rdi, rbx
    store8(&spawn_parent_payload + 31, 0x48);
    store8(&spawn_parent_payload + 32, 0x89);
    store8(&spawn_parent_payload + 33, 0xDF);
    # syscall
    store8(&spawn_parent_payload + 34, 0x0F);
    store8(&spawn_parent_payload + 35, 0x05);
    # cmp eax, -2  (32-bit WOULD_BLOCK check)
    store8(&spawn_parent_payload + 36, 0x83);
    store8(&spawn_parent_payload + 37, 0xF8);
    store8(&spawn_parent_payload + 38, 0xFE);
    # je .poll (rel -15 = 0xF1 -> off 26)
    store8(&spawn_parent_payload + 39, 0x74);
    store8(&spawn_parent_payload + 40, 0xF1);
    # child exited: mov eax, 0 (exit)
    store8(&spawn_parent_payload + 41, 0xB8);
    # mov edi, 0xABCD (success exit code)
    store8(&spawn_parent_payload + 46, 0xBF);
    store8(&spawn_parent_payload + 47, 0xCD);
    store8(&spawn_parent_payload + 48, 0xAB);
    # syscall (exit 0xABCD)
    store8(&spawn_parent_payload + 51, 0x0F);
    store8(&spawn_parent_payload + 52, 0x05);
    # jmp -2 (spin until descheduled — exit() RETURNS to ring 3; the scheduler retires the
    # state-0 proc on the next tick, so the proc must spin here, not fall into zero bytes)
    store8(&spawn_parent_payload + 53, 0xEB);
    store8(&spawn_parent_payload + 54, 0xFE);
    # .fail @ off 55: mov eax, 0 (exit)
    store8(&spawn_parent_payload + 55, 0xB8);
    # mov edi, 1 (failure exit code)
    store8(&spawn_parent_payload + 60, 0xBF);
    store8(&spawn_parent_payload + 61, 0x01);
    # syscall (exit 1)
    store8(&spawn_parent_payload + 65, 0x0F);
    store8(&spawn_parent_payload + 66, 0x05);
    # jmp -2 (spin)
    store8(&spawn_parent_payload + 67, 0xEB);
    store8(&spawn_parent_payload + 68, 0xFE);
    # --- child ELF built INLINE at payload offset 256 (the lea target): a minimal
    # exit-only ELF64 (no memory writes → needs no per-child page mapping). 131 bytes.
    # memset already zeroed this region; store only the non-zero bytes, one per line.
    # ehdr:
    store8(&spawn_parent_payload + 256, 0x7F);
    store8(&spawn_parent_payload + 257, 0x45);
    store8(&spawn_parent_payload + 258, 0x4C);
    store8(&spawn_parent_payload + 259, 0x46);
    store8(&spawn_parent_payload + 260, 0x02);
    store8(&spawn_parent_payload + 261, 0x01);
    store8(&spawn_parent_payload + 262, 0x01);
    store8(&spawn_parent_payload + 272, 0x02);
    store8(&spawn_parent_payload + 274, 0x3E);
    store8(&spawn_parent_payload + 276, 0x01);
    store8(&spawn_parent_payload + 280, 0x78);
    store8(&spawn_parent_payload + 282, 0x40);
    store8(&spawn_parent_payload + 288, 0x40);
    store8(&spawn_parent_payload + 308, 0x40);
    store8(&spawn_parent_payload + 310, 0x38);
    store8(&spawn_parent_payload + 312, 0x01);
    # phdr (offset 64 within the child → payload 320):
    store8(&spawn_parent_payload + 320, 0x01);
    store8(&spawn_parent_payload + 324, 0x07);
    store8(&spawn_parent_payload + 338, 0x40);
    store8(&spawn_parent_payload + 346, 0x40);
    store8(&spawn_parent_payload + 352, 0x83);
    store8(&spawn_parent_payload + 360, 0x83);
    store8(&spawn_parent_payload + 369, 0x10);
    # code (file offset 120 within the child → payload 376): exit(0), spin
    store8(&spawn_parent_payload + 376, 0xB8);
    store8(&spawn_parent_payload + 381, 0x31);
    store8(&spawn_parent_payload + 382, 0xFF);
    store8(&spawn_parent_payload + 383, 0x0F);
    store8(&spawn_parent_payload + 384, 0x05);
    store8(&spawn_parent_payload + 385, 0xEB);
    store8(&spawn_parent_payload + 386, 0xFE);
    return 0;
}
# 1.44.x schedulable-agnsh — validate spawn_path(#43) end-to-end. The from-disk analog of
# the spawn_parent (#3) proof above: a ring-3 PARENT issues spawn_path(#43) on an ext2 path
# ("/bin/prog2", seeded by exec_disk_selftest), poll-waitpid(#4)s the returned pid, and EXITs
# with the child's exit code (prog2 = 42) — proving #43 made a READY ring-3 proc the scheduler
# picked up AND the parent reaped it via the non-blocking #4 (the exact pair agnsh `&` will use).
# This is what agnsh `&` does in kernel form; agnsh must NOT be the thing that first proves #43.
# Identical structure to spawn_parent_fill EXCEPT: mov eax,43 (not 3); arg2=10 (path len); the
# lea target is an inline cstring "/bin/prog2" (not a child ELF); exit propagates rax (child
# code) so a green assert is the literal 42 round-tripped through #43+#4. Runs ONLY when
# ext2_active (the exec-smoke disk profile) — no-op under the ring3-smoke VirtIO profile.
var spawn_path_parent_payload[4096];   # parent code @0, "/bin/prog2" cstring @256
var spawn_path_parent_pid = 0;
fn spawn_path_parent_fill() {
    memset(&spawn_path_parent_payload, 0, 4096);
    # store ONLY non-zero bytes, ONE store8 per line (multi-store8-per-line parser-drop caveat).
    # lea rdi, [rip+0xF9]  (cstring @256; disp = 256-7 = 249 = 0xF9 — same as spawn_parent's lea)
    store8(&spawn_path_parent_payload + 0, 0x48);
    store8(&spawn_path_parent_payload + 1, 0x8D);
    store8(&spawn_path_parent_payload + 2, 0x3D);
    store8(&spawn_path_parent_payload + 3, 0xF9);
    # mov esi, 10  (path length of "/bin/prog2")
    store8(&spawn_path_parent_payload + 7, 0xBE);
    store8(&spawn_path_parent_payload + 8, 0x0A);
    # mov eax, 43 (spawn_path)
    store8(&spawn_path_parent_payload + 12, 0xB8);
    store8(&spawn_path_parent_payload + 13, 0x2B);
    # syscall
    store8(&spawn_path_parent_payload + 17, 0x0F);
    store8(&spawn_path_parent_payload + 18, 0x05);
    # mov rbx, rax (save child pid; survives waitpid syscalls)
    store8(&spawn_path_parent_payload + 19, 0x48);
    store8(&spawn_path_parent_payload + 20, 0x89);
    store8(&spawn_path_parent_payload + 21, 0xC3);
    # test ebx, ebx  (spawn failed if negative)
    store8(&spawn_path_parent_payload + 22, 0x85);
    store8(&spawn_path_parent_payload + 23, 0xDB);
    # js .fail (rel +0x1A -> off 52)
    store8(&spawn_path_parent_payload + 24, 0x78);
    store8(&spawn_path_parent_payload + 25, 0x1A);
    # .poll @ off 26: mov eax, 4 (waitpid)
    store8(&spawn_path_parent_payload + 26, 0xB8);
    store8(&spawn_path_parent_payload + 27, 0x04);
    # mov rdi, rbx
    store8(&spawn_path_parent_payload + 31, 0x48);
    store8(&spawn_path_parent_payload + 32, 0x89);
    store8(&spawn_path_parent_payload + 33, 0xDF);
    # syscall
    store8(&spawn_path_parent_payload + 34, 0x0F);
    store8(&spawn_path_parent_payload + 35, 0x05);
    # cmp eax, -2  (WOULD_BLOCK while child alive)
    store8(&spawn_path_parent_payload + 36, 0x83);
    store8(&spawn_path_parent_payload + 37, 0xF8);
    store8(&spawn_path_parent_payload + 38, 0xFE);
    # je .poll (rel -15 = 0xF1 -> off 26)
    store8(&spawn_path_parent_payload + 39, 0x74);
    store8(&spawn_path_parent_payload + 40, 0xF1);
    # child exited: mov edi, eax (propagate the child's exit code = prog2's 42)
    store8(&spawn_path_parent_payload + 41, 0x89);
    store8(&spawn_path_parent_payload + 42, 0xC7);
    # mov eax, 0 (exit)
    store8(&spawn_path_parent_payload + 43, 0xB8);
    # syscall (exit child-code)
    store8(&spawn_path_parent_payload + 48, 0x0F);
    store8(&spawn_path_parent_payload + 49, 0x05);
    # jmp -2 (spin until descheduled)
    store8(&spawn_path_parent_payload + 50, 0xEB);
    store8(&spawn_path_parent_payload + 51, 0xFE);
    # .fail @ off 52: mov eax, 0 (exit)
    store8(&spawn_path_parent_payload + 52, 0xB8);
    # mov edi, 1 (failure exit code — distinguishes a #43 spawn-fail from a real child code)
    store8(&spawn_path_parent_payload + 57, 0xBF);
    store8(&spawn_path_parent_payload + 58, 0x01);
    # syscall (exit 1)
    store8(&spawn_path_parent_payload + 62, 0x0F);
    store8(&spawn_path_parent_payload + 63, 0x05);
    # jmp -2 (spin)
    store8(&spawn_path_parent_payload + 64, 0xEB);
    store8(&spawn_path_parent_payload + 65, 0xFE);
    # cstring "/bin/prog2" @256 (the lea target; len 10, no NUL needed — #43 is length-based)
    store8(&spawn_path_parent_payload + 256, 0x2F);   # '/'
    store8(&spawn_path_parent_payload + 257, 0x62);   # 'b'
    store8(&spawn_path_parent_payload + 258, 0x69);   # 'i'
    store8(&spawn_path_parent_payload + 259, 0x6E);   # 'n'
    store8(&spawn_path_parent_payload + 260, 0x2F);   # '/'
    store8(&spawn_path_parent_payload + 261, 0x70);   # 'p'
    store8(&spawn_path_parent_payload + 262, 0x72);   # 'r'
    store8(&spawn_path_parent_payload + 263, 0x6F);   # 'o'
    store8(&spawn_path_parent_payload + 264, 0x67);   # 'g'
    store8(&spawn_path_parent_payload + 265, 0x32);   # '2'
    return 0;
}
# Spawn one ring-3 proc and map its 0x2000000 onto `counter_phys`. -1 on fail.
fn ring3_spawn_one(counter_phys) {
    var pid = spawn_user_proc(&ring3_payload);       # per-proc CR3 + user code/stack, state=ready
    if (pid < 0) { return 0 - 1; }
    proc_map_page(proc_get_cr3(pid), 0x2000000, counter_phys);   # this proc's OWN CR3 -> its own counter
    proc_set_ring3(pid);                             # CS=0x23 / SS=0x1B (else it would iretq into ring 0)
    return pid;
}
# 1.44.x page-table-fix validation: a NO-WRITE getpid-loop payload for STRESS procs that
# push the pid count to >=8, so the in-memory loaders' user code/stack land in PD[8..63]
# (>=16 MB) — the exact region whose identity-SUPERVISOR map the OLD striped VAs overwrote.
# Pure compute + syscall (no memory write → no per-proc counter needed): each loops
# `getpid` forever, staying ready so the scheduler keeps context-switching to it. PRE-fix,
# the context-switch proc_get_user_cr3(corrupted CR3) SMAP-faults (triple fault → no output);
# POST-fix all stress procs stay live. mov eax,2; syscall; jmp -9 (back to mov).
var ring3_idle_payload[16];
var ring3_stress_first = 0;
var ring3_stress_count = 0;
# 1.44.16 sched_yield(#44) proof: a YIELDER payload — yield, check rax==0, bump the
# counter, loop. The rax check bakes the return-value contract into the assertion: a
# nonzero return jumps to the spin and FREEZES the counter (test fails). Its counter
# advances ~1 per rotation (it donates every slice), so the non-yielder A's counter must
# dwarf it — the RATIO is the slice-donation proof, and it's TCG-speed-independent.
#   .top: mov eax,44; syscall; test rax,rax; jnz .spin; movabs rbx,0x2000000;
#         inc qword [rbx]; jmp .top;  .spin: jmp $
var ring3_yield_payload[64];
var ring3_counter_y = 0;
var ring3_pid_y = 0;
fn ring3_yield_fill() {
    store8(&ring3_yield_payload + 0, 0xB8);    # mov eax, 44 (sched_yield)
    store8(&ring3_yield_payload + 1, 0x2C);
    store8(&ring3_yield_payload + 2, 0x00);
    store8(&ring3_yield_payload + 3, 0x00);
    store8(&ring3_yield_payload + 4, 0x00);
    store8(&ring3_yield_payload + 5, 0x0F);    # syscall
    store8(&ring3_yield_payload + 6, 0x05);
    store8(&ring3_yield_payload + 7, 0x48);    # test rax, rax
    store8(&ring3_yield_payload + 8, 0x85);
    store8(&ring3_yield_payload + 9, 0xC0);
    store8(&ring3_yield_payload + 10, 0x75);   # jnz +15 -> .spin (nonzero return = freeze)
    store8(&ring3_yield_payload + 11, 0x0F);
    store8(&ring3_yield_payload + 12, 0x48);   # movabs rbx, 0x2000000 (the counter VA)
    store8(&ring3_yield_payload + 13, 0xBB);
    store8(&ring3_yield_payload + 14, 0x00);
    store8(&ring3_yield_payload + 15, 0x00);
    store8(&ring3_yield_payload + 16, 0x00);
    store8(&ring3_yield_payload + 17, 0x02);
    store8(&ring3_yield_payload + 18, 0x00);
    store8(&ring3_yield_payload + 19, 0x00);
    store8(&ring3_yield_payload + 20, 0x00);
    store8(&ring3_yield_payload + 21, 0x00);
    store8(&ring3_yield_payload + 22, 0x48);   # inc qword [rbx]
    store8(&ring3_yield_payload + 23, 0xFF);
    store8(&ring3_yield_payload + 24, 0x03);
    store8(&ring3_yield_payload + 25, 0xEB);   # jmp -27 -> .top
    store8(&ring3_yield_payload + 26, 0xE5);
    store8(&ring3_yield_payload + 27, 0xEB);   # .spin: jmp $
    store8(&ring3_yield_payload + 28, 0xFE);
    return 0;
}
fn ring3_idle_fill() {
    store8(&ring3_idle_payload + 0, 0xB8);   # mov eax, 2 (getpid)
    store8(&ring3_idle_payload + 1, 0x02);
    store8(&ring3_idle_payload + 2, 0x00);
    store8(&ring3_idle_payload + 3, 0x00);
    store8(&ring3_idle_payload + 4, 0x00);
    store8(&ring3_idle_payload + 5, 0x0F);   # syscall
    store8(&ring3_idle_payload + 6, 0x05);
    store8(&ring3_idle_payload + 7, 0xEB);   # jmp -9 (back to off 0)
    store8(&ring3_idle_payload + 8, 0xF7);
    return 0;
}
# Spawn one stress proc (no counter, no 0x2000000 map). -1 on fail.
fn ring3_spawn_idle() {
    var pid = spawn_user_proc(&ring3_idle_payload);
    if (pid < 0) { return 0 - 1; }
    proc_set_ring3(pid);
    return pid;
}
# 1.44.x non-LIFO reap proof: a minimal exit-only ring-3 payload (no memory write → no
# counter map needed): mov eax,0; xor edi,edi; syscall(exit 0); jmp $ (spin until reaped).
var ring3_exit_payload[16];
fn ring3_exit_fill() {
    store8(&ring3_exit_payload + 0, 0xB8);   # mov eax, 0 (exit)
    store8(&ring3_exit_payload + 1, 0x00);
    store8(&ring3_exit_payload + 2, 0x00);
    store8(&ring3_exit_payload + 3, 0x00);
    store8(&ring3_exit_payload + 4, 0x00);
    store8(&ring3_exit_payload + 5, 0x31);   # xor edi, edi (code 0)
    store8(&ring3_exit_payload + 6, 0xFF);
    store8(&ring3_exit_payload + 7, 0x0F);   # syscall
    store8(&ring3_exit_payload + 8, 0x05);
    store8(&ring3_exit_payload + 9, 0xEB);   # jmp -2 (spin)
    store8(&ring3_exit_payload + 10, 0xFE);
    return 0;
}
# Prove the NON-LIFO proc-table-slot reclaim. Runs FIRST in selftest-setup on a DENSE table
# (only proc 0 + idle, no holes) for deterministic pids, then fully cleans up so the main
# selftest starts fresh. Spawn A (exits) then B (stays alive) — A takes the lower slot so it
# sits BELOW B; reaping A is a NON-TOP reap → A's slot becomes a mid-range hole; the next spawn
# (C) must REUSE that hole (pidC == pidA, proc_count unchanged) rather than append. Also proves
# proc_alloc_slot CLEARS the recycled slot's pending-signal state. Pre-fix: C appends (pidC !=
# pidA, proc_count grows, A's slot leaks) and a stale signal survives. KERNEL context (direct
# spawn/reap, not ring-3 syscalls).
fn ring3_nonlifo_check() {
    ring3_exit_fill();
    var pidA = spawn_user_proc(&ring3_exit_payload);   # A: exits (lower slot — spawned first)
    if (pidA < 0) { kprintln("ring3: FAIL nonlifo (no A)", 26); return 0; }
    proc_set_ring3(pidA);
    var pidB = ring3_spawn_idle();                     # B: stays alive, ABOVE A → A non-top
    if (pidB < 0) { kprintln("ring3: FAIL nonlifo (no B)", 26); return 0; }
    var w = 0;                                         # drive scheduler until A exits, bounded
    while (w < 3000) {
        if (proc_get_state(pidA) == 0) { w = 3000; } else { arch_wait(); w = w + 1; }
    }
    proc_send_signal(pidA, 10);                        # stamp a pending signal on A's (dead) slot
    proc_reap_child(pidA);                             # NON-TOP reap (B above) → A's slot is a hole
    var pc1 = proc_count;                              # high-water mark AFTER the non-top reap
    var pidC = spawn_user_proc(&ring3_exit_payload);   # C: must REUSE A's hole (created, not run)
    var sig = proc_check_pending_signals(pidC);        # must be 0 — proc_alloc_slot cleared it
    kprint("ring3: nl A=", 12); kprint_num(pidA); kprint(" B=", 3); kprint_num(pidB); kprint(" C=", 3); kprint_num(pidC); kprint(" pc1=", 5); kprint_num(pc1); kprint(" pc=", 4); kprint_num(proc_count); kprintln("", 0);
    if (pidC == pidA) {
        if (proc_count == pc1) { kprintln("ring3: nonlifo reuse OK", 23); }   # reused, no append
        else { kprintln("ring3: FAIL nonlifo leak", 24); }
    } else { kprintln("ring3: FAIL nonlifo leak", 24); }
    if (sig == 0) { kprintln("ring3: nonlifo signal clear OK", 30); } else { kprintln("ring3: FAIL nonlifo signal", 26); }
    # Clean up TOP-DOWN so the LIFO collapse returns proc_count to its pre-check value (dense
    # table for the main selftest). Higher pid first: B then C.
    if (pidB > pidC) {
        proc_set_state(pidB, 0); proc_reap_child(pidB);
        proc_set_state(pidC, 0); proc_reap_child(pidC);
    } else {
        proc_set_state(pidC, 0); proc_reap_child(pidC);
        proc_set_state(pidB, 0); proc_reap_child(pidB);
    }
    return 0;
}
fn ring3_selftest_setup() {
    ring3_nonlifo_check();                            # non-LIFO slot-reuse proof on a dense table (cleans up after)
    ring3_counter_a = pmm_alloc_2mb();               # 2 MB-aligned — proc_map_page maps a 2 MB page
    ring3_counter_b = pmm_alloc_2mb();
    if (ring3_counter_a == 0) { return 0; }
    if (ring3_counter_b == 0) { return 0; }
    if (vmm_is_mapped(ring3_counter_a) == 0) { vmm_map(ring3_counter_a, ring3_counter_a, 0x83); }
    if (vmm_is_mapped(ring3_counter_b) == 0) { vmm_map(ring3_counter_b, ring3_counter_b, 0x83); }
    store64(ring3_counter_a, 0);
    store64(ring3_counter_b, 0);
    ring3_payload_fill();                            # A: getpid (infinite "stays live")
    ring3_pid_a = ring3_spawn_one(ring3_counter_a);
    # B = a real in-memory ELF (finite count + exit) loaded by elf_load — the spawn #3
    # loader, which (1.44.8) sets ring-3 selectors + state=ready (proc_create_full).
    ring3_elf_fill();
    ring3_pid_b = elf_load(&ring3_elf, 159);
    if (ring3_pid_b >= 0) { proc_map_page(proc_get_cr3(ring3_pid_b), 0x2000000, ring3_counter_b); }
    # P = a ring-3 PARENT that spawn(#3)s + poll-waitpid(#4)s a child ELF entirely from
    # ring 3 (1.44.10). Unlike B (loaded by a KERNEL-context elf_load), P invokes spawn as
    # a SYSCALL under its own CR3 — the path the kernel-CR3 fix unblocks. P makes no memory
    # writes (only spawn/waitpid/exit syscalls), so it needs NO 0x2000000 mapping; success
    # is its exit code 0xABCD (read by the verify via proc_get_exit_code). proc_create_full
    # already left it state=ready; only proc_set_ring3 (ring-3 selectors) is needed.
    spawn_parent_fill();
    spawn_parent_pid = spawn_user_proc(&spawn_parent_payload);
    if (spawn_parent_pid >= 0) { proc_set_ring3(spawn_parent_pid); }
    # Y = the 1.44.16 sched_yield(#44) YIELDER (own counter at its 0x2000000, like A).
    # Spawned BEFORE the stress block so the stress pids stay contiguous.
    ring3_counter_y = pmm_alloc_2mb();
    if (ring3_counter_y != 0) {
        if (vmm_is_mapped(ring3_counter_y) == 0) { vmm_map(ring3_counter_y, ring3_counter_y, 0x83); }
        store64(ring3_counter_y, 0);
        ring3_yield_fill();
        ring3_pid_y = spawn_user_proc(&ring3_yield_payload);
        if (ring3_pid_y >= 0) {
            proc_map_page(proc_get_cr3(ring3_pid_y), 0x2000000, ring3_counter_y);
            proc_set_ring3(ring3_pid_y);
        }
    }
    # STRESS: spawn 4 extra ring-3 procs (pids ~5-8) so the in-memory loaders' user code
    # (0x400000 striped → 16 MB at pid 6 pre-fix) + stack land in PD[8..63]. With ~9 procs
    # the pmm pushes page-table pages into the same 16-128 MB region — so PRE-fix a context
    # switch SMAP-faults; POST-fix all stay live. Created AFTER P so P's spawn-child (created
    # when P runs) stays the TOP proc-table slot → P's waitpid reap LIFO stays valid.
    ring3_idle_fill();
    ring3_stress_first = ring3_spawn_idle();
    ring3_stress_count = 1;
    var ski = 1;
    while (ski < 4) {
        if (ring3_spawn_idle() >= 0) { ring3_stress_count = ring3_stress_count + 1; }
        ski = ski + 1;
    }
    # 1.44.x: spawn_path(#43) validator — ONLY under the exec-smoke disk profile (ext2_active),
    # where exec_disk_selftest has already seeded /bin/prog2. Spawned LAST so the stress procs
    # keep their contiguous slots; its from-disk child + P's child reap out-of-order, exercising
    # the 1.44.12 non-LIFO reclaim. No-op under the ring3-smoke VirtIO profile (ext2_active==0).
    if (ext2_active != 0) {
        spawn_path_parent_fill();
        spawn_path_parent_pid = spawn_user_proc(&spawn_path_parent_payload);
        if (spawn_path_parent_pid >= 0) { proc_set_ring3(spawn_path_parent_pid); }
    }
    return 0;
}
fn ring3_selftest_verify() {
    # Run the scheduler until BOTH proc B (the kernel-loaded ELF) exits AND the ring-3
    # PARENT P has written its sentinel (child spawned + waitpid'd from ring 3), or a
    # generous tick budget. A loops forever (the "stays live" proc); B counts to N then
    # exit()s; P spawns C, polls waitpid, then exits — all time-sliced. Budget is larger
    # than the B-only era (400) because four procs now share the round-robin.
    var i = 0;
    while (i < 3000) {
        var bp_done = 0;
        if (proc_get_state(ring3_pid_b) == 0) {
            if (proc_get_state(spawn_parent_pid) == 0) { bp_done = 1; }
        }
        # spawn_path_parent (#43 validator) loads prog2 from DISK — slower than B/P's in-memory
        # spawn — so the early-exit must wait for it too (else verify reads a still-running SP).
        var sp_done = 1;
        if (spawn_path_parent_pid > 0) {
            if (proc_get_state(spawn_path_parent_pid) != 0) { sp_done = 0; }
        }
        if (bp_done == 1) {
            if (sp_done == 1) { i = 3000; }                # all done — stop early
            else { arch_wait(); i = i + 1; }
        } else { arch_wait(); i = i + 1; }
    }
    var ca = load64(ring3_counter_a);
    var cb = load64(ring3_counter_b);
    var bstate = proc_get_state(ring3_pid_b);
    kprint("ring3: A=", 9); kprint_num(ca); kprint(" B=", 3); kprint_num(cb); kprint(" Bst=", 5); kprint_num(bstate); kprintln("", 0);
    # B (real ELF) ran to completion (counter == N) and exited (state 0) WHILE A kept running.
    if (bstate == 0) {
        if (cb == 16777216) {
            if (ca > 0) { kprintln("ring3: child exited", 19); }
            else { kprintln("ring3: FAIL A idle", 18); }
        } else { kprintln("ring3: FAIL B partial", 21); }
    } else { kprintln("ring3: FAIL B hung", 18); }
    # A is still live + preemptible — proves "another proc stays live".
    if (ca > 0) { kprintln("ring3: preempt OK", 17); } else { kprintln("ring3: FAIL no A", 16); }
    # P (ring-3 PARENT) spawn(#3)ed a child ELF + poll-waitpid(#4)ed it to exit, all from
    # ring 3, then exit(0xABCD). The exit code is set ONLY after a successful waitpid, so
    # 0xABCD proves the spawn#3 kernel-CR3 fix end-to-end (the child's tables were wired
    # correctly under the parent's CR3; the #UD-at-child blocker is gone). Pst 0 = P exited.
    var pcode = proc_get_exit_code(spawn_parent_pid);
    var pstate = proc_get_state(spawn_parent_pid);
    kprint("ring3: Pcode=", 13); kprint_num(pcode); kprint(" Pst=", 5); kprint_num(pstate); kprintln("", 0);
    if (pcode == 0xABCD) { kprintln("ring3: parent spawn+wait OK", 27); } else { kprintln("ring3: FAIL parent spawn", 24); }
    # spawn_path(#43) end-to-end: the ring-3 SP-parent issued spawn_path(#43) on "/bin/prog2"
    # (from DISK, non-blocking), poll-waitpid(#4)ed it, and exited with prog2's code (42). 42
    # proves #43 made a READY ring-3 proc the scheduler ran AND #4 reaped its real exit code —
    # the exact non-blocking spawn+reap agnsh `&` uses. Only present under the ext2 disk profile.
    if (spawn_path_parent_pid > 0) {
        var spcode = proc_get_exit_code(spawn_path_parent_pid);
        var spstate = proc_get_state(spawn_path_parent_pid);
        kprint("ring3: SPcode=", 14); kprint_num(spcode); kprint(" SPst=", 6); kprint_num(spstate); kprintln("", 0);
        if (spcode == 42) { kprintln("ring3: spawnpath OK", 19); } else { kprintln("ring3: FAIL spawnpath", 21); }
    }
    # STRESS / page-table-fix proof: every extra proc (pids pushed into PD[8..63]) is still
    # ALIVE (state 1) after the scheduler round-robined to it many times. Reaching this print
    # AT ALL means no context switch SMAP-faulted (pre-fix the machine triple-faults here and
    # NOTHING prints). All-alive = the de-striped VAs kept the identity-supervisor pool map
    # intact across >=8 concurrent ring-3 procs.
    var salive = 0;
    var spi = 0;
    while (spi < ring3_stress_count) {
        if (proc_get_state(ring3_stress_first + spi) == 1) { salive = salive + 1; }
        spi = spi + 1;
    }
    kprint("ring3: stress alive=", 20); kprint_num(salive); kprint("/", 1); kprint_num(ring3_stress_count); kprintln("", 0);
    if (salive == ring3_stress_count) { kprintln("ring3: stress OK", 16); } else { kprintln("ring3: FAIL stress", 18); }
    # Retire the stress procs (they loop forever) so boot continues.
    var srp = 0;
    while (srp < ring3_stress_count) { proc_set_state(ring3_stress_first + srp, 0); srp = srp + 1; }
    # 1.44.16 sched_yield(#44): the YIELDER Y donated every slice. (i) cy > 0 proves the
    # abandon-frame round trip — Y was resumed in ring 3 at the post-SYSCALL RIP with
    # rax==0 AND its callee-saved/RSP state intact (any breakage spins, faults, or freezes
    # the counter). (ii) ca >> cy (10x) proves the yield actually ENDS the slice — a
    # silently-non-switching yield (all guards refusing) would make Y a busy increment
    # loop with cy ~= ca and FAIL the ratio. The RATIO is TCG-speed-independent.
    if (ring3_pid_y > 0) {
        var cy = load64(ring3_counter_y);
        var cay = load64(ring3_counter_a);
        kprint("ring3: Y=", 9); kprint_num(cy); kprint(" A=", 3); kprint_num(cay); kprintln("", 0);
        if (cy > 0) {
            if (cay > cy * 10) { kprintln("ring3: yield OK", 15); }
            else { kprintln("ring3: FAIL yield ratio", 23); }
        } else { kprintln("ring3: FAIL yield dead", 22); }
        proc_set_state(ring3_pid_y, 0);              # retire Y; boot continues
    }
    # Preempt gate still covers the live proc A.
    var sa = load64(ring3_counter_a);
    preempt_disable();
    var g = 0;
    while (g < 20) { arch_wait(); g = g + 1; }
    preempt_enable();
    if (load64(ring3_counter_a) == sa) { kprintln("ring3: gate held", 16); } else { kprintln("ring3: gate LEAK", 16); }
    proc_set_state(ring3_pid_a, 0);                  # retire the surviving proc A; boot continues
    kprintln("ring3: done", 11);
    return 0;
}
#endif

#ifndef KTEST
proc_count = 0;
proc_current = 0;
proc_create(0);                 # proc 0 = kernel main (running now; context saved on first switch-away)
proc_set_state(0, 2);           # running
sched_idle_pid = kthread_create(&kernel_idle_loop);  # proc 1 = idle (ready) — 1.44.1: via the kthread primitive (pool stack); 1.44.17: registered so sched_next deprioritizes it (idle runs only when nothing else is ready)
#ifdef THREAD_SELFTEST
# 1.44.0 opening bite: spawn two kernel threads on the shared AS (tight-loopers).
thr_pid_a = kthread_create(&thread_test_a);
thr_pid_b = kthread_create(&thread_test_b);
#endif
#ifdef RING3_SELFTEST
# 1.44.4: spawn + map + ring-3-ify a single user proc before the scheduler arms.
ring3_selftest_setup();
#endif
#endif

sched_active = 1;

# === CMOS kernel checkpoint 16 (scheduler armed) ===
# This is the AGNOS MVP closed-beta gate: reaching CP 16 means kernel
# init succeeded end-to-end through scheduler activation. Subsequent
# stall (no CP 17 ever emitted, no shell prompt) is a scheduler /
# context-switch issue, not an init issue. Held since Attempt 16.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x10; 0xE6; 0x71; }

#ifdef THREAD_SELFTEST
# 1.44.0 opening bite: prove preemptive kernel-thread time-slicing + the preempt
# gate on the live scheduler, then retire the test threads so boot continues.
thread_selftest_verify();
#endif

#ifdef RING3_SELFTEST
# 1.44.4: prove a ring-3 proc (own CR3, IF=1) is preempted + resumed by the scheduler.
ring3_selftest_verify();
#endif

#ifdef KTEST
# Kernel idle loop: halts, wakes on timer, scheduler switches to A or B
# After enough ticks, deactivate and report
var idle_count = 0;
while (idle_count < 50) {
    arch_wait();
    if (idle_count == 0) {
        # CMOS CP 0x12: first hlt returned — timer ISR + first context-switch round-trip OK
        asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x12; 0xE6; 0x71; }
    }
    if (idle_count == 9) {
        # CMOS CP 0x13: 10 hlts done — matches QEMU's known-good count under gnoboot
        asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x13; 0xE6; 0x71; }
    }
    if (idle_count == 24) {
        # CMOS CP 0x14: 25 hlts done — between QEMU known-good and loop end
        asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x14; 0xE6; 0x71; }
    }
    idle_count = idle_count + 1;
}

# Deactivate scheduler, report results
sched_active = 0;
# CMOS CP 0x11: post-scheduler idle loop completed
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x11; 0xE6; 0x71; }
kprintln("", 0);
kprint("Scheduler test done. Timer ticks: ", 34);
kprint_num(timer_ticks);
kprintln("", 0);
#endif

#ifdef KTEST
# === Memory Isolation Test ===
# VFS + initrd test
kprint("VFS write: ", 11);
vfs_write(0, "OK\n", 3);

# Build and mount test initrd at 0x6000 (free page table area)
initrd_build_test(0x6000);
var nfiles = initrd_init(0x6000);
kprint("Initrd: ", 8);
kprint_num(nfiles);
kprintln(" files", 6);

# Open and read hello.txt
var hfd = initrd_open("hello.txt", 9);
var hbuf[16];
var hn = vfs_read(hfd, &hbuf, 14);
kprint("initrd hello.txt: ", 18);
kprint(&hbuf, hn);
vfs_close(hfd);

# Open and read test
var tfd = initrd_open("test", 4);
var tbuf[8];
var tn = vfs_read(tfd, &tbuf, 5);
kprint("initrd test: ", 13);
kprint(&tbuf, tn);
vfs_close(tfd);
var mf = vfs_create_memfile("HELLO", 5);
var rbuf[8];
var rn = vfs_read(mf, &rbuf, 5);
kprint("VFS memfile read: ", 18);
kprint(&rbuf, rn);
kprintln("", 0);
vfs_close(mf);
# CMOS CP 0x12: post-VFS / initrd / memfile tests
