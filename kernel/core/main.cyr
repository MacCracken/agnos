# === 64-bit Cyrius kernel code ===

serial_println("AGNOS kernel v1.30.0", 20);
serial_println("64-bit long mode", 16);

# Bisector 0x80: about to call gdt_init. If we see 5 but not 0x80,
# the fault is in one of the two serial_println calls above.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x80; 0xE6; 0x71; }
cp_fb(0x80, 0x00FFFF00);  # YELLOW — early arch

gdt_init();
serial_println("GDT loaded", 10);

# Bisector 0x81: gdt_init returned, about to call tss_init.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x81; 0xE6; 0x71; }
cp_fb(0x81, 0x00FFFF00);  # YELLOW — early arch

tss_init();
serial_println("TSS loaded (ring 3 ready)", 25);

# Bisector 0x82: tss_init returned, about to call idt_init.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x82; 0xE6; 0x71; }
cp_fb(0x82, 0x00FFFF00);  # YELLOW — early arch

idt_init();
serial_println("IDT loaded", 10);

# === CMOS kernel checkpoint 6 (arch interrupts ready: GDT+TSS+IDT) ===
# Pairs with boot_shim CPs 1-5 (early entry) and gnoboot CPs 1-5 (pre-jmp,
# CMOS[0x52]/[0x53]). Decoded by agnosticos/scripts/read-boot-log.sh.
# Slot map: 0x50 = kernel CP, 0x51 = kernel magic, 0x52/0x53 = gnoboot.
# (Pre-2026-05-14 builds used 0x40-0x43; BIOS on archaemenid was
# observed writing 0x42/0x43/0x44 every cold boot, so the whole 4-byte
# scheme shifted +0x10 into the virgin 0x50-0x7F CMOS region.)
# 8 bytes, clobbers AL only.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x06; 0xE6; 0x71; }
cp_fb(0x06, 0x00FFFF00);  # YELLOW — GDT+TSS+IDT loaded

pic_init();
serial_println("PIC remapped", 12);

timer_ticks = 0;
timer_isr_build();
idt_set_gate(&idt + 32 * 16, &timer_isr, 0x08, 0x8E);
serial_println("Timer ISR installed", 19);

# Initialize Local APIC (keeps PIC for keyboard IRQ1)
apic_init();
# Start APIC timer on vector 32 (same as PIT), ~100Hz
# QEMU bus freq varies; 10000000 gives roughly 100Hz
apic_timer_init(32, 10000000);
serial_print("APIC: id=", 9);
kprint_num(cpu_id);
serial_println(" timer active", 13);

# === CMOS kernel checkpoint 7 (APIC + timer live) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x07; 0xE6; 0x71; }
cp_fb(0x07, 0x0000FF00);  # GREEN — APIC + timer live

# Start Application Processors
cpu_count = 1;
ap_ready = 0;
smp_lock = 0;
smp_start_aps();
serial_print("SMP: ", 5);
kprint_num(cpu_count);
serial_println(" CPUs online", 12);

kb_head = 0;
kb_tail = 0;
kb_shift = 0;
kb_caps = 0;
kb_ctrl = 0;
kb_init_tables();
kb_isr_build();
idt_set_gate(&idt + 33 * 16, &kb_isr, 0x08, 0x8E);
serial_println("Keyboard ISR installed (full US QWERTY)", 39);

pt_init();
serial_print("Page tables: ", 13);
kprint_num(pt_get_mapped_mb());
serial_println("MB mapped", 9);

# === CMOS kernel checkpoint 8 (page tables built — historical stall point) ===
# Pre-RDRAND-fix (cyrius 5.11.x, missing -cpu max in QEMU smoke) this was
# the visible stall. Iron may surface the same or different geometry —
# CP 8 == reached, CP 8 not reached == pt_init internals faulted.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x08; 0xE6; 0x71; }
cp_fb(0x08, 0x0000FF00);  # GREEN — page tables built

pmm_init();
serial_print("PMM: ", 5);
kprint_num(pmm_free_count());
serial_print(" free / ", 8);
kprint_num(pmm_total);
serial_println(" pages", 6);

# === CMOS kernel checkpoint 9 (physical memory manager up) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x09; 0xE6; 0x71; }
cp_fb(0x09, 0x0000FF00);  # GREEN — PMM up

# KASLR probe — emits the randomized next-free hint so two consecutive
# boots can be diffed for "did randomization actually fire". Asserted
# by .github/workflows/ci.yml's boot-test job (two-boot-diff check).
# v1.28.0.
serial_print("KASLR: pmm_next_free=", 21);
kprint_num(pmm_next_free);
serial_println("", 0);

var pg1 = pmm_alloc();
pmm_free(pg1);
serial_print("PMM test: ", 10);
kprint_num(pmm_free_count());
serial_println(" free", 5);

vmm_alloc_at(0x1000000);
store64(0x1000000, 0xDEAD);
serial_print("VMM: ", 5);
kprint_num(load64(0x1000000));
serial_println(" (expect 57005)", 15);

# Initialize kernel heap
heap_init();
serial_println("Heap initialized", 16);

# === CMOS kernel checkpoint 10 (heap up — kmalloc usable) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0A; 0xE6; 0x71; }
cp_fb(0x0A, 0x0000FF00);  # GREEN — heap up

dev_init();
serial_println("Devices registered", 18);
# Parse ACPI tables (RSDP, RSDT, DMAR) for hardware discovery
acpi_init();
if (acpi_rsdp_addr != 0) {
    serial_print("ACPI: RSDP at ", 14);
    kprint_num(acpi_rsdp_addr);
    serial_println("", 0);
    if (acpi_dmar_addr != 0) {
        serial_print("ACPI: DMAR at ", 14);
        kprint_num(acpi_dmar_addr);
        serial_print(" IOMMU base=", 12);
        kprint_num(acpi_iommu_base);
        serial_println("", 0);
    }
} else {
    serial_println("ACPI: no RSDP found", 19);
}

pci_scan();
serial_print("PCI: ", 5);
kprint_num(pci_count);
serial_println(" devices", 8);

# === CMOS kernel checkpoint 11 (ACPI + PCI enumerated) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0B; 0xE6; 0x71; }
cp_fb(0x0B, 0x0000FF00);  # GREEN — ACPI + PCI enumerated

# Initialize IOMMU if DMAR table found (S10: restrict DMA)
if (acpi_iommu_base != 0) {
    if (iommu_init() == 0) {
        serial_println("IOMMU: VT-d enabled, DMA restricted", 36);
    } else {
        serial_println("IOMMU: init failed", 18);
    }
}

if (pci_find(0x1AF4, 0x1000) >= 0) {
    if (virtio_net_init() == 0) {
        serial_print("VirtIO-net: MAC=", 16);
        for (var mi = 0; mi < 6; mi = mi + 1) {
            kprint_num(load8(&vnet_mac + mi));
            if (mi < 5) { serial_print(":", 1); }
        }
        serial_println("", 0);
        net_init(ip4(10,0,2,15), ip4(10,0,2,2), ip4(255,255,255,0));
        serial_println("Net: 10.0.2.15/24 gw 10.0.2.2", 30);
    }
}
if (pci_find(0x1AF4, 0x1001) >= 0) {
    if (virtio_blk_init() == 0) {
        serial_print("VirtIO-blk: ", 12);
        kprint_num(vblk_capacity);
        serial_println(" sectors", 8);
        if (fatfs_init() == 0) {
            serial_println("FAT16 filesystem mounted", 24);
        }
    }
}
vfs_init();
serial_println("VFS initialized", 15);

# === CMOS kernel checkpoint 12 (VFS up) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0C; 0xE6; 0x71; }
cp_fb(0x0C, 0x0000FF00);  # GREEN — VFS up

var h1 = kmalloc(16);
var h2 = kmalloc(100);
var h3 = kmalloc(4096);
serial_print("Heap: ", 6);
kprint_num(h1);
serial_print(" ", 1);
kprint_num(h2);
serial_print(" ", 1);
kprint_num(h3);
serial_println("", 0);
kfree_sized(h2, 100);

# Initialize SYSCALL/SYSRET
syscall_init();
serial_println("SYSCALL/SYSRET initialized", 26);

# Initialize stack canary secret (S13)
stack_canary_init();
serial_println("Stack canary initialized", 24);

# === CMOS kernel checkpoint 13 (SYSCALL + stack canary) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0D; 0xE6; 0x71; }
cp_fb(0x0D, 0x0000FF00);  # GREEN — SYSCALL + stack canary

# Syscall test (direct call — still works)
kernel_return_rsp = 0;
kernel_return_rip = 0;
proc_count = 0;
proc_current = 0;
var p0 = proc_create(0x100000);
proc_set_state(0, 2);  # kernel "process" is running

var pid = ksyscall(2, 0, 0, 0);
serial_print("Syscall getpid=", 15);
kprint_num(pid);
serial_println("", 0);

ksyscall(1, 0, "Syscall write works!\n", 21);

ksyscall(0, 42, 0, 0);
serial_print("Exit code: ", 11);
kprint_num(sys_exit_code);
serial_println("", 0);

# Hardware SYSCALL test (from kernel mode — same privilege, tests the plumbing)
serial_print("HW syscall test: ", 17);
test_hw_syscall();

# === Context Switch Test ===
# Create two test processes with dedicated stacks.
# Process stacks at 0x800000 + pid * 0x10000, 64KB apart.
# Stack grows down, so stack_top is base + size.
serial_println("Creating test processes...", 25);

proc_count = 0;
proc_current = 0;

# Process 0: kernel idle (the code running right now)
var kern_pid = proc_create(0);
proc_set_state(0, 2);  # running

# Process 1: test_proc_a
var stack_a = 0x800000 + 1 * 0x10000;
if (vmm_is_mapped(stack_a) == 0) { vmm_alloc_at(stack_a); }
var pa = proc_create_full(&test_proc_a, stack_a + 0x4000);
serial_print("Process A (pid=", 15);
kprint_num(pa);
serial_println(") created", 9);

# Process 2: test_proc_b
var stack_b = 0x800000 + 2 * 0x10000;
if (vmm_is_mapped(stack_b) == 0) { vmm_alloc_at(stack_b); }
var pb = proc_create_full(&test_proc_b, stack_b + 0x4000);
serial_print("Process B (pid=", 15);
kprint_num(pb);
serial_println(") created", 9);

serial_print("Processes: ", 11);
kprint_num(proc_count);
serial_print(" total, ", 8);
kprint_num(proc_count_by_state(1));
serial_println(" ready", 6);

# === CMOS kernel checkpoint 14 (test procs created) ===
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0E; 0xE6; 0x71; }
cp_fb(0x0E, 0x0000FFFF);  # CYAN — scheduler arming (test procs created)

# Enable interrupts and activate scheduler
asm { sti; }
serial_println("Interrupts enabled", 18);

# === CMOS kernel checkpoint 15 (interrupts enabled — sti executed) ===
# CP 15 reached but CP 16 not = scheduler activation faulted, or a flood
# of interrupts post-sti is preventing forward progress.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x0F; 0xE6; 0x71; }
cp_fb(0x0F, 0x0000FFFF);  # CYAN — sti executed

# Wait a few ticks before activating scheduler
arch_wait();
arch_wait();
serial_print("Timer ticks before sched: ", 26);
kprint_num(timer_ticks);
serial_println("", 0);

serial_println("Activating scheduler...", 23);
sched_active = 1;

# === CMOS kernel checkpoint 16 (scheduler armed) ===
# This is the AGNOS MVP closed-beta gate: reaching CP 16 means kernel
# init succeeded end-to-end through scheduler activation. Subsequent
# stall (no CP 17 ever emitted, no shell prompt) is a scheduler /
# context-switch issue, not an init issue. See state.md § "Open:
# timer-driven context switch broken".
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x10; 0xE6; 0x71; }
cp_fb(0x10, 0x0000FFFF);  # CYAN — scheduler armed (CLOSED-BETA GATE)

# Kernel idle loop: halts, wakes on timer, scheduler switches to A or B
# After enough ticks, deactivate and report
var idle_count = 0;
while (idle_count < 50) {
    arch_wait();
    if (idle_count == 0) {
        # CMOS CP 0x12: first hlt returned — timer ISR + first context-switch round-trip OK
        asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x12; 0xE6; 0x71; }
        cp_fb(0x12, 0x0000FFFF);  # CYAN — first hlt round-trip
    }
    if (idle_count == 9) {
        # CMOS CP 0x13: 10 hlts done — matches QEMU's known-good count under gnoboot
        asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x13; 0xE6; 0x71; }
        cp_fb(0x13, 0x0000FFFF);  # CYAN — 10 hlts done
    }
    if (idle_count == 24) {
        # CMOS CP 0x14: 25 hlts done — between QEMU known-good and loop end
        asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x14; 0xE6; 0x71; }
        cp_fb(0x14, 0x0000FFFF);  # CYAN — 25 hlts done
    }
    idle_count = idle_count + 1;
}

# Deactivate scheduler, report results
sched_active = 0;
# CMOS CP 0x11: post-scheduler idle loop completed
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x11; 0xE6; 0x71; }
cp_fb(0x11, 0x00FF00FF);  # MAGENTA — post-scheduler idle loop completed
serial_println("", 0);
serial_print("Scheduler test done. Timer ticks: ", 34);
kprint_num(timer_ticks);
serial_println("", 0);

# === Memory Isolation Test ===
# VFS + initrd test
serial_print("VFS write: ", 11);
vfs_write(0, "OK\n", 3);

# Build and mount test initrd at 0x6000 (free page table area)
initrd_build_test(0x6000);
var nfiles = initrd_init(0x6000);
serial_print("Initrd: ", 8);
kprint_num(nfiles);
serial_println(" files", 6);

# Open and read hello.txt
var hfd = initrd_open("hello.txt", 9);
var hbuf[16];
var hn = vfs_read(hfd, &hbuf, 14);
serial_print("initrd hello.txt: ", 18);
serial_print(&hbuf, hn);
vfs_close(hfd);

# Open and read test
var tfd = initrd_open("test", 4);
var tbuf[8];
var tn = vfs_read(tfd, &tbuf, 5);
serial_print("initrd test: ", 13);
serial_print(&tbuf, tn);
vfs_close(tfd);
var mf = vfs_create_memfile("HELLO", 5);
var rbuf[8];
var rn = vfs_read(mf, &rbuf, 5);
serial_print("VFS memfile read: ", 18);
serial_print(&rbuf, rn);
serial_println("", 0);
vfs_close(mf);
# CMOS CP 0x12: post-VFS / initrd / memfile tests
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x12; 0xE6; 0x71; }
cp_fb(0x12, 0x00FF00FF);  # MAGENTA — overwrites CYAN; reached post-VFS/initrd/memfile

# Memory-isolation test. v1.25.1 gated this behind MEMORY_ISOLATION_TEST
# after `store64(0xC00000, ...)` page-faulted post-cr3-switch despite
# AS1's PD[6] being verified correct. v1.27.1 identified the root cause
# as SMAP: proc_map_page writes per-process PD entries with US=1 (0x87,
# since the page must be user-accessible from CPL=3), and SMAP traps
# CPL=0 access to US=1 pages. The fix is `stac`/`clac` brackets around
# the test's user-page accesses, the same pattern userland-accessing
# kernels use everywhere. Pre-switch diagnostic reads worked because
# they hit kernel's own US=0 page-table pages.
#
# **CR4.SMAP enable site (v1.30.1):** under Path A (legacy ELF32 multi-
# boot1) the boot shim itself enables SMEP/SMAP — see arch/x86_64/
# boot_shim.cyr lines 70-88 (CPUID-gated). Under Path C (ELF64 + gnoboot
# sovereign handoff) UEFI hands us CR4 with both bits at 0 and we enable
# them right after `boot_info_capture_rdi()` at checkpoint 6 — see arch/
# x86_64/boot_shim.cyr `#ifdef ELF64_KERNEL` block, post-CP-5. Pre-v1.30.1
# Path C kernels left SMAP=0, which made the `stac` two lines below an
# illegal-opcode #UD and triple-faulted iron at this site (Attempts 16-18,
# iron-boot log).
serial_println("Memory isolation test...", 23);

# CMOS CP 0x1A: cp_fb sanity check entering mem-iso block (Attempt 18). On
# kernel CR3, BEFORE any AS-creation work. Attempt 17 left cells 0x16/0x17/0x18
# unpainted despite CMOS writes landing — the cp_fb-vs-AS1 hypothesis says
# cp_fb works on kernel CR3 but #PFs after cr3_load(as1) because the
# framebuffer phys (high UEFI address) isn't in AS1's per-process PT mirror
# (PD-copy only covers 0-4 GB). If cell 0x1A paints YELLOW, that hypothesis
# survives. If it doesn't, cp_fb broke somewhere upstream of this point.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x1A; 0xE6; 0x71; }
cp_fb(0x1A, 0x00FFFF00);  # YELLOW — distinguishes from MAGENTA bisector cells

# Create two address spaces
var as1 = proc_create_address_space();
var as2 = proc_create_address_space();

# CMOS CP 0x16: address spaces created OK
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x16; 0xE6; 0x71; }
cp_fb(0x16, 0x00FF00FF);  # MAGENTA — mem-iso bisector: post create-address-space x2

# Map virtual address 0xC00000 (12MB) in each, to different 2MB physical regions.
# We need 2MB-aligned physical addresses since we use huge pages.
#
# v1.28.0: both phys regions moved above 16 MB (PMM-tracked range is
# 0-16 MB / pages 0-4095). KASLR's randomized pmm_next_free means
# pmm_alloc may have already claimed pages anywhere in 2-16 MB by the
# time this test runs; using phys regions above 16 MB guarantees no
# collision with heap/allocator state. The 0-4 GB identity map (v1.25.0)
# makes both addresses kernel-reachable; v1.25.1's per-process PD-copy
# extends to PD entry 510 (just under 1 GB) plus PDPT[1..3] for 1-4 GB,
# so 0x1000000 / 0x1200000 are reachable from AS1/AS2 too.
var phys1 = 0x1000000;
var phys2 = 0x1200000;
# Ensure both phys regions are mapped in kernel page tables (the
# identity-map ceiling covers 0-4 GB so they should already be).
if (vmm_is_mapped(phys1) == 0) {
    vmm_map(phys1, phys1, 0x83);
}
if (vmm_is_mapped(phys2) == 0) {
    vmm_map(phys2, phys2, 0x83);
}
proc_map_page(as1, 0xC00000, phys1);
proc_map_page(as2, 0xC00000, phys2);

# CMOS CP 0x17: per-process page mappings installed OK
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x17; 0xE6; 0x71; }
cp_fb(0x17, 0x00FF00FF);  # MAGENTA — mem-iso bisector: post proc_map_page x2

# Write different values via each address space. cr3_load() is a helper
# in proc.cyr that loads its parameter into CR3 via [rbp-8] — robust
# under cc5's regalloc, unlike the pre-v1.26.0 `var x = y; asm { mov
# cr3, rax }` pattern which relied on cc3-era codegen leaving the
# assigned value in RAX. See docs/development/issue/2026-04-27-cr3-load-helper.md.

# Switch to AS1, write 0xAAAA to 0xC00000. The page is mapped US=1
# (proc_map_page emits 0x87 — P | RW | US | PS) because it must be
# reachable from CPL=3. We're in CPL=0 here, so SMAP would trap the
# access without RFLAGS.AC=1 — `stac` (0F 01 CB) sets it, `clac`
# (0F 01 CA) clears it. The bracket discipline is per-access-block:
# if an interrupt fires between stac and clac, the kernel's interrupt
# entry stub re-clears AC implicitly (the interrupt gate clears
# RFLAGS.AC on entry per Intel SDM Vol 3 §6.12.1.4).
cr3_load(as1);
# CMOS CP 0x18: first cr3 switch (AS1) survived — AS1 has kernel-text mapped.
# Any post-CP-0x18 stall is in the SMAP'd accesses or subsequent CR3 switches.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x18; 0xE6; 0x71; }
# Attempt 18: CR4 byte 2 (bits 16-23) → CMOS[0x54]. Pins down CR4.SMAP (bit 21
# = byte 2 bit 5) enforcement state on iron BEFORE the suspected cp_fb-under-
# AS1 fault. Port I/O only — runs even if AS1's PT mirror is broken. Byte 2
# bit map (LSB-first within the byte): FSGSBASE/PCIDE/OSXSAVE/-/SMEP/SMAP/PKE/-.
asm {
    0xB0; 0x54;                # mov al, 0x54  — select CMOS register 0x54
    0xE6; 0x70;                # out 0x70, al
    0x0F; 0x20; 0xE0;          # mov rax, cr4
    0x48; 0xC1; 0xE8; 0x10;    # shr rax, 16
    0xE6; 0x71;                # out 0x71, al  — write byte 2 of CR4
}
cp_fb(0x18, 0x00FF00FF);  # MAGENTA — mem-iso bisector: post first cr3_load(as1)

# Attempt 19: re-dump CR4 byte 2 to CMOS[0x55] right before `stac`.
# Attempt 18's CMOS[0x54] = 0x00 read proved CR4.SMAP = 0 at CP 0x18,
# which made `stac` below a #UD → triple-fault. v1.30.1 added SMEP+SMAP
# enable in boot_shim.cyr (Path C, post-CP-5). This second dump confirms
# the new CR4 value reached the test site — if CMOS[0x55] = 0x30 (SMEP
# 0x10 | SMAP 0x20), the enable held all the way here. If 0x00 again,
# something between boot_shim and this site cleared CR4 (investigate
# any CR3/CR0/CR4 mutation downstream of boot_shim).
asm {
    0xB0; 0x55;                # mov al, 0x55  — select CMOS register 0x55
    0xE6; 0x70;                # out 0x70, al
    0x0F; 0x20; 0xE0;          # mov rax, cr4
    0x48; 0xC1; 0xE8; 0x10;    # shr rax, 16
    0xE6; 0x71;                # out 0x71, al  — write byte 2 of CR4
}

asm { 0x0F; 0x01; 0xCB; }   # stac
# CMOS CP 0x1B: stac executed without faulting under AS1 CR3 (Attempt 18 SMAP bisector).
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x1B; 0xE6; 0x71; }
cp_fb(0x1B, 0x00FF00FF);  # MAGENTA — SMAP bisector: post-stac, AS1 CR3
store64(0xC00000, 0xAAAA);
var val_as1 = load64(0xC00000);
# CMOS CP 0x1C: SMAP-bracketed store64+load64 succeeded under AS1 (Attempt 18 SMAP bisector).
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x1C; 0xE6; 0x71; }
cp_fb(0x1C, 0x00FF00FF);  # MAGENTA — SMAP bisector: post-store/load
asm { 0x0F; 0x01; 0xCA; }   # clac
# CMOS CP 0x1D: clac executed; AS1 SMAP-bracketed round-trip complete (Attempt 18 SMAP bisector).
# Any post-0x1D stall is in cr3_load(as2) at line 456 or beyond.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x1D; 0xE6; 0x71; }
cp_fb(0x1D, 0x00FF00FF);  # MAGENTA — SMAP bisector: post-clac, AS1 done

# Switch to AS2, write 0xBBBB to same virtual address
cr3_load(as2);
asm { 0x0F; 0x01; 0xCB; }   # stac
store64(0xC00000, 0xBBBB);
var val_as2 = load64(0xC00000);
asm { 0x0F; 0x01; 0xCA; }   # clac

# Switch back to AS1, read again — should still be 0xAAAA
cr3_load(as1);
asm { 0x0F; 0x01; 0xCB; }   # stac
var val_as1_check = load64(0xC00000);
asm { 0x0F; 0x01; 0xCA; }   # clac

# Restore kernel page tables (literal 0x1000 → mov rax, imm64; mov cr3, rax)
asm {
    0x48; 0xB8; 0x00; 0x10; 0x00; 0x00; 0x00; 0x00; 0x00; 0x00;   # mov rax, 0x1000
    0x0F; 0x22; 0xD8;                                              # mov cr3, rax
}

# CMOS CP 0x19: all three CR3 switches + SMAP-bracketed stores/loads + kernel-PT
# restore survived. Any post-CP-0x19 stall is in the serial-print / branch logic
# at lines 462-479, not in the page-table machinery.
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x19; 0xE6; 0x71; }
cp_fb(0x19, 0x00FF00FF);  # MAGENTA — mem-iso bisector: post all 3 CR3 switches + restore

serial_print("AS1 wrote 0xAAAA, read=", 23);
kprint_num(val_as1);
serial_print(" recheck=", 9);
kprint_num(val_as1_check);
serial_println("", 0);
serial_print("AS2 wrote 0xBBBB, read=", 23);
kprint_num(val_as2);
serial_println("", 0);

if (val_as1_check == 0xAAAA) {
    if (val_as2 == 0xBBBB) {
        serial_println("Memory isolation: PASS", 22);
    } else {
        serial_println("Memory isolation: FAIL (AS2)", 28);
    }
} else {
    serial_println("Memory isolation: FAIL (AS1 clobbered)", 38);
}
# CMOS CP 0x13: post-memory-isolation test
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x13; 0xE6; 0x71; }
cp_fb(0x13, 0x00FF00FF);  # MAGENTA — overwrites CYAN; reached post-mem-isolation

# === Userland Exec Test ===
# Spawn user_test_proc as a proper isolated process with its own address space
serial_println("Userland exec test...", 21);
var exec_pid = spawn_user_proc(&user_test_proc);
serial_print("Spawned pid=", 12);
kprint_num(exec_pid);
serial_println("", 0);

if (exec_pid >= 0) {
    var ep = &proc_table + exec_pid * 176;
    var exec_entry = load64(ep + 24);
    var exec_rsp = load64(ep + 16);
    var exec_cr3 = load64(ep + 160);
    # skipped
    serial_println("Userland exec complete", 22);
}
# CMOS CP 0x14: post-userland-exec test (spawn done, exec_and_wait still bypassed)
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x14; 0xE6; 0x71; }
cp_fb(0x14, 0x00FF00FF);  # MAGENTA — overwrites CYAN; reached post-userland-exec

# Launch kybernet (PID 1)
serial_println("Launching kybernet...", 21);
# CMOS CP 0x15: reached kybernet-launch site (sh_cmd_bench is placeholder)
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x15; 0xE6; 0x71; }
cp_fb(0x15, 0x00FF00FF);  # MAGENTA — kybernet-launch reached
sh_cmd_bench(); arch_halt();

serial_println("Halted.", 7);
arch_halt();
