# Memory-isolation test removed 2026-05-15 (Attempt 27). The AS1/AS2 build + CR3
# dance was post-MVP verification, not boot infrastructure. Under restored kernel
# CR3 the test pegged kcp at 0x19 for 9 repair letters (F-N); per UEFI handoff
# contract (docs/development/uefi-boot-prior-art.md §6), early kernels inherit
# UEFI's identity map — pt_init's 0-4GB mapping doesn't cover the GOP FB BAR
# the way UEFI's did. Mem-iso correctness is post-closed-beta work.

#ifdef KTEST
# === Userland Exec Test ===
# Spawn user_test_proc as a proper isolated process with its own address space
kprintln("Userland exec test...", 21);
var exec_pid = spawn_user_proc(&user_test_proc);
kprint("Spawned pid=", 12);
kprint_num(exec_pid);
kprintln("", 0);

if (exec_pid >= 0) {
    var ep = &proc_table + exec_pid * 176;
    var exec_entry = load64(ep + 24);
    var exec_rsp = load64(ep + 16);
    var exec_cr3 = load64(ep + 160);
    # skipped
    kprintln("Userland exec complete", 22);
}
# CMOS CP 0x14: post-userland-exec test (spawn done, exec_and_wait still bypassed)
asm { 0xB0; 0x50; 0xE6; 0x70; 0xB0; 0x14; 0xE6; 0x71; }
#endif

# TCP listen-accept smoke (1.32.0 bite A). Build-flag-gated so production
# boots don't bind a port. With TCP_LISTEN_SMOKE=1: listen on 8080, poll
# briefly for one incoming connection, on accept send a banner + close.
# Pairs with scripts/tcp-listen-smoke.sh's host-side TCP probe.
# Placed post-interrupt-enable so arch_wait() (= HLT) actually waits for
# a timer tick rather than hanging on no-IRQ. Pre-kybernet so the test
# completes before the shell loop swallows the boot serial.
# DHCP client (1.32.0 bite G, re-enabled 1.32.9) — the standard way to
# get an IP: SLIRP serves it in QEMU, real LANs serve it on iron. The
# 1.32.3 STATIC bypass that sat here is removed: its OFFER timeout was
# the r8169 unicast-RX drop fixed at 1.32.7 (RX ring 16->64; both on-LAN
# and off-LAN TCP handshakes complete on iron), not a DHCP-layer bug.
# See the 1.32.7 CHANGELOG entry + r8169-iron-burn-audit.md.
if (vnet_active != 0 || nic_ready() != 0) {
    # Iron fallback: seed a workable STATIC address before the DHCP
    # exchange (192.168.1.222 — the 1.32.3 bypass IP, distinct from
    # Linux's lease; the EEPROM hardware MAC claiming it draws gateway
    # ARP replies even with Linux's lease active). On the iron path the
    # pre-DHCP net_init was net_init(0,0,0), which is not a workable
    # fallback if DHCP misses. QEMU keeps its 10.0.2.15 SLIRP fallback
    # from the virtio branch above.
    if (vnet_active == 0) {
        net_init(ip4(192,168,1,222), ip4(192,168,1,1), ip4(255,255,255,0));
    }
    # dhcp_init() sends DISCOVER from 0.0.0.0 and, on ACK, overwrites
    # net_ip/net_gateway/net_netmask with the real lease (returns 0,
    # printing "dhcp: ACK ip=..."). On timeout/NAK it returns nonzero
    # and the fallback above stays in place.
    if (dhcp_init() != 0) {
        kprintln("net: DHCP failed -- using static fallback", 41);
    }
    # Resolve the gateway MAC for off-LAN routing. net_gateway now holds
    # the DHCP-leased gateway (or the static fallback) — the ARP probe
    # targets whichever we ended with.
    arp_request(net_gateway);
    kprintln("arp: request -> gateway", 23);
    var arp_start = timer_ticks;
    var arp_got = 0;
    # Honest-self-test counters (1325): record what RX actually delivered
    # during the gateway-probe wait, not just whether the gateway replied.
    # attempt_4 pcap proved broadcast RX + the ARP responder fire on iron
    # while THIS very gate times out -- the old flat "L1/L2 FAILED" verdict
    # hid a live NIC for the whole arc. rx_frames = any frame net_poll
    # handled; arp_seen = inbound ARP frames; net_arp_replies_sent (net.cyr)
    # = replies we TX'd in response.
    var rx_frames = 0;
    var arp_seen = 0;
    # ARP request retransmit schedule (RFC 1122 §2.3.2.1). A single request
    # that is missed or not yet elicited would otherwise time out the whole
    # 5 s window with no retry — and ARP replies are only sent in response to
    # a request, so a missed first reply is never re-offered. Every prior-art
    # stack (Linux neigh, iPXE, lwIP etharp, *BSD) re-sends ~1/sec until
    # reply/timeout. next_retx = the next tick (100 Hz timer → 100 ticks = 1 s)
    # to re-send; 4 retransmits across the window (initial + @100/200/300/400).
    var next_retx = 100;
    while ((timer_ticks - arp_start) < 500) {
        var pr = net_poll();
        if (pr > 0) { rx_frames = rx_frames + 1; }
        if (pr == 1) { arp_seen = arp_seen + 1; }
        if (arp_pending_ip == 0) { arp_got = 1; break; }
        if ((timer_ticks - arp_start) >= next_retx) {
            arp_request(net_gateway);
            next_retx = next_retx + 100;
        }
        arch_wait();
    }
    if (arp_got == 1) {
        # Persist the gateway MAC into the route helper's slot — every
        # off-LAN packet (1.1.1.1, etc.) now resolves through this.
        memcpy(&net_gateway_mac, &arp_cache_mac, 6);
        net_gateway_mac_valid = 1;
        kprint("arp: REPLY gw_mac=", 18);
        kprint_byte(load8(&arp_cache_mac + 0)); kprint(":", 1);
        kprint_byte(load8(&arp_cache_mac + 1)); kprint(":", 1);
        kprint_byte(load8(&arp_cache_mac + 2)); kprint(":", 1);
        kprint_byte(load8(&arp_cache_mac + 3)); kprint(":", 1);
        kprint_byte(load8(&arp_cache_mac + 4)); kprint(":", 1);
        kprint_byte(load8(&arp_cache_mac + 5));
        kprintln("", 0);
        kprintln("net: L2 OK -- gateway MAC cached", 32);

        # --- Net diagnostics behind NET_VERBOSE (1.32.8 cleanup) ----------
        # The 1.32.x r8169 unicast-RX arc is CLOSED (1.32.7: ring 16->64, both
        # on-LAN and off-LAN handshakes complete on iron). Its two diagnostic
        # instruments stay available for future debugging but are compiled out
        # of the production boot so the FB ends cleanly at "net: L2 OK":
        #   - the 1.1.1.1:80 outbound-TCP smoke (proves TX-to-gateway-MAC +
        #     off-LAN routing + unicast RX of the reply + the 3-way handshake)
        #   - the r8169 silicon tally readback (rx_uc/rx_bc/rx_mc + missed)
        # The .121 on-LAN-peer discriminator (1.32.7 bite-2) was removed
        # entirely with this cleanup -- it required the mbp-lan-probe harness
        # running during boot and is not reproducible without it.
        #ifdef NET_VERBOSE
        # Outbound TCP test: 1.1.1.1:80. SYN+ACK proves r8169 TX unicast
        # to gateway-MAC, off-LAN routing, r8169 RX of the unicast reply, and
        # the TCP three-way handshake all at once.
        kprintln("tcp: connect 1.1.1.1:80", 23);
        var conn = tcp_connect(ip4(1,1,1,1), 80, 49152);
        if (conn >= 0) {
            kprintln("net: L3+TCP OK -- outbound TCP handshake established", 52);
            tcp_close(conn);
        } else {
            kprintln("net: L3+TCP FAIL -- SYN sent but no SYN+ACK", 43);
        }

        # r8169 silicon accept-counter readback (FreeBSD re_sysctl_stats /
        # RTL8168 datasheet 6.8.4): rx_uc/rx_bc/rx_mc split by frame class +
        # missed (RxMissed FIFO overflow). r8169-only (QEMU uses virtio_net
        # and has no RTL8168 to count).
        if (r8169_present == 1) {
            r8169_print_stats();
        }
        #endif
    } else {
        # Gateway unicast reply never arrived -- but that is NOT "RX dead".
        # Report what RX did so the FB distinguishes a silent NIC from a
        # live one still waiting on one unicast round-trip.
        kprintln("arp: gateway reply not seen within ~5s", 38);
        if (rx_frames > 0) {
            kprint("net: L2 RX ALIVE rx=", 20);
            kprint_num(rx_frames);
            kprint(" arp_in=", 8);
            kprint_num(arp_seen);
            kprint(" arp_ans=", 9);
            kprint_num(net_arp_replies_sent);
            kprintln(" -- gateway unicast reply pending", 33);
        } else {
            kprintln("net: L2 RX SILENT -- 0 frames in ~5s", 36);
        }
    }
}

# === Boot self-tests + kybernet launch split out (1.36.2 refactor) ===
# main.cyr is now the boot-init sequence only. See core/selftests.cyr (compile-
# gated checks) and core/boot_finish.cyr (kybernet launch), included after this
# file in agnos.cyr in that order. FS/KTEST selftests stay inline (mid-sequence).
