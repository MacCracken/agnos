        if (arg1 < 0 || arg1 >= 4) { stack_canary_check(canary); return 0 - 1; }
        if (load64(&snd_slot_used + arg1 * 8) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (load64(&snd_slot_pid + arg1 * 8) != proc_current_get()) { stack_canary_check(canary); return 0 - 1; }
        var sd_target = snd_appl;
        var sd_start = timer_ticks;
        preempt_disable();
        asm { sti; }
        while ((timer_ticks - sd_start) < 100) {                                     # ~1s cap (full ring ~34 ticks)
            if (snd_hw_frames >= sd_target) { break; }
            arch_wait();
        }
        asm { cli; }
        preempt_enable();
        stack_canary_check(canary);
        return 0;
    }
    if (num == 69) {
        # snd_avail(slot=a1) -> free frames (>=0) / -1. Non-blocking, IF=0-safe.
        if (arg1 < 0 || arg1 >= 4) { stack_canary_check(canary); return 0 - 1; }
        if (load64(&snd_slot_used + arg1 * 8) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (load64(&snd_slot_pid + arg1 * 8) != proc_current_get()) { stack_canary_check(canary); return 0 - 1; }
        if (snd_hw_frames > snd_appl) { snd_appl = snd_hw_frames; }
        var sa_free = 16384 - (snd_appl - snd_hw_frames) - 1;
        if (sa_free < 0) { sa_free = 0; }
        stack_canary_check(canary);
        return sa_free;
    }
    stack_canary_check(canary);
    return 0 - 1;
}
