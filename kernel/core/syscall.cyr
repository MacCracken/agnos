        # Security: validate fd bounds and userspace pointer
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= 32) { return 0 - 1; }
        if (arg3 < 0) { return 0 - 1; }
        if (arg3 > 16) { arg3 = 16; }
        # 1.41.5: validate the events buffer for the bytes actually written (each
        # event record is 12 bytes, up to arg3 of them) — not a single ptr.
        if (is_user_range(arg2, arg3 * 12) == 0) { return 0 - 1; }
        var ebase = &vfs_table + arg1 * 32;
        # 1.41.5: epfd must be a real epoll instance, else wl/wc below are a
        # foreign fd's payload — wl used as a base address gives arbitrary
        # kernel reads and wc (e.g. a file's pos) an attacker-driven loop count.
        if (ktag(ebase) != VFS_EPOLL) { return 0 - 1; }
        var wl = kpayload(ebase, 2);
        var wc = kpayload(ebase, 0);
        var found = 0;
        for (var wi = 0; wi < wc; wi = wi + 1) {
            var wfd = load64(wl + wi * 16);
            var wdata = load64(wl + wi * 16 + 8);
            var rdy = 0;
            # 1.41.5: defense-in-depth — only consult a watched fd that indexes a
            # real slot (epoll_ctl now bounds it at insert time as well).
            if (wfd >= 0) {
                if (wfd < 32) {
                    var wbase = &vfs_table + wfd * 32;
                    var wtype = ktag(wbase);
                    if (wtype == VFS_SIGNALFD) {
                        var smask = kpayload(wbase, 2);
                        var spend = load64(&proc_signals + proc_current * 8);
                        if ((spend & smask) != 0) { rdy = 1; }
                    }
                    if (wtype == VFS_TIMERFD) {
                        if (timer_ticks >= kpayload(wbase, 1)) { rdy = 1; }
                    }
                }
            }
            if (rdy == 1) {
                if (found < arg3) {
                    store32(arg2 + found * 12, 1);
                    store64(arg2 + found * 12 + 4, wdata);
                    found = found + 1;
                }
            }
        }
        if (found == 0) { arch_wait(); }
        return found;
    }
    if (num == 22) {
        # timerfd_create
        var tfd = vfs_alloc();
        if (tfd < 0) { return 0 - 1; }
        var tbase = &vfs_table + tfd * 32;
        ktag_set(tbase, VFS_TIMERFD);
        kpayload_set(tbase, 0, 0);              # interval
        kpayload_set(tbase, 1, 0);              # next_fire
        return tfd;
    }
    if (num == 23) {
        # timerfd_settime(fd=arg1, flags=arg2, new_value=arg3)
        # Security: validate fd bounds and userspace pointer
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= 32) { return 0 - 1; }
        if (is_user_range(arg3, 24) == 0) { return 0 - 1; }
        var tbase = &vfs_table + arg1 * 32;
        # 1.41.5: fd must be a timerfd, else kpayload_set below writes into a
        # foreign fd's payload (corrupting a file's pos/inode or a pipe's ptrs).
        if (ktag(tbase) != VFS_TIMERFD) { return 0 - 1; }
        var int_sec = load64(arg3);
        var init_sec = load64(arg3 + 16);
        kpayload_set(tbase, 0, int_sec * 100);            # interval
        kpayload_set(tbase, 1, timer_ticks + init_sec * 100);   # next_fire
        return 0;
    }
    if (num == 25) {
        # pipe(fds_ptr=arg1)
        # Security: validate userspace pointer for 2x u64
        if (is_user_range(arg1, 16) == 0) { stack_canary_check(canary); return 0 - 1; }
        stack_canary_check(canary);
        return vfs_create_pipe(arg1);
    }
    if (num == 26) {
        # write_boot_checkpoint(byte=arg1) — writes CMOS[0x50] = arg1 & 0xFF.
        # Diagnostic for iron-boot bring-up: lets PID 1 / kybernet mark its
        # own progress in the same CMOS slot the kernel uses for kernel-side
        # checkpoints (0x01..0x1F kernel, 0x20+ ring-3 transitions, 0x30+
        # userspace). Read back via scripts/read-boot-log.sh after a stall.
        outb(0x70, 0x50);
        outb(0x71, arg1 & 0xFF);
        stack_canary_check(canary);
        return 0;
    }
    if (num == 27) {
        # mmap(length=arg1) — anonymous, zero-filled, 2 MB-granular (1.35.3).
        # addr/prot/flags/fd/offset ignored (always anonymous R/W/U). Returns
        # the base vaddr or 0 (MAP_FAILED). See proc.cyr sys_mmap.
        stack_canary_check(canary);
        return sys_mmap(arg1);
    }
    if (num == 28) {
        # munmap(addr=arg1, length=arg2) — release an mmap region + free its
        # physical 2 MB pages (1.35.4). Returns 0 / -1. See proc.cyr sys_munmap.
        stack_canary_check(canary);
        return sys_munmap(arg1, arg2);
    }
    if (num == 29) {
        # getdents(dir_fd=arg1, buf=arg2, bufsize=arg3) — emit agnos dirent
        # records (§4.2) from a VFS_EXT2_DIR fd (open AO_DIRECTORY). Returns
        # bytes written, 0 at end of dir, -1 on error. (1.41.3)
        if (arg1 < 0) { stack_canary_check(canary); return 0 - 1; }
        if (arg1 >= 32) { stack_canary_check(canary); return 0 - 1; }
        if (arg3 < 1) { stack_canary_check(canary); return 0 - 1; }
        if (is_user_range(arg2, arg3) == 0) { stack_canary_check(canary); return 0 - 1; }
        var gbase = &vfs_table + arg1 * 32;
        if (ktag(gbase) != VFS_EXT2_DIR) { stack_canary_check(canary); return 0 - 1; }
        var gn = ext2_getdents(kpayload(gbase, 2), kpayload(gbase, 0), arg2, arg3);
        if (gn >= 0) { kpayload_set(gbase, 0, ext2_gd_next); }
        stack_canary_check(canary);
        return gn;
    }
    if (num == 30) {
        # unlink(path=arg1, pathlen=arg2) — remove a file, mount-routed (1.41.3).
        if (sc_path_ok(arg1, arg2) == 0) { stack_canary_check(canary); return 0 - 1; }
        var be30 = vfs_resolve_mount(arg1, arg2);
        if (be30 == FS_FAT || be30 == FS_EXFAT) { stack_canary_check(canary); return vfs_delete_on(be30, arg1 + vfs_mnt_reloff, arg2 - vfs_mnt_reloff); }
        if (be30 == FS_EXT2) {
            var par30 = vfs_ext2_parent(arg1, arg2);
            if (par30 <= 0) { stack_canary_check(canary); return 0 - 1; }
            stack_canary_check(canary);
            return ext2_unlink(par30, arg1 + vfs_base_off, vfs_base_len);
        }
        stack_canary_check(canary);
        return 0 - 1;
    }
    if (num == 31) {
        # rename(old=arg1, oldlen=arg2, new=arg3, newlen=a4) — within one
        # filesystem (a4=r10 via ksyscall_a4, 1.41.3).
        var a4r = ksyscall_a4;
        if (sc_path_ok(arg1, arg2) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (sc_path_ok(arg3, a4r) == 0) { stack_canary_check(canary); return 0 - 1; }
        var beo = vfs_resolve_mount(arg1, arg2);
        var ro = vfs_mnt_reloff;
        var ben = vfs_resolve_mount(arg3, a4r);
        var rn = vfs_mnt_reloff;
        if (beo != ben) { stack_canary_check(canary); return 0 - 1; }   # cross-FS
        if (beo == FS_FAT || beo == FS_EXFAT) {
            stack_canary_check(canary);
            return vfs_rename_on(beo, arg1 + ro, arg2 - ro, arg3 + rn, a4r - rn);
        }
        if (beo == FS_EXT2) {
            var sp = vfs_ext2_parent(arg1, arg2);
            if (sp <= 0) { stack_canary_check(canary); return 0 - 1; }
            var s_off = vfs_base_off;
            var s_len = vfs_base_len;
            var dp = vfs_ext2_parent(arg3, a4r);
            if (dp <= 0) { stack_canary_check(canary); return 0 - 1; }
            stack_canary_check(canary);
            return ext2_rename(sp, arg1 + s_off, s_len, dp, arg3 + vfs_base_off, vfs_base_len);
        }
        stack_canary_check(canary);
        return 0 - 1;
    }
    if (num == 32) {
        # link(target=arg1, targetlen=arg2, linkpath=arg3, linkpathlen=a4) —
        # hard link, ext2-only (a4=r10 via ksyscall_a4, 1.41.3). FAT/exFAT → -1
        # (O4: no inodes/hard links).
        var a4l = ksyscall_a4;
        if (sc_path_ok(arg1, arg2) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (sc_path_ok(arg3, a4l) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (vfs_resolve_mount(arg1, arg2) != FS_EXT2) { stack_canary_check(canary); return 0 - 1; }
        if (vfs_resolve_mount(arg3, a4l) != FS_EXT2) { stack_canary_check(canary); return 0 - 1; }
        var tino = ext2_path_lookup(arg1, arg2);
        if (tino <= 0) { stack_canary_check(canary); return 0 - 1; }
        var ldp = vfs_ext2_parent(arg3, a4l);
        if (ldp <= 0) { stack_canary_check(canary); return 0 - 1; }
        stack_canary_check(canary);
        return ext2_link(tino, ldp, arg3 + vfs_base_off, vfs_base_len);
    }
    if (num == 33) {
        # stat(path=arg1, pathlen=arg2, statbuf=arg3) — fills the 48-byte agnos
        # stat struct (§4.1). ext2 fully; FAT/exFAT degrade to -1 for now (O4's
        # ino=0+size/type fill is a follow-on). (1.41.3)
        if (sc_path_ok(arg1, arg2) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (is_user_range(arg3, 48) == 0) { stack_canary_check(canary); return 0 - 1; }
        var be33 = vfs_resolve_mount(arg1, arg2);
        if (be33 != FS_EXT2) { stack_canary_check(canary); return 0 - 1; }
        var sino = ext2_path_lookup(arg1, arg2);
        if (sino <= 0) { stack_canary_check(canary); return 0 - 1; }
        var sr = ext2_fill_stat(sino, arg3);
        stack_canary_check(canary);
        return sr;
    }
    if (num == 34) {
        # uname(buf=arg1, len=arg2) — writes the 64-byte identity struct: four
        # 16-byte NUL-padded fields at offsets 0/16/32/48 = sysname / nodename /
        # release / machine. Static boot-time identity; invoked from ring 3 so
        # the string gvars (_AGNOS_VERSION, kernel_hostname) are post-init-live.
        # a3 unused. Read by fixed offset, NOT NUL-terminated-variable. (sysinfo ABI)
        if (is_user_range(arg1, 64) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (arg2 < 64) { stack_canary_check(canary); return 0 - 1; }
        sysinfo_put_str(arg1 +  0, "AGNOS", 16);          # sysname (kernel name)
        sysinfo_put_str(arg1 + 16, kernel_hostname, 16);  # nodename (hostname)
        sysinfo_put_str(arg1 + 32, _AGNOS_VERSION, 16);   # release (kernel version)
        sysinfo_put_str(arg1 + 48, "x86_64", 16);         # machine (arch; aarch64 build would #ifdef)
        stack_canary_check(canary);
        return 0;
    }
    if (num == 35) {
        # sysinfo(buf=arg1, len=arg2) — writes the 40-byte counters struct: 5x
        # u64 LE at offsets 0/8/16/24/32 = uptime_secs / totalram / freeram /
        # procs / cpus. Live volatile snapshot; single-core so no lock. The
        # kernel does the unit conversion (ticks→sec at 100 Hz, pages→bytes at
        # 4 KB) so userland never re-derives units. a3 unused.
        if (is_user_range(arg1, 40) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (arg2 < 40) { stack_canary_check(canary); return 0 - 1; }
        store64(arg1 +  0, timer_ticks / 100);            # uptime seconds (100 Hz)
        store64(arg1 +  8, pmm_total * 4096);             # total RAM bytes (4 KB pages)
        store64(arg1 + 16, pmm_free_count() * 4096);      # free RAM bytes
        store64(arg1 + 24, proc_count);                   # live process count
        store64(arg1 + 32, cpu_count);                    # online CPUs (=1 until SMP enumerates)
        stack_canary_check(canary);
        return 0;
    }
    if (num == 36) {
        # klog(buf=arg1, len=arg2) — copy the unified klug log ring (core/klug.cyr)
        # into the user buffer, OLDEST→NEWEST. Returns bytes written (≤ len, ≤ the
        # ring fill), or -1 on a bad buffer. When the buffer is smaller than the
        # log, returns the NEWEST `len` bytes (the dmesg tail). Linear fill: oldest
        # at offset 0. Wrapped (klug_count saturated at 16384): oldest sits at
        # klug_head; the (idx & 0x3FFF) mask unwraps both cases uniformly. Reads
        # ONLY klug_buf (never other kernel memory) so it can't leak past the log.
        if (is_user_range(arg1, arg2) == 0) { stack_canary_check(canary); return 0 - 1; }
        var kl_avail = klug_count;
        var kl_want = arg2;
        if (kl_want > kl_avail) { kl_want = kl_avail; }
        var kl_oldest = 0;
        if (klug_count >= 16384) { kl_oldest = klug_head; }
        var kl_start = (kl_oldest + (kl_avail - kl_want)) & 0x3FFF;   # newest kl_want bytes
        var kl_w = 0;
        while (kl_w < kl_want) {
            store8(arg1 + kl_w, load8(&klug_buf + ((kl_start + kl_w) & 0x3FFF)));
            kl_w = kl_w + 1;
