            # epoll_wait — bound it to a real fd slot so it can't index OOB.
            if (arg3 < 0) { return 0 - 1; }
            if (arg3 >= 32) { return 0 - 1; }
            store64(wl + wc * 16, arg3);
            store64(wl + wc * 16 + 8, arg3);
            kpayload_set(ebase, 0, wc + 1);
        }
        if (arg2 == 2) {
            # EPOLL_CTL_DEL — current impl clears ALL watches (not just arg3).
            kpayload_set(ebase, 0, 0);
        }
        return 0;
    }
    if (num == 21) {
