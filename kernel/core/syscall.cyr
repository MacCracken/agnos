# === Stack Canary (S13) ===
# Random secret initialized at boot via RDRAND. Checked in critical functions
# to detect stack buffer overflows before they corrupt return addresses.
var stack_canary_secret = 0;

fn stack_canary_init() {
    # v1.28.0: use the shared rdrand_u64() helper (arch/x86_64/io.cyr +
    # arch/aarch64/stubs.cyr). Same entropy source as KASLR's
    # kaslr_seed() — one helper, two callers. The timer-mixer fallback
    # is preserved so the canary still gets a varying value if RDRAND
    # fails this boot.
    var val = rdrand_u64();
    if (val == 0) {
        val = timer_ticks * 6364136223846793005 + 0xDEAD1337CAFE4242;
    }
    stack_canary_secret = val;
    return 0;
}

fn stack_canary_check(canary) {
    if (canary != stack_canary_secret) {
        serial_println("PANIC: stack smash detected", 27);
        arch_halt();
    }
    return 0;
}

# === Syscall Interface ===
# Syscall#: 0=exit 1=write 2=getpid 3=spawn 4=waitpid 5=read 6=close 7=open
# 8=dup 9=mkdir 10=rmdir 11=mount 12=sync 13=reboot 14=pause 15=getuid
# 16=kill 17=sigprocmask 18=signalfd 19=epoll_create 20=epoll_ctl
# 21=epoll_wait 22=timerfd_create 23=timerfd_settime 24=umount 25=pipe
# 26=write_boot_checkpoint(byte) — diagnostic-only, writes CMOS[0x50]=arg1.
#    Added for iron-boot bring-up so userspace (kybernet) can mark progress
#    in the same CMOS slot the kernel uses. Will likely stay through MVP.
# 27=mmap(length) — anonymous, zero-filled, 2 MB-granular (1.35.3). The first
#    new functional syscall since v1.21.0; the CVE-2026-31431 immunity is
#    anchored on the absence of the AF_ALG/socket/splice surface, which mmap
#    (a pure memory syscall) does not add.
# 28=munmap(addr, length) — release an mmap region + free its physical 2 MB
#    pages (1.35.4). The natural pair to 27; same pure-memory posture.
# 45-57 = the net band (getrandom / time_unix / sock_* / udp_* / icmp_echo) — see
#    the inline handlers below + cyrius lib/syscalls_x86_64_agnos.cyr for the full map.
# 58=lseek(fd, offset, whence) — VFS_EXT2_FILE read/write cursor reposition (1.45.13).
# 59=flock(fd, op) — BSD advisory whole-file lock, inode-keyed, non-blocking, released
#    on close#6 + proc exit (1.45.13). Both serve the server-stage persistence/locking
#    consumers (descent libro/patra, agora shared-world door games).
# 60=winsize() — console char grid packed as (cols<<16 | rows) from the live
#    framebuffer (fb_width/fb_height/fb_scale, 8×16 glyph), or -1 (FB not up). No
#    args, no buffer (like uptime#40). Lets a ring-3 TUI size to the real console
#    instead of a hardcoded 80×24 (darshana tty_winsize on agnos → kii/cyim/chakshu). (1.45.13)
# 61=net_config / 62=exec_redirect / 63=symlink / 64-69=HDA audio band — see the
#    inline handlers below + cyrius lib/syscalls_x86_64_agnos.cyr for the full map.
# 70=readlink(path, pathlen, buf, buflen) — symlink INTROSPECTION peer of #63: read a
#    symbolic link's TEXT target into buf, returning the target byte length or -1. The
#    final path component is resolved NO-FOLLOW (ext2_path_lookup_ex follow_last=0) so it
#    reads the LINK, not its target; ext2-only. The ring-3 primitive a symlink manager
#    (hapi) needs to SEE an existing link + byte-compare its target (stat#33 follows).

var sys_exit_code = 0;

# --- execwait #37 nested-exec save block (1.43.x) ---
# Snapshot of agnsh's kernel resume context across the nested exec_and_wait(child).
# ALL module-global, NOT [rbp-N] locals: agnsh was itself entered via exec_and_wait
# (by kybernet PID 1), so the resume-context GLOBALS (exec_ctx + kernel_return_* +
# kpti_* + kernel_rsp_save) currently hold KYBERNET's armed frame — the frame
# agnsh's OWN exit() must longjmp into. The nested exec_and_wait(child) overwrites
# them with the #37-handler frame and kernel_resume zeroes kernel_return_*, so
# without a save/restore agnsh's later exit() would find kernel_return_rsp=0 and
# never resume kybernet. Single-slot: correct for one-level nesting under the
# single-threaded run-to-completion model (agnsh runs leaf programs); a recursive
# execwait is refused via ew37_busy. Module-global `var X[N]` = N*u64 — the 8-u64
# exec_ctx mirror is exactly right.
# 1.46.x SMP STEP-2 (#3, 2026-06-26): the ew37_* save block goes PER-CPU (the deferred note below,
# now resolved). Each CPU nesting a #37 gets its OWN snapshot — two CPUs in a #37 simultaneously
# (a bg-proc execwait on an AP while agnsh's #37 runs on the BSP) no longer collide on this scratch.
# Scalars: pcpu_X[4] cell at byte cpu*8; the ew37_ctx mirror: pcpu_ew37_ctx[32], block for cpu c at
# byte c*64 (ew37_ctx_base folds pcpu_cpu()*64 so the copy loop's +0..+56 read VERBATIM). pcpu_cpu()
# cpu_count<2 fast path = slot 0 → single-core byte-identical.
var pcpu_ew37_ctx[32];    # exec_ctx[0..7] mirror per CPU (kybernet's armed resume frame)
fn ew37_ctx_base() { return &pcpu_ew37_ctx + pcpu_cpu() * 64; }
var pcpu_ew37_kr_rsp[4];      # kernel_return_rsp (==1 armed)
fn ew37_kr_rsp_set(v) { store64(&pcpu_ew37_kr_rsp + pcpu_cpu() * 8, v); return 0; }
fn ew37_kr_rsp_get() { return load64(&pcpu_ew37_kr_rsp + pcpu_cpu() * 8); }
var pcpu_ew37_kr_rip[4];      # kernel_return_rip
fn ew37_kr_rip_set(v) { store64(&pcpu_ew37_kr_rip + pcpu_cpu() * 8, v); return 0; }
fn ew37_kr_rip_get() { return load64(&pcpu_ew37_kr_rip + pcpu_cpu() * 8); }
var pcpu_ew37_rsp_save[4];    # kernel_rsp_save — agnsh's user RSP (the exit stub reloads it pre-SYSRET)
fn ew37_rsp_save_set(v) { store64(&pcpu_ew37_rsp_save + pcpu_cpu() * 8, v); return 0; }
fn ew37_rsp_save_get() { return load64(&pcpu_ew37_rsp_save + pcpu_cpu() * 8); }
var pcpu_ew37_a4[4];          # ksyscall_a4 (defense-in-depth)
fn ew37_a4_set(v) { store64(&pcpu_ew37_a4 + pcpu_cpu() * 8, v); return 0; }
fn ew37_a4_get() { return load64(&pcpu_ew37_a4 + pcpu_cpu() * 8); }
var pcpu_ew37_pid[4];         # proc_current_get() (agnsh's pid)
fn ew37_pid_set(v) { store64(&pcpu_ew37_pid + pcpu_cpu() * 8, v); return 0; }
fn ew37_pid_get() { return load64(&pcpu_ew37_pid + pcpu_cpu() * 8); }
var pcpu_ew37_resume_pid[4];  # 1.44.14: exec_resume_pid (agnsh) saved across the nested exec
fn ew37_resume_pid_set(v) { store64(&pcpu_ew37_resume_pid + pcpu_cpu() * 8, v); return 0; }
fn ew37_resume_pid_get() { return load64(&pcpu_ew37_resume_pid + pcpu_cpu() * 8); }
var pcpu_ew37_cr3[4];         # agnsh's CR3 (kpti_user_cr3 the exit stub reloads into CR3)
fn ew37_cr3_set(v) { store64(&pcpu_ew37_cr3 + pcpu_cpu() * 8, v); return 0; }
fn ew37_cr3_get() { return load64(&pcpu_ew37_cr3 + pcpu_cpu() * 8); }
var pcpu_ew37_cpid[4];        # child pid (per-CPU; a [rbp-N] local would survive the disjoint kstack
fn ew37_cpid_set(v) { store64(&pcpu_ew37_cpid + pcpu_cpu() * 8, v); return 0; }   # too, but the slot is the contract)
fn ew37_cpid_get() { return load64(&pcpu_ew37_cpid + pcpu_cpu() * 8); }
var pcpu_ew37_code[4];        # child exit code captured post-resume
fn ew37_code_set(v) { store64(&pcpu_ew37_code + pcpu_cpu() * 8, v); return 0; }
fn ew37_code_get() { return load64(&pcpu_ew37_code + pcpu_cpu() * 8); }
# 1.46.x SMP sub-bite 4d: the #37 re-entrancy guard goes PER-CPU (was a single global `ew37_busy`).
# Each CPU tracks its OWN nested-exec state so a #37 in flight on CPU N does not block CPU M. Capped
# via pcpu_cpu() (syscall_hw.cyr); single-core fast path = slot 0 → byte-for-byte the old global.
# RESOLVED 1.46.x STEP-2 (#3, 2026-06-26): the ew37_* SCRATCH (ew37_cr3/_cpid/_code/_path/_env + ew37_ctx
# + the kr/rsp_save/a4/pid/resume_pid scalars) are NOW per-CPU (above + below), joining the already-per-CPU
# kernel_rsp_save+kpti_* (4b/4c). Two CPUs nesting #37 SIMULTANEOUSLY (reachable post-flip: a bg-proc
# execwait on an AP while agnsh's #37 runs on the BSP) each get their own slot — no scratch collision.
var pcpu_ew37_busy[4];
fn pcpu_ew37_busy_get() { return load64(&pcpu_ew37_busy + pcpu_cpu() * 8); }
fn pcpu_ew37_busy_set(v) { store64(&pcpu_ew37_busy + pcpu_cpu() * 8, v); return 0; }
var pcpu_ew37_path[64];   # 1.46.x STEP-2 (#3): PER-CPU. 16 u64 (128 B) per CPU × 4; cpu c at byte c*128.
fn ew37_path_base() { return &pcpu_ew37_path + pcpu_cpu() * 128; }   # kernel copy of the caller's path cstr (128 B). elf_load_from_file
# does ext2/NVMe I/O under boot CR3 (the user VA + the NVMe BAR are
# NOT both mapped under one CR3), so the path is copied here from the
# user buffer BEFORE the CR3 switch — mirroring sh_cmd_run's sh_path_buf.

# 1.44.10: spawn(#3) in-memory-ELF staging buffer (16 KB = 2048 u64). A ring-3
# PARENT calling spawn runs the handler under the PARENT's CR3, which mirrors only
# 0-256 MB + the GB ranges — so elf_load's fresh page-table pages (allocated
# anywhere in phys) may land in the 256 MB-1 GB gap the parent CR3 does NOT map,
# mis-wiring the child's tables (the 1.44.9 #UD-at-child-entry blocker). The user
# ELF is copied here while the caller CR3 still resolves it, then elf_load runs
# under boot CR3 0x1000 (maps all phys) — the proven 1.44.8 kernel-side condition.
# Mirrors the execwait#37 copy-then-boot-CR3 idiom (no kstack swap — spawn does not
# block). 16 KB bounds an in-memory payload; real binaries load from disk (#37).
# 1.46.x SMP STEP-2 (#3): PER-CPU. Two CPUs each in spawn#3 (e.g. a bg-proc spawn on an AP) would
# clobber one another's staging. 2048 u64 (16 KB) per CPU × 4; cpu c at byte c*16384.
var pcpu_spawn_elf_buf[8192];
fn spawn_elf_buf_base() { return &pcpu_spawn_elf_buf + pcpu_cpu() * 16384; }

# 1.44.11: spawn_path(#43) path/argv staging buffer ([16] = 16 u64 = 128 B, exactly like
# ew37_path — a module-global var X[N] is N*u64 = 8N bytes). Holds the caller's "PATH
# [args..]" line (capped ≤127 by the arg2>127 guard) for the NON-BLOCKING from-disk spawn —
# copied here under the caller CR3 BEFORE the boot-CR3 switch (the user VA won't resolve once
# CR3 is the NVMe-BAR-mapping boot CR3). A DEDICATED buffer (not ew37_path) so a #43 from a
# bg proc can never collide with agnsh's in-flight #37 frame.
var pcpu_spawn_path_buf[64];   # 1.46.x STEP-2 (#3): PER-CPU. 16 u64 (128 B) per CPU × 4; cpu c at byte c*128.
fn spawn_path_buf_base() { return &pcpu_spawn_path_buf + pcpu_cpu() * 128; }
# 1.44.19: per-process env staging — kernel copies of the caller's flat "KEY=V\0KEY=V\0"
# blob (a3=ptr, a4=len on #37/#43; <=1024 B, <=16 entries). DEDICATED buffers per the
# spawn_path_buf rationale above (a bg-proc #43 must never collide with agnsh's in-flight
# #37 frame). No ew37-style save/restore needed: the blob is fully consumed onto the
# child's stack page INSIDE elf_load_from_file, which returns before exec_and_wait runs
# the child — by the time any nested syscall exists, these contents are dead.
# [128] = 128 u64 = 1024 B each (the 8N module-global rule).
var pcpu_ew37_env[512];   # 1.46.x STEP-2 (#3): PER-CPU execwait(#37) env staging. 128 u64 (1024 B) per CPU × 4; cpu c at byte c*1024.
fn ew37_env_base() { return &pcpu_ew37_env + pcpu_cpu() * 1024; }

# 1.46.x (fd-redirect for output capture) — issue 2026-06-15-cyrius-stdlib-missing-syscalls
# group 1 ("the high-value one": an fd-redirect primitive for capturing subprocess helpers;
# consumers: cyrius's regression test-runner (run-a-tool-and-read-its-stdout), shakti session
# logging). A ONE-SHOT redirect consumed by the NEXT execwait#37: route the child's writes to
# `redir_src_fd` (e.g. 1=stdout) to `redir_dst_fd`'s backend (an open writable file or pipe).
# Works because #37 is run-to-completion (the parent is suspended while the child runs), so we
# save the src fd's vfs_table entry, copy the dst entry over it for the child's run, and restore
# on resume — no per-proc fd table needed. NOT applied to the non-blocking spawn#3 (the child
# runs later → a per-proc redirect is the follow-on). vfs_table entry = 32 B (4 u64).
# 1.46.x SMP STEP-2 (#3): PER-CPU. The redirect spans TWO syscalls (exec_redirect#62 arms, the
# next execwait#37 consumes) — both run on the SAME CPU (each CPU's agnsh/bg-proc arms then execs
# on itself), so per-CPU state keeps one CPU's armed redirect from leaking into another CPU's #37.
var pcpu_redir_pending[4];   # 1 = a redirect is armed for the next execwait#37
fn redir_pending_set(v) { store64(&pcpu_redir_pending + pcpu_cpu() * 8, v); return 0; }
fn redir_pending_get() { return load64(&pcpu_redir_pending + pcpu_cpu() * 8); }
var pcpu_redir_src_fd[4];    # the fd the child writes to (gets repointed)
fn redir_src_fd_set(v) { store64(&pcpu_redir_src_fd + pcpu_cpu() * 8, v); return 0; }
fn redir_src_fd_get() { return load64(&pcpu_redir_src_fd + pcpu_cpu() * 8); }
var pcpu_redir_dst_fd[4];    # the backend the writes go to
fn redir_dst_fd_set(v) { store64(&pcpu_redir_dst_fd + pcpu_cpu() * 8, v); return 0; }
fn redir_dst_fd_get() { return load64(&pcpu_redir_dst_fd + pcpu_cpu() * 8); }
var pcpu_redir_backup[16];   # 4 u64 (32-byte vfs_table entry save) per CPU × 4; cpu c at byte c*32.
fn redir_backup_base() { return &pcpu_redir_backup + pcpu_cpu() * 32; }

# Apply the armed redirect: save vfs_table[src] into redir_backup, copy vfs_table[dst] over it.
# Called by execwait#37 right before running the child (under boot CR3 — vfs_table is kernel
# memory, identity-mapped). No-op when nothing is armed (so #37 stays byte-identical by default).
fn exec_redirect_apply() {
    if (redir_pending_get() == 0) { return 0; }
    var rsrc = vfs_fd_table_of(ew37_cpid_get()) + redir_src_fd_get() * 32;
    var rdst = vfs_fd_table_of(ew37_cpid_get()) + redir_dst_fd_get() * 32;
    var rbk = redir_backup_base();
    var k = 0;
    while (k < 32) {
        store64(rbk + k, load64(rsrc + k));   # save src entry
        store64(rsrc + k, load64(rdst + k));             # src <- dst (child's writes now route to dst)
        k = k + 8;
    }
    return 0;
}
# Restore the src fd entry after the child run; clears the one-shot.
fn exec_redirect_restore() {
    if (redir_pending_get() == 0) { return 0; }
    var rsrc = vfs_fd_table_of(ew37_cpid_get()) + redir_src_fd_get() * 32;
    var k = 0;
    var rbk = redir_backup_base();
    while (k < 32) { store64(rsrc + k, load64(rbk + k)); k = k + 8; }
    redir_pending_set(0);
    return 0;
}
var pcpu_spawn_env_buf[512];   # 1.46.x STEP-2 (#3): PER-CPU spawn_path(#43) env staging. 128 u64 (1024 B) per CPU × 4; cpu c at byte c*1024.
fn spawn_env_buf_base() { return &pcpu_spawn_env_buf + pcpu_cpu() * 1024; }
# 1.44.20: blit#39 scaled-row staging — ONE expanded src row (w*scale px, 32bpp). [4096] =
# 4096 u64 = 32 KB (8N), the invariant the handler's `w*scale <= 8192` gate enforces (NOT
# "max FB row" — the expanded width is what lands here). Single-core IF=0 handler scratch.
var fb_scale_rowbuf[4096];

# Security: a userspace pointer must lie in the user VA window [0x200000, 0x40000000):
# above the kernel low region (0-2 MB) and below the 1 GB arena ceiling. EVERY
# legitimate user address is below 1 GB — ELF segments (p_vaddr >= 2 MB, p_memsz
# <= 32 MB, so < 34 MB), the per-pid user stack (0x800000 + pid*0x400000, < 72 MB
# for the 16-process cap), and the mmap arena [0x10000000, 0x40000000). Device
# MMIO / PCI BARs (e.g. NVMe ~0xC0000000) and the 1-4 GB PDPT range the per-process
# CR3 ALSO mirrors all sit ABOVE the ceiling — so without the upper bound a ring-3
# caller could aim a kernel load64/store64 at MMIO or high kernel memory (1.41.5).
# Returns 1 if the pointer/range is safe, 0 otherwise.
fn is_user_ptr(ptr) {
    if (ptr < 0x200000) { return 0; }
    if (ptr >= 0x40000000) { return 0; }   # above the 1 GB user ceiling
    return 1;
}

fn is_user_range(ptr, len) {
    if (ptr < 0x200000) { return 0; }
    if (ptr + len < ptr) { return 0; }          # wrap check
    if (ptr + len > 0x40000000) { return 0; }    # above the 1 GB user ceiling
    return 1;
}

# A RELATIVE path (no leading '/') has no CWD in agnos, so it is rooted at the "/"
# mount — the writable ext2/primary root. This scratch buffer holds the "/"-prepended
# form so bare names (`touch foo`, `cmd > foo`) create in the root FS instead of
# falling through to the read-only initrd (the open handler uses it; the ext2 lookup
# needs the leading '/'). Single-threaded per syscall ⇒ one shared buffer is safe.
var sc_open_abs[32];   # 256 bytes: '/' + up to 254-char relative name

# 1.41.6 (#22): the path-argument preamble every mount-routed FS syscall shares —
# a non-empty length AND a valid user range. Returns 1 if (ptr,len) is an
# acceptable path argument, 0 otherwise. Pure factoring of the duplicated
# `if (len < 1) ... if (is_user_range(ptr,len) == 0) ...` pair; callers keep
# their own canary/return conventions on the reject.
fn sc_path_ok(ptr, len) {
    if (len < 1) { return 0; }
    return is_user_range(ptr, len);
}

# 1.44.19: validate a KERNEL COPY of a caller env blob — flat NUL-separated "KEY=V\0KEY=V\0".
# Rules: the last byte MUST be NUL; every NUL-split entry must be non-empty with '=' (61) at
# index >= 1 (a KEY exists); 1..16 entries. The 16-entry cap is LOAD-BEARING, not stylistic:
# the SysV envp pointer array ends at stack offset 0x3008+(argc+3+envc)*8 and must stay below
# the 0x3100 string base (elf.cyr) — with argc<=8, envc=16 tops out at 0x30E0; envc>=20 would
# overwrite the first string bytes. Enforced HERE on the kernel copy, never trusted from
# caller-side counts. Returns 1 ok / 0 reject (the callers fall back to the default env).
fn sc_env_blob_ok(buf, len) {
    if (len < 1) { return 0; }
    if (load8(buf + len - 1) != 0) { return 0; }     # must end on a NUL
    var entries = 0;
    var i = 0;
    while (i < len) {
        var es = i;
        while (i < len) { if (load8(buf + i) == 0) { break; } i = i + 1; }
        var el = i - es;                              # entry [es, es+el), NUL at i
        if (el > 0) {
            # require a '=' at index >= 1 within the entry
            var eq = 0;
            var j = es + 1;
            while (j < es + el) { if (load8(buf + j) == 61) { eq = 1; break; } j = j + 1; }
            if (eq == 0) { return 0; }
            entries = entries + 1;
            if (entries > 16) { return 0; }
        }
        i = i + 1;                                    # skip the NUL
    }
    if (entries < 1) { return 0; }
    return 1;
}

# Resume kernel execution after a user process exits, by performing
# exec_and_wait's epilogue: ret_rsp is exec_and_wait's OWN rbp, so
# `mov rsp, ret_rsp; pop rbp; ret` restores the caller's rbp and returns into
# the caller (sh_cmd_run) exactly as if exec_and_wait had returned normally —
# letting the kernel/shell continue (run more programs) instead of halting on a
# garbage rbp. (1.40.4 — the old version jmp'd without restoring rbp.)
fn kernel_resume() {
    # 1.42.14 SECURITY (audit #3): the SYSCALL entry stub's STAC (AC=1, SMAP off
    # for the user-copy window) is paired with a CLAC only on the NORMAL return.
    # The exit syscall (num==0) reaches here and longjmps out (jmp rdx below) —
    # it never returns to the stub, so AC would stay 1 and ALL post-exit kernel
    # work (the next `run`, ext2/VFS) would execute with SMAP disabled. Re-enable
    # SMAP here so the exit path resumes with the backstop intact.
    asm {
        0x0F; 0x01; 0xCA;   # clac
    }
    kernel_return_rsp_set(0);
    kernel_return_rip_set(0);
    # 1.40.10 bite 2 — restore the kernel main thread (proc 0) as current after a
    # program exits. sh_cmd_run sets proc_current_get() = the exec pid for exit-code
    # attribution; without this reset proc_current_get() stays on that now-dead
    # (state=0) proc, and the next timer tick's do_context_switch (sched.cyr)
    # takes it as `old` and unconditionally marks it ready again (line 150,
    # deliberately unconditional per iron Attempt 14 — do NOT make it conditional),
    # resurrecting a dead exec proc that sched_next could then switch into → an
    # iretq into ring-3 user code under CS=0x08. Pointing proc_current_get() back at
    # proc 0 (the kmain thread registered before sched_active=1) keeps every
    # post-exit timer tick switching kmain↔idle only. Exit-code attribution is
    # unaffected: sh_cmd_run reads the local pid (shell.cyr:765), not proc_current_get(),
    # and the exit code was already stamped before kernel_resume was called. During
    # the boot exec selftest sched_active=0 (no scheduling) so this is a no-op there.
    proc_current_set(0);
    # 1.53.x B3b: arm #NM for the resumed context — the foreground-exec-return longjmps
    # back to the parent WITHOUT passing through enter_ring3 or the scheduler, so its
    # next SSE op must fault to FXRSTOR its FP area rather than run on the reaped child's
    # stale XMM. Bare CR0.TS RMW; the kernel is FP-free so TS=1 is inert until that op.
    fpu_set_ts();
    # 1.40.6: restore the BOOT kernel CR3 (0x1000). On the program's exit the
    # SYSCALL stub left CR3 = the per-process CR3, which mirrors only 0-1 GB +
    # PDPT[1..3] — it does NOT map the device MMIO (NVMe BAR ~0xC0000010xx) that
    # the next kernel work (ext2 read for the next `run`) touches → a second
    # sequential exec faulted on the NVMe BAR. Switch back to the boot CR3 (maps
    # everything, incl. MMIO) so the kernel runs clean after a program exits.
    # kernel_resume's code + exec_ctx are in 0-2 MB, mapped under 0x1000 too.
    asm {
        0x48; 0xC7; 0xC0; 0x00; 0x10; 0x00; 0x00;  # mov rax, 0x1000
        0x0F; 0x22; 0xD8;                           # mov cr3, rax
    }
    # Switch back to kernel data segments (SS/DS/ES = 0x10).
    asm {
        0x48; 0xC7; 0xC0; 0x10; 0x00; 0x00; 0x00;  # mov rax, 0x10
        0x8E; 0xD8;  # mov ds, ax
        0x8E; 0xC0;  # mov es, ax
        0x8E; 0xD0;  # mov ss, ax
    }
    # Restore the full resume context exec_and_wait saved (callee-saved regs +
    # caller rbp + return rsp/rip), then jmp — exec_and_wait "returns" exactly
    # as a normal call. `var c = &exec_ctx` lands the address in rax; rdx scratch.
    var c = exec_ctx_base();
    asm {
        0x48; 0x8B; 0x18;        # mov rbx, [rax]
        0x4C; 0x8B; 0x60; 0x08;  # mov r12, [rax+8]
        0x4C; 0x8B; 0x68; 0x10;  # mov r13, [rax+16]
        0x4C; 0x8B; 0x70; 0x18;  # mov r14, [rax+24]
        0x4C; 0x8B; 0x78; 0x20;  # mov r15, [rax+32]
        0x48; 0x8B; 0x68; 0x28;  # mov rbp, [rax+40]   (caller rbp)
        0x48; 0x8B; 0x50; 0x38;  # mov rdx, [rax+56]   (return rip)
        0x48; 0x8B; 0x60; 0x30;  # mov rsp, [rax+48]   (caller post-call rsp)
        0xFF; 0xE2;              # jmp rdx
    }
    return 0;
}

# === proc-teardown-on-fault (1.47.x fault-resilience arc) ===
# A RING-3 (CPL3) CPU exception (#PF/#GP/#UD) is routed here by the idt.cyr exception
# stub, which calls this ONLY when the saved-frame CS has RPL==3 (a ring-3 fault), instead
# of painting the 1.45.16 fault-canary bar and halting the box. We mirror exit#0's teardown
# for the FAULTING proc, then — when it is the foreground exec_and_wait child (the common
# case: agnsh exec'd a tool that segfaulted, e.g. the cyrius-doom OOB #PF) — kernel_resume()
# back into agnsh EXACTLY as a clean exit would (restores boot CR3 + the saved continuation;
# DOES NOT RETURN). A userland segfault must not take the whole system down.
#
# Scope (first bite): the foreground child case. A CPL3 fault in a `&` BACKGROUND job
# (proc_current != exec_resume_pid) returns to the stub, which halts — bg-proc fault teardown
# needs a scheduler-yield-from-fault path (follow-on, same arc). A KERNEL (CPL0) fault never
# reaches here (the stub gates on RPL==3), so a real kernel bug still halts loudly behind the
# canary bar — the CPL0 path is deliberately untouched.
#
# Runs on the faulting proc's OWN per-proc RSP0 kstack (1.46.x region-7) with the proc's CR3
# still loaded — identical to exit#0, which also runs its teardown on the child's CR3 before
# kernel_resume switches to boot CR3. The IDT interrupt gate cleared IF on entry, so the
# teardown is uninterruptible (no preemption mid-teardown), matching exit#0's IF=0 handler.
#
# Exit code = 128 + vector (POSIX-ish): a fault-killed proc is distinguishable from a small
# clean exit code. agnsh surfaces it via its normal "run: exit N" path; a dedicated
# "killed (#PF)" message is a userland (agnoshi) follow-on (kprint here is unsafe — the FB
# may be unmapped under the faulting proc's CR3, per the idt.cyr canary-paint #DF note).
fn fault_kill_current(vector) {
    var pid = proc_current_get();
    var code = 128 + vector;
    sys_exit_code = code;
    proc_set_exit_code(pid, code);
    flock_release_pid(pid);                       # release advisory locks (mirror exit#0)
    snd_release_pid(pid);                         # release any snd#64 audio slot (Gate 2)
    gpu_release_pid(pid);                         # 1.55.x: hand the scanout back to the console. Without
    # this a full-screen app that FAULTS would strand its last
    # frame on the panel forever while the console scrolled
    # invisibly — the crash path must mirror exit#0 exactly.
    if (pid < proc_count) {
        proc_set_state(pid, 0);                   # mark dead — sched_next won't pick it
        # 1.53.x B3b: clear this CPU's FP owner if it named the dying proc, so a recycled
        # slot (same pid) doesn't hit nm_handler's prev==cur fast-path and SKIP the restore
        # (a silent XMM leak into the new occupant). No fxsave — the dying XMM is garbage.
        var _fkc = pcpu_cpu();
        if (load64(&fpu_owner + _fkc * 8) == pid) { store64(&fpu_owner + _fkc * 8, 0 - 1); }
        var ppid = proc_get_ppid(pid);
        if (ppid >= 0) { proc_send_signal(ppid, 17); }   # SIGCHLD to parent
    }
    # Foreground exec child → resume agnsh's exec_and_wait as a clean exit would.
    # kernel_resume restores boot CR3 + the saved continuation and NEVER returns.
    if (kernel_return_rsp_get() != 0) {
        if (pid == exec_resume_pid_get()) {
            kernel_resume();
        }
    }
    # 1.50.7 bg-job fault teardown: a BACKGROUND (`&`) proc faulted — it is NOT the
    # foreground exec child (no armed kernel_resume for it), so control reached here
    # instead of the kernel_resume() above. The proc is already torn down (state 0 +
    # SIGCHLD to its parent), so the box must NOT halt: a server running concurrent bg
    # services has to survive one service's ring-3 fault. Yield to the scheduler via the
    # PROVEN timer-preemption path — enable interrupts and halt; the next timer tick's
    # do_context_switch saves this now-dead slot (harmless), declines to revive it
    # (state 0, sched.cyr:336 guard), and context-switches to the next ready proc
    # (agnsh / idle) through the timer ISR's OWN pop+iretq epilogue. We never return
    # through the abandoned exception frame.
    #
    # Why sti+hlt and not a direct switch here: do_context_switch restores the next proc
    # INTO an isr_rsp frame and relies on the timer ISR's epilogue (pic.cyr) to iretq it
    # — this fault stub has no such epilogue (it `call`s us, then falls through to halt).
    # Letting the REAL timer tick drive the switch reuses that epilogue intact (lowest-
    # risk; the roadmap-blessed "existing sched_next/do_context_switch path"). preempt_count
    # is 0 here — only a CPL3 fault reaches this fn (the idt.cyr stub gates on saved-CS
    # RPL==3, so the faulter was in ring 3, never mid kernel critical-section) — so
    # do_context_switch is not preempt-gated and WILL switch. Mirrors the smp.cyr:586 /
    # kernel_idle_loop idle pattern (sti;hlt) until that switch fires.
    while (1) { asm { sti; hlt; } }
    return 0;                             # unreachable — kept for the type checker
}

# === Blocking keyboard stdin (1.41.1 — shell-separation arc; line discipline 1.41.15) ===
# read(fd=0) for a ring-3 process: block, read a WHOLE LINE in ONE continuous
# interrupts-enabled window, echo as we go, return when Enter (newline) is seen
# or the caller's buffer fills. Canonical-lite line discipline (ABI O1, revised
# 1.41.15): kernel echoes printable bytes + handles backspace + terminates on
# newline — the userland shell consumes a ready-made line. This is a deliberate
# move AWAY from the original RAW per-byte design, for the reason below.
#
# WHY THE PER-BYTE RAW DESIGN BROKE ON IRON (the 1.41.14 `14114` "Command: D"
# burn): keystrokes on archaemenid arrive via IRQ1 -> kb_isr -> kb_buf (the UEFI
# USB-legacy i8042 emulation; hid_poll's xHCI ring stays empty on that box). The
# in-kernel recovery shell types correctly there because it holds IF=1 across the
# ENTIRE line in one loop, so every scancode — including the SHIFT-RELEASE break
# (0xAA) — is processed in-window and kb_shift is cleared. The old userland path
# returned after the FIRST char, and ring 3 runs with IF=0 between syscalls
# (ring3.cyr:108 sets RFLAGS=0x002; SYSRET restores it via R11). In that IF=0
# inter-byte gap IRQ1 is masked, so a shift-release landing there was DROPPED:
# kb_shift latched at 1, and scancode 0x20 ('d') resolved through sc_shifted to
# 'D'=68 — every typed line collapsed to a stuck shift+d. The fix is to stop
# diverging from the proven reference: drain the whole line under one continuous
# sti window, exactly like shell.cyr's input loop.
#
# Why `sti` is safe in a ring-3 syscall: the only unsafe interrupt mid-syscall
# is the TIMER (its handler calls do_context_switch; the kernel is not reentrant
# across a switch on the syscall stack). We clear sched_active for the duration:
# the timer ISR still fires (EOIs + advances timer_ticks, so net/NTP timing keeps
# moving) but do_context_switch early-returns. Held across the whole line, same
# regime the in-kernel shell runs in.
#
# kb_has_key() also calls hid_poll() to drain the xHCI USB-HID event ring (how
# QEMU's usb-kbd delivers — events DMA in regardless of any interrupt). One loop
# serves both: iron fills kb_buf via IRQ1, QEMU via the polled hid_poll drain. We
# busy-poll (no hlt) so the QEMU path needs no wake interrupt. Echo uses kputc
# (serial + GOP framebuffer mirror) — the same fb path write(1) uses from a
# ring-3 syscall since 1.41.12, so it renders under the unified exec CR3 on iron.
fn kbd_read_blocking(buf, count) {
    if (count <= 0) { return 0; }
    preempt_disable();         # 1.44.1: suspend preemption for the whole line read.
    # The timer ISR still EOIs + ticks, but do_context_switch is a no-op while
    # preempt_count>0. Replaces the old `sched_active=0`/save+restore toggle: the
    # counted gate is nestable and composes with the boot sched_active=0 (which keeps
    # do_context_switch returning regardless) — no manual save/restore needed.
    kb_shift = 0; kb_ctrl = 0; # defensive: never enter a read with a stranded
    # modifier from a prior partial read (continuous drain below keeps it honest
    # within the line; this just guarantees a clean start)
    kbd_irq_enable();          # IF=1 for the WHOLE line so the spin can take the
    # timer wake. INPUT PATH (corrected 1.44.x): archaemenid is USB-keyboard-only
    # (no PS/2 / i8042), so keystrokes arrive via the xHCI USB-HID ring that
    # kb_has_key()->hid_poll() drains; the IRQ1/kb_isr/PIC path is DEAD CODE on
    # this hardware (QEMU's usb-kbd delivers via the same hid_poll ring). The old
    # "IRQ1 fills kb_buf on iron" comment here was wrong and misdirected five
    # iron burns — see project_archaemenid_keystroke_path_usb_only.
    hid_kbd_kick();            # KBD-RING-DEPTH FIX: re-kick the kbd EP in case it
    # stalled during the IF=0 command-execution gap since the previous read. The
    # deep transfer ring (hid_kbd_configure) prevents the stall; this restarts the
    # EP if one ever happens anyway. No-op if no HID kbd (slot 0) / already Running.
    var n = 0;
    while (n < count) {
        while (kb_has_key() == 0) { arch_wait(); }   # hlt-park until timer/kbd IRQ — NOT a busy-spin.
        # A continuous IF=1 ring-0 CPU busy-spin starves the firmware's SMM USB-legacy keyboard
        # emulation on real Zen (it injects i8042 scancodes via periodic SMIs, which a never-yielding
        # spin can't let run) -> keyboard dies after the first line; invisible in QEMU (no SMM legacy
        # emulation). hlt yields the pipeline so SMM runs, and is the proven-on-iron recipe used by
        # sleep_ms#41 (DOOM frame pacing) + kbscan#42 (DOOM input). IF=1 (sti above) so the 100 Hz
        # timer guarantees a wake even with no key; a keystroke's own IRQ1 wakes hlt immediately.
        # preempt_count>0 (preempt_disable above) so the timer ISR ticks+EOIs but never switches.
        var sc = kb_read_scancode();
        var ch = scancode_to_ascii(sc);
        if (ch == 10) {                 # Enter: terminate the line. Echo newline,
            kputc(10);                  # store it as the terminator, return.
            store8(buf + n, 10);
            n = n + 1;
            kbd_irq_disable();
            preempt_enable();
            return n;
        }
        if (ch == 4) {                  # Ctrl-D (EOF). Canonical tty semantics:
            # at line start (n==0) signal end-of-input by returning 0 — this is
            # the ONLY path by which read(fd 0) can return 0 on agnos, so it's
            # what lets a stdin filter (anuenue, cat) terminate; without it a
            # filter loops forever (no pipes, no other EOF). Mid-line (n>0) it
            # delivers the bytes typed so far WITHOUT a terminating LF, so a
            # second Ctrl-D at the fresh line start then yields EOF. Not echoed.
            kbd_irq_disable();
            preempt_enable();
            return n;
        }
        if (ch == 8) {                  # Backspace: erase one cell + drop one byte
            if (n > 0) {                # (BS SP BS), mirrors shell.cyr:797.
                n = n - 1;
                kputc(8); kputc(32); kputc(8);
            }
        } elif (ch > 31) {              # Printable: store + echo (shell.cyr:800-805)
            store8(buf + n, ch);
            n = n + 1;
            kputc(ch);
        }
        # ch == 0 (modifier/release) or other control (<32, non-LF/BS): consumed
        # in-window, never stored — so the whole make/break stream is drained here
        # and kb_shift can't strand across a syscall boundary.
    }
    # Buffer filled before a newline arrived — return the partial line.
    kbd_irq_disable();
    preempt_enable();
    return n;
}

# 1.44.x — NON-BLOCKING cooked-line stdin read for schedulable agnsh (Option B). The blocking
# read above busy-spins `while kb_has_key()==0` holding preempt_disable for the WHOLE line — so a
# background job CANNOT run while agnsh waits at the prompt. This variant instead DRAINS whatever
# is already in kb_buf (cook + echo + line-edit into the nbline_buf accumulator), and returns:
#   - the line length (incl. the trailing LF) when Enter completes a line, OR
#   - -2 (WOULD_BLOCK) when no complete line is ready yet — DISTINCT from Ctrl-D EOF (0).
# agnsh polls this between bg-job waitpid(#4) polls; bg jobs time-slice in the preemptible RING-3
# gap between agnsh's polls. CRITICAL: the preempt_disable window is SHORT (drain-what's-there,
# NEVER spin) and released before every return, so the scheduler can run bg procs between calls.
fn kbd_read_nonblock(buf, count) {
    if (count <= 0) { return 0; }
    preempt_disable();             # SHORT window — drain only, never spin (see header).
    kbd_irq_enable();              # IF=1 so IRQ1 -> kb_isr (iron) / hid_poll (QEMU) can fill kb_buf.
    if (nbline_pos == 0) { kb_shift = 0; kb_ctrl = 0; }   # clean modifiers ONLY at a fresh line
    # (never mid-line — a shift HELD across a poll boundary must survive into the next drain).
    var ret = 0 - 2;               # default WOULD_BLOCK — NOT 0 (0 is reserved for Ctrl-D EOF).
    var draining = 1;
    while (draining == 1) {
        if (kb_has_key() == 0) { draining = 0; }    # nothing buffered -> stop (do NOT spin)
        else {
            var sc = kb_read_scancode();
            var ch = scancode_to_ascii(sc);
            if (ch == 10) {                          # Enter: flush the accumulated line + LF
                kputc(10);
                # 1.44.21 HARDENING: clamp the flush to THIS call's validated buffer. nbline_buf +
                # nbline_pos PERSIST across poll calls, but `buf` is range-checked only for THIS
                # call's `count` (read#5: is_user_range(arg2, arg3)). A ring-3 caller can accumulate
                # under a large count, then flush under a SMALLER count — copying nbline_pos+1 bytes
                # would then write PAST [buf, buf+count) (an OOB write into the caller's AS, or a
                # fatal kernel #PF under STAC on an unmapped/over-ceiling page). Clamp to count-1 (LF
                # takes the last slot). count>=1 here (the count<=0 guard returns at fn entry).
                # FOREGROUND agnsh polls with a fixed prompt count >= the line, so flush_n==nbline_pos
                # and this is byte-identical; only a shrinking-count caller truncates (safe).
                var flush_n = nbline_pos;
                if (flush_n > count - 1) { flush_n = count - 1; }
                var k = 0;
                while (k < flush_n) { store8(buf + k, load8(&nbline_buf + k)); k = k + 1; }
                store8(buf + flush_n, 10);
                ret = flush_n + 1;
                nbline_pos = 0;
                draining = 0;
            } elif (ch == 4) {                       # Ctrl-D: canonical EOF (mirror kbd_read_blocking)
                if (nbline_pos == 0) { ret = 0; }    # at line start -> EOF (return 0)
                else {                                # mid-line -> deliver typed bytes, no LF
                    # 1.44.21 HARDENING: clamp to THIS call's validated count (no LF on this path,
                    # so the full count is available for data). Same cross-call rationale as Enter.
                    var flush_n2 = nbline_pos;
                    if (flush_n2 > count) { flush_n2 = count; }
                    var k2 = 0;
                    while (k2 < flush_n2) { store8(buf + k2, load8(&nbline_buf + k2)); k2 = k2 + 1; }
                    ret = flush_n2;
                    nbline_pos = 0;
                }
                draining = 0;
            } elif (ch == 8) {                       # Backspace: drop one accumulated byte + erase cell
                if (nbline_pos > 0) {
                    nbline_pos = nbline_pos - 1;
                    kputc(8); kputc(32); kputc(8);
                }
            } elif (ch > 31) {                       # Printable: accumulate + echo (cap: leave room for LF)
                if (nbline_pos + 1 < count) {
                    if (nbline_pos < 4095) {         # nbline_buf capacity (512 u64 = 4096 B)
                        store8(&nbline_buf + nbline_pos, ch);
                        nbline_pos = nbline_pos + 1;
                        kputc(ch);
                    }
                }
            }
            # ch == 0 (modifier/release) or other control: consumed in-window, never stored.
        }
    }
    kbd_irq_disable();
    preempt_enable();
    # 1.44.14: distinguish "no complete line, but a PARTIAL line is buffered here" (-3) from
    # "nothing buffered at all" (-2). The accumulator (nbline_buf) persists ACROSS poll calls, so
    # if agnsh's last background job drains mid-line and agnsh switched to the BLOCKING read (which
    # accumulates into the USER buffer, NOT nbline_buf), the half-typed line would be ORPHANED and
    # the command would split + misparse. -3 tells agnsh to KEEP polling (never switch to blocking)
    # until this line completes; -2 (truly empty) is safe to block on.
    if (ret == 0 - 2) {
        if (nbline_pos > 0) { ret = 0 - 3; }
    }
    return ret;
}

# System hostname — read-only identity for uname(34).nodename. Seeded to
# "agnos"; no sethostname syscall yet (added only when a native workload needs a
# mutable hostname — kernel grows per workload, not by Linux default). A gvar
# string literal, safe to read from a syscall (post-gvar-init, like _AGNOS_VERSION).
var kernel_hostname = "agnos";

# Copy a NUL-terminated kernel string literal into a fixed `max`-byte user field,
# NUL-padding the remainder. Stops at the source NUL or `max` bytes, whichever
# comes first — never reads past a short literal. `dst` is part of a user buffer
# the caller already validated with is_user_range. Used by uname(34).
fn sysinfo_put_str(dst, src, max) {
    var copying = 1;
    var i = 0;
    while (i < max) {
        var c = 0;
        if (copying == 1) {
            c = load8(src + i);
            if (c == 0) { copying = 0; }   # hit end of source — pad zeros from here
        }
        store8(dst + i, c);
        i = i + 1;
    }
    return 0;
}

# SMP sub-bite 5 (fs_lock): the ext2 open/create body, extracted so the syscall #2
# arm can wrap it in a SINGLE fs_lock/unlock (one return point → the lock can't leak
# across an early return). Caller has already resolved be7==FS_EXT2 and set the
# vfs_base_off/vfs_base_len globals via vfs_resolve_mount. All ext2_*/vfs_ext2_parent
# called here are leaves w.r.t. the VFS boundary (no locked-fn re-entry).
fn sys_open_ext2_inner(arg1, arg2, arg3) {
    if ((arg3 & 0x800) != 0) { return ext2_open_dir(arg1, arg2); }
    var ino7 = ext2_path_lookup(arg1, arg2);
    if (ino7 <= 0) {
        if ((arg3 & 0x100) == 0) { return 0 - 1; }
        var par7 = vfs_ext2_parent(arg1, arg2);
        if (par7 <= 0) { return 0 - 1; }
        if (ext2_create(par7, arg1 + vfs_base_off, vfs_base_len) <= 0) { return 0 - 1; }
    } else {
        if ((arg3 & 0x200) != 0) { ext2_truncate_zero(ino7); }
    }
    return ext2_open(arg1, arg2);
}

# ================================================================
# Kernel shared-memory buffers (shm #71-74) — the sovereign shared-buffer PRESENT
# backend (setu buf.cyr's agnos path). A client WRITEs its rendered pixels into a
# kernel-OWNED buffer keyed by a small id, ATTACH carries the id (not the pixels),
# and the compositor READs them back out. This sidesteps the single-CPU two-proc TCP
# flow-control deadlock (TCP_RX_RING = 2 KB, but a surface is hundreds of KB).
#
# COPY-based (not shared-page-mapped) ON PURPOSE: the buffer is kmalloc'd (kernel heap,
# present in EVERY proc's CR3 via the kernel mirror), so the client's shm_write and the
# compositor's shm_read each reach it from their own syscall CR3 with a plain copy — no
# cross-proc page mapping, and a client that exits right after present can't free it
# (proc_free_address_space only frees a proc's OWN arena pages, never the kernel heap).
# See agnosticos docs/development/planning/shared-buffer-present.md.
var SHM_MAX = 16;
var SHM_MAX_SIZE = 2097152;         # 2 MB — one pmm page per buffer (bite-2 cap; multi-page = follow-up)
var shm_phys[16];                   # 2 MB physical base per slot (0 = free)
var shm_kva[16];                    # kernel access VA for the page (kernel-mirror; every-CR3 reachable)
var shm_size[16];                   # byte size per slot
var shm_mc[16];                     # GPU MC address per slot (0 = PMM-backed ⇒ NOT GPU-reachable)

# ids are 1-BASED: 0 is the setu "inline pixels" sentinel (setu_attach arg5), so a real
# shm buffer must never be 0. slot = id - 1.
fn shm_slot_valid(id) {
    if (id < 1) { return 0; }
    if (id > SHM_MAX) { return 0; }
    if (load64(&shm_phys + (id - 1) * 8) == 0) { return 0; }
    return 1;
}

# Byte copy (word-fast + byte tail). Both ends are reachable in the current CR3
# (the user range in the caller's arena + the shm page's kernel-mirror KVA).
fn shm_copy(dst, src, n) {
    var words = n / 8;
    var wi = 0;
    while (wi < words) { store64(dst + wi * 8, load64(src + wi * 8)); wi = wi + 1; }
    var bi = words * 8;
    while (bi < n) { store8(dst + bi, load8(src + bi)); bi = bi + 1; }
    return 0;
}

# shm_create(size) -> slot id (0..SHM_MAX-1) or -1 (bad size / OOM / table full).
# Backed by a single 2 MB pmm page (kmalloc caps out well below a surface); the page's
# kernel-access VA lives in the kernel mirror, so shm_write (client CR3) and shm_read
# (compositor CR3) both reach it with a plain copy — no cross-proc page mapping.
fn shm_create(size) {
    if (size <= 0) { return 0 - 1; }
    if (size > SHM_MAX_SIZE) { return 0 - 1; }
    var i = 0;
    while (i < SHM_MAX) {
        if (load64(&shm_phys + i * 8) == 0) {
            var phys = pmm_alloc_2mb();
            if (phys == 0) { return 0 - 1; }
            var kva = pmm_kva_for_access(phys);
            store64(&shm_phys + i * 8, phys);
            store64(&shm_kva + i * 8, kva);
            store64(&shm_size + i * 8, size);
            return i + 1;                           # 1-based id (0 reserved for "inline")
        }
        i = i + 1;
    }
    return 0 - 1;
}

# shm_create_gpu(size) -> slot id (1-based) / -1. The GPU-VISIBLE peer of shm_create#71: same table, same
# shm_write#72 / shm_read#73 / shm_free#74, but the page is carved out of the GPU CARVEOUT instead of PMM so
# it has an MC address the CP-DMA engine can actually read. That is not an optimisation — `pmm_alloc_2mb`
# returns SYSTEM RAM and the GPU cannot reach it at all (bus-master off by design), so a GPU composite is
# impossible from a #71 buffer. Slot i is a FIXED 2 MB window at GPU_SHM_REGION_OFF + i*GPU_SHM_SLOT_SIZE —
# no allocator, and the MC address is pure arithmetic off the carveout base. Returns -1 when there is no GPU
# carveout (QEMU): the caller then falls back to shm_create#71 and the CPU path, unchanged.
fn shm_create_gpu(size) {
    if (size <= 0) { return 0 - 1; }
    if (size > SHM_MAX_SIZE) { return 0 - 1; }
    if (gpu_present == 0) { return 0 - 1; }
    if (gpu_arena_mc == 0) { return 0 - 1; }
    if (gpu_arena_phys == 0) { return 0 - 1; }
    # Carveout bases, derived from the arena globals (arena = base + GPU_VM_ARENA_OFF on both sides).
    var cpu_carve = gpu_arena_phys - GPU_VM_ARENA_OFF;
    var mc_carve  = gpu_arena_mc   - GPU_VM_ARENA_OFF;
    var i = 0;
    while (i < SHM_MAX) {
        if (load64(&shm_phys + i * 8) == 0) {
            var off = GPU_SHM_REGION_OFF + i * GPU_SHM_SLOT_SIZE;
            var cpu = cpu_carve + off;                  # CPU-side direct-DRAM window
            var mc  = mc_carve  + off;                  # what the CP-DMA engine addresses
            vmm_remap_wc_2mb(cpu);                      # WC: shm_write is a big sequential CPU store run
            store64(&shm_phys + i * 8, cpu);            # non-zero ⇒ slot in use (shm_slot_valid)
            store64(&shm_kva  + i * 8, cpu);            # the direct window IS the access VA
            store64(&shm_size + i * 8, size);
            store64(&shm_mc   + i * 8, mc);             # the GPU-visibility marker
            return i + 1;                               # 1-based id (0 = setu "inline pixels" sentinel)
        }
        i = i + 1;
    }
    return 0 - 1;
}

# gpu_blit_shm_sys(id, wh, dstxy) -> 0 / -1. THE compositor composite primitive: GPU-blit a client's
# surface straight from its carveout shm slot into the current blit back buffer at (dx,dy), via
# gpu_cp_dma_blit (one CP-DMA per row, src stride = w*4, dst stride = the framebuffer pitch). Replaces the
# per-pixel userland composite AND the shm->userland read that precedes it: the pixels never leave the
# kernel's GPU-visible memory. Pack: wh = (h<<16)|w, dstxy = (dy<<16)|dx — same convention as blit#39.
# Ring-3 passes an id + geometry only; no MC address crosses the boundary. Pair with gpu_fill#85 for the
# background and gpu_present#84 to flip. Returns -1 if the slot is PMM-backed (use #86 to allocate),
# out of bounds, or the GPU/display isn't usable.
fn gpu_blit_shm_sys(id, wh, dstxy) {
    if (gpu_present == 0) { return 0 - 1; }
    if (shm_slot_valid(id) == 0) { return 0 - 1; }
    var slot = id - 1;
    var src_mc = load64(&shm_mc + slot * 8);
    if (src_mc == 0) { return 0 - 1; }                  # PMM-backed ⇒ the GPU cannot read it
    if (gpu_blit_arm() != 1) { return 0 - 1; }
    if (gpu_bb_pitch == 0) { return 0 - 1; }
    var w  = wh & 0xFFFF;
    var h  = (wh >> 16) & 0xFFFF;
    var dx = dstxy & 0xFFFF;
    var dy = (dstxy >> 16) & 0xFFFF;
    if (w < 1) { return 0 - 1; }
    if (h < 1) { return 0 - 1; }
    var row = w * 4;                                    # 32bpp packed source rows
    if (row * h > load64(&shm_size + slot * 8)) { return 0 - 1; }   # source must fit its slot
    # Reject (don't silently clip) anything off-screen — the compositor owns clipping.
    var fbw = gpu_bb_pitch / 4;
    var fbh = gpu_bb_fbsize / gpu_bb_pitch;
    if (dx + w > fbw) { return 0 - 1; }
    if (dy + h > fbh) { return 0 - 1; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    if (gpu_cp_dma_blit(dst_mc, gpu_bb_pitch, src_mc, row, row, h) != 1) { return 0 - 1; }
    return 0;
}

# gpu_fill_rect_sys(color, wh, dstxy) -> 0 / -1. The RECT peer of gpu_fill#85 (which only clears the WHOLE
# back buffer). GPU-fills a sub-rectangle with a 32-bit xRGB8888 colour via gpu_cp_dma_fill_rect. This is the
# window-chrome primitive: a compositor draws body/titlebar/focus-accent/buttons as ~10 of these per window
# per frame, today a per-pixel CPU loop with 4 compares + 2 loads + 2 multiplies BEFORE each store32.
# Pack: wh = (h<<16)|w, dstxy = (dy<<16)|dx — blit#39's convention. Rejects (does not clip) off-screen
# rects; the compositor owns clipping and learns the bounds from gpu_caps#89.
fn gpu_fill_rect_sys(color, wh, dstxy) {
    if (gpu_present == 0) { return 0 - 1; }
    if (gpu_blit_arm() != 1) { return 0 - 1; }
    if (gpu_bb_pitch == 0) { return 0 - 1; }
    var w  = wh & 0xFFFF;
    var h  = (wh >> 16) & 0xFFFF;
    var dx = dstxy & 0xFFFF;
    var dy = (dstxy >> 16) & 0xFFFF;
    if (w < 1) { return 0 - 1; }
    if (h < 1) { return 0 - 1; }
    var fbw = gpu_bb_pitch / 4;
    var fbh = gpu_bb_fbsize / gpu_bb_pitch;
    if (dx + w > fbw) { return 0 - 1; }
    if (dy + h > fbh) { return 0 - 1; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    if (gpu_cp_dma_fill_rect(dst_mc, gpu_bb_pitch, color, w * 4, h) != 1) { return 0 - 1; }
    return 0;
}

# gpu_readback_shm_sys(id, wh, srcxy) -> 0 / -1. The INVERSE of gpu_blit_shm#87: GPU-copy a rectangle OUT of
# the current blit back buffer at (sx,sy) INTO the client's carveout shm slot `id`, via gpu_cp_dma_blit (one
# CP-DMA per row, src stride = the framebuffer pitch, dst stride = w*4 packed). This is the screen-capture /
# read-pixels primitive; without it a compositor reading its own shm sees STALE content because the composited
# result lives in the kernel's GPU back buffer, never in the client page. The captured pixels are the frame
# the compositor just built (the render target #87/#88/#92 write), before #84 flips it. Pack: wh = (h<<16)|w,
# srcxy = (sy<<16)|sx. Ring 3 passes an id + geometry only; no MC address crosses the boundary. Returns -1 if
# the slot is PMM-backed (the GPU cannot WRITE it — use #86 to allocate), the capture won't fit the slot, the
# rect is off-screen, or the GPU/display isn't usable.
fn gpu_readback_shm_sys(id, wh, srcxy) {
    if (gpu_present == 0) { return 0 - 1; }
    if (shm_slot_valid(id) == 0) { return 0 - 1; }
    var slot = id - 1;
    var dst_mc = load64(&shm_mc + slot * 8);
    if (dst_mc == 0) { return 0 - 1; }                  # PMM-backed ⇒ the GPU cannot write it
    if (gpu_blit_arm() != 1) { return 0 - 1; }
    if (gpu_bb_pitch == 0) { return 0 - 1; }
    var w  = wh & 0xFFFF;
    var h  = (wh >> 16) & 0xFFFF;
    var sx = srcxy & 0xFFFF;
    var sy = (srcxy >> 16) & 0xFFFF;
    if (w < 1) { return 0 - 1; }
    if (h < 1) { return 0 - 1; }
    var row = w * 4;                                    # 32bpp packed destination rows
    if (row * h > load64(&shm_size + slot * 8)) { return 0 - 1; }   # capture must fit the slot
    # Reject (don't silently clip) anything off-screen — the compositor owns clipping.
    var fbw = gpu_bb_pitch / 4;
    var fbh = gpu_bb_fbsize / gpu_bb_pitch;
    if (sx + w > fbw) { return 0 - 1; }
    if (sy + h > fbh) { return 0 - 1; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var src_mc = tgt + sy * gpu_bb_pitch + sx * 4;
    # COHERENCE: the destination slot's CPU window is WC-mapped, and the CPU reads it via shm_read#73 AFTER
    # this CP-DMA writes it. Empirically (iron 2026-07-23, gpucopy) a slot the CPU has ALREADY read returns a
    # STALE cache-line ghost of its previous contents on the next read — the fresh GPU write never reaches the
    # CPU. Same class as gpu.md C2g-1 ("dispatch into a fresh, never-CPU-touched slot"). Evict the stale/dirty
    # lines BEFORE the DMA (not after: a flush after would write a dirty line back OVER the GPU's fresh data).
    # A whole-cache wbinvd proved this on iron (gpucopy exit 95, burn 4); this is the SCOPED form — clflush
    # only the destination window [kva, kva+row*h), so a per-frame screen capture doesn't flush the world.
    var kva = load64(&shm_kva + slot * 8);
    var total = row * h;
    var off = 0;
    while (off < total) { clflush(kva + off); off = off + 64; }
    gpu_mfence();
    if (gpu_cp_dma_blit(dst_mc, row, src_mc, gpu_bb_pitch, row, h) != 1) { return 0 - 1; }
    return 0;
}

# gpu_blit_bb_sys(srcxy, wh, dstxy) -> 0 / -1. A rect COPY within the blit back buffer, from (sx,sy) to
# (dx,dy): the move-a-window / scroll-a-region primitive, entirely on the GPU (gpu_cp_dma_blit, framebuffer
# pitch on both sides). Pack: wh = (h<<16)|w, srcxy = (sy<<16)|sx, dstxy = (dy<<16)|dx. Rejects (does not clip)
# either rect off-screen; the compositor owns clipping. OVERLAP: the copy is one CP-DMA per row, so a DOWNWARD
# move (dy > sy) into overlapping rows must run BOTTOM-UP or it would read a row after the row above it was
# overwritten (memmove semantics) — handled below. An upward or non-overlapping move is safe top-down.
# Intra-row horizontal overlap on the SAME source row is still undefined (one DMA reads-then-writes the whole
# row); a caller must not self-overlap a single row.
fn gpu_blit_bb_sys(srcxy, wh, dstxy) {
    if (gpu_present == 0) { return 0 - 1; }
    if (gpu_blit_arm() != 1) { return 0 - 1; }
    if (gpu_bb_pitch == 0) { return 0 - 1; }
    var w  = wh & 0xFFFF;
    var h  = (wh >> 16) & 0xFFFF;
    var sx = srcxy & 0xFFFF;
    var sy = (srcxy >> 16) & 0xFFFF;
    var dx = dstxy & 0xFFFF;
    var dy = (dstxy >> 16) & 0xFFFF;
    if (w < 1) { return 0 - 1; }
    if (h < 1) { return 0 - 1; }
    var fbw = gpu_bb_pitch / 4;
    var fbh = gpu_bb_fbsize / gpu_bb_pitch;
    if (sx + w > fbw) { return 0 - 1; }
    if (sy + h > fbh) { return 0 - 1; }
    if (dx + w > fbw) { return 0 - 1; }
    if (dy + h > fbh) { return 0 - 1; }
    var tgt = gpu_bb_a_mc;
    if (gpu_bb_back != 0) { tgt = gpu_bb_b_mc; }
    var row = w * 4;
    # Downward overlapping move ⇒ copy rows bottom-up so each source row is read before the destination row
    # one place above it (which shares its pixels) is overwritten. Upward/non-overlapping is safe top-down.
    if (dy > sy) {
        var i = h;
        var s = 0;
        var d = 0;
        while (i > 0) {
            i = i - 1;
            s = tgt + (sy + i) * gpu_bb_pitch + sx * 4;
            d = tgt + (dy + i) * gpu_bb_pitch + dx * 4;
            if (gpu_cp_dma(d, s, row) != 1) { return 0 - 1; }
        }
        return 0;
    }
    var src_mc = tgt + sy * gpu_bb_pitch + sx * 4;
    var dst_mc = tgt + dy * gpu_bb_pitch + dx * 4;
    if (gpu_cp_dma_blit(dst_mc, gpu_bb_pitch, src_mc, gpu_bb_pitch, row, h) != 1) { return 0 - 1; }
    return 0;
}

# ── #92 gpu_shader_op — THE shader-compositing seam (plan bite S8, decision D-3) ───────────────────────
#
# ONE syscall number. An ARRAY of fixed-size op records. The operation is an op code INSIDE each record,
# so alpha blend, coverage, glyph expand and gradient are op codes rather than syscall numbers, and every
# later primitive (channel swap, CP-DMA fill/blit as ops, batched frames) rides this same number.
#
# WHY A DESCRIPTOR AND NOT ONE NUMBER PER OP. The arc plan settled this as decision D-3 *before* any of it
# was built; 1.56.2/1.56.3 then shipped the rejected shape anyway (#92 blend, #93 coverage, #94 glyph).
# All four of D-3's reasons still hold:
#   - The dispatcher offers four args and a coverage blit needs five operands. That is exactly why #93/#94
#     had to smuggle their colour through ksyscall_a4 (r10), and why a gradient — which needs two stops
#     plus geometry — had NO room left at all and never got a ring-3 path. A record has no such ceiling.
#   - Syscall numbers are not free. (⚠ HISTORICAL: #90/#91 were *reserved* when this was written; they are
#     now IMPLEMENTED and iron-proven — gpu_readback_shm_sys and gpu_blit_bb_sys, ~1700 lines below. The
#     next free number is #93, ratified for gpu_modeset_op by operator decision MD-4.) This band lands on
#     OCCUPIED, partly DESTRUCTIVE Linux numbers: 92=chown, 93=fchown, 94=lchown, 95=umask. One number
#     costs one collision to document and gate; four cost four.
#   - The consolidated cyrius wrapper ticket exists specifically to end the one-ask-per-syscall pattern.
#   - It makes plan bite S12 (N ops in ONE submission — one flush, one write-back, one fence) an
#     IMPLEMENTATION change rather than an ABI break. That is the point of specifying the array now,
#     while there is exactly one shipped consumer, instead of after a compositor depends on it.
#
# NO ADDRESS APPEARS IN A RECORD. Sources are named by shm slot id and resolved to an MC address inside
# the kernel, so "no MC address crosses the ring-3 boundary" is a property of the LAYOUT rather than a
# rule this handler has to remember to enforce.
#
# ⚠ SOURCES MUST BE PREMULTIPLIED (every colour channel already scaled by its own alpha, so c <= a). The
# shaders compute `out = src + dst*(1 - src_a/255)` with no per-pixel divide, which is only correct for
# premultiplied input. Straight-alpha input produces washed-out edges SILENTLY — never an error. This is
# the single most likely way a caller misuses this syscall, so it is stated here, in the ABI doc, and in
# the cyrius wrapper docstring.

# --- Descriptor staging -------------------------------------------------------------------------------
# syscall.cyr is an INCLUDED module, so a module-global `var X[N]` allocates N x u64 = 8N BYTES (in a
# TOP-LEVEL program the same syntax allocates N bytes — the unit differs by scope, and getting it wrong
# silently under-allocates by 8x). 2048 x 8 = 16384 B = 4 CPUs x 4096 B.
#
# PER-CPU, not one shared buffer. A single global staging cell is precisely what corrupted an FS operation
# under SMP at 1.46.x, where `rename` ran with another CPU's length. Same shape as pcpu_ksyscall_a4[4].
var pcpu_sc_gpuop[2048];             # 16384 B total = GPU_OP_CPUS x GPU_OP_BUF_BYTES
var GPU_OP_CPUS      = 4;            # matches pcpu_cpu()'s `if (c >= 4) { c = 0; }` clamp
var GPU_OP_BUF_BYTES = 4096;         # per-CPU share
var GPU_OP_STRIDE    = 64;           # bytes per op record — a power of two, so indexing is a shift
var GPU_OP_MAX       = 64;           # GPU_OP_BUF_BYTES / GPU_OP_STRIDE
fn sc_gpuop_buf() { return &pcpu_sc_gpuop + pcpu_cpu() * GPU_OP_BUF_BYTES; }

# --- Op codes. Codes 0x00-0x1F are the bitmask tier: an op code IS its bit index in gpu_caps#89's
# support word at +28, so ring 3 can discover exactly which ops this kernel implements instead of
# probing by trial. Minting a code >= 0x20 requires growing gpu_caps first; that is the only sanctioned
# growth path, and it is deliberately awkward so the mask stays authoritative.
var GPU_OP_NOP         = 0x00;       # validated, dispatches nothing — batch padding / ABI probe
var GPU_OP_BLEND_RECT  = 0x01;       # 32bpp premultiplied source, per-pixel src-over   (was #92)
var GPU_OP_BLEND_COV   = 0x02;       # 8bpp coverage mask x one uniform colour           (was #93)
var GPU_OP_GLYPH_1BPP  = 0x03;       # 1bpp bitmap, colour where set, dst untouched      (was #94)
var GPU_OP_GRAD_LINEAR = 0x04;       # two-stop vertical gradient, NO source buffer      (never had one)
# 0x05 channel swap (plan S4) · 0x06 cov-modulated source · 0x07 packed VOP3P blend ·
# 0x10-0x17 CP-DMA-domain ops (fill/blit/readback, plan S12) · 0x18-0x1F control (barrier/present).
var GPU_OP_SUPPORTED   = 0x1F;       # bits 0..4 — MUST equal the set gpo_validate accepts

# Flags word (+4). NOTHING is accepted here yet, on purpose: a flag that is accepted and ignored is how
# a caller silently gets behaviour it did not ask for. bit0 SERIALIZE and bit1 CHECK_PREMUL are reserved
# for S12, where they will mean something; until then a non-zero flags word is rejected.
var GPU_OP_FLAGS_KNOWN = 0x00;

# --- Failure reasons. The syscall returns 0, or a PACKED negative naming WHICH op failed and why:
#       e = 0 - rc ;  idx = e >> 8 ;  reason = e & 0xFF
# reason is always >= 1, so a valid failure never encodes as 0. GPO_E_NOGPU at idx 0 encodes as exactly
# -1, which keeps every existing `if (rc != 0)` / `if (rc == -1)` caller working unchanged.
var GPO_E_NOGPU    = 1;              # call  — GPU/display unavailable
var GPO_E_BADOP    = 2;              # op    — unknown, reserved, or not implemented in this kernel
var GPO_E_BADSLOT  = 3;              # op    — slot invalid/free, or PMM-backed (the GPU cannot read it)
var GPO_E_SLOTSIZE = 4;              # op    — source does not fit its slot under this op's stride rule
var GPO_E_BOUNDS   = 5;              # op    — rect off-screen (REJECT, never clip)
var GPO_E_DIM      = 6;              # op    — w < 1 or h < 1
var GPO_E_ARM      = 7;              # op    — the shader could not be made resident
var GPO_E_DISPATCH = 8;              # op    — the dispatch watchdog expired (pass 2 only)
var GPO_E_DESC     = 11;             # call  — bad desc_uva / len, or the copy-in failed
var GPO_E_RESERVED = 12;             # op    — a reserved field or an undefined flag bit was non-zero
var GPO_E_UNPROVEN = 13;             # call  — the dispatch envelope is unproven on this boot
# call — the BATCH's single completion fence never retired. Distinct from GPO_E_DISPATCH on purpose: with
# one submission there is one marker, so the failing op is NOT identifiable and reporting an index would be
# a fabrication. idx is 0 and carries no meaning for this reason.
var GPO_E_BATCH    = 15;

# gpo_field_mask(op) — bit i set <=> this op DEFINES record dword i (byte offset i*4).
# Every dword an op does not define MUST be zero. That rule is what makes the reserved dwords safe to
# fill in later: a v1 caller physically cannot ship garbage in a field a future kernel will read, so
# `srcxy` / `src_pitch` / `mask_pitch` (dwords 6/7/8) can gain "0 = derive" meaning without an ABI break.
# They are laid out NOW so adding them is never a stride change.
fn gpo_field_mask(op) {
    if (op == GPU_OP_NOP)         { return 0x0003; }   # op flags
    if (op == GPU_OP_BLEND_RECT)  { return 0x0037; }   # op flags src_id wh dstxy
    if (op == GPU_OP_BLEND_COV)   { return 0x023B; }   # op flags mask_id wh dstxy color0
    if (op == GPU_OP_GLYPH_1BPP)  { return 0x023B; }   # op flags mask_id wh dstxy color0
    if (op == GPU_OP_GRAD_LINEAR) { return 0x0633; }   # op flags wh dstxy color0 color1
    return 0;
}

# gpo_slot_bytes(op, w, h) — how many source bytes this op reads from its slot. The three rules differ,
# and using the wrong one is a live bug class: 1bpp rows are BYTE-ALIGNED, so a 12 px glyph run costs 2
# bytes per row and not 1.5 — copying blend_cov's w*h rule here would reject valid callers.
fn gpo_slot_bytes(op, w, h) {
    if (op == GPU_OP_BLEND_RECT) { return w * 4 * h; }
    if (op == GPU_OP_BLEND_COV)  { return w * h; }
    if (op == GPU_OP_GLYPH_1BPP) { return ((w + 7) / 8) * h; }
    return 0;
}

# gpo_slot_field(op) — record byte offset of the slot id this op sources from, or 0 for none.
fn gpo_slot_field(op) {
    if (op == GPU_OP_BLEND_RECT) { return 8; }         # src_id
    if (op == GPU_OP_BLEND_COV)  { return 12; }        # mask_id
    if (op == GPU_OP_GLYPH_1BPP) { return 12; }        # mask_id
    return 0;
}

# gpo_validate(rec, fbw, fbh) -> 0 or a GPO_E_* reason. PURE READS on the KERNEL-RESIDENT copy: no ring
# traffic, nothing drawn. Validating the copy rather than user memory is a security property, not a
# convenience — ring 3 cannot change the descriptor between the check and the use.
fn gpo_validate(rec, fbw, fbh) {
    var op = load32(rec + 0) & 0xFFFFFFFF;
    if (op > 0x1F) { return GPO_E_BADOP; }
    if (((GPU_OP_SUPPORTED >> op) & 1) == 0) { return GPO_E_BADOP; }

    # Every dword this op does not define must be zero.
    var mask = gpo_field_mask(op);
    var i = 0;
    while (i < 16) {
        if (((mask >> i) & 1) == 0) {
            if ((load32(rec + i * 4) & 0xFFFFFFFF) != 0) { return GPO_E_RESERVED; }
        }
        i = i + 1;
    }
    if (((load32(rec + 4) & 0xFFFFFFFF) & ~GPU_OP_FLAGS_KNOWN) != 0) { return GPO_E_RESERVED; }
    if (op == GPU_OP_NOP) { return 0; }                # no geometry, no slot, no arm

    var wh  = load32(rec + 16) & 0xFFFFFFFF;
    var dxy = load32(rec + 20) & 0xFFFFFFFF;
    var w  = wh & 0xFFFF;
    var h  = (wh >> 16) & 0xFFFF;
    if (w < 1) { return GPO_E_DIM; }
    if (h < 1) { return GPO_E_DIM; }
    var dx = dxy & 0xFFFF;
    var dy = (dxy >> 16) & 0xFFFF;
    if (dx + w > fbw) { return GPO_E_BOUNDS; }         # REJECT off-screen; the compositor owns clipping
    if (dy + h > fbh) { return GPO_E_BOUNDS; }

    var sf = gpo_slot_field(op);
    if (sf != 0) {
        var id = load32(rec + sf) & 0xFFFFFFFF;
        if (shm_slot_valid(id) == 0) { return GPO_E_BADSLOT; }
        var slot = id - 1;
        if (load64(&shm_mc + slot * 8) == 0) { return GPO_E_BADSLOT; }   # PMM-backed => GPU can't read it
        if (gpo_slot_bytes(op, w, h) > load64(&shm_size + slot * 8)) { return GPO_E_SLOTSIZE; }
    }

    # Residency last: it is the only check with a side effect (a shader upload), so everything cheap and
    # pure runs first and a malformed batch never uploads anything.
    if (op == GPU_OP_BLEND_RECT)  { if (gpu_blend_arm() != 1) { return GPO_E_ARM; } }
    if (op == GPU_OP_BLEND_COV)   { if (gpu_cov_arm()   != 1) { return GPO_E_ARM; } }
    if (op == GPU_OP_GLYPH_1BPP)  { if (gpu_glyph_arm() != 1) { return GPO_E_ARM; } }
    if (op == GPU_OP_GRAD_LINEAR) { if (gpu_grad_arm()  != 1) { return GPO_E_ARM; } }
    return 0;
}

# gpo_execute(rec) -> 0 or GPO_E_DISPATCH. Runs one already-validated record.
fn gpo_execute(rec) {
    var op  = load32(rec + 0)  & 0xFFFFFFFF;
    if (op == GPU_OP_NOP) { return 0; }
    var wh  = load32(rec + 16) & 0xFFFFFFFF;
    var dxy = load32(rec + 20) & 0xFFFFFFFF;
    var w  = wh & 0xFFFF;
    var h  = (wh >> 16) & 0xFFFF;
    var dx = dxy & 0xFFFF;
    var dy = (dxy >> 16) & 0xFFFF;
    var c0 = load32(rec + 36) & 0xFFFFFFFF;
    var c1 = load32(rec + 40) & 0xFFFFFFFF;

    if (op == GPU_OP_BLEND_RECT) {
        var s1 = load64(&shm_mc + ((load32(rec + 8) & 0xFFFFFFFF) - 1) * 8);
        if (gpu_blend_surface(s1, w, h, dx, dy) != 1) { return GPO_E_DISPATCH; }
        return 0;
    }
    if (op == GPU_OP_BLEND_COV) {
        var s2 = load64(&shm_mc + ((load32(rec + 12) & 0xFFFFFFFF) - 1) * 8);
        if (gpu_cov_surface(s2, w, h, dx, dy, c0) != 1) { return GPO_E_DISPATCH; }
        return 0;
    }
    if (op == GPU_OP_GLYPH_1BPP) {
        var s3 = load64(&shm_mc + ((load32(rec + 12) & 0xFFFFFFFF) - 1) * 8);
        if (gpu_glyph_surface(s3, w, h, dx, dy, c0) != 1) { return GPO_E_DISPATCH; }
        return 0;
    }
    if (op == GPU_OP_GRAD_LINEAR) {
        if (gpu_grad_surface(w, h, dx, dy, c0, c1) != 1) { return GPO_E_DISPATCH; }
        return 0;
    }
    return GPO_E_BADOP;
}

# gpu_shader_op_sys(desc_uva, len) -> 0 / packed negative.
#
# TWO PHASES, and the split is part of the ABI. Every op is validated before ANY op is dispatched, so a
# call that fails validation draws NOTHING — "reject rather than clip" generalised from one rect to an
# array. Only a pass-2 failure (GPO_E_DISPATCH) can leave a composited prefix, and the returned index
# names exactly where it stopped.
#
# `len` is a BYTE length, not an op count. A future kernel with a wider record rejects a v1 caller on
# `len % stride`; an op count would have passed and misparsed silently.
fn gpu_shader_op_sys(desc_uva, len) {
    if (gpu_present == 0) { return 0 - GPO_E_NOGPU; }
    if (len < GPU_OP_STRIDE) { return 0 - GPO_E_DESC; }
    if (len > GPU_OP_BUF_BYTES) { return 0 - GPO_E_DESC; }
    if (len % GPU_OP_STRIDE != 0) { return 0 - GPO_E_DESC; }
    if (is_user_range(desc_uva, len) == 0) { return 0 - GPO_E_DESC; }

    # gpu_matmul_ok is the honest per-boot evidence that the dispatch envelope works: gpu_shader_dispatch5
    # runs UNGATED at every boot (main.cyr), so this is a real gate rather than a tautology.
    # ⚠ gpu_blend_ok is deliberately NOT part of this gate. It is set only inside the #ifdef SHADER_BLEND
    # boot self-test, so requiring it would make #92 return E_UNPROVEN in every production kernel — the
    # gate would disable the feature it is supposed to protect.
    if (gpu_matmul_ok != 1) { return 0 - GPO_E_UNPROVEN; }
    if (gpu_blit_arm() != 1) { return 0 - GPO_E_NOGPU; }
    if (gpu_bb_pitch == 0) { return 0 - GPO_E_NOGPU; }

    # Fault-proof copy-in: proc_copy_from_user page-walks the caller's CR3 and refuses a not-present or
    # non-user page instead of a blind deref that could #PF the kernel on a wild-but-in-range pointer.
    var buf = sc_gpuop_buf();
    if (proc_copy_from_user(proc_get_cr3(proc_current_get()), buf, desc_uva, len) == 0) {
        return 0 - GPO_E_DESC;
    }

    var n   = len / GPU_OP_STRIDE;
    var fbw = gpu_bb_pitch / 4;
    var fbh = gpu_bb_fbsize / gpu_bb_pitch;

    var i = 0;
    while (i < n) {
        var e = gpo_validate(buf + i * GPU_OP_STRIDE, fbw, fbh);
        if (e != 0) { return 0 - ((i << 8) | e); }
        i = i + 1;
    }
    return gpo_execute_all(buf, n);
}

# gpo_execute_all — plan-S12: the WHOLE op array in ONE GPU submission.
#
# This is the payoff decision D-3 was made for. Because the ABI was specified as an ARRAY of ops from day
# one, batching is an IMPLEMENTATION change here and not an ABI break — the same #92, the same records, the
# same return convention. Had the band shipped one syscall number per op (as 1.56.2/1.56.3 did before the
# 1.56.4 realignment), this function could not exist without a second ABI migration.
#
# WHAT IT SAVES, per op after the first: the 7-dword TC write-back, the 5-dword completion fence, and a
# whole CPU round-trip (register submit + spin). What it does NOT save, deliberately: the per-dispatch
# pre-dispatch invalidate and CS_PARTIAL_FLUSH. See the batch-seam note in gpu.cyr.
#
# ⚠ HONEST LIMIT ON THE ERROR REPORT. One submission means ONE completion marker, so a batch that times out
# cannot say WHICH op hung — hence GPO_E_BATCH rather than a per-op GPO_E_DISPATCH with a fabricated index.
# Naming the op would need a per-op fence slot, which costs back a chunk of what batching just saved; that
# is a measurable follow-up, not a silent omission. Ring 3 recovers exactly as it would from any failed
# frame: re-clear with #85 and do not call #84.
#
# Emitting cannot fail partway. Pass 1 has already validated every op — bounds, slots, sizes, residency —
# so pass 2's emitters only put dwords in the ring. That is what makes it safe to leave gpu_batch_active
# set across the loop: there is no path that aborts mid-array and strands a fenceless partial program.
fn gpo_execute_all(buf, n) {
    var done_phys = gpu_arena_phys + GPU_BLEND_DONE_SUBOFF;
    var done_mc   = gpu_arena_mc   + GPU_BLEND_DONE_SUBOFF;
    store32(done_phys, GPU_MT_NOTYET);
    gpu_mfence();

    gpu_batch_active = 1;
    var err = 0;
    var j = 0;
    while (j < n) {
        var e2 = gpo_execute(buf + j * GPU_OP_STRIDE);
        if (e2 != 0) { err = (j << 8) | e2; j = n; }
        j = j + 1;
    }
    gpu_batch_active = 0;                      # restored on EVERY exit path below

    if (err != 0) { return 0 - err; }
    gpu_batch_tail(done_mc);
    gpu_mfence();
    if (gpu_ring_kick_wait(done_phys, 100000) != 1) { return 0 - GPO_E_BATCH; }
    return 0;
}

# gpu_caps_sys(buf, len) -> 0 / -1. The capability + geometry probe ring 3 has been missing. Two problems it
# solves: (1) the ONLY way to discover GPU compositing today is to call #86 and look for -1; (2) #87/#88
# REJECT off-screen rects rather than clipping, so a compositor MUST know the true BACK-BUFFER geometry —
# which is NOT what fbinfo#38 reports (that is the console framebuffer). 8x u32 LE, mirroring fbinfo's
# struct-write pattern:
#   +0  flags   bit0 = GPU present · bit1 = double-buffer armed · bit2 = carveout (GPU-visible) shm available
#               bit3 = SHADER COMPOSITING available (gpu_shader_op#92 will run)
#               bit4 = BATCHED: one #92 call is one GPU submission (plan-S12) — see GPO_E_BATCH
#   +4  bb_pitch  (bytes/row)      +16 shm_slots_total
#   +8  bb_width  (px)             +20 shm_slots_free
#   +12 bb_height (px)             +24 shm_max_size (bytes)   +28 #92 op-support mask (bit N = op code N)
# No MC address is exposed — geometry and counts only. An info query, so the CP-DMA constraints don't apply.
fn gpu_caps_sys(buf, len) {
    if (is_user_range(buf, 32) == 0) { return 0 - 1; }
    if (len < 32) { return 0 - 1; }
    # ARM LAZILY FIRST. #89 is the syscall a compositor calls BEFORE anything else, but gpu_bb_pitch /
    # gpu_bb_fbsize are only populated by gpu_blit_arm — so probing first would report width=0/height=0, and
    # since #87/#88 REJECT rather than clip, a probe-then-clip compositor would then fail every blit. Arming
    # here (idempotent — returns immediately once armed) makes the reported geometry the REAL back buffer
    # rather than a prediction. Side effect is the one the caller is about to trigger anyway on its first
    # fill/blit; on a box where the double-buffer cannot arm, flags bit1 stays clear and the geometry reads 0,
    # which is the honest answer. (Caught by /bin/gpublit's self-validation: exit 97, iron 1.55.32.)
    gpu_blit_arm();
    var flags = 0;
    if (gpu_present != 0) { flags = flags | 1; }
    if (gpu_bb_armed == 1) { flags = flags | 2; }
    if (gpu_arena_mc != 0) { flags = flags | 4; }        # a carveout exists ⇒ #86 can serve
    # bit3 — SHADER COMPOSITING available, i.e. gpu_shader_op#92 can actually run. Mirrors #92's own
    # call-level gate exactly, so a caller that sees this bit set will not then get E_UNPROVEN/E_NOGPU.
    # Without it the only way to discover #92 is to call it and read the error, which is what #86's
    # "call it and look for -1" already proved to be the wrong shape.
    var shader_ok = 0;
    if (gpu_present != 0) {
        if (gpu_arena_mc != 0) {
            if (gpu_ring_wptr != 0) {
                if (gpu_matmul_ok == 1) { shader_ok = 1; }
            }
        }
    }
    if (shader_ok == 1) { flags = flags | 8; }
    # bit4 — BATCHED SUBMISSION: one #92 call is ONE GPU submission (plan-S12). This is a SEMANTIC bit, not
    # a performance hint. With it CLEAR, a GPO_E_DISPATCH means ops [0,idx) composited and idx failed. With
    # it SET, a GPO_E_BATCH means an INDETERMINATE prefix landed and no op is identifiable — ring 3 recovers
    # by re-clearing with #85 and not calling #84. A caller that does not read this bit cannot know which
    # recovery it owes, which is why it ships in the same cut as the batching itself.
    if (shader_ok == 1) { flags = flags | 16; }
    var bw = 0;
    var bh = 0;
    if (gpu_bb_pitch != 0) {
        bw = gpu_bb_pitch / 4;
        bh = gpu_bb_fbsize / gpu_bb_pitch;
    }
    var freeslots = 0;
    var i = 0;
    while (i < SHM_MAX) {
        if (load64(&shm_phys + i * 8) == 0) { freeslots = freeslots + 1; }
        i = i + 1;
    }
    store32(buf +  0, flags);
    store32(buf +  4, gpu_bb_pitch);
    store32(buf +  8, bw);
    store32(buf + 12, bh);
    store32(buf + 16, SHM_MAX);
    store32(buf + 20, freeslots);
    store32(buf + 24, SHM_MAX_SIZE);
    # +28 — the gpu_shader_op#92 OP-SUPPORT MASK: bit N set <=> op code N is implemented by this kernel.
    # This is why op codes are capped at 0x1F (see GPU_OP_SUPPORTED): the code IS its bit index here, so
    # ring 3 discovers the exact op set instead of probing each one and reading E_BADOP. Reported as 0
    # when the shader path is unavailable, so one read answers "can I" and "which ops" together.
    var opmask = 0;
    if (shader_ok == 1) { opmask = GPU_OP_SUPPORTED; }
    store32(buf + 28, opmask);
    return 0;
}

# ══ #93 gpu_modeset_op — THE MODESET SEAM (MD-4 ratified, H3) ═══════════════════════════════════════════
#
# ONE syscall number. An ARRAY of fixed-size 64-byte records. The operation is an op code INSIDE each record
# — exactly the D-3 shape #92 uses, for exactly the same reason: batching and new ops are IMPLEMENTATION
# changes, never ABI breaks. No pointer or MC address that names GPU memory crosses the boundary; the kernel
# validates every record before executing any, and REJECTS rather than clips.
#
# ⚠ WHY A SEPARATE NUMBER FROM #92, given #92's comment says "never mint #93": #92 is shader COMPOSITING —
# drawing into an already-lit back buffer. #93 is MODESET — taking the pipe away from the GOP (PLL / OTG /
# PHY / ATOM), the most dangerous thing this kernel does, gated behind the arm-once latch (H2). Folding the
# two would put "reprogram the display timing" and "blend a translucent rect" behind one validator and one
# op-support mask. MD-4 (2026-07-23) ratified the split and cyrius 6.4.74 shipped the `sys_gpu_modeset_op`
# wrapper for it. The #92 comment's "retires #93" aspiration is superseded by that ratification.
#
# ⚠ THE ACTUAL MODESET WRITE OPS ARE THE M-LANE (iron). At H3 this handler dispatches NOP + CAPS only, both
# read-only, both safe under QEMU. When an M-lane write op is added it MUST call modeset_arm() before its
# first DCN write, and THE GATE in gpu_otg_lock / gpu_dcn_write_committed (H2) enforces it structurally.
#
# ⚠ CAPS DOES NOT GATE ON gpu_present. Under QEMU there is no AMD GPU, but `run /bin/modeset --caps` must
# still return so the tool can report "no display here" — that is the whole point of a caps probe, and it is
# how ring 3 tells "this kernel has no #93" (an old kernel) apart from "#93 is here but there is no GPU".
# The GPU/display state is reported IN the caps flags, not by refusing the call.
#
# Return: 0 on success · -((idx<<8)|reason) naming the failing record · reason is always >= 1.
# ⚠ LINUX COLLISION: #93 = fchown(fd,uid,gid). arg1 is a userland VA, essentially never a valid fd, so a
# stray off-agnos call is ~always EBADF — milder than #92's path-resolving chown. The file-level
# #ifdef CYRIUS_TARGET_AGNOS gate in cyrius/lib/syscalls.cyr is still the load-bearing barrier.

var MDO_OP_STRIDE    = 64;          # bytes per record (matches #92's GPU_OP_STRIDE)
var MDO_OP_MAX_LEN   = 4096;        # cap on the whole array
var MDO_OP_NOP       = 0x00;        # validated, dispatches nothing — batch padding / ABI probe
var MDO_OP_CAPS      = 0x01;        # write the modeset caps (8x u32 LE) to the record's out_uva
var MDO_OP_SUPPORTED = 0x3;         # bit N set <=> op code N implemented: bit0 NOP, bit1 CAPS
var MDO_E_NOGPU      = 1;           # call/op — GPU/display unavailable (write ops only, once they exist)
var MDO_E_BADOP      = 2;           # op    — unknown, reserved, or not implemented in this kernel
var MDO_E_OUTBUF     = 3;           # op    — CAPS out_uva/out_len invalid
var MDO_E_DESC       = 11;          # call  — bad desc_uva / len, or the copy-in failed
var MDO_E_RESERVED   = 12;          # op    — a reserved dword or an undefined field was non-zero

# mdo_caps_write(out_uva) -> 0 / MDO_E_OUTBUF. Writes 8x u32 LE describing the modeset surface. READ-ONLY of
# kernel state; the ONLY write is to the validated user buffer, via the gpu_caps_sys direct-store idiom.
#   +0  flags  bit0 latch-armable (ext2 mounted + writable) · bit1 display lit (gpu_display_ok==1)
#              bit2 ATOM interpreter available (VBIOS acquired) · bit3 pixel clock measured
#              bit4 latch BLOCKED this boot (a previous modeset did not disarm — H2)
#   +4  op-support mask (MDO_OP_SUPPORTED)      +16 h_total          +24 pixclk_100hz
#   +8  h_active                                +20 v_total          +28 refresh milliHz (I2, 0 if unmeasured)
#   +12 v_active (0 at H3 — M1/M3 populate)
fn mdo_caps_write(out_uva) {
    if (is_user_range(out_uva, 32) == 0) { return MDO_E_OUTBUF; }
    var flags = 0;
    if (ext2_active != 0) { if (ext2_write_ok != 0) { flags = flags | 1; } }
    if (gpu_display_ok == 1) { flags = flags | 2; }
    if (gpu_vbios_va != 0) { flags = flags | 4; }
    if (gpu_pixclk_100hz != 0) { flags = flags | 8; }
    if (modeset_latch_blocked != 0) { flags = flags | 16; }
    store32(out_uva +  0, flags);
    store32(out_uva +  4, MDO_OP_SUPPORTED);
    store32(out_uva +  8, gpu_h_active);
    store32(out_uva + 12, 0);
    store32(out_uva + 16, gpu_h_total);
    store32(out_uva + 20, gpu_v_total);
    store32(out_uva + 24, gpu_pixclk_100hz);
    store32(out_uva + 28, gpu_refresh_mhz);
    return 0;
}

# mdo_validate(rec) -> 0 or an MDO_E_* reason. PURE READS on the KERNEL-RESIDENT copy. Every dword an op does
# not define MUST be zero — a non-zero reserved field is REJECTED rather than ignored, which is what keeps
# today's unused dwords safe to define in a later kernel without an ABI break.
fn mdo_validate(rec) {
    var op = load32(rec) & 0xFFFFFFFF;
    if (op > 0x1F) { return MDO_E_BADOP; }
    if (((MDO_OP_SUPPORTED >> op) & 1) == 0) { return MDO_E_BADOP; }
    if ((load32(rec + 4) & 0xFFFFFFFF) != 0) { return MDO_E_RESERVED; }   # flags — none defined at H3
    # reserved tail, dwords 6..15 (+24..+63), must be zero for every op
    var k = 6;
    while (k < 16) {
        if ((load32(rec + k * 4) & 0xFFFFFFFF) != 0) { return MDO_E_RESERVED; }
        k = k + 1;
    }
    # op-specific fields. Sequential ifs on the fixed op selector (Cyrius has no chained else-if).
    if (op == MDO_OP_NOP) {
        # NOP uses nothing past the op code — +8..+23 must also be zero
        if ((load32(rec +  8) & 0xFFFFFFFF) != 0) { return MDO_E_RESERVED; }
        if ((load32(rec + 12) & 0xFFFFFFFF) != 0) { return MDO_E_RESERVED; }
        if ((load32(rec + 16) & 0xFFFFFFFF) != 0) { return MDO_E_RESERVED; }
        if ((load32(rec + 20) & 0xFFFFFFFF) != 0) { return MDO_E_RESERVED; }
    }
    if (op == MDO_OP_CAPS) {
        var out_len = load64(rec + 16);
        if (out_len < 32) { return MDO_E_OUTBUF; }
        if (is_user_range(load64(rec + 8), 32) == 0) { return MDO_E_OUTBUF; }
    }
    return 0;
}

fn mdo_execute(rec) {
    var op = load32(rec) & 0xFFFFFFFF;
    if (op == MDO_OP_NOP)  { return 0; }
    if (op == MDO_OP_CAPS) { return mdo_caps_write(load64(rec + 8)); }
    return MDO_E_BADOP;                              # unreachable after validate — belt-and-suspenders
}

# gpu_modeset_op(desc_uva, len) — the ring-3 entry point. Validates EVERY record before executing ANY, so a
# rejected batch does nothing. Copy-in is fault-proof (page-walks the caller's CR3). Reuses #92's per-CPU
# scratch buffer — the two are never concurrent (both are GPU-band ops on the boot/compositor path).
fn gpu_modeset_op_sys(desc_uva, len) {
    if (len < MDO_OP_STRIDE)       { return 0 - MDO_E_DESC; }
    if (len > MDO_OP_MAX_LEN)      { return 0 - MDO_E_DESC; }
    if (len % MDO_OP_STRIDE != 0)  { return 0 - MDO_E_DESC; }
    if (is_user_range(desc_uva, len) == 0) { return 0 - MDO_E_DESC; }
    var buf = sc_gpuop_buf();
    if (proc_copy_from_user(proc_get_cr3(proc_current_get()), buf, desc_uva, len) == 0) {
        return 0 - MDO_E_DESC;
    }
    var n = len / MDO_OP_STRIDE;
    var i = 0;
    while (i < n) {
        var e = mdo_validate(buf + i * MDO_OP_STRIDE);
        if (e != 0) { return 0 - ((i << 8) | e); }
        i = i + 1;
    }
    var j = 0;
    while (j < n) {
        var e2 = mdo_execute(buf + j * MDO_OP_STRIDE);
        if (e2 != 0) { return 0 - ((j << 8) | e2); }
        j = j + 1;
    }
    return 0;
}

# shm_write(id, user_src, size) -> 0 / -1. Copies user src INTO the shm page.
fn shm_write(id, src, size) {
    if (shm_slot_valid(id) == 0) { return 0 - 1; }
    var slot = id - 1;
    if (size <= 0) { return 0 - 1; }
    if (size > load64(&shm_size + slot * 8)) { return 0 - 1; }
    if (is_user_range(src, size) == 0) { return 0 - 1; }
    shm_copy(load64(&shm_kva + slot * 8), src, size);
    return 0;
}

# shm_read(id, user_dst, size) -> 0 / -1. Copies the shm page OUT into user dst.
fn shm_read(id, dst, size) {
    if (shm_slot_valid(id) == 0) { return 0 - 1; }
    var slot = id - 1;
    if (size <= 0) { return 0 - 1; }
    if (size > load64(&shm_size + slot * 8)) { return 0 - 1; }
    if (is_user_range(dst, size) == 0) { return 0 - 1; }
    shm_copy(dst, load64(&shm_kva + slot * 8), size);
    return 0;
}

# shm_free(id) -> 0 / -1. Release the 2 MB page + the slot.
fn shm_free(id) {
    if (shm_slot_valid(id) == 0) { return 0 - 1; }
    var slot = id - 1;
    # ⚠ Release to the RIGHT allocator. A #86 (GPU-visible) slot is a FIXED window in the GPU carveout, never
    # a pmm page — handing its address to pmm_free_2mb would corrupt the page allocator's bitmap with an
    # address it never owned. Carveout slots are reclaimed by simply clearing the table entry; the window is
    # statically owned by GPU_SHM_REGION_OFF + slot*GPU_SHM_SLOT_SIZE and is reused on the next create.
    if (load64(&shm_mc + slot * 8) == 0) { pmm_free_2mb(load64(&shm_phys + slot * 8)); }
    store64(&shm_phys + slot * 8, 0);
    store64(&shm_kva + slot * 8, 0);
    store64(&shm_size + slot * 8, 0);
    store64(&shm_mc + slot * 8, 0);
    return 0;
}

# =============================================================================
# 1.53.10 — raw block-device syscalls (#75-80): the native-install primitive.
#
# Exposes the kernel block layer (blk_read_on) to a privileged ring-3 installer so
# agnova + sovereign mkfs/partition tools can detect disks and read raw sectors
# WITHOUT shelling out to Linux parted/mkfs. This is the READ-PATH (Phase 1) —
# enum / open(RO) / read / info / close, all NON-DESTRUCTIVE. blk_write#78 is
# Phase 2 (capability-gated). Design + security posture:
#   docs/development/issue/2026-07-09-ring3-block-device-syscalls-for-install.md
#
# Handle model (Phase 1): the handle IS the backend tag (BLK_VIRTIO..BLK_RAMDISK,
# 1..5), validated against blk_registered — no per-open state. Capacity is exact
# for the ACTIVE backend; secondary-backend capacity (0 here) is a follow-up.
# =============================================================================
var blk_sc_bounce[512];   # 4096 B — one-LBA bounce (backends DMA into kernel mem, not user VA)

# Phase 2 write-path GATE. Raw block WRITE (blk_open RW + blk_write#78) is OFF by
# default; it is enabled only after a deliberate arm — blk_open(_, BLK_RW_ARM_MAGIC).
# agnos has no per-proc capability/uid yet (proc.cyr: "NOT Unix uid", auth-posture),
# so this default-off + explicit-magic-arm is the boundary: a raw disk write can
# never happen accidentally/incidentally, and the arm call is the exact seam where an
# aegis/shakti installer-capability check lands when agnos grows per-proc caps.
var blk_rw_armed     = 0;
var BLK_RW_ARM_MAGIC = 0x424C4B5F5257;   # "BLK_RW" — deliberate-arm token (not a plausible mode value)

# blk_enum(buf, cap) -> registered-device count / -1. Writes {tag, capacity_lbas,
# lba_bytes} (3xu64 = 24 B) per registered backend into the user buf, bounded by cap.
fn blk_enum_sys(buf, cap) {
    if (is_user_range(buf, cap) == 0) { return 0 - 1; }
    var count = 0;
    var tag = 1;
    while (tag <= 5) {
        if (blk_is_registered(tag) == 1) {
            var off = count * 24;
            if (off + 24 > cap) { return count; }
            var capv = 0;
            if (tag == blk_active) { capv = blk_capacity; }
            store64(buf + off + 0, tag);
            store64(buf + off + 8, capv);
            store64(buf + off + 16, blk_lba_bytes);
            count = count + 1;
        }
        tag = tag + 1;
    }
    return count;
}

# blk_open(tag, mode) -> handle(==tag) / -1 / arm-ack(0). mode 0 = RO (always), mode 1
# = RW (only when armed). mode == BLK_RW_ARM_MAGIC = the deliberate arm (sets the
# write gate, returns 0) — the aegis/shakti capability seam. Validates tag registered.
fn blk_open_sys(tag, mode) {
    if (mode == BLK_RW_ARM_MAGIC) { blk_rw_armed = 1; return 0; }   # deliberate RW arm
    if (tag < 1) { return 0 - 1; }
    if (tag > 5) { return 0 - 1; }
    if (blk_is_registered(tag) == 0) { return 0 - 1; }
    if (mode == 0) { return tag; }                                  # RO handle
    if (mode == 1) {                                                # RW handle — gated
        if (blk_rw_armed == 0) { return 0 - 1; }                    # EPERM: not armed
        return tag;
    }
    return 0 - 1;                                                   # unknown mode
}

# blk_read(h, lba, buf, nsec) -> nsec / -1. Reads nsec LBAs from device h at lba
# into the user buf, one LBA at a time via the kernel bounce (backends DMA into
# kernel memory, never a user VA). fs_spin_lock serializes the shared bounce +
# device access against FS reads (same lock ext2 takes around blk_read_on).
fn blk_read_sys(h, lba, buf, nsec) {
    if (h < 1) { return 0 - 1; }
    if (h > 5) { return 0 - 1; }
    if (blk_is_registered(h) == 0) { return 0 - 1; }
    if (nsec <= 0) { return 0 - 1; }
    if (lba < 0) { return 0 - 1; }
    if (h == blk_active) {
        if (lba + nsec > blk_capacity) { return 0 - 1; }
    }
    var total = nsec * blk_lba_bytes;
    if (is_user_range(buf, total) == 0) { return 0 - 1; }
    fs_spin_lock();
    var rc = nsec;
    var i = 0;
    while (i < nsec) {
        if (blk_read_on(h, lba + i, &blk_sc_bounce) != 0) { rc = 0 - 1; i = nsec; }
        else {
            shm_copy(buf + i * blk_lba_bytes, &blk_sc_bounce, blk_lba_bytes);
            i = i + 1;
        }
    }
    fs_spin_unlock();
    return rc;
}

# blk_write(h, lba, buf, nsec) -> nsec / -1. Phase 2: the DESTRUCTIVE write-path,
# GATED on blk_rw_armed (off by default; armed via blk_open(_, BLK_RW_ARM_MAGIC)).
# Copies user buf -> kernel bounce -> blk_write_on, one LBA at a time, then flushes
# the device cache (durability). fs_spin_lock serializes with FS + the shared bounce.
fn blk_write_sys(h, lba, buf, nsec) {
    if (blk_rw_armed == 0) { return 0 - 1; }          # THE GATE — raw write off unless armed
    if (h < 1) { return 0 - 1; }
    if (h > 5) { return 0 - 1; }
    if (blk_is_registered(h) == 0) { return 0 - 1; }
    if (nsec <= 0) { return 0 - 1; }
    if (lba < 0) { return 0 - 1; }
    if (h == blk_active) {
        if (lba + nsec > blk_capacity) { return 0 - 1; }
    }
    var total = nsec * blk_lba_bytes;
    if (is_user_range(buf, total) == 0) { return 0 - 1; }
    fs_spin_lock();
    var rc = nsec;
    var i = 0;
    while (i < nsec) {
        shm_copy(&blk_sc_bounce, buf + i * blk_lba_bytes, blk_lba_bytes);   # user -> bounce
        if (blk_write_on(h, lba + i, &blk_sc_bounce) != 0) { rc = 0 - 1; i = nsec; }
        else { i = i + 1; }
    }
    blk_flush_on(h);                                  # durability barrier (best-effort)
    fs_spin_unlock();
    return rc;
}

# blk_info(h, out) -> 0 / -1. Writes {capacity_lbas, lba_bytes} (2xu64) to out.
fn blk_info_sys(h, out) {
    if (h < 1) { return 0 - 1; }
    if (h > 5) { return 0 - 1; }
    if (blk_is_registered(h) == 0) { return 0 - 1; }
    if (is_user_range(out, 16) == 0) { return 0 - 1; }
    var capv = 0;
    if (h == blk_active) { capv = blk_capacity; }
    store64(out + 0, capv);
    store64(out + 8, blk_lba_bytes);
    return 0;
}

# blk_close(h) -> 0 / -1. Phase 1 RO: no per-open state; validate + no-op.
fn blk_close_sys(h) {
    if (h < 1) { return 0 - 1; }
    if (h > 5) { return 0 - 1; }
    if (blk_is_registered(h) == 0) { return 0 - 1; }
    return 0;
}

fn ksyscall(num, arg1, arg2, arg3) {
    # Stack-canary backstop: snapshot at entry, re-checked before returning on the
    # syscalls that do the most pointer/buffer work (the 1.41.3 FS group + pipe/
    # mmap/munmap). Coverage is deliberately NOT uniform across every branch
    # (audit 1.41.6 #14/#23): ksyscall itself has no local array buffer for a
    # smash to corrupt, so these checks are a backstop against a *callee* (ext2_*/
    # elf_*) overrunning back into this frame — the leaf functions that own real
    # buffers (e.g. elf_load) carry their own canary. A single-tail collapse was
    # rejected: it would require rewriting ~25 early-returns in this security-
    # critical dispatcher with no clean Cyrius idiom, for a non-vuln cosmetic gain.
    var canary = stack_canary_secret;
    if (num == 0) {
        # exit — halt current process, return to kernel if context saved
        sys_exit_code = arg1;
        proc_set_exit_code(proc_current_get(), arg1);
        # flock#59: release every advisory lock held by the exiting proc (so a
        # fork-per-accept worker that dies mid-turn can't strand the shared world).
        flock_release_pid(proc_current_get());
        snd_release_pid(proc_current_get());      # release any snd#64 audio slot (Gate 2)
        gpu_release_pid(proc_current_get());      # 1.55.x: if it owned the scanout, hand the screen back
        # to the console (else a full-screen app quitting would
        # leave its last frame up while console text scrolled
        # invisibly into a buffer nothing is scanning)
        if (proc_current_get() < proc_count) {
            proc_set_state(proc_current_get(), 0);
            # 1.53.x B3b: clear this CPU's FP owner if it named the exiting proc (same
            # recycled-slot prev==cur hazard as fault_kill). No fxsave (exiting XMM garbage).
            var _xc = pcpu_cpu();
            if (load64(&fpu_owner + _xc * 8) == proc_current_get()) { store64(&fpu_owner + _xc * 8, 0 - 1); }
            # Send SIGCHLD (signal 17) to parent process
            var ppid = proc_get_ppid(proc_current_get());
            if (ppid >= 0) {
                proc_send_signal(ppid, 17);
            }
        }
        # If we have a saved kernel return point, jump back to it — but ONLY when the EXITING
        # proc is the one exec_and_wait is run-to-completion waiting on (exec_resume_pid). 1.44.14:
        # a PREEMPTIVELY-scheduled #43 background job exit()s with proc_current_get() = ITS pid (the
        # scheduler set it), which != exec_resume_pid (agnsh) — so it must NOT fire agnsh's
        # kernel_resume (that would resume kybernet as if agnsh exited). It already went state 0
        # above, so its parent's waitpid#4 reaps it. Pre-1.44.14 this gate was just
        # `kernel_return_rsp != 0`, which fired for ANY exit while a resume was armed.
        if (kernel_return_rsp_get() != 0) {
            if (proc_current_get() == exec_resume_pid_get()) {
                kernel_resume();
            }
        }
        return 0;
    }
    if (num == 1) {
        # write(fd=arg1, buf=arg2, len=arg3)
        if (arg3 > 0) {
            if (is_user_range(arg2, arg3) == 0) { return 0 - 1; }
        }
        return vfs_write(arg1, arg2, arg3);
    }
    if (num == 2) { return proc_current_get(); }
    if (num == 3) {
        # spawn(elf_addr, elf_size) — load an in-memory ELF + create a user process.
        # Returns new pid or -1. 1.41.5: the ELF image is a USER buffer — validate
        # the whole (addr,size) range so elf_load's load8/load64 can't be aimed at
        # kernel memory (a ring-3 caller passing a kernel addr would disclose it).
        if (arg2 < 1) { return 0 - 1; }
        if (is_user_range(arg1, arg2) == 0) { return 0 - 1; }
        # 1.44.10: bound by the staging buffer, then run elf_load under the KERNEL CR3.
        # A ring-3 parent's CR3 mirrors only 0-256 MB + the GB ranges, so the child's
        # fresh page-table pages can land in the 256 MB-1 GB gap (the 1.44.9 #UD-at-child
        # blocker). Copy the user ELF to spawn_elf_buf NOW (caller CR3 resolves arg1, SMAP
        # AC=1 from the entry STAC), switch to boot CR3 0x1000 (maps all phys, so every PT
        # page elf_load writes is reachable — the proven 1.44.8 condition), elf_load the
        # kernel copy, then restore the caller CR3. Mirrors the execwait#37 idiom; no
        # kstack swap / resume-ctx since spawn does not block. From a KERNEL caller (the
        # RING3_SELFTEST loads its B proc via elf_load directly, not this path) this code
        # is not reached.
        if (arg2 > 16384) { return 0 - 1; }
        var sp_caller_cr3 = proc_get_cr3(proc_current_get());
        var sp_dst = spawn_elf_buf_base();
        var sp_i = 0;
        while (sp_i < arg2) { store8(sp_dst + sp_i, load8(arg1 + sp_i)); sp_i = sp_i + 1; }
        cr3_load(0x1000);
        var new_pid = elf_load(sp_dst, arg2);
        cr3_load(sp_caller_cr3);
        if (new_pid >= 0) {
            # Mark as ready; will be scheduled on next timer tick
            proc_set_state(new_pid, 1);
        }
        return new_pid;
    }
    if (num == 4) {
        # waitpid(pid) — NON-BLOCKING poll (1.44.9). Returns the child's exit code if it
        # has exited (state 0), or -2 (WOULD_BLOCK) if it is still alive. A ring-3 parent
        # polls this FROM RING 3 — between calls it holds no kernel state, so the child's
        # syscalls can't clobber a blocked-in-kernel waitpid frame on the shared syscall
        # kstack. (The classic BLOCKING form, which sleeps the parent in the kernel, needs
        # per-proc kernel stacks first — deferred.) Was a busy-wait `while(state!=0) hlt`,
        # which would hang anyway: the handler runs IF=0, so the hlt never wakes.
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= proc_count) { return 0 - 1; }
        # Never wait on (and never reap) the caller itself.
        if (arg1 == proc_current_get()) { return 0 - 1; }
        # 1.50.8: ownership — only the parent (or init) may reap, else -1 (not your child).
        # Stops a non-parent from stealing the exit code + collapsing the slot out from under
        # the real parent's pending waitpid. BEFORE the alive/dead check so a non-child gets
        # -1 regardless of state. Unblocked by 1.50.7's real proc_get_ppid (inert while it
        # stubbed 0 → the 1.44.22 audit deferral). agnsh IS the parent of its `&` jobs (set at
        # proc_create_user), so this preserves bg-job reaping; ring3-smoke parent-spawn+wait
        # + agnsh-bg/multijob exercise it. (proc_may_reap: proc.cyr.)
        if (proc_may_reap(proc_current_get(), arg1) == 0) { return 0 - 1; }
        if (proc_get_state(arg1) != 0) { return 0 - 2; }   # still alive → WOULD_BLOCK
        # 1.42.x: reap the in-memory-spawned child here — the symmetric point to
        # the from-disk path's "read exit code in sh_cmd_run, then proc_reap".
        # Read the exit code FIRST (proc_reap_child may collapse the slot), then
        # reclaim the child's address space (ELF + stack + ANY un-munmap'd mmap
        # huge pages) and proc_table slot. Without this, every spawn()ed child
        # leaked its whole address space for the boot; with it the in-memory
        # path is leak-symmetric with elf_load_from_file's run/reap. Safe: the
        # child is confirmed dead (loop above) and is not proc_current_get() (guarded),
        # so its distinct CR3 is not the one the CPU is walking.
        var wcode = proc_get_exit_code(arg1);
        proc_reap_child(arg1);
        return wcode;
    }
    if (num == 5) {
        # read(fd=arg1, buf=arg2, len=arg3)
        # 1.42.14: reject negative len explicitly (defense-in-depth — the fd-type
        # read helpers now also enforce their own minimum count, so a too-small
        # buffer can no longer drive a fixed-size store past the validated range).
        if (arg3 < 0) { return 0 - 1; }
        if (arg3 > 0) {
            if (is_user_range(arg2, arg3) == 0) { return 0 - 1; }
        }
        # 1.41.1: fd 0 = line-disciplined keyboard stdin. Other fds keep the vfs_read path.
        # 1.44.x: a4=r10 (ksyscall_a4) != 0 selects the NON-BLOCKING cooked-line read — returns
        # -2/WOULD_BLOCK until a full line, so schedulable agnsh can poll stdin without freezing
        # background jobs at the prompt. a4==0 keeps the efficient blocking read (the default,
        # used when agnsh has no live bg jobs). The syscall entry stub resets ksyscall_a4 per
        # ring-3 entry (syscall_hw.cyr), so a stale a4 can't mis-route a later blocking read.
        if (arg1 == 0) {
            # fd 0 is the keyboard ONLY while it is still the console device. A pipe
            # redirect (exec_redirect#62) copies the pipe read-end's vfs_table entry
            # over vfs_table[0] (tag VFS_PIPE), so a REDIRECTED stdin must fall through
            # to vfs_read -> pipe_read — the `cmd2` side of `cmd1 | cmd2`. The a4
            # non-blocking cooked-line read is keyboard-only; a piped fd 0 ignores it.
            if (ktag(vfs_fd_table()) == VFS_DEVICE) {
                if (ksyscall_a4_get() != 0) { return kbd_read_nonblock(arg2, arg3); }
                return kbd_read_blocking(arg2, arg3);
            }
        }
        return vfs_read(arg1, arg2, arg3);
    }
    if (num == 6) { return vfs_close(arg1); }
    if (num == 7) {
        # open(name=arg1, namelen=arg2, flags=arg3) — mount-routed (1.41.3).
        # Re-routes from initrd-only: ext2 / FAT / exFAT by mount, with initrd
        # as the bare-name fallback. AO_DIRECTORY(0x800)→dir-fd (getdents);
        # AO_CREAT(0x100) creates if absent; AO_TRUNC(0x200) zeroes existing.
        if (sc_path_ok(arg1, arg2) == 0) { return 0 - 1; }
        # Normalize a RELATIVE name (no leading '/') to rooted-at-'/' — agnos has no
        # CWD, so `touch foo` / `cmd > foo` land in the writable root FS instead of
        # failing against the read-only initrd. Prepend '/' into a kernel scratch buffer
        # + route THAT (the ext2 lookup needs the leading '/'). Absolute paths pass
        # through untouched. (1.54.11: the redirect/touch-can't-create fix.)
        var op_path = arg1;
        var op_len  = arg2;
        if (load8(arg1) != 47) {
            store8(&sc_open_abs, 47);
            var opi = 0;
            while (opi < arg2 && opi < 254) { store8(&sc_open_abs + 1 + opi, load8(arg1 + opi)); opi = opi + 1; }
            op_path = &sc_open_abs;
            op_len  = opi + 1;
        }
        var be7 = vfs_resolve_mount(op_path, op_len);
        if (be7 == FS_EXT2) {
            # SMP sub-bite 5 (fs_lock): the ext2 open/create arm — lookup + (optional)
            # create + truncate + open all touch ext2 scratch. Locked at the syscall
            # arm (the dispatch boundary) because ext2_* are called DIRECTLY here (no
            # locked wrapper). The called ext2_* are leaves w.r.t. the VFS boundary,
            # and none of them is independently fs_lock'd → single acquire, no nest.
            # INNER-WRAPPER form (one return point) so the lock can't leak.
            fs_spin_lock();
            var ofd7 = sys_open_ext2_inner(op_path, op_len, arg3);
            fs_spin_unlock();
            return ofd7;
        }
        if (be7 == FS_FAT || be7 == FS_EXFAT) {
            var roff = op_path + vfs_mnt_reloff;
            var rlen = op_len - vfs_mnt_reloff;
            if ((arg3 & 0x100) != 0) { vfs_create_on(be7, roff, rlen); }   # AO_CREAT
            # 1.41.7: write-access (AO_WRONLY/AO_RDWR, low 2 bits) → a write-back
            # fd that buffers content + flushes the whole file via vfs_write_on at
            # close, so agnsh can write a FAT/exFAT data partition. Else a read
            # memfile. AO_TRUNC is implicit (whole-file replace); AO_APPEND TODO.
            if ((arg3 & 0x3) != 0) { return vfs_sec_wfile_open(be7, roff, rlen); }
            return vfs_open_on(be7, roff, rlen);
        }
        # bare-name / unmounted fallback (legacy initrd)
        return initrd_open(arg1, arg2);
    }
    # Tier 1: stubs
    if (num == 8) { return arg1; }           # dup(fd) -> return same fd
    if (num == 9) {
        # mkdir(path=arg1, pathlen=arg2) — real, mount-routed (1.41.3).
        if (sc_path_ok(arg1, arg2) == 0) { return 0 - 1; }
        var be9 = vfs_resolve_mount(arg1, arg2);
        if (be9 == FS_FAT || be9 == FS_EXFAT) { return vfs_mkdir_on(be9, arg1 + vfs_mnt_reloff, arg2 - vfs_mnt_reloff); }
        if (be9 == FS_EXT2) {
            # SMP sub-bite 5 (fs_lock): ext2 mkdir touches dir/bitmap/bgdt scratch +
            # jbd2 tx. vfs_ext2_parent + ext2_mkdir are leaves → one acquire, no nest.
            fs_spin_lock();
            var par9 = vfs_ext2_parent(arg1, arg2);
            if (par9 <= 0) { fs_spin_unlock(); return 0 - 1; }
            var mkr9 = ext2_mkdir(par9, arg1 + vfs_base_off, vfs_base_len);
            fs_spin_unlock();
            if (mkr9 > 0) { return 0; }
            return 0 - 1;
        }
        return 0 - 1;
    }
    if (num == 10) {
        # rmdir(path=arg1, pathlen=arg2) — real, mount-routed (1.41.3).
        if (sc_path_ok(arg1, arg2) == 0) { return 0 - 1; }
        var be10 = vfs_resolve_mount(arg1, arg2);
        if (be10 == FS_FAT || be10 == FS_EXFAT) { return vfs_rmdir_on(be10, arg1 + vfs_mnt_reloff, arg2 - vfs_mnt_reloff); }
        if (be10 == FS_EXT2) {
            # SMP sub-bite 5 (fs_lock): ext2_rmdir (calls ext2_truncate_zero internally,
            # which is NOT independently locked → no nest). One acquire around the arm.
            fs_spin_lock();
            var par10 = vfs_ext2_parent(arg1, arg2);
            if (par10 <= 0) { fs_spin_unlock(); return 0 - 1; }
            var rmr10 = ext2_rmdir(par10, arg1 + vfs_base_off, vfs_base_len);
            fs_spin_unlock();
            return rmr10;
        }
        return 0 - 1;
    }
    if (num == 12) {
        # sync() — flush ext2 metadata + all block devices to stable media
        # (1.41.3 — was a stub returning 0).
        if (ext2_active != 0) { ext2_sync(); }
        blk_flush();
        return 0;
    }
    if (num == 15) { return 0; }             # getuid (root)
    if (num == 24) { return 0; }             # umount
    # Tier 2: simple
    if (num == 11) { return 0; }             # mount (noop for now)
    if (num == 13) {                          # reboot(magic1, magic2, cmd, arg)
        # Until 1.55.x this printed a line and called arch_halt() — a LIVE WEDGE, not
        # a stub: it is reachable from ring 3 (cyrius exposes sys_reboot()), so any
        # caller froze the box with a dirty ext2 superblock and no device quiesce.
        # It now runs the real shutdown sequence, gated on the magic pair so the
        # garbage-argument callers the old nullary ABI left behind fail closed.
        return power_sys(arg1, arg2, arg3, ksyscall_a4_get());
    }
    if (num == 14) {                          # pause — no-ready-proc FALLBACK (safe hlt)
        # Ring-3 pause is normally handled in syscall_handler (#14): it yields to a ready
        # proc first, and only falls through to HERE when nothing else is ready (also the
        # path for any in-kernel ksyscall(14)). Do ONE SAFE (IF=1) hlt so a device IRQ
        # (e.g. NIC RX) or the 100 Hz timer wakes it. A BARE arch_wait() would be a hlt
        # with IF=0 (SYSCALL clears IF via SFMASK 0x40700) = the "IF=0 hlt hard-hang" the
        # sleep_ms#41 recipe warns about — it deadlocked the single core (the two-proc
        # setu-present freeze, 1.53.9). preempt_disable keeps the timer ticking+EOIing
        # without switching us off mid-pause; sti BEFORE the hlt; cli on the way out
        # (SYSRET restores the caller's IF from R11 anyway).
        preempt_disable();
        asm { sti; }
        arch_wait();                          # hlt until the next interrupt
        asm { cli; }
        preempt_enable();
        return 0;
    }
    # Tier 3: signals
    if (num == 16) {
        # kill(pid=arg1, sig=arg2)
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= proc_count) { return 0 - 1; }
        if (arg2 < 0) { return 0 - 1; }
        if (arg2 >= 64) { return 0 - 1; }
        # Security (1.50.7): authorization = proc_may_signal (proc.cyr) — init signals anyone;
        # a non-init caller may signal only itself or its own direct child. Now a REAL gate:
        # proc_get_ppid returns the actual parent (was stubbed 0, leaving this inert). Arg
        # bounds (above) stay here; the ownership policy is the extracted, selftested predicate.
        if (proc_may_signal(proc_current_get(), arg1) == 0) { return 0 - 1; }
        var sig_pending = load64(&proc_signals + arg1 * 8);
        store64(&proc_signals + arg1 * 8, sig_pending | (1 << arg2));
        return 0;
    }
    if (num == 17) {
        # sigprocmask(how=arg1, set=arg2, oldset=arg3)
        # Security: validate userspace pointers for the full 8 bytes touched
        # (load64(arg2) / store64(arg3) below). 1.41.5: range not bare ptr.
        if (is_user_range(arg2, 8) == 0) { return 0 - 1; }
        if (arg3 != 0) {
            if (is_user_range(arg3, 8) == 0) { return 0 - 1; }
        }
        var old_mask = load64(&proc_sigmask + proc_current_get() * 8);
        if (arg3 != 0) { store64(arg3, old_mask); }
        var new_bits = load64(arg2);
        if (arg1 == 0) { new_bits = old_mask | new_bits; }
        if (arg1 == 1) { new_bits = old_mask & (0 - 1 - new_bits); }
        store64(&proc_sigmask + proc_current_get() * 8, new_bits);
        return 0;
    }
    if (num == 18) {
        # signalfd(fd=arg1, mask_ptr=arg2, flags=arg3)
        # Security: validate the 8 bytes read (load64(arg2)). 1.41.5: range.
        if (is_user_range(arg2, 8) == 0) { return 0 - 1; }
        var sfd = vfs_alloc();
        if (sfd < 0) { return 0 - 1; }
        var sbase = vfs_fd_table() + sfd * 32;
        ktag_set(sbase, VFS_SIGNALFD);
        kpayload_set(sbase, 2, load64(arg2));   # sigmask
        return sfd;
    }
    # Tier 4: epoll + timerfd
    if (num == 19) {
        # epoll_create
        var efd = vfs_alloc();
        if (efd < 0) { return 0 - 1; }
        var ebase = vfs_fd_table() + efd * 32;
        # 1.41.5: allocate the watch list BEFORE claiming the slot — on OOM the
        # slot stays VFS_FREE (vfs_alloc doesn't mark it) so nothing leaks and we
        # never hand back an epoll fd with a NULL watch list.
        var wl = kmalloc(128);
        if (wl == 0) { return 0 - 1; }
        ktag_set(ebase, VFS_EPOLL);
        kpayload_set(ebase, 0, 0);              # watch count
        kpayload_set(ebase, 2, wl);             # watch list ptr
        return efd;
    }
    if (num == 20) {
        # epoll_ctl(epfd=arg1, op=arg2, fd=arg3)
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= 32) { return 0 - 1; }
        var ebase = vfs_fd_table() + arg1 * 32;
        # 1.41.5: the epfd MUST be an epoll instance. Without this a ring-3 caller
        # could pass ANY allocated fd whose payload[2] is a kernel heap pointer
        # (pipe/memfile) or a small integer (an ext2 fd's inode number) — the
        # store64s below would then write an attacker-controlled value to that
        # address: an arbitrary kernel write. Mirrors the getdents VFS_EXT2_DIR
        # tag check.
        if (ktag(ebase) != VFS_EPOLL) { return 0 - 1; }
        var wl = kpayload(ebase, 2);
        if (wl == 0) { return 0 - 1; }
        var wc = kpayload(ebase, 0);
        if (arg2 == 1) {
            # Max 8 watches (128 bytes / 16 bytes per watch)
            if (wc >= 8) { return 0 - 1; }
            # 1.41.5: the watched fd is later used as vfs_fd_table() + wfd*32 in
            # epoll_wait — bound it to a real fd slot so it can't index OOB.
            if (arg3 < 0) { return 0 - 1; }
            if (arg3 >= 32) { return 0 - 1; }
            store64(wl + wc * 16, arg3);
            store64(wl + wc * 16 + 8, arg3);
            kpayload_set(ebase, 0, wc + 1);
        }
        if (arg2 == 2) {
            # EPOLL_CTL_DEL — current impl clears ALL watches (not just arg3).
            kpayload_set(ebase, 0, 0);
        }
        return 0;
    }
    if (num == 21) {
        # epoll_wait(epfd=arg1, events=arg2, max=arg3)
        # Security: validate fd bounds and userspace pointer
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= 32) { return 0 - 1; }
        if (arg3 < 0) { return 0 - 1; }
        if (arg3 > 16) { arg3 = 16; }
        # 1.41.5: validate the events buffer for the bytes actually written (each
        # event record is 12 bytes, up to arg3 of them) — not a single ptr.
        if (is_user_range(arg2, arg3 * 12) == 0) { return 0 - 1; }
        var ebase = vfs_fd_table() + arg1 * 32;
        # 1.41.5: epfd must be a real epoll instance, else wl/wc below are a
        # foreign fd's payload — wl used as a base address gives arbitrary
        # kernel reads and wc (e.g. a file's pos) an attacker-driven loop count.
        if (ktag(ebase) != VFS_EPOLL) { return 0 - 1; }
        var wl = kpayload(ebase, 2);
        var wc = kpayload(ebase, 0);
        var found = 0;
        for (var wi = 0; wi < wc; wi = wi + 1) {
            var wfd = load64(wl + wi * 16);
