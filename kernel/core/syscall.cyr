        stack_canary_check(canary);
        return kl_w;
    }
    if (num == 37) {
        # execwait(path=arg1, pathlen=arg2) — load a static ELF64 from the active
        # ext2 root, run it to completion in ring 3, return its exit code (or -1).
        # The ring-3 BLOCKING-exec primitive (1.43.x; roadmap "no preemption
        # needed"). This is the FIRST exec_and_wait invoked from a live ring-3
        # SYSCALL frame (agnsh, itself entered by kybernet's exec_and_wait), so it
        # carries two hazards the from-kernel callers (sh_cmd_run / kybernet) never
        # had — both handled below:
        #  (H1) the nested exec_and_wait OVERWRITES the resume-context globals
        #       (exec_ctx + kernel_return_* + kpti_* + kernel_rsp_save) that hold
        #       KYBERNET's armed frame — the frame agnsh's OWN exit() longjmps into.
        #       We snapshot them before, restore them after.
        #  (H2) the child's syscalls reuse the shared SYSCALL kstack (0x3F0000) and
        #       would smash agnsh's suspended #37 frame AND its stub-pushed SYSRET
        #       rcx/r11/rbp cells. We run the child on the DISJOINT second kstack
        #       (syscall_kstack_top2) by swapping syscall_kstack_top before the call
        #       — exec_and_wait's own syscall_init() bakes the swap into the child's
        #       stub — then restore + rebuild for agnsh on resume.

        # (a) validate path arg + length + ext2-root guard (elf_load_from_file is
        # ext2-only) + re-entrancy guard. The single-slot save block holds ONE level:
        # a child that itself calls execwait would clobber agnsh's saved frame and
        # reuse syscall_kstack_top2 recursively — refuse cleanly (recursive exec is
        # out of scope until the multithreading arc).
        if (sc_path_ok(arg1, arg2) == 0) { stack_canary_check(canary); return 0 - 1; }
        if (arg2 > 127) { stack_canary_check(canary); return 0 - 1; }
        if (ext2_active == 0) { stack_canary_check(canary); return 0 - 1; }
        if (ew37_busy != 0) { stack_canary_check(canary); return 0 - 1; }

        # (b) COPY the user path into the kernel buffer NOW, while CR3 is still the
        # caller's (so the user VA resolves) and SMAP AC=1 (the entry stub's STAC).
        # elf_load_from_file below runs under BOOT CR3 (it needs the NVMe BAR, which
        # the per-process CR3 does not map — the same reason kernel_resume reverts to
        # 0x1000), where the user VA would NOT resolve — hence the copy up front.
        var pdst = &ew37_path;
        var pi = 0;
        while (pi < arg2) { store8(pdst + pi, load8(arg1 + pi)); pi = pi + 1; }

        # (c) snapshot agnsh's resume context (H1) BEFORE the nested exec_and_wait
        # clobbers it. proc_current is still agnsh here.
        var s37 = &ew37_ctx;
        var es  = &exec_ctx;
        var si = 0;
        while (si < 64) { store64(s37 + si, load64(es + si)); si = si + 8; }
        ew37_kr_rsp   = kernel_return_rsp;          # == 1 (kybernet frame armed)
        ew37_kr_rip   = kernel_return_rip;
        ew37_rsp_save = kernel_rsp_save;            # agnsh's user RSP
        ew37_a4       = ksyscall_a4;
        ew37_pid      = proc_current;               # agnsh's pid
        ew37_cr3      = proc_get_cr3(proc_current); # agnsh's CR3 (robust source)
        ew37_busy     = 1;

        # (d) switch to the BOOT CR3 (maps all phys incl. the NVMe BAR) for the disk
        # I/O, then load the child ELF from the kernel path copy (own address space;
        # argv[0] = the path, matches sh_cmd_run). On failure nothing else was
        # clobbered (no exec_and_wait, no kstack swap) — restore the caller CR3,
        # clear the guard, return -1.
        cr3_load(0x1000);
        var cpid = elf_load_from_file(pdst, arg2, pdst, arg2);
        if (cpid < 0) {
