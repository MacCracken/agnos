# === Stack Canary (S13) ===
# Random secret initialized at boot via RDRAND. Checked in critical functions
# to detect stack buffer overflows before they corrupt return addresses.
var stack_canary_secret = 0;

fn stack_canary_init() {
    # v1.28.0: use the shared rdrand_u64() helper (arch/x86_64/io.cyr +
    # arch/aarch64/stubs.cyr). Same entropy source as KASLR's
    # kaslr_seed() — one helper, two callers. The timer-mixer fallback
    # is preserved so the canary still gets a varying value if RDRAND
    # fails this boot.
    var val = rdrand_u64();
    if (val == 0) {
        val = timer_ticks * 6364136223846793005 + 0xDEAD1337CAFE4242;
    }
    stack_canary_secret = val;
    return 0;
}

fn stack_canary_check(canary) {
    if (canary != stack_canary_secret) {
        serial_println("PANIC: stack smash detected", 27);
        arch_halt();
    }
    return 0;
}

# === Syscall Interface ===
# Syscall#: 0=exit 1=write 2=getpid 3=spawn 4=waitpid 5=read 6=close 7=open
# 8=dup 9=mkdir 10=rmdir 11=mount 12=sync 13=reboot 14=pause 15=getuid
# 16=kill 17=sigprocmask 18=signalfd 19=epoll_create 20=epoll_ctl
# 21=epoll_wait 22=timerfd_create 23=timerfd_settime 24=umount 25=pipe
# 26=write_boot_checkpoint(byte) — diagnostic-only, writes CMOS[0x50]=arg1.
#    Added for iron-boot bring-up so userspace (kybernet) can mark progress
#    in the same CMOS slot the kernel uses. Will likely stay through MVP.
# 27=mmap(length) — anonymous, zero-filled, 2 MB-granular (1.35.3). The first
#    new functional syscall since v1.21.0; the CVE-2026-31431 immunity is
#    anchored on the absence of the AF_ALG/socket/splice surface, which mmap
#    (a pure memory syscall) does not add.
# 28=munmap(addr, length) — release an mmap region + free its physical 2 MB
#    pages (1.35.4). The natural pair to 27; same pure-memory posture.

var sys_exit_code = 0;

# --- execwait #37 nested-exec save block (1.43.x) ---
# Snapshot of agnsh's kernel resume context across the nested exec_and_wait(child).
# ALL module-global, NOT [rbp-N] locals: agnsh was itself entered via exec_and_wait
# (by kybernet PID 1), so the resume-context GLOBALS (exec_ctx + kernel_return_* +
# kpti_* + kernel_rsp_save) currently hold KYBERNET's armed frame — the frame
# agnsh's OWN exit() must longjmp into. The nested exec_and_wait(child) overwrites
# them with the #37-handler frame and kernel_resume zeroes kernel_return_*, so
# without a save/restore agnsh's later exit() would find kernel_return_rsp=0 and
# never resume kybernet. Single-slot: correct for one-level nesting under the
# single-threaded run-to-completion model (agnsh runs leaf programs); a recursive
# execwait is refused via ew37_busy. Module-global `var X[N]` = N*u64 — the 8-u64
# exec_ctx mirror is exactly right.
var ew37_ctx[8];          # exec_ctx[0..7] mirror (kybernet's armed resume frame)
var ew37_kr_rsp = 0;      # kernel_return_rsp (==1 armed)
var ew37_kr_rip = 0;      # kernel_return_rip
var ew37_rsp_save = 0;    # kernel_rsp_save — agnsh's user RSP (the exit stub reloads it pre-SYSRET)
var ew37_a4 = 0;          # ksyscall_a4 (defense-in-depth)
var ew37_pid = 0;         # proc_current (agnsh's pid)
var ew37_cr3 = 0;         # agnsh's CR3 (kpti_user_cr3 the exit stub reloads into CR3)
var ew37_cpid = 0;        # child pid — MUST be a global (a [rbp-N] local survives via
# the disjoint kstack, but globals are the contract here)
var ew37_code = 0;        # child exit code captured post-resume
var ew37_busy = 0;        # re-entrancy guard: 1 while a #37 nested exec is in flight
var ew37_path[16];        # kernel copy of the caller's path cstr (128 B). elf_load_from_file
# does ext2/NVMe I/O under boot CR3 (the user VA + the NVMe BAR are
# NOT both mapped under one CR3), so the path is copied here from the
# user buffer BEFORE the CR3 switch — mirroring sh_cmd_run's sh_path_buf.

# Security: a userspace pointer must lie in the user VA window [0x200000, 0x40000000):
# above the kernel low region (0-2 MB) and below the 1 GB arena ceiling. EVERY
# legitimate user address is below 1 GB — ELF segments (p_vaddr >= 2 MB, p_memsz
# <= 32 MB, so < 34 MB), the per-pid user stack (0x800000 + pid*0x400000, < 72 MB
# for the 16-process cap), and the mmap arena [0x10000000, 0x40000000). Device
# MMIO / PCI BARs (e.g. NVMe ~0xC0000000) and the 1-4 GB PDPT range the per-process
# CR3 ALSO mirrors all sit ABOVE the ceiling — so without the upper bound a ring-3
# caller could aim a kernel load64/store64 at MMIO or high kernel memory (1.41.5).
# Returns 1 if the pointer/range is safe, 0 otherwise.
fn is_user_ptr(ptr) {
    if (ptr < 0x200000) { return 0; }
    if (ptr >= 0x40000000) { return 0; }   # above the 1 GB user ceiling
    return 1;
}

fn is_user_range(ptr, len) {
    if (ptr < 0x200000) { return 0; }
    if (ptr + len < ptr) { return 0; }          # wrap check
    if (ptr + len > 0x40000000) { return 0; }    # above the 1 GB user ceiling
    return 1;
}

# 1.41.6 (#22): the path-argument preamble every mount-routed FS syscall shares —
# a non-empty length AND a valid user range. Returns 1 if (ptr,len) is an
# acceptable path argument, 0 otherwise. Pure factoring of the duplicated
# `if (len < 1) ... if (is_user_range(ptr,len) == 0) ...` pair; callers keep
# their own canary/return conventions on the reject.
fn sc_path_ok(ptr, len) {
    if (len < 1) { return 0; }
    return is_user_range(ptr, len);
}

# Resume kernel execution after a user process exits, by performing
# exec_and_wait's epilogue: ret_rsp is exec_and_wait's OWN rbp, so
# `mov rsp, ret_rsp; pop rbp; ret` restores the caller's rbp and returns into
# the caller (sh_cmd_run) exactly as if exec_and_wait had returned normally —
# letting the kernel/shell continue (run more programs) instead of halting on a
# garbage rbp. (1.40.4 — the old version jmp'd without restoring rbp.)
fn kernel_resume() {
    # 1.42.14 SECURITY (audit #3): the SYSCALL entry stub's STAC (AC=1, SMAP off
    # for the user-copy window) is paired with a CLAC only on the NORMAL return.
    # The exit syscall (num==0) reaches here and longjmps out (jmp rdx below) —
    # it never returns to the stub, so AC would stay 1 and ALL post-exit kernel
    # work (the next `run`, ext2/VFS) would execute with SMAP disabled. Re-enable
    # SMAP here so the exit path resumes with the backstop intact.
    asm {
        0x0F; 0x01; 0xCA;   # clac
    }
    kernel_return_rsp = 0;
    kernel_return_rip = 0;
    # 1.40.10 bite 2 — restore the kernel main thread (proc 0) as current after a
    # program exits. sh_cmd_run sets proc_current = the exec pid for exit-code
    # attribution; without this reset proc_current stays on that now-dead
    # (state=0) proc, and the next timer tick's do_context_switch (sched.cyr)
    # takes it as `old` and unconditionally marks it ready again (line 150,
    # deliberately unconditional per iron Attempt 14 — do NOT make it conditional),
    # resurrecting a dead exec proc that sched_next could then switch into → an
    # iretq into ring-3 user code under CS=0x08. Pointing proc_current back at
    # proc 0 (the kmain thread registered before sched_active=1) keeps every
    # post-exit timer tick switching kmain↔idle only. Exit-code attribution is
    # unaffected: sh_cmd_run reads the local pid (shell.cyr:765), not proc_current,
    # and the exit code was already stamped before kernel_resume was called. During
    # the boot exec selftest sched_active=0 (no scheduling) so this is a no-op there.
    proc_current = 0;
    # 1.40.6: restore the BOOT kernel CR3 (0x1000). On the program's exit the
    # SYSCALL stub left CR3 = the per-process CR3, which mirrors only 0-1 GB +
    # PDPT[1..3] — it does NOT map the device MMIO (NVMe BAR ~0xC0000010xx) that
    # the next kernel work (ext2 read for the next `run`) touches → a second
    # sequential exec faulted on the NVMe BAR. Switch back to the boot CR3 (maps
    # everything, incl. MMIO) so the kernel runs clean after a program exits.
    # kernel_resume's code + exec_ctx are in 0-2 MB, mapped under 0x1000 too.
    asm {
        0x48; 0xC7; 0xC0; 0x00; 0x10; 0x00; 0x00;  # mov rax, 0x1000
        0x0F; 0x22; 0xD8;                           # mov cr3, rax
    }
    # Switch back to kernel data segments (SS/DS/ES = 0x10).
    asm {
        0x48; 0xC7; 0xC0; 0x10; 0x00; 0x00; 0x00;  # mov rax, 0x10
        0x8E; 0xD8;  # mov ds, ax
        0x8E; 0xC0;  # mov es, ax
        0x8E; 0xD0;  # mov ss, ax
    }
    # Restore the full resume context exec_and_wait saved (callee-saved regs +
    # caller rbp + return rsp/rip), then jmp — exec_and_wait "returns" exactly
    # as a normal call. `var c = &exec_ctx` lands the address in rax; rdx scratch.
    var c = &exec_ctx;
    asm {
        0x48; 0x8B; 0x18;        # mov rbx, [rax]
        0x4C; 0x8B; 0x60; 0x08;  # mov r12, [rax+8]
        0x4C; 0x8B; 0x68; 0x10;  # mov r13, [rax+16]
        0x4C; 0x8B; 0x70; 0x18;  # mov r14, [rax+24]
        0x4C; 0x8B; 0x78; 0x20;  # mov r15, [rax+32]
        0x48; 0x8B; 0x68; 0x28;  # mov rbp, [rax+40]   (caller rbp)
        0x48; 0x8B; 0x50; 0x38;  # mov rdx, [rax+56]   (return rip)
        0x48; 0x8B; 0x60; 0x30;  # mov rsp, [rax+48]   (caller post-call rsp)
        0xFF; 0xE2;              # jmp rdx
    }
    return 0;
}

# === Blocking keyboard stdin (1.41.1 — shell-separation arc; line discipline 1.41.15) ===
# read(fd=0) for a ring-3 process: block, read a WHOLE LINE in ONE continuous
# interrupts-enabled window, echo as we go, return when Enter (newline) is seen
# or the caller's buffer fills. Canonical-lite line discipline (ABI O1, revised
# 1.41.15): kernel echoes printable bytes + handles backspace + terminates on
# newline — the userland shell consumes a ready-made line. This is a deliberate
# move AWAY from the original RAW per-byte design, for the reason below.
#
# WHY THE PER-BYTE RAW DESIGN BROKE ON IRON (the 1.41.14 `14114` "Command: D"
# burn): keystrokes on archaemenid arrive via IRQ1 -> kb_isr -> kb_buf (the UEFI
# USB-legacy i8042 emulation; hid_poll's xHCI ring stays empty on that box). The
# in-kernel recovery shell types correctly there because it holds IF=1 across the
# ENTIRE line in one loop, so every scancode — including the SHIFT-RELEASE break
# (0xAA) — is processed in-window and kb_shift is cleared. The old userland path
# returned after the FIRST char, and ring 3 runs with IF=0 between syscalls
# (ring3.cyr:108 sets RFLAGS=0x002; SYSRET restores it via R11). In that IF=0
# inter-byte gap IRQ1 is masked, so a shift-release landing there was DROPPED:
# kb_shift latched at 1, and scancode 0x20 ('d') resolved through sc_shifted to
# 'D'=68 — every typed line collapsed to a stuck shift+d. The fix is to stop
# diverging from the proven reference: drain the whole line under one continuous
# sti window, exactly like shell.cyr's input loop.
#
# Why `sti` is safe in a ring-3 syscall: the only unsafe interrupt mid-syscall
# is the TIMER (its handler calls do_context_switch; the kernel is not reentrant
# across a switch on the syscall stack). We clear sched_active for the duration:
# the timer ISR still fires (EOIs + advances timer_ticks, so net/NTP timing keeps
# moving) but do_context_switch early-returns. Held across the whole line, same
# regime the in-kernel shell runs in.
#
# kb_has_key() also calls hid_poll() to drain the xHCI USB-HID event ring (how
# QEMU's usb-kbd delivers — events DMA in regardless of any interrupt). One loop
# serves both: iron fills kb_buf via IRQ1, QEMU via the polled hid_poll drain. We
# busy-poll (no hlt) so the QEMU path needs no wake interrupt. Echo uses kputc
# (serial + GOP framebuffer mirror) — the same fb path write(1) uses from a
# ring-3 syscall since 1.41.12, so it renders under the unified exec CR3 on iron.
fn kbd_read_blocking(buf, count) {
    if (count <= 0) { return 0; }
    var saved_sched = sched_active;
    sched_active = 0;          # suspend preemption: timer ISR still EOIs + ticks,
    # but do_context_switch early-returns (no switch)
    kb_shift = 0; kb_ctrl = 0; # defensive: never enter a read with a stranded
    # modifier from a prior partial read (continuous drain below keeps it honest
    # within the line; this just guarantees a clean start)
    kbd_irq_enable();          # IF=1 for the WHOLE line — IRQ1 -> kb_isr fills
    # kb_buf (iron); hid_poll drains the ring (QEMU). Held continuously so every
    # scancode incl. shift-release breaks is processed in-window.
    var n = 0;
    while (n < count) {
        while (kb_has_key() == 0) { }   # IRQ1 fills kb_buf (iron); hid_poll drains ring (QEMU)
        var sc = kb_read_scancode();
        var ch = scancode_to_ascii(sc);
        if (ch == 10) {                 # Enter: terminate the line. Echo newline,
            kputc(10);                  # store it as the terminator, return.
            store8(buf + n, 10);
            n = n + 1;
            kbd_irq_disable();
            sched_active = saved_sched;
            return n;
        }
        if (ch == 4) {                  # Ctrl-D (EOF). Canonical tty semantics:
            # at line start (n==0) signal end-of-input by returning 0 — this is
            # the ONLY path by which read(fd 0) can return 0 on agnos, so it's
            # what lets a stdin filter (anuenue, cat) terminate; without it a
            # filter loops forever (no pipes, no other EOF). Mid-line (n>0) it
            # delivers the bytes typed so far WITHOUT a terminating LF, so a
            # second Ctrl-D at the fresh line start then yields EOF. Not echoed.
            kbd_irq_disable();
            sched_active = saved_sched;
            return n;
        }
        if (ch == 8) {                  # Backspace: erase one cell + drop one byte
            if (n > 0) {                # (BS SP BS), mirrors shell.cyr:797.
                n = n - 1;
                kputc(8); kputc(32); kputc(8);
            }
        } elif (ch > 31) {              # Printable: store + echo (shell.cyr:800-805)
            store8(buf + n, ch);
            n = n + 1;
            kputc(ch);
        }
        # ch == 0 (modifier/release) or other control (<32, non-LF/BS): consumed
        # in-window, never stored — so the whole make/break stream is drained here
        # and kb_shift can't strand across a syscall boundary.
    }
    # Buffer filled before a newline arrived — return the partial line.
    kbd_irq_disable();
    sched_active = saved_sched;
    return n;
}

# System hostname — read-only identity for uname(34).nodename. Seeded to
# "agnos"; no sethostname syscall yet (added only when a native workload needs a
# mutable hostname — kernel grows per workload, not by Linux default). A gvar
# string literal, safe to read from a syscall (post-gvar-init, like _AGNOS_VERSION).
var kernel_hostname = "agnos";

# Copy a NUL-terminated kernel string literal into a fixed `max`-byte user field,
# NUL-padding the remainder. Stops at the source NUL or `max` bytes, whichever
# comes first — never reads past a short literal. `dst` is part of a user buffer
# the caller already validated with is_user_range. Used by uname(34).
fn sysinfo_put_str(dst, src, max) {
    var copying = 1;
    var i = 0;
    while (i < max) {
        var c = 0;
        if (copying == 1) {
            c = load8(src + i);
            if (c == 0) { copying = 0; }   # hit end of source — pad zeros from here
        }
        store8(dst + i, c);
        i = i + 1;
    }
    return 0;
}

fn ksyscall(num, arg1, arg2, arg3) {
    # Stack-canary backstop: snapshot at entry, re-checked before returning on the
    # syscalls that do the most pointer/buffer work (the 1.41.3 FS group + pipe/
    # mmap/munmap). Coverage is deliberately NOT uniform across every branch
    # (audit 1.41.6 #14/#23): ksyscall itself has no local array buffer for a
    # smash to corrupt, so these checks are a backstop against a *callee* (ext2_*/
    # elf_*) overrunning back into this frame — the leaf functions that own real
    # buffers (e.g. elf_load) carry their own canary. A single-tail collapse was
    # rejected: it would require rewriting ~25 early-returns in this security-
    # critical dispatcher with no clean Cyrius idiom, for a non-vuln cosmetic gain.
    var canary = stack_canary_secret;
    if (num == 0) {
        # exit — halt current process, return to kernel if context saved
        sys_exit_code = arg1;
        proc_set_exit_code(proc_current, arg1);
        if (proc_current < proc_count) {
            proc_set_state(proc_current, 0);
            # Send SIGCHLD (signal 17) to parent process
            var ppid = proc_get_ppid(proc_current);
            if (ppid >= 0) {
                proc_send_signal(ppid, 17);
            }
        }
        # If we have a saved kernel return point, jump back to it
        if (kernel_return_rsp != 0) {
            kernel_resume();
        }
        return 0;
    }
    if (num == 1) {
        # write(fd=arg1, buf=arg2, len=arg3)
        if (arg3 > 0) {
            if (is_user_range(arg2, arg3) == 0) { return 0 - 1; }
        }
        return vfs_write(arg1, arg2, arg3);
    }
    if (num == 2) { return proc_current; }
    if (num == 3) {
        # spawn(elf_addr, elf_size) — load an in-memory ELF + create a user process.
        # Returns new pid or -1. 1.41.5: the ELF image is a USER buffer — validate
        # the whole (addr,size) range so elf_load's load8/load64 can't be aimed at
        # kernel memory (a ring-3 caller passing a kernel addr would disclose it).
        if (arg2 < 1) { return 0 - 1; }
        if (is_user_range(arg1, arg2) == 0) { return 0 - 1; }
        var new_pid = elf_load(arg1, arg2);
        if (new_pid >= 0) {
            # Mark as ready; will be scheduled on next timer tick
            proc_set_state(new_pid, 1);
        }
        return new_pid;
    }
    if (num == 4) {
        # waitpid(pid) — wait for a process to exit (state=0)
        # Simple busy-wait for now; returns per-process exit code
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= proc_count) { return 0 - 1; }
        # Never wait on (and never reap) the caller itself — that would block
        # forever and, post-loop, free the running proc's own address space.
        if (arg1 == proc_current) { return 0 - 1; }
        while (proc_get_state(arg1) != 0) {
            arch_wait();
        }
        # 1.42.x: reap the in-memory-spawned child here — the symmetric point to
        # the from-disk path's "read exit code in sh_cmd_run, then proc_reap".
        # Read the exit code FIRST (proc_reap_child may collapse the slot), then
        # reclaim the child's address space (ELF + stack + ANY un-munmap'd mmap
        # huge pages) and proc_table slot. Without this, every spawn()ed child
        # leaked its whole address space for the boot; with it the in-memory
        # path is leak-symmetric with elf_load_from_file's run/reap. Safe: the
        # child is confirmed dead (loop above) and is not proc_current (guarded),
        # so its distinct CR3 is not the one the CPU is walking.
        var wcode = proc_get_exit_code(arg1);
        proc_reap_child(arg1);
        return wcode;
    }
    if (num == 5) {
        # read(fd=arg1, buf=arg2, len=arg3)
        # 1.42.14: reject negative len explicitly (defense-in-depth — the fd-type
        # read helpers now also enforce their own minimum count, so a too-small
        # buffer can no longer drive a fixed-size store past the validated range).
        if (arg3 < 0) { return 0 - 1; }
        if (arg3 > 0) {
            if (is_user_range(arg2, arg3) == 0) { return 0 - 1; }
        }
        # 1.41.1: fd 0 = blocking keyboard stdin (RAW), the dispositive new
        # capability for the userland shell. Other fds keep the vfs_read path.
        if (arg1 == 0) { return kbd_read_blocking(arg2, arg3); }
        return vfs_read(arg1, arg2, arg3);
    }
    if (num == 6) { return vfs_close(arg1); }
    if (num == 7) {
        # open(name=arg1, namelen=arg2, flags=arg3) — mount-routed (1.41.3).
        # Re-routes from initrd-only: ext2 / FAT / exFAT by mount, with initrd
        # as the bare-name fallback. AO_DIRECTORY(0x800)→dir-fd (getdents);
        # AO_CREAT(0x100) creates if absent; AO_TRUNC(0x200) zeroes existing.
        if (sc_path_ok(arg1, arg2) == 0) { return 0 - 1; }
        var be7 = vfs_resolve_mount(arg1, arg2);
        if (be7 == FS_EXT2) {
            if ((arg3 & 0x800) != 0) { return ext2_open_dir(arg1, arg2); }
            var ino7 = ext2_path_lookup(arg1, arg2);
            if (ino7 <= 0) {
                if ((arg3 & 0x100) == 0) { return 0 - 1; }
                var par7 = vfs_ext2_parent(arg1, arg2);
                if (par7 <= 0) { return 0 - 1; }
                if (ext2_create(par7, arg1 + vfs_base_off, vfs_base_len) <= 0) { return 0 - 1; }
            } else {
                if ((arg3 & 0x200) != 0) { ext2_truncate_zero(ino7); }
            }
            return ext2_open(arg1, arg2);
        }
        if (be7 == FS_FAT || be7 == FS_EXFAT) {
            var roff = arg1 + vfs_mnt_reloff;
            var rlen = arg2 - vfs_mnt_reloff;
            if ((arg3 & 0x100) != 0) { vfs_create_on(be7, roff, rlen); }   # AO_CREAT
            # 1.41.7: write-access (AO_WRONLY/AO_RDWR, low 2 bits) → a write-back
            # fd that buffers content + flushes the whole file via vfs_write_on at
            # close, so agnsh can write a FAT/exFAT data partition. Else a read
            # memfile. AO_TRUNC is implicit (whole-file replace); AO_APPEND TODO.
            if ((arg3 & 0x3) != 0) { return vfs_sec_wfile_open(be7, roff, rlen); }
            return vfs_open_on(be7, roff, rlen);
        }
        # bare-name / unmounted fallback (legacy initrd)
        return initrd_open(arg1, arg2);
    }
    # Tier 1: stubs
    if (num == 8) { return arg1; }           # dup(fd) -> return same fd
    if (num == 9) {
        # mkdir(path=arg1, pathlen=arg2) — real, mount-routed (1.41.3).
        if (sc_path_ok(arg1, arg2) == 0) { return 0 - 1; }
        var be9 = vfs_resolve_mount(arg1, arg2);
        if (be9 == FS_FAT || be9 == FS_EXFAT) { return vfs_mkdir_on(be9, arg1 + vfs_mnt_reloff, arg2 - vfs_mnt_reloff); }
        if (be9 == FS_EXT2) {
            var par9 = vfs_ext2_parent(arg1, arg2);
            if (par9 <= 0) { return 0 - 1; }
            if (ext2_mkdir(par9, arg1 + vfs_base_off, vfs_base_len) > 0) { return 0; }
            return 0 - 1;
        }
        return 0 - 1;
    }
    if (num == 10) {
        # rmdir(path=arg1, pathlen=arg2) — real, mount-routed (1.41.3).
        if (sc_path_ok(arg1, arg2) == 0) { return 0 - 1; }
        var be10 = vfs_resolve_mount(arg1, arg2);
        if (be10 == FS_FAT || be10 == FS_EXFAT) { return vfs_rmdir_on(be10, arg1 + vfs_mnt_reloff, arg2 - vfs_mnt_reloff); }
        if (be10 == FS_EXT2) {
            var par10 = vfs_ext2_parent(arg1, arg2);
            if (par10 <= 0) { return 0 - 1; }
            return ext2_rmdir(par10, arg1 + vfs_base_off, vfs_base_len);
        }
        return 0 - 1;
    }
    if (num == 12) {
        # sync() — flush ext2 metadata + all block devices to stable media
        # (1.41.3 — was a stub returning 0).
        if (ext2_active != 0) { ext2_sync(); }
        blk_flush();
        return 0;
    }
    if (num == 15) { return 0; }             # getuid (root)
    if (num == 24) { return 0; }             # umount
    # Tier 2: simple
    if (num == 11) { return 0; }             # mount (noop for now)
    if (num == 13) {                          # reboot
        serial_println("AGNOS: reboot", 13);
        arch_halt();
        return 0;
    }
    if (num == 14) { arch_wait(); return 0; } # pause
    # Tier 3: signals
    if (num == 16) {
        # kill(pid=arg1, sig=arg2)
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= proc_count) { return 0 - 1; }
        if (arg2 < 0) { return 0 - 1; }
        if (arg2 >= 64) { return 0 - 1; }
        # Security: non-init processes cannot signal PID 0 (init)
        if (arg1 == 0) {
            if (proc_current != 0) { return 0 - 1; }
        }
        # Security: processes can only signal themselves or children
        # For now, allow signaling own process or if sender is PID 0 (init)
        if (proc_current != 0) {
            if (arg1 != proc_current) {
                var target_ppid = proc_get_ppid(arg1);
                if (target_ppid != proc_current) { return 0 - 1; }
            }
        }
        var sig_pending = load64(&proc_signals + arg1 * 8);
        store64(&proc_signals + arg1 * 8, sig_pending | (1 << arg2));
        return 0;
    }
    if (num == 17) {
        # sigprocmask(how=arg1, set=arg2, oldset=arg3)
        # Security: validate userspace pointers for the full 8 bytes touched
        # (load64(arg2) / store64(arg3) below). 1.41.5: range not bare ptr.
        if (is_user_range(arg2, 8) == 0) { return 0 - 1; }
        if (arg3 != 0) {
            if (is_user_range(arg3, 8) == 0) { return 0 - 1; }
        }
        var old_mask = load64(&proc_sigmask + proc_current * 8);
        if (arg3 != 0) { store64(arg3, old_mask); }
        var new_bits = load64(arg2);
        if (arg1 == 0) { new_bits = old_mask | new_bits; }
        if (arg1 == 1) { new_bits = old_mask & (0 - 1 - new_bits); }
        store64(&proc_sigmask + proc_current * 8, new_bits);
        return 0;
    }
    if (num == 18) {
        # signalfd(fd=arg1, mask_ptr=arg2, flags=arg3)
        # Security: validate the 8 bytes read (load64(arg2)). 1.41.5: range.
        if (is_user_range(arg2, 8) == 0) { return 0 - 1; }
        var sfd = vfs_alloc();
        if (sfd < 0) { return 0 - 1; }
        var sbase = &vfs_table + sfd * 32;
        ktag_set(sbase, VFS_SIGNALFD);
        kpayload_set(sbase, 2, load64(arg2));   # sigmask
        return sfd;
    }
    # Tier 4: epoll + timerfd
    if (num == 19) {
        # epoll_create
        var efd = vfs_alloc();
        if (efd < 0) { return 0 - 1; }
        var ebase = &vfs_table + efd * 32;
        # 1.41.5: allocate the watch list BEFORE claiming the slot — on OOM the
        # slot stays VFS_FREE (vfs_alloc doesn't mark it) so nothing leaks and we
        # never hand back an epoll fd with a NULL watch list.
        var wl = kmalloc(128);
        if (wl == 0) { return 0 - 1; }
        ktag_set(ebase, VFS_EPOLL);
        kpayload_set(ebase, 0, 0);              # watch count
        kpayload_set(ebase, 2, wl);             # watch list ptr
        return efd;
    }
    if (num == 20) {
        # epoll_ctl(epfd=arg1, op=arg2, fd=arg3)
        if (arg1 < 0) { return 0 - 1; }
        if (arg1 >= 32) { return 0 - 1; }
        var ebase = &vfs_table + arg1 * 32;
        # 1.41.5: the epfd MUST be an epoll instance. Without this a ring-3 caller
        # could pass ANY allocated fd whose payload[2] is a kernel heap pointer
        # (pipe/memfile) or a small integer (an ext2 fd's inode number) — the
        # store64s below would then write an attacker-controlled value to that
        # address: an arbitrary kernel write. Mirrors the getdents VFS_EXT2_DIR
        # tag check.
        if (ktag(ebase) != VFS_EPOLL) { return 0 - 1; }
        var wl = kpayload(ebase, 2);
        if (wl == 0) { return 0 - 1; }
        var wc = kpayload(ebase, 0);
        if (arg2 == 1) {
            # Max 8 watches (128 bytes / 16 bytes per watch)
            if (wc >= 8) { return 0 - 1; }
