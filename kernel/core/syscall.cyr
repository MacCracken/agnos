        # uses, shell.cyr:460-463).
        ew37_cpid = cpid;
        var cep = &proc_table + cpid * 176;
        var ce  = load64(cep + 24);
        var cr  = load64(cep + 16);
        var cc  = load64(cep + 160);

        # (f) SWITCH the SYSCALL kstack to the disjoint second top (H2) for the
        # nested run. exec_and_wait calls syscall_init() (ring3.cyr:53), which
        # rebuilds the entry stub re-reading syscall_kstack_top — so this write
        # bakes syscall_kstack_top2 into the child's stub. The child's syscalls then
        # grow down 0x3D0000 and never touch agnsh's suspended #37 frame on 0x3F0000.
        syscall_kstack_top = syscall_kstack_top2;

        # (g) make the child current (so ITS exit() stamps the code on ITS pid),
        # then run to completion. The child's exit() -> kernel_resume longjmps back
        # to the line after this call with CR3=boot 0x1000, proc_current=0,
        # kernel_return_*=0, kpti_*=child, kernel_rsp_save=child's last user RSP.
        proc_current = cpid;
        exec_and_wait(ce, cr, cc);
        # ===== RESUME POINT (child exited) =====

        # (h) restore the PRIMARY SYSCALL kstack and rebuild the stub so agnsh's own
        # subsequent syscalls go back on 0x3F0000 (the stub baked 0x3D0000 during
        # the child run; kernel_resume does NOT rebuild). syscall_init is idempotent
        # (exec_and_wait calls it every exec) and safe under boot CR3.
        syscall_kstack_top = 0x3F0000;
        syscall_init();

        # (i) read the child's exit code (from the GLOBAL pid) BEFORE reaping (reap
        # collapses the slot), then reap: proc_reap_child frees the child's address
        # space + LIFO slot only (NOT proc_reap, which sweeps fds). Safe: child is
        # dead, proc_current==0 (!=cpid) so its guard passes, CPU is on boot CR3.
        ew37_code = proc_get_exit_code(ew37_cpid);
        proc_reap_child(ew37_cpid);

        # (j) rebuild agnsh's resume world from the snapshot (H1) so agnsh's own
        # later exit() resumes kybernet, and so the exit stub reloads agnsh's CR3 +
        # user RSP (not the child's leftovers). &ew37_ctx/&exec_ctx are fresh global
        # addresses (not carried locals).
        var r37 = &ew37_ctx;
        var er  = &exec_ctx;
        var ri  = 0;
        while (ri < 64) { store64(er + ri, load64(r37 + ri)); ri = ri + 8; }
        kernel_return_rsp = ew37_kr_rsp;             # re-arm (==1): agnsh's exit() resumes kybernet
        kernel_return_rip = ew37_kr_rip;
        kpti_kernel_cr3   = ew37_cr3;                # agnsh's CR3 (kernel-side)
        kpti_user_cr3     = ew37_cr3;                # the value the exit stub reloads into CR3 pre-SYSRET
        kernel_rsp_save   = ew37_rsp_save;           # the exit stub does `mov rsp,[kernel_rsp_save]` pre-SYSRET
        ksyscall_a4       = ew37_a4;
        proc_current      = ew37_pid;                # agnsh's pid (its write/exit attribute to agnsh)

        # (k) reload the LIVE CR3 to agnsh now (kernel_resume left boot 0x1000) so
        # this handler tail + the exit stub run under agnsh's mappings. cr3_load
        # (proc.cyr:153) is the robust param-based idiom.
        cr3_load(ew37_cr3);

        ew37_busy = 0;
        # (l) NO post-resume canary check: the entry `canary` local was legitimately
        # handed to exec_and_wait's longjmp; ksyscall's canary guards CALLEE overruns
        # and there are no callees after this point (syscall.cyr:250-258). Return the
        # child code from the GLOBAL.
        return ew37_code;
    }
    stack_canary_check(canary);
    return 0 - 1;
}
