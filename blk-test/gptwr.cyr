# gptwr — agnos ring-3 sovereign GPT partition-table + FAT32-ESP writer (1.53.x Phase 4).
#
# The ring-3 successor to blkprobe/blkwr: it replaces the Linux `parted mklabel/mkpart`
# + `mkfs.fat -F32` shell-outs agnova depends on, building a byte-accurate GPT + FAT ESP
# in userland and writing it through the sys_blk_* wrappers (the kernel exposes raw sector
# I/O; userland owns the on-disk format — as every OS does). Built + proven on Linux-hosted
# QEMU against a real NVMe/GPT disk via the *_SELFTEST exit-code harness.
#
# Uses the native cyrius `sys_blk_*` wrappers (v6.4.39) — no raw syscall numbers.
#
# Built in small bites, each independently exit-code-gated (97 = fresh pass; 90..70 diag).
#   Bite 1: CRC32 correctness (canonical vectors) — the GPT CRCs gate everything.  [91/92/93]
#   Bite 2: build the protective MBR + primary GPT header + 128-entry array + BACKUP header in
#                  RAM for a synthetic disk, then SELF-VERIFY every structure with the kernel's
#                  exact field offsets/CRCs (gpt.cyr). The type-GUID trick: writing the kernel's
#                  own GPT_TYPE_*_LO/HI u64 constants via store64 reproduces the exact mixed-
#                  endian on-disk bytes automatically, bit-consistent with the reader that will
#                  validate them. Diagnostics: 83 MBR, 84 hdr-fields, 85 backup, 86 rootfs-GUID,
#                  87 ESP-GUID, 88 array-CRC, 89 hdr-CRC, 90 signature.
#   Bite 3a: the FIRST real disk write. Enumerate the single active NVMe, read its capacity, and
#                  assert the whole synthetic image fits in the live disk's UNALLOCATED TAIL
#                  (SCRATCH_BASE, past the 240 MiB live rootfs) — a bug can only clobber throwaway
#                  sectors, never the live GPT/ESP/rootfs at absolute LBA 0/1/2-33. Arm the write
#                  gate, RW-open, write ONLY the MBR (base+0), read it back, byte-compare.
#                  Diagnostics: 79 no disk, 78 capacity overrun, 77 arm/RW-open, 76 write,
#                  75 readback, 74 mismatch.
#   Bite 3b: write the REST of the GPT to the scratch tail — primary header (base+1), the entry
#                  array (base+2..33, ONE 32-sector write), the backup array (base+N-33), and the
#                  backup header (base+N-1) — then readback-verify every region against RAM. After
#                  this the tool-authored GPT is complete on disk; the smoke's sgdisk oracle
#                  (Bite 5) validates it independently. Diagnostics: 73 hdr-write, 72 array-write,
#                  71 backup-array-write, 70 backup-hdr-write, 69 readback.
#   Bite 6: FAT32 mkfs into the ESP partition — compute FATSz32 (fatgen formula), build the BPB +
#                  FSInfo + FAT[0..2] + root-dir volume-label dirent, guard CountOfClusters >= 65525
#                  (else it's FAT16), zero the metadata region, then write the boot sector (+backup
#                  @6), FSInfo (+backup @7), both FATs' sector 0, and the root cluster, and readback-
#                  verify. The ESP is now a valid FAT32 (mtools + fsck.fat clean). Diagnostics:
#                  68 not-FAT32, 67 boot-write, 66 fsinfo-write, 65 FAT/root-write, 64 zeroing,
#                  63 boot-readback, 62 FAT-readback, 61 BPB-self-check.
#   Bite 7: create the \EFI subdirectory — allocate cluster 3, write its '.'/'..' dirents, mark it
#                  EOC in both FATs, and publish the \EFI dirent in the root (the split FstClusHI@20
#                  / FstClusLO@26 fields written as TWO store16, never a store32 that would clobber
#                  WrtTime@22). Crash-safe order: data cluster -> FAT -> parent dirent -> FSInfo.
#                  Diagnostics: 60 \EFI-cluster-write, 59 FAT-rewrite, 58 root-publish-write,
#                  57 fsinfo-rewrite, 56 \EFI-readback, 55 root-dirent-readback.
#   Bite 8a: complete the boot directory skeleton — \EFI\BOOT (cluster 4, parent \EFI) and \boot
#                  (cluster 5, parent root), via the build_dir_cluster/put_dir_dirent helpers, same
#                  crash-safe order. These are the parents for BOOTX64.EFI and the kernel (8b/8c).
#                  Diagnostics: 54 dir-cluster-write, 53 FAT-rewrite, 52 parent-publish-write,
#                  51 fsinfo-rewrite, 50 readback.
#   Bite 8b: write \EFI\BOOT\BOOTX64.EFI (gnoboot, ~30 KB) from the rootfs into the FAT — the first
#                  real file I/O in the tool. open a FIXED ROOTFS PATH, lseek(END) for the size,
#                  allocate a contiguous cluster run, STREAM the body 512 B at a time into the
#                  cluster sectors, chain the FAT (fits FAT sector 0), publish the 8.3 file dirent.
#                  The smoke mcopy's the file back out + cmp's it byte-for-byte against gnoboot.
#                  Diagnostics: 49 open, 48 size/overrun, 47 FAT-write, 46 dirent-write, 45 body-
#                  write, 44 short-read, 43 dirent-readback, 42 FAT-readback, 41 fsinfo-write.
#   Bite 8c (THIS): write \boot\agnos (the ~1.4 MB kernel) the same way, but the chain spans ~22 FAT
#                  sectors (fat_write_chain RMWs each) and the body streams 32 clusters (16 KB) per
#                  write so we don't flush thousands of single sectors. After this the ESP holds a
#                  complete bootable payload the tool wrote itself. The smoke mcopy+cmp's the kernel
#                  too. Diagnostics: 39 open, 38 size/overrun, 37 FAT-chain, 36 dirent, 35 body,
#                  34 short-read, 33 dirent-readback, 32 FAT-readback, 31 fsinfo.
#
# Bitwise CRC-32/ISO-HDLC, transcribed from the kernel's own gpt_crc32_chunk
# (kernel/core/gpt.cyr:114-128): poly 0xEDB88320 (reflected), init/final 0xFFFFFFFF.

# --- GPT partition-type GUIDs (the load64 LE views of the on-disk 16 bytes) ----------------
# IDENTICAL to the kernel's constants (gpt.cyr:210-215): the kernel COMPARES type GUIDs via
# load64 against these, so writing them via store64 yields the exact on-disk bytes it expects.
var GPT_TYPE_ESP_LO      = 0x11D2F81FC12A7328;   # ESP:      C12A7328-F81F-11D2-BA4B-00A0C93EC93B
var GPT_TYPE_ESP_HI      = 0x3BC93EC9A0004BBA;
var GPT_TYPE_LINUX_FS_LO = 0x477284830FC63DAF;   # Linux FS: 0FC63DAF-8483-4772-8E79-3D69D8477DE4
var GPT_TYPE_LINUX_FS_HI = 0xE47D47D8693D798E;

# Fixed, deterministic disk/partition unique GUIDs (a sovereign installer need not randomize;
# they only must be nonzero + distinct). Values are arbitrary.
var DISK_GUID_LO  = 0x4E5347414E4F1D2A;
var DISK_GUID_HI  = 0x11E6A5D0C7B3F8A0;
var ESP_UNIQUE_LO = 0x4553501D2A7328C1;
var ESP_UNIQUE_HI = 0x00A0C93EC93BBA4B;
var RF_UNIQUE_LO  = 0x524F4F540FC63DAF;
var RF_UNIQUE_HI  = 0x3D69D8477DE48E79;

# --- In-RAM structure buffers (MODULE-global: var X[N] = N*8 bytes, ext2.cyr:44-46) --------
var mbr[64];      #   512 B — protective MBR (LBA 0)
var hdr[64];      #   512 B — primary GPT header (LBA 1)
var pea[2048];    # 16384 B — partition entry array (128 x 128 B = 32 LBAs)
var bhdr[64];     #   512 B — backup GPT header (LBA N-1)
var rback[2048];  # 16384 B — readback scratch for the 32-LBA entry array
var fatbs[64];    #   512 B — FAT32 boot sector (BPB)
var fsinfo[64];   #   512 B — FAT32 FSInfo sector
var fatsec[64];   #   512 B — first sector of each FAT (holds FAT[0..2])
var z32[2048];    # 16384 B — zero buffer for bulk-zeroing the FAT metadata region
var rootbuf[64];  #   512 B — FAT32 root-cluster sector 0 (volume-label dirent + \EFI dirent)
var efidir[64];     # 512 B — the \EFI directory cluster ('.'/'..' + BOOT dirent)
var efibootdir[64]; # 512 B — the \EFI\BOOT directory cluster ('.'/'..' + BOOTX64.EFI dirent)
var bootdir[64];    # 512 B — the \boot directory cluster ('.'/'..' + AGNOS dirent)
var filebuf[64];    # 512 B — one-sector streaming buffer for file bodies
var nm[8];          #  64 B — 8.3 name scratch (11 bytes used)

fn crc32(buf: i64, len: i64): i64 {
    var crc = 0xFFFFFFFF;
    var i = 0;
    while (i < len) {
        crc = crc ^ (load8(buf + i) & 0xFF);
        var k = 0;
        while (k < 8) {
            if ((crc & 1) == 1) { crc = (crc >> 1) ^ 0xEDB88320; }   # >> is LOGICAL in Cyrius
            else               { crc = crc >> 1; }
            k = k + 1;
        }
        i = i + 1;
    }
    return (crc ^ 0xFFFFFFFF) & 0xFFFFFFFF;   # mask = defensive normalization, NOT sign-extend guard
}

# Zero `nbytes` (must be a multiple of 8) of a buffer via 8-byte stores.
fn zero(buf: i64, nbytes: i64): i64 {
    var i = 0;
    while (i < nbytes) { store64(buf + i, 0); i = i + 8; }
    return 0;
}

# --- Protective MBR (UEFI § 5.2.3): one 0xEE partition covering the whole disk -------------
fn build_mbr(n: i64): i64 {
    zero(&mbr, 512);
    store8(&mbr + 446, 0x00);               # boot indicator (not bootable)
    store8(&mbr + 447, 0x00);               # starting CHS = 0x000200 (LBA 1, legacy)
    store8(&mbr + 448, 0x02);
    store8(&mbr + 449, 0x00);
    store8(&mbr + 450, 0xEE);               # OS type = GPT protective
    store8(&mbr + 451, 0xFF);               # ending CHS = 0xFFFFFF (disk exceeds CHS range)
    store8(&mbr + 452, 0xFF);
    store8(&mbr + 453, 0xFF);
    store32(&mbr + 454, 1);                 # starting LBA = 1
    var sz = n - 1;                         # size in LBA = whole disk minus the MBR
    if (sz > 0xFFFFFFFF) { sz = 0xFFFFFFFF; }
    store32(&mbr + 458, sz);
    store8(&mbr + 510, 0x55);               # boot signature
    store8(&mbr + 511, 0xAA);
    return 0;
}

# --- Primary + backup GPT header + entry array (UEFI § 5.3.2 / § 5.3.3) --------------------
fn build_gpt(n: i64, esp_s: i64, esp_e: i64, rf_s: i64, rf_e: i64): i64 {
    # Partition entry array — entry 0 = ESP, entry 1 = rootfs, 2..127 empty (zeroed).
    zero(&pea, 16384);
    store64(&pea + 0,   GPT_TYPE_ESP_LO);   # ESP type GUID (on-disk bytes via LE store64)
    store64(&pea + 8,   GPT_TYPE_ESP_HI);
    store64(&pea + 16,  ESP_UNIQUE_LO);     # unique GUID
    store64(&pea + 24,  ESP_UNIQUE_HI);
    store64(&pea + 32,  esp_s);             # first LBA
    store64(&pea + 40,  esp_e);             # last LBA
    store64(&pea + 48,  0);                 # attributes
    store64(&pea + 128, GPT_TYPE_LINUX_FS_LO);   # entry 1: Linux Filesystem (rootfs)
    store64(&pea + 136, GPT_TYPE_LINUX_FS_HI);
    store64(&pea + 144, RF_UNIQUE_LO);
    store64(&pea + 152, RF_UNIQUE_HI);
    store64(&pea + 160, rf_s);
    store64(&pea + 168, rf_e);
    store64(&pea + 176, 0);

    # Primary GPT header.
    zero(&hdr, 512);
    store32(&hdr + 0,  0x20494645);         # "EFI " (matches kernel GPT_SIG_LO)
    store32(&hdr + 4,  0x54524150);         # "PART" (matches kernel GPT_SIG_HI)
    store32(&hdr + 8,  0x00010000);         # revision 1.0 (bytes 00 00 01 00)
    store32(&hdr + 12, 92);                 # header size
    store32(&hdr + 16, 0);                  # header CRC32 — zero during compute
    store32(&hdr + 20, 0);                  # reserved
    store64(&hdr + 24, 1);                  # MyLBA = 1
    store64(&hdr + 32, n - 1);              # AlternateLBA = last sector
    store64(&hdr + 40, 34);                 # first usable LBA (after the 33-LBA header+array)
    store64(&hdr + 48, n - 34);             # last usable LBA (before the backup array+header)
    store64(&hdr + 56, DISK_GUID_LO);
    store64(&hdr + 64, DISK_GUID_HI);
    store64(&hdr + 72, 2);                  # partition entry array starting LBA
    store32(&hdr + 80, 128);                # number of entries
    store32(&hdr + 84, 128);                # size of each entry
    var arr_crc = crc32(&pea, 16384);       # CRC over the FULL array (incl. zero entries)
    store32(&hdr + 88, arr_crc);
    var hc = crc32(&hdr, 92);               # header CRC over 92 bytes, field @16 zeroed
    store32(&hdr + 16, hc);

    # Backup header = copy of primary with My/Alternate LBAs swapped, array LBA moved to the
    # tail, and the header CRC recomputed (array CRC is unchanged — same array bytes).
    var i = 0;
    while (i < 512) { store64(&bhdr + i, load64(&hdr + i)); i = i + 8; }
    store64(&bhdr + 24, n - 1);             # MyLBA = last sector
    store64(&bhdr + 32, 1);                 # AlternateLBA = primary
    store64(&bhdr + 72, n - 33);            # backup array starts 33 LBAs before the end
    store32(&bhdr + 16, 0);
    var bc = crc32(&bhdr, 92);
    store32(&bhdr + 16, bc);
    return 0;
}

# --- Self-verify the built structures against the kernel's exact reader offsets ------------
fn self_verify(n: i64, esp_s: i64, esp_e: i64, rf_s: i64, rf_e: i64): i64 {
    # Protective MBR.
    if ((load8(&mbr + 450) & 0xFF) != 0xEE) { return 83; }
    if ((load8(&mbr + 510) & 0xFF) != 0x55) { return 83; }
    if ((load8(&mbr + 511) & 0xFF) != 0xAA) { return 83; }
    if (load32(&mbr + 454) != 1)            { return 83; }

    # GPT signature (kernel gpt_validate_signature).
    if (load32(&hdr + 0) != 0x20494645) { return 90; }
    if (load32(&hdr + 4) != 0x54524150) { return 90; }

    # Header field sanity (kernel gpt_decode_header offsets).
    if (load32(&hdr + 12) != 92)        { return 84; }
    if (load64(&hdr + 24) != 1)         { return 84; }
    if (load64(&hdr + 32) != (n - 1))   { return 84; }
    if (load64(&hdr + 40) != 34)        { return 84; }
    if (load64(&hdr + 48) != (n - 34))  { return 84; }
    if (load64(&hdr + 72) != 2)         { return 84; }
    if (load32(&hdr + 80) != 128)       { return 84; }
    if (load32(&hdr + 84) != 128)       { return 84; }

    # Header CRC — recompute exactly like kernel gpt_validate_header_crc.
    var saved = load32(&hdr + 16);
    store32(&hdr + 16, 0);
    var hc = crc32(&hdr, 92);
    store32(&hdr + 16, saved);
    if (hc != saved) { return 89; }

    # Partition array CRC — kernel gpt_validate_array_crc streams 128*128 = 16384 bytes.
    var ac = crc32(&pea, 16384);
    if (ac != load32(&hdr + 88)) { return 88; }

    # ESP entry: both GUID halves (kernel gates on LO AND HI) + LBAs.
    if (load64(&pea + 0)  != GPT_TYPE_ESP_LO) { return 87; }
    if (load64(&pea + 8)  != GPT_TYPE_ESP_HI) { return 87; }
    if (load64(&pea + 32) != esp_s)           { return 87; }
    if (load64(&pea + 40) != esp_e)           { return 87; }

    # Rootfs entry: both GUID halves (ext2_try_partition_mount checks LO AND HI) + LBAs.
    if (load64(&pea + 128) != GPT_TYPE_LINUX_FS_LO) { return 86; }
    if (load64(&pea + 136) != GPT_TYPE_LINUX_FS_HI) { return 86; }
    if (load64(&pea + 160) != rf_s)                 { return 86; }
    if (load64(&pea + 168) != rf_e)                 { return 86; }

    # Backup header: swapped LBAs, tail array LBA, same array CRC, valid own CRC.
    if (load64(&bhdr + 24) != (n - 1))              { return 85; }
    if (load64(&bhdr + 32) != 1)                    { return 85; }
    if (load64(&bhdr + 72) != (n - 33))             { return 85; }
    if (load32(&bhdr + 88) != load32(&hdr + 88))    { return 85; }
    var bsaved = load32(&bhdr + 16);
    store32(&bhdr + 16, 0);
    var bc = crc32(&bhdr, 92);
    store32(&bhdr + 16, bsaved);
    if (bc != bsaved) { return 85; }

    return 0;
}

# --- FAT32 mkfs (Microsoft FAT spec / fatgen) ---------------------------------------------
# FATSz32 via the canonical fatgen "FAT size" formula (RootDirSectors = 0 for FAT32).
fn fat32_fatsz(total: i64, reserved: i64, spc: i64, numfats: i64): i64 {
    var tmpval1 = total - reserved;
    var tmpval2 = (256 * spc + numfats) / 2;    # /2 is the FAT32 case of the fatgen formula
    return (tmpval1 + tmpval2 - 1) / tmpval2;
}

# Build the boot sector (BPB), FSInfo, and a FAT-sector-0 for an empty FAT32 volume of
# `esp_sectors` 512-B sectors (SecPerClus=1, RsvdSecCnt=32, NumFATs=2). Returns FATSz32.
fn build_fat(esp_sectors: i64): i64 {
    var fatsz = fat32_fatsz(esp_sectors, 32, 1, 2);

    # --- Boot sector / BPB (offsets per the FAT spec; the kernel reads these in fatfs.cyr) ---
    zero(&fatbs, 512);
    store8(&fatbs + 0, 0xEB); store8(&fatbs + 1, 0x58); store8(&fatbs + 2, 0x90);   # BS_jmpBoot
    store8(&fatbs + 3, 0x41); store8(&fatbs + 4, 0x47); store8(&fatbs + 5, 0x4E);   # OEM "AGNOS   "
    store8(&fatbs + 6, 0x4F); store8(&fatbs + 7, 0x53); store8(&fatbs + 8, 0x20);
    store8(&fatbs + 9, 0x20); store8(&fatbs + 10, 0x20);
    store16(&fatbs + 11, 512);              # BytesPerSec (kernel requires 512)
    store8(&fatbs + 13, 1);                 # SecPerClus
    store16(&fatbs + 14, 32);               # RsvdSecCnt
    store8(&fatbs + 16, 2);                 # NumFATs
    store16(&fatbs + 17, 0);                # RootEntCnt = 0 (FAT32)
    store16(&fatbs + 19, 0);                # TotSec16 = 0 -> TotSec32
    store8(&fatbs + 21, 0xF8);              # Media (fixed disk)
    store16(&fatbs + 22, 0);                # FATSz16 = 0 (FAT32 signal)
    store16(&fatbs + 24, 32);               # SecPerTrk (cosmetic)
    store16(&fatbs + 26, 8);                # NumHeads (cosmetic)
    store32(&fatbs + 28, 0);                # HiddSec
    store32(&fatbs + 32, esp_sectors);      # TotSec32
    store32(&fatbs + 36, fatsz);            # FATSz32
    store16(&fatbs + 40, 0);                # ExtFlags
    store16(&fatbs + 42, 0);                # FSVer
    store32(&fatbs + 44, 2);                # RootClus
    store16(&fatbs + 48, 1);                # FSInfo sector
    store16(&fatbs + 50, 6);                # BkBootSec
    store8(&fatbs + 64, 0x80);              # DrvNum
    store8(&fatbs + 66, 0x29);              # BootSig (extended)
    store32(&fatbs + 67, 0x41474E53);       # VolID
    store8(&fatbs + 71, 0x41); store8(&fatbs + 72, 0x47); store8(&fatbs + 73, 0x4E);  # VolLab "AGNOSBOOT  "
    store8(&fatbs + 74, 0x4F); store8(&fatbs + 75, 0x53); store8(&fatbs + 76, 0x42);
    store8(&fatbs + 77, 0x4F); store8(&fatbs + 78, 0x4F); store8(&fatbs + 79, 0x54);
    store8(&fatbs + 80, 0x20); store8(&fatbs + 81, 0x20);
    store8(&fatbs + 82, 0x46); store8(&fatbs + 83, 0x41); store8(&fatbs + 84, 0x54);  # FilSysType "FAT32   "
    store8(&fatbs + 85, 0x33); store8(&fatbs + 86, 0x32); store8(&fatbs + 87, 0x20);
    store8(&fatbs + 88, 0x20); store8(&fatbs + 89, 0x20);
    store8(&fatbs + 510, 0x55); store8(&fatbs + 511, 0xAA);

    # CountOfClusters (SecPerClus=1): data region / spc. Clusters are numbered 2..(coc+1);
    # cluster 2 is the root, so free = coc - 1 and the next free cluster is 3.
    var coc = esp_sectors - (32 + 2 * fatsz);

    # --- FSInfo (sector 1) ---
    zero(&fsinfo, 512);
    store32(&fsinfo + 0,   0x41615252);     # FSI_LeadSig  "RRaA"
    store32(&fsinfo + 484, 0x61417272);     # FSI_StrucSig "rrAa"
    store32(&fsinfo + 488, coc - 1);        # FSI_Free_Count (all data clusters minus the root)
    store32(&fsinfo + 492, 3);              # FSI_Nxt_Free (first cluster after the root)
    store32(&fsinfo + 508, 0xAA550000);     # FSI_TrailSig (bytes 00 00 55 AA)

    # --- FAT sector 0: reserved entries + root-cluster (2) end-of-chain ---
    zero(&fatsec, 512);
    store32(&fatsec + 0, 0x0FFFFFF8);       # FAT[0] = media byte 0xF8 in the low byte
    store32(&fatsec + 4, 0x0FFFFFFF);       # FAT[1] = EOC / clean-shutdown flags
    store32(&fatsec + 8, 0x0FFFFFFF);       # FAT[2] = root cluster end-of-chain

    # --- Root cluster sector 0: the volume-label dirent (attr 0x08), name matches the BPB label ---
    zero(&rootbuf, 512);
    store8(&rootbuf + 0, 0x41); store8(&rootbuf + 1, 0x47); store8(&rootbuf + 2, 0x4E);  # "AGNOSBOOT  "
    store8(&rootbuf + 3, 0x4F); store8(&rootbuf + 4, 0x53); store8(&rootbuf + 5, 0x42);
    store8(&rootbuf + 6, 0x4F); store8(&rootbuf + 7, 0x4F); store8(&rootbuf + 8, 0x54);
    store8(&rootbuf + 9, 0x20); store8(&rootbuf + 10, 0x20);
    store8(&rootbuf + 11, 0x08);            # ATTR_VOLUME_ID

    return fatsz;
}

# Build a fresh FAT directory cluster in `buf`: the '.' (self) and '..' (parent; cluster 0 if
# the parent is the root) dirents, rest zero (0x00 first byte = end-of-directory). The split
# FstClusHI@20 / FstClusLO@26 fields are each a store16 (never a store32 over WrtTime@22).
fn build_dir_cluster(buf: i64, self_clus: i64, parent_clus: i64): i64 {
    zero(buf, 512);
    store8(buf + 0, 0x2E);                           # "."
    var i = 1;
    while (i < 11) { store8(buf + i, 0x20); i = i + 1; }
    store8(buf + 11, 0x10);                          # ATTR_DIRECTORY
    store16(buf + 20, (self_clus >> 16) & 0xFFFF);
    store16(buf + 26, self_clus & 0xFFFF);
    store8(buf + 32, 0x2E); store8(buf + 33, 0x2E);  # ".."
    i = 34;
    while (i < 43) { store8(buf + i, 0x20); i = i + 1; }
    store8(buf + 43, 0x10);
    store16(buf + 52, (parent_clus >> 16) & 0xFFFF);
    store16(buf + 58, parent_clus & 0xFFFF);
    return 0;
}

# Publish an 8.3 DIRECTORY dirent into parent buffer `pbuf` at slot `slot` (offset slot*32):
# an 8-char space-padded name (bytes n0..n7), ext = 3 spaces, ATTR_DIRECTORY, first cluster
# (split HI/LO), FileSize 0. Used to link a subdirectory from its parent.
fn put_dir_dirent(pbuf: i64, slot: i64, clus: i64, n0: i64, n1: i64, n2: i64, n3: i64, n4: i64, n5: i64, n6: i64, n7: i64): i64 {
    var o = pbuf + slot * 32;
    store8(o + 0, n0); store8(o + 1, n1); store8(o + 2, n2); store8(o + 3, n3);
    store8(o + 4, n4); store8(o + 5, n5); store8(o + 6, n6); store8(o + 7, n7);
    store8(o + 8, 0x20); store8(o + 9, 0x20); store8(o + 10, 0x20);   # ext = spaces
    store8(o + 11, 0x10);                            # ATTR_DIRECTORY
    store16(o + 20, (clus >> 16) & 0xFFFF);          # FstClusHI (split field)
    store16(o + 26, clus & 0xFFFF);                  # FstClusLO
    store32(o + 28, 0);                              # FileSize = 0 for a directory
    return 0;
}

# Read up to `want` bytes into buf from fd, looping over short reads. Returns bytes actually
# read (< want only at EOF). vfs_read can legally return a short count mid-file, so loop.
fn read_fill(fd: i64, buf: i64, want: i64): i64 {
    var got = 0;
    while (got < want) {
        var n = sys_read(fd, buf + got, want - got);
        if (n <= 0) { return got; }             # EOF or error
        got = got + n;
    }
    return got;
}

# Publish an 8.3 dirent (11-byte name at name_ptr) into pbuf at slot: attr, first cluster
# (split HI@20/LO@26), FileSize@28. Used for files (attr 0x20).
fn put_dirent(pbuf: i64, slot: i64, name_ptr: i64, attr: i64, clus: i64, size: i64): i64 {
    var o = pbuf + slot * 32;
    var i = 0;
    while (i < 11) { store8(o + i, load8(name_ptr + i) & 0xFF); i = i + 1; }
    store8(o + 11, attr);
    store16(o + 20, (clus >> 16) & 0xFFFF);
    store16(o + 26, clus & 0xFFFF);
    store32(o + 28, size);
    return 0;
}

# Write a contiguous FAT32 cluster chain [first..last] to BOTH FATs, sector by sector: read each
# touched FAT sector (to preserve entries outside the run), set this run's entries (c -> c+1, the
# final cluster -> EOC), write it back. Handles chains that span multiple FAT sectors. Uses the
# fatsec buffer as RMW scratch. Returns 0 / -1.
fn fat_write_chain(hrw: i64, esp_abs: i64, fatsz: i64, first: i64, last: i64): i64 {
    var s = (first * 4) / 512;              # first FAT sector the chain touches
    var slast = (last * 4) / 512;
    while (s <= slast) {
        if (sys_blk_read(hrw, esp_abs + 32 + s, &fatsec, 1) != 1) { return 0 - 1; }
        var c = s * 128;                    # first cluster mapped by FAT sector s
        if (c < first) { c = first; }
        var cend = s * 128 + 127;           # last cluster mapped by FAT sector s
        if (cend > last) { cend = last; }
        while (c <= cend) {
            var val = c + 1;
            if (c == last) { val = 0x0FFFFFFF; }        # end-of-chain on the final cluster
            store32(&fatsec + (c * 4 - s * 512), val);  # byte offset within this FAT sector
            c = c + 1;
        }
        if (sys_blk_write(hrw, esp_abs + 32 + s, &fatsec, 1) != 1)         { return 0 - 1; }
        if (sys_blk_write(hrw, esp_abs + 32 + fatsz + s, &fatsec, 1) != 1) { return 0 - 1; }
        s = s + 1;
    }
    return 0;
}

fn gptwr_main(): i64 {
    # --- Bite 1 regression: CRC32 canonical vectors (cheap; guards the whole format) ---
    var s[9];
    store8(&s + 0, 0x31); store8(&s + 1, 0x32); store8(&s + 2, 0x33);
    store8(&s + 3, 0x34); store8(&s + 4, 0x35); store8(&s + 5, 0x36);
    store8(&s + 6, 0x37); store8(&s + 7, 0x38); store8(&s + 8, 0x39);
    if (crc32(&s, 9) != 0xCBF43926) { return 91; }
    if (crc32(&s, 0) != 0x00000000) { return 92; }
    var a[1]; store8(&a, 0x61);
    if (crc32(&a, 1) != 0xE8B7BE43) { return 93; }

    # --- Bite 2: build + self-verify a full GPT for a synthetic 128 MiB disk ---
    # N' = 131072 sectors (64 MiB @ 512 B) — small enough that the whole nested image fits in
    # the live disk's unallocated tail. ESP = 34 MiB (spec-honest FAT32 minimum); the rootfs
    # fills the rest to the last usable LBA. Geometry chosen so ESP_end < LastUsable.
    var N   = 131072;
    var ESP_S = 2048;                       # 1 MiB alignment
    var ESP_E = 2048 + 69632 - 1;           # 34 MiB = 69632 sectors -> end LBA 71679
    var RF_S  = 71680;
    var RF_E  = N - 34;                      # rootfs fills to last usable LBA (131038)

    build_mbr(N);
    build_gpt(N, ESP_S, ESP_E, RF_S, RF_E);
    var v = self_verify(N, ESP_S, ESP_E, RF_S, RF_E);
    if (v != 0) { return v; }

    # --- Bite 3a: first real disk write — arm the gate + write/readback the MBR ---
    # Write the nested image at SCRATCH_BASE in the live disk's UNALLOCATED TAIL: absolute
    # sector = SCRATCH_BASE + (synthetic LBA). Base = 524288 (256 MiB) is past the live 240 MiB
    # rootfs, so nothing here touches the boot table the kernel/gnoboot just used.
    var SCRATCH = 524288;
    var ebuf[192];
    if (sys_blk_enum(&ebuf, 192) < 1) { return 79; }   # no block device enumerated
    var tag = load64(&ebuf);                # entry 0 tag (the single active NVMe)
    var hro = sys_blk_open(tag, 0);         # RO handle for the capacity query
    if (hro < 0) { return 79; }
    var dinfo[16];
    sys_blk_info(hro, &dinfo);
    var cap = load64(&dinfo);               # capacity in LBAs (offset 0)
    if ((SCRATCH + N) > cap) { return 78; } # the whole synthetic image must fit the tail

    sys_blk_open(0, 0x424C4B5F5257);        # arm the write gate (BLK_RW_ARM_MAGIC)
    var hrw = sys_blk_open(tag, 1);         # RW handle (armed)
    if (hrw < 0) { return 77; }
    if (sys_blk_write(hrw, SCRATCH + 0, &mbr, 1) != 1) { return 76; }   # write MBR at base+0
    var rsec[512];
    if (sys_blk_read(hrw, SCRATCH + 0, &rsec, 1) != 1) { return 75; }   # read it back
    var ci = 0;
    while (ci < 64) {                       # byte-compare (64 x u64 = 512 B)
        if (load64(&rsec + ci * 8) != load64(&mbr + ci * 8)) { return 74; }
        ci = ci + 1;
    }

    # --- Bite 3b: write the rest of the GPT (header + array + backup), readback-verify all ---
    if (sys_blk_write(hrw, SCRATCH + 1, &hdr, 1) != 1)           { return 73; }  # primary header @ base+1
    if (sys_blk_write(hrw, SCRATCH + 2, &pea, 32) != 32)        { return 72; }  # entry array @ base+2..33
    if (sys_blk_write(hrw, SCRATCH + (N - 33), &pea, 32) != 32) { return 71; }  # backup array @ base+N-33
    if (sys_blk_write(hrw, SCRATCH + (N - 1), &bhdr, 1) != 1)   { return 70; }  # backup header @ base+N-1

    # readback-verify each region against the RAM source (durability + write correctness).
    if (sys_blk_read(hrw, SCRATCH + 1, &rsec, 1) != 1) { return 69; }
    var vi = 0;
    while (vi < 64)   { if (load64(&rsec  + vi*8) != load64(&hdr  + vi*8)) { return 69; } vi = vi + 1; }
    if (sys_blk_read(hrw, SCRATCH + 2, &rback, 32) != 32) { return 69; }
    vi = 0;
    while (vi < 2048) { if (load64(&rback + vi*8) != load64(&pea  + vi*8)) { return 69; } vi = vi + 1; }
    if (sys_blk_read(hrw, SCRATCH + (N - 33), &rback, 32) != 32) { return 69; }
    vi = 0;
    while (vi < 2048) { if (load64(&rback + vi*8) != load64(&pea  + vi*8)) { return 69; } vi = vi + 1; }
    if (sys_blk_read(hrw, SCRATCH + (N - 1), &rsec, 1) != 1) { return 69; }
    vi = 0;
    while (vi < 64)   { if (load64(&rsec  + vi*8) != load64(&bhdr + vi*8)) { return 69; } vi = vi + 1; }

    # --- Bite 6: FAT32 mkfs into the ESP region (partition = SCRATCH + ESP_S, sectors ESP_S..ESP_E) ---
    var ESP_ABS = SCRATCH + ESP_S;          # absolute base LBA of the ESP partition
    var ESP_SECTORS = ESP_E - ESP_S + 1;    # ESP length (69632 sectors = 34 MiB)
    var fatsz = build_fat(ESP_SECTORS);

    # geometry (must match the kernel's fatfs parse) + FAT-type guard
    var root_start = 32 + 2 * fatsz;        # reserved + both FATs; data_start == root_start (FAT32)
    var coc = (ESP_SECTORS - root_start) / 1;   # CountOfClusters (SecPerClus = 1)
    if (coc < 65525) { return 68; }         # would parse as FAT16 — geometry bug

    # zero the metadata region [0 .. root_start] (reserved + both FATs + root cluster) so the FS
    # is clean on ANY disk (idempotent on the pre-zeroed smoke disk), in 32-sector chunks.
    zero(&z32, 16384);
    var zs = 0;
    while (zs <= root_start) {
        var zn = root_start - zs + 1;
        if (zn > 32) { zn = 32; }
        if (sys_blk_write(hrw, ESP_ABS + zs, &z32, zn) != zn) { return 64; }
        zs = zs + zn;
    }

    # lay down boot sector (+ backup @6), FSInfo (+ backup @7), and both FATs' sector 0.
    if (sys_blk_write(hrw, ESP_ABS + 0, &fatbs, 1) != 1)          { return 67; }
    if (sys_blk_write(hrw, ESP_ABS + 6, &fatbs, 1) != 1)          { return 67; }   # backup boot
    if (sys_blk_write(hrw, ESP_ABS + 1, &fsinfo, 1) != 1)         { return 66; }
    if (sys_blk_write(hrw, ESP_ABS + 7, &fsinfo, 1) != 1)         { return 66; }   # backup FSInfo
    if (sys_blk_write(hrw, ESP_ABS + 32, &fatsec, 1) != 1)         { return 65; }   # FAT #0 sector 0
    if (sys_blk_write(hrw, ESP_ABS + 32 + fatsz, &fatsec, 1) != 1) { return 65; }   # FAT #1 sector 0
    if (sys_blk_write(hrw, ESP_ABS + root_start, &rootbuf, 1) != 1) { return 65; }  # root cluster (vol label)

    # readback-verify the boot sector + FAT sector 0 + the root cluster's volume-label dirent.
    if (sys_blk_read(hrw, ESP_ABS + 0, &rsec, 1) != 1) { return 63; }
    if ((load8(&rsec + 510) & 0xFF) != 0x55) { return 63; }
    if ((load8(&rsec + 511) & 0xFF) != 0xAA) { return 63; }
    var fi = 0;
    while (fi < 64) { if (load64(&rsec + fi*8) != load64(&fatbs + fi*8)) { return 63; } fi = fi + 1; }
    if (sys_blk_read(hrw, ESP_ABS + 32, &rsec, 1) != 1) { return 62; }
    if (load32(&rsec + 0) != 0x0FFFFFF8) { return 62; }
    if (load32(&rsec + 4) != 0x0FFFFFFF) { return 62; }
    if (load32(&rsec + 8) != 0x0FFFFFFF) { return 62; }
    if (sys_blk_read(hrw, ESP_ABS + root_start, &rsec, 1) != 1) { return 62; }
    if ((load8(&rsec + 11) & 0xFF) != 0x08) { return 62; }     # root dirent attr = ATTR_VOLUME_ID

    # BPB self-checks (mirror the kernel's fatfs parse expectations).
    if (load16(&fatbs + 11) != 512)         { return 61; }
    if (load32(&fatbs + 32) != ESP_SECTORS) { return 61; }
    if (load32(&fatbs + 44) != 2)           { return 61; }   # RootClus
    if (load16(&fatbs + 22) != 0)           { return 61; }   # FATSz16 must be 0 for FAT32

    # --- Bite 7: create the \EFI subdirectory (cluster 3) ---
    # Cluster N's data sector = data_start + (N-2)*SecPerClus; data_start = root_start (FAT32),
    # SecPerClus = 1. Root = cluster 2 @ root_start; \EFI = cluster 3 @ root_start+1.
    var EFI_CLUS = 3;
    var efi_sec = root_start + (EFI_CLUS - 2);

    # Build the \EFI directory cluster: '.' (self) and '..' (parent = root -> cluster 0).
    zero(&efidir, 512);
    store8(&efidir + 0, 0x2E);                       # "."
    var di = 1;
    while (di < 11) { store8(&efidir + di, 0x20); di = di + 1; }
    store8(&efidir + 11, 0x10);                      # ATTR_DIRECTORY
    store16(&efidir + 20, (EFI_CLUS >> 16) & 0xFFFF);   # FstClusHI  (split field:
    store16(&efidir + 26, EFI_CLUS & 0xFFFF);           # FstClusLO   two store16, NOT a store32)
    store8(&efidir + 32, 0x2E); store8(&efidir + 33, 0x2E);   # ".."
    di = 34;
    while (di < 43) { store8(&efidir + di, 0x20); di = di + 1; }
    store8(&efidir + 43, 0x10);                      # ATTR_DIRECTORY (32+11)
    store16(&efidir + 52, 0);                        # FstClusHI (32+20) = 0
    store16(&efidir + 58, 0);                        # FstClusLO (32+26) = 0 (parent is root)

    # Allocate cluster 3 in the FAT (EOC), publish the \EFI dirent in root slot 1 (offset 32).
    store32(&fatsec + 12, 0x0FFFFFFF);               # FAT[3] EOC (cluster 3 * 4 bytes = offset 12)
    store8(&rootbuf + 32, 0x45); store8(&rootbuf + 33, 0x46); store8(&rootbuf + 34, 0x49);  # "EFI"
    var ri = 35;
    while (ri < 43) { store8(&rootbuf + ri, 0x20); ri = ri + 1; }
    store8(&rootbuf + 43, 0x10);                     # ATTR_DIRECTORY (32+11)
    store16(&rootbuf + 52, (EFI_CLUS >> 16) & 0xFFFF);  # FstClusHI (32+20) — split field, two store16
    store16(&rootbuf + 58, EFI_CLUS & 0xFFFF);          # FstClusLO (32+26)

    # Update FSInfo free-count (clusters 2 + 3 now used).
    store32(&fsinfo + 488, coc - 2);
    store32(&fsinfo + 492, 4);

    # Crash-safe write order: data cluster -> FAT -> parent dirent -> FSInfo (a crash leaks a
    # cluster, never dangles a dirent).
    if (sys_blk_write(hrw, ESP_ABS + efi_sec, &efidir, 1) != 1)    { return 60; }
    if (sys_blk_write(hrw, ESP_ABS + 32, &fatsec, 1) != 1)         { return 59; }
    if (sys_blk_write(hrw, ESP_ABS + 32 + fatsz, &fatsec, 1) != 1) { return 59; }
    if (sys_blk_write(hrw, ESP_ABS + root_start, &rootbuf, 1) != 1) { return 58; }
    if (sys_blk_write(hrw, ESP_ABS + 1, &fsinfo, 1) != 1)          { return 57; }
    if (sys_blk_write(hrw, ESP_ABS + 7, &fsinfo, 1) != 1)          { return 57; }

    # readback-verify the \EFI cluster, FAT[3], and the root \EFI dirent.
    if (sys_blk_read(hrw, ESP_ABS + efi_sec, &rsec, 1) != 1) { return 56; }
    if ((load8(&rsec + 0)  & 0xFF) != 0x2E) { return 56; }   # '.'
    if ((load8(&rsec + 11) & 0xFF) != 0x10) { return 56; }   # '.' is a directory
    if (load16(&rsec + 26) != EFI_CLUS)     { return 56; }   # '.' -> cluster 3
    if ((load8(&rsec + 32) & 0xFF) != 0x2E) { return 56; }   # '..'
    if ((load8(&rsec + 33) & 0xFF) != 0x2E) { return 56; }
    if (load16(&rsec + 58) != 0)            { return 56; }   # '..' -> cluster 0 (root)
    if (sys_blk_read(hrw, ESP_ABS + 32, &rsec, 1) != 1) { return 56; }
    if (load32(&rsec + 12) != 0x0FFFFFFF)   { return 56; }   # FAT[3] EOC on disk
    if (sys_blk_read(hrw, ESP_ABS + root_start, &rsec, 1) != 1) { return 55; }
    if ((load8(&rsec + 32) & 0xFF) != 0x45) { return 55; }   # root dirent 'E'
    if ((load8(&rsec + 43) & 0xFF) != 0x10) { return 55; }   # is a directory
    if (load16(&rsec + 58) != EFI_CLUS)     { return 55; }   # -> cluster 3

    # --- Bite 8a: create \EFI\BOOT (cluster 4) and \boot (cluster 5) directories ---
    var EFIBOOT_CLUS = 4;
    var BOOT_CLUS = 5;
    var efiboot_sec = root_start + (EFIBOOT_CLUS - 2);   # cluster 4 data sector
    var boot_sec    = root_start + (BOOT_CLUS - 2);      # cluster 5 data sector

    build_dir_cluster(&efibootdir, EFIBOOT_CLUS, EFI_CLUS);            # \EFI\BOOT: parent = \EFI (3)
    if (sys_blk_write(hrw, ESP_ABS + efiboot_sec, &efibootdir, 1) != 1) { return 54; }
    build_dir_cluster(&bootdir, BOOT_CLUS, 0);                         # \boot: parent = root (0)
    if (sys_blk_write(hrw, ESP_ABS + boot_sec, &bootdir, 1) != 1)      { return 54; }

    store32(&fatsec + 16, 0x0FFFFFFF);   # FAT[4] EOC (4*4=16)
    store32(&fatsec + 20, 0x0FFFFFFF);   # FAT[5] EOC (5*4=20)
    if (sys_blk_write(hrw, ESP_ABS + 32, &fatsec, 1) != 1)          { return 53; }
    if (sys_blk_write(hrw, ESP_ABS + 32 + fatsz, &fatsec, 1) != 1)  { return 53; }

    put_dir_dirent(&efidir,  2, EFIBOOT_CLUS, 0x42, 0x4F, 0x4F, 0x54, 0x20, 0x20, 0x20, 0x20);  # "BOOT" under \EFI
    put_dir_dirent(&rootbuf, 2, BOOT_CLUS,    0x42, 0x4F, 0x4F, 0x54, 0x20, 0x20, 0x20, 0x20);  # "BOOT" under root
    if (sys_blk_write(hrw, ESP_ABS + root_start + 1, &efidir, 1) != 1) { return 52; }  # \EFI cluster
    if (sys_blk_write(hrw, ESP_ABS + root_start, &rootbuf, 1) != 1)    { return 52; }  # root cluster

    store32(&fsinfo + 488, coc - 4);     # clusters 2,3,4,5 used
    store32(&fsinfo + 492, 6);
    if (sys_blk_write(hrw, ESP_ABS + 1, &fsinfo, 1) != 1) { return 51; }
    if (sys_blk_write(hrw, ESP_ABS + 7, &fsinfo, 1) != 1) { return 51; }

    if (sys_blk_read(hrw, ESP_ABS + efiboot_sec, &rsec, 1) != 1) { return 50; }
    if ((load8(&rsec + 0) & 0xFF) != 0x2E) { return 50; }            # '.' present
    if (load16(&rsec + 58) != EFI_CLUS)    { return 50; }            # '..' -> \EFI (3)
    if (sys_blk_read(hrw, ESP_ABS + boot_sec, &rsec, 1) != 1) { return 50; }
    if (load16(&rsec + 58) != 0)           { return 50; }            # '..' -> root (0)
    if (sys_blk_read(hrw, ESP_ABS + root_start + 1, &rsec, 1) != 1) { return 50; }
    if ((load8(&rsec + 64) & 0xFF) != 0x42)      { return 50; }      # \EFI slot 2 = 'B' (BOOT)
    if (load16(&rsec + 64 + 26) != EFIBOOT_CLUS) { return 50; }      # -> cluster 4
    if (sys_blk_read(hrw, ESP_ABS + root_start, &rsec, 1) != 1) { return 50; }
    if ((load8(&rsec + 64) & 0xFF) != 0x42)      { return 50; }      # root slot 2 = 'B' (boot)
    if (load16(&rsec + 64 + 26) != BOOT_CLUS)    { return 50; }      # -> cluster 5

    # --- Bite 8b: write \EFI\BOOT\BOOTX64.EFI (gnoboot) from the rootfs into the FAT ---
    # Read the blob from a FIXED ROOTFS PATH (never argv). gnoboot is ~30 KB (~59 clusters),
    # whose FAT chain fits FAT sector 0 alone — so this proves the whole file-write mechanism
    # (open -> lseek-size -> allocate -> stream -> dirent) without multi-sector-FAT handling.
    var nfree = 6;                          # first free cluster (2,3,4,5 = the skeleton)
    var fd = sys_open("/stage/bootx64.efi", 18, 0);
    if (fd < 0) { return 49; }
    var bsize = sys_lseek(fd, 0, 2);        # SEEK_END -> file size
    if (bsize <= 0) { return 48; }
    sys_lseek(fd, 0, 0);                     # rewind to SEEK_SET 0
    var bclus = (bsize + 511) / 512;
    var bfirst = nfree;
    if ((bfirst + bclus) > 128) { return 48; }   # 8b invariant: chain must fit FAT sector 0

    # Stream the body into clusters bfirst..bfirst+bclus-1 (data BEFORE FAT/dirent = crash-safe).
    var wi = 0;
    var total = 0;
    while (wi < bclus) {
        zero(&filebuf, 512);
        total = total + read_fill(fd, &filebuf, 512);   # last cluster partial; rest stays zero
        if (sys_blk_write(hrw, ESP_ABS + root_start + (bfirst + wi - 2), &filebuf, 1) != 1) { return 45; }
        wi = wi + 1;
    }
    sys_close(fd);
    if (total != bsize) { return 44; }       # short read mid-file (should not happen)

    # FAT chain: bfirst..last-1 -> next, last -> EOC (all within FAT sector 0 for gnoboot).
    var fc = bfirst;
    while (fc < bfirst + bclus - 1) { store32(&fatsec + fc * 4, fc + 1); fc = fc + 1; }
    store32(&fatsec + (bfirst + bclus - 1) * 4, 0x0FFFFFFF);
    if (sys_blk_write(hrw, ESP_ABS + 32, &fatsec, 1) != 1)         { return 47; }
    if (sys_blk_write(hrw, ESP_ABS + 32 + fatsz, &fatsec, 1) != 1) { return 47; }

    # Publish the BOOTX64.EFI 8.3 dirent in \EFI\BOOT (slot 2), re-write the directory cluster.
    store8(&nm + 0, 0x42); store8(&nm + 1, 0x4F); store8(&nm + 2, 0x4F); store8(&nm + 3, 0x54);  # "BOOTX64 EFI"
    store8(&nm + 4, 0x58); store8(&nm + 5, 0x36); store8(&nm + 6, 0x34); store8(&nm + 7, 0x20);
    store8(&nm + 8, 0x45); store8(&nm + 9, 0x46); store8(&nm + 10, 0x49);
    put_dirent(&efibootdir, 2, &nm, 0x20, bfirst, bsize);
    if (sys_blk_write(hrw, ESP_ABS + efiboot_sec, &efibootdir, 1) != 1) { return 46; }

    nfree = bfirst + bclus;
    store32(&fsinfo + 488, coc - (nfree - 2));
    store32(&fsinfo + 492, nfree);
    if (sys_blk_write(hrw, ESP_ABS + 1, &fsinfo, 1) != 1) { return 41; }
    if (sys_blk_write(hrw, ESP_ABS + 7, &fsinfo, 1) != 1) { return 41; }

    # readback: the dirent fields + FAT chain endpoints.
    if (sys_blk_read(hrw, ESP_ABS + efiboot_sec, &rsec, 1) != 1) { return 43; }
    if ((load8(&rsec + 64) & 0xFF) != 0x42)      { return 43; }     # 'B' (BOOTX64)
    if ((load8(&rsec + 64 + 11) & 0xFF) != 0x20) { return 43; }     # attr = ARCHIVE (a file)
    if (load16(&rsec + 64 + 26) != bfirst)       { return 43; }     # first cluster
    if (load32(&rsec + 64 + 28) != bsize)        { return 43; }     # file size
    if (sys_blk_read(hrw, ESP_ABS + 32, &rsec, 1) != 1) { return 42; }
    if (load32(&rsec + bfirst * 4) != (bfirst + 1))            { return 42; }  # chain head links on
    if (load32(&rsec + (bfirst + bclus - 1) * 4) != 0x0FFFFFFF) { return 42; }  # chain tail is EOC

    # --- Bite 8c: write \boot\agnos (the ~1.4 MB kernel) from the rootfs into the FAT ---
    # Same mechanism as 8b, but the chain spans ~22 FAT sectors (fat_write_chain) and the body is
    # streamed 32 clusters (16 KB) per write so we don't flush thousands of single sectors.
    var kfd = sys_open("/stage/kernel", 13, 0);
    if (kfd < 0) { return 39; }
    var ksize = sys_lseek(kfd, 0, 2);        # SEEK_END -> size
    if (ksize <= 0) { return 38; }
    sys_lseek(kfd, 0, 0);
    var kclus = (ksize + 511) / 512;
    var kfirst = nfree;                      # continues after BOOTX64.EFI
    if ((kfirst + kclus) > (coc + 2)) { return 38; }   # last valid cluster is coc+1

    # Stream the kernel body in 32-cluster (16 KB) batches into the contiguous run.
    var kwi = 0;
    var ktotal = 0;
    while (kwi < kclus) {
        var chunk = kclus - kwi;
        if (chunk > 32) { chunk = 32; }
        zero(&rback, 16384);
        ktotal = ktotal + read_fill(kfd, &rback, chunk * 512);   # last batch partial; rest zero
        if (sys_blk_write(hrw, ESP_ABS + root_start + (kfirst + kwi - 2), &rback, chunk) != chunk) { return 35; }
        kwi = kwi + chunk;
    }
    sys_close(kfd);
    if (ktotal != ksize) { return 34; }

    # FAT chain across all touched FAT sectors, then publish the AGNOS dirent in \boot.
    if (fat_write_chain(hrw, ESP_ABS, fatsz, kfirst, kfirst + kclus - 1) != 0) { return 37; }
    store8(&nm + 0, 0x41); store8(&nm + 1, 0x47); store8(&nm + 2, 0x4E); store8(&nm + 3, 0x4F);  # "AGNOS      "
    store8(&nm + 4, 0x53); store8(&nm + 5, 0x20); store8(&nm + 6, 0x20); store8(&nm + 7, 0x20);
    store8(&nm + 8, 0x20); store8(&nm + 9, 0x20); store8(&nm + 10, 0x20);
    put_dirent(&bootdir, 2, &nm, 0x20, kfirst, ksize);
    if (sys_blk_write(hrw, ESP_ABS + boot_sec, &bootdir, 1) != 1) { return 36; }

    nfree = kfirst + kclus;
    store32(&fsinfo + 488, coc - (nfree - 2));
    store32(&fsinfo + 492, nfree);
    if (sys_blk_write(hrw, ESP_ABS + 1, &fsinfo, 1) != 1) { return 31; }
    if (sys_blk_write(hrw, ESP_ABS + 7, &fsinfo, 1) != 1) { return 31; }

    # readback: the AGNOS dirent + the chain tail EOC in its FAT sector.
    if (sys_blk_read(hrw, ESP_ABS + boot_sec, &rsec, 1) != 1) { return 33; }
    if ((load8(&rsec + 64) & 0xFF) != 0x41) { return 33; }        # 'A' (AGNOS)
    if (load16(&rsec + 64 + 26) != kfirst)  { return 33; }        # first cluster
    if (load32(&rsec + 64 + 28) != ksize)   { return 33; }        # file size
    var klast = kfirst + kclus - 1;
    var ksec = (klast * 4) / 512;
    if (sys_blk_read(hrw, ESP_ABS + 32 + ksec, &rsec, 1) != 1) { return 32; }
    if (load32(&rsec + (klast * 4 - ksec * 512)) != 0x0FFFFFFF) { return 32; }   # chain tail EOC

    sys_blk_close(hrw);

    return 97;    # GPT + FAT32 ESP + directory tree + BOOTX64.EFI + the kernel written; all readback-verified
}

# No-argv bite -> the var-r-main form is safe here (matches blkprobe/blkwr; later bites that
# read a blob open a FIXED ROOTFS PATH, never argv, sidestepping the gvar-init argv trap).
# SYS_EXIT (NOT literal 60): agnos exit=0, Linux exit=60 — the wrapper is correct on both.
fn _entry(): i64 { var r = gptwr_main(); syscall(SYS_EXIT, r); return 0; }
_entry();
