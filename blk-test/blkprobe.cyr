# blkprobe — agnos ring-3 raw block-device read-path exerciser (1.53.10 Phase 1).
#
# Proves the #75-80 READ-PATH end to end FROM RING 3, against the real GPT disk QEMU
# presents: blk_enum finds the active disk, blk_open returns a RO handle, blk_read pulls
# LBA 1 (the GPT header), and its first 8 bytes are the "EFI PART" GPT signature.
# Exits 95 iff the whole chain works; 90-94 pinpoint where it broke.
#
# Uses the native cyrius `sys_blk_*` wrappers (added v6.4.39) — no raw syscall numbers.

fn blkprobe_main(): i64 {
    var ebuf[192];                        # up to 8 entries * 24 B (function-local = 192 bytes)
    var n = sys_blk_enum(&ebuf, 192);
    if (n < 0) { return 90; }             # enum syscall error
    if (n < 1) { return 91; }             # no block device registered
    var tag = load64(&ebuf);              # entry 0's tag (offset 0)

    var h = sys_blk_open(tag, 0);         # RO
    if (h < 0) { return 92; }

    var ibuf[16];                         # {capacity_lbas, lba_bytes} — best-effort, not gating
    sys_blk_info(h, &ibuf);

    var sec[512];                         # one 512-B LBA (QEMU NVMe default sector size)
    var r = sys_blk_read(h, 1, &sec, 1);  # LBA 1 -> the GPT header
    if (r != 1) { return 93; }

    # GPT header signature at LBA 1, bytes 0..7 = "EFI PART" (45 46 49 20 50 41 52 54).
    var ok = 1;
    if ((load8(&sec + 0) & 0xFF) != 0x45) { ok = 0; }   # E
    if ((load8(&sec + 1) & 0xFF) != 0x46) { ok = 0; }   # F
    if ((load8(&sec + 2) & 0xFF) != 0x49) { ok = 0; }   # I
    if ((load8(&sec + 3) & 0xFF) != 0x20) { ok = 0; }   # (space)
    if ((load8(&sec + 4) & 0xFF) != 0x50) { ok = 0; }   # P
    if ((load8(&sec + 5) & 0xFF) != 0x41) { ok = 0; }   # A
    if ((load8(&sec + 6) & 0xFF) != 0x52) { ok = 0; }   # R
    if ((load8(&sec + 7) & 0xFF) != 0x54) { ok = 0; }   # T

    sys_blk_close(h);
    if (ok == 0) { return 94; }           # read succeeded but LBA 1 isn't a GPT header
    return 95;                            # ALL PASS — ring-3 read-path works on a real GPT disk
}

fn _entry(): i64 { var r = blkprobe_main(); syscall(SYS_EXIT, r); return 0; }
_entry();
