[package]
name = "blkprobe"
version = "0.1.0"
description = "agnos ring-3 raw block-device read-path exerciser (1.53.10 Phase 1) — blk_enum#75 / blk_open#76 (RO) / blk_read#77 LBA 1 + GPT 'EFI PART' check; exits 95 iff the read-path works end to end."
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.4.2"

[build]
src = "blkprobe.cyr"
output = "build/blkprobe"

# syscalls -> SYS_EXIT + the syscall() binding. blkprobe calls the raw block syscall
# NUMBERS (75-80) directly — the sys_blk_* wrappers don't exist yet (cyrius issue) —
# so nothing else is needed; the result IS the exit code, checked via "run: exit N".
[deps]
stdlib = ["syscalls"]
