# gpufill — agnos ring-3 CP-DMA FILL proof (P9 / #13).
#
# Proves syscall #85 gpu_fill(color) end to end FROM RING 3: the kernel GPU-clears the blit back
# buffer with a PM4 DMA_DATA constant-fill on the compute ring (no CPU store-loop), then present#84
# flips it to the scanout. Cycles red -> green -> blue, giving TWO independent oracles:
#   * VISUAL  — the screen really changes colour, so the scanout is showing GPU-filled pixels.
#   * EXIT CODE — klug-capturable (`run: exit 95`), the same idiom blkprobe uses.
#
# Exit codes: 95 = ALL PASS (three fills filled + presented)
#             90 / 91  = RED   cycle: fill REJECTED (#85 -> -1) / present returned 0
#             100 / 101 = GREEN cycle: same two failures
#             110 / 111 = BLUE  cycle: same two failures
# (so the code says WHICH cycle broke, not just that one did)
#
# ⚠ v2 (iron run #1 stuck on RED): v1's hold was a bare `while (t - t0 < ms) { t = sys_uptime_ms(); }` —
# an UNBOUNDED spin, and the only unbounded loop anywhere in this path (every kernel-side wait is
# watchdog-bounded). If the ms clock ever fails to advance under a tight syscall loop, that spins forever
# and the screen stays stuck on the presented frame. gpufill_hold is now bounded TWICE (deadline AND a hard
# spin cap) and yields each pass so it cannot starve the timer/scheduler.
#
# Raw syscall numbers for #84/#85: their canonical ring-3 wrappers live in the CYRIUS stdlib, which is
# hands-off here (filed as an ask: 2026-07-21-gpu-present-fill-syscall-cyrius-wrappers.md), so this calls the
# syscall intrinsic directly — identical ABI (rax=num, rdi=a1). sys_uptime_ms (#40) comes from the stdlib.

# Hold the presented frame on screen. BOUNDED TWICE OVER — a millisecond deadline AND a hard spin cap — so a
# stalled or coarse clock can never wedge the program. Yields each pass instead of hot-spinning.
fn gpufill_hold(ms): i64 {
    var t0 = sys_uptime_ms();
    var t = t0;
    var spins = 0;
    while (t - t0 < ms) {
        if (spins >= 4000000) { return 0; }        # hard cap — guarantees termination
        syscall(44);                                # sched_yield — don't starve the timer/scheduler
        t = sys_uptime_ms();
        spins = spins + 1;
    }
    return 0;
}

# One cycle: GPU-clear the back buffer to `color` via CP-DMA, flip it to the scanout, hold it.
fn gpufill_show(color, ms): i64 {
    if (syscall(85, color) != 0) { return 90; }    # gpu_fill(color) -> 0 ok / -1
    if (syscall(84) != 1) { return 91; }           # present() -> 1 presented / 0 nothing
    gpufill_hold(ms);
    return 0;
}

fn gpufill_main(): i64 {
    var e = gpufill_show(0x00FF0000, 1000);        # red   (xRGB8888)
    if (e != 0) { return e; }                      # 90 / 91
    e = gpufill_show(0x0000FF00, 1000);            # green
    if (e != 0) { return e + 10; }                 # 100 / 101
    e = gpufill_show(0x000000FF, 1000);            # blue
    if (e != 0) { return e + 20; }                 # 110 / 111
    return 95;                                     # ALL PASS — ring-3 CP-DMA fill works end to end
}

fn _entry(): i64 { var r = gpufill_main(); syscall(SYS_EXIT, r); return 0; }
_entry();
