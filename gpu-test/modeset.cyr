# modeset — agnos ring-3 /bin/modeset. H3 of the modeset arc: the userland entry to the modeset seam.
#
# `run /bin/modeset --caps` (or bare) calls #93 gpu_modeset_op with a CAPS op and prints the modeset surface
# it discovered, then exits with a code that names the outcome — the klug-capturable oracle the gpu-test
# tools use (`run: exit NN`):
#
#   95 = caps read, display LIT and the modeset seam is live
#   96 = caps read, seam live, but NO lit display here (QEMU, or a dark port) — informational, not a failure
#   97 = #93 returned an ABI / validation error (decoded + printed: idx + reason)
#   98 = the LATCH is BLOCKED this boot — a previous modeset did not disarm (H2). Recover: rm /.modeset-armed
#   99 = the syscall returned an unexpected value
#
# The ACTUAL modeset (M-lane: dump / measure / OTG re-commit / transmitter) is iron work behind the arm-once
# latch, added as new op codes to this same #93 with NO new syscall number (decision D-3 / MD-4). H3 proves
# the seam: the tool reaches the kernel, the kernel validates a descriptor array and writes caps back, and
# the exit code is decisive under QEMU with no GPU.
#
# Uses the NAMED wrapper sys_gpu_modeset_op (cyrius >= 6.4.74, filed as
# 2026-07-23-gpu-modeset-op-93-cyrius-wrapper.md). It lives behind a FILE-LEVEL #ifdef CYRIUS_TARGET_AGNOS
# gate, so off-agnos it does not exist and a build referencing it fails at COMPILE time with no binary —
# which matters because on Linux x86_64 #93 is fchown.

# ── op codes + caps layout (mirror kernel syscall.cyr) ──
# record (64 B): +0 op · +4 flags(=0) · +8 out_uva(u64) · +16 out_len(u64) · +24..63 reserved(=0)
# caps  (32 B): +0 flags · +4 opmask · +8 h_active · +12 v_active · +16 h_total · +20 v_total
#               +24 pixclk_100hz · +28 refresh_mHz

fn m_puts(s): i64 {
    var n = 0;
    while (load8(s + n) != 0) { n = n + 1; }
    syscall(1, 1, s, n);
    return 0;
}
fn m_num(v): i64 {
    var buf[24];
    var i = 23;
    var neg = 0;
    var x = v;
    if (x < 0) { neg = 1; x = 0 - x; }
    if (x == 0) { store8(&buf + i, 48); i = i - 1; }
    while (x > 0) { store8(&buf + i, 48 + x % 10); i = i - 1; x = x / 10; }
    if (neg == 1) { store8(&buf + i, 45); i = i - 1; }
    syscall(1, 1, &buf + i + 1, 23 - i);
    return 0;
}
fn m_nl(): i64 { syscall(1, 1, "\n", 1); return 0; }

# one "modeset: KEY=VAL" line
fn m_kv(k, v): i64 { m_puts("modeset: "); m_puts(k); m_puts("="); m_num(v); m_nl(); return 0; }

fn modeset_caps(): i64 {
    var rec[64];
    var i = 0;
    while (i < 16) { store32(&rec + i * 4, 0); i = i + 1; }   # zero the whole record
    store32(&rec + 0, 1);                                     # op = MDO_OP_CAPS (0x01)
    var caps[32];
    var c = 0;
    while (c < 8) { store32(&caps + c * 4, 0); c = c + 1; }
    store64(&rec + 8, &caps);                                 # out_uva
    store64(&rec + 16, 32);                                   # out_len

    var r = sys_gpu_modeset_op(&rec, 64);
    if (r < 0) {
        var code = 0 - r;
        m_puts("modeset: #93 error idx="); m_num(code >> 8);
        m_puts(" reason="); m_num(code & 0xFF); m_nl();
        m_puts("modeset: (reasons: 2=badop 3=outbuf 11=desc 12=reserved)"); m_nl();
        return 97;
    }
    if (r != 0) {
        m_puts("modeset: #93 returned unexpected "); m_num(r); m_nl();
        return 99;
    }

    var flags   = load32(&caps + 0);
    var opmask  = load32(&caps + 4);
    m_puts("modeset: caps OK"); m_nl();
    m_kv("opmask", opmask);
    m_kv("flags", flags);
    m_kv("h_active", load32(&caps + 8));
    m_kv("v_active", load32(&caps + 12));
    m_kv("h_total", load32(&caps + 16));
    m_kv("v_total", load32(&caps + 20));
    m_kv("pixclk_100hz", load32(&caps + 24));
    m_kv("refresh_mHz", load32(&caps + 28));

    # decode the flag bits into greppable words (machine + operator)
    if ((flags & 1) != 0)  { m_puts("modeset: latch-armable YES"); m_nl(); }
    if ((flags & 1) == 0)  { m_puts("modeset: latch-armable NO"); m_nl(); }
    if ((flags & 2) != 0)  { m_puts("modeset: display LIT"); m_nl(); }
    if ((flags & 2) == 0)  { m_puts("modeset: display DARK"); m_nl(); }
    if ((flags & 4) != 0)  { m_puts("modeset: atom AVAILABLE"); m_nl(); }
    if ((flags & 8) != 0)  { m_puts("modeset: pixclk MEASURED"); m_nl(); }

    if ((flags & 16) != 0) {
        m_puts("modeset: LATCH BLOCKED this boot -- a previous modeset did not disarm"); m_nl();
        m_puts("modeset: recover with:  rm /.modeset-armed"); m_nl();
        return 98;
    }
    if ((flags & 2) != 0) { return 95; }    # display lit + seam live — the full-green result on iron
    return 96;                              # seam live, no lit display (QEMU / dark port) — informational
}

# M1/M2/M3 — trigger the read-only DCN pipe dump (#93 op 0x02). The dump itself prints `rd <off> <val>`
# to the KERNEL log (klug) progressively (hang-localising), so capture it with `run /bin/klug > m1.txt`;
# this call just triggers it and reports the outcome. Under QEMU (no DCN) it returns reason 1.
fn modeset_dump(): i64 {
    var rec[64];
    var i = 0;
    while (i < 16) { store32(&rec + i * 4, 0); i = i + 1; }
    store32(&rec + 0, 2);                                    # op = MDO_OP_DUMP (0x02)
    var r = sys_gpu_modeset_op(&rec, 64);
    if (r < 0) {
        var code = 0 - r;
        var reason = code & 0xFF;
        m_puts("modeset: #93 dump error idx="); m_num(code >> 8);
        m_puts(" reason="); m_num(reason); m_nl();
        # reason 1 (no GPU / live pipe != 0) is the QEMU informational path, not a failure — 96 like caps
        # and --lock, so the exit code means the same thing across all three M-lane arg ops.
        if (reason == 1) { m_puts("modeset: no GPU / live pipe != 0 -- QEMU has no DCN"); m_nl(); return 96; }
        return 97;
    }
    m_puts("modeset: dump complete -- capture with:  run /bin/klug > m1.txt"); m_nl();
    return 95;
}

# M4 — trigger the OTG-lock proof (#93 op 0x03). The kernel op arms the H2 latch, takes the OTG master
# update lock, writes V_TOTAL back to its OWN value, re-arms the surface (VUPDATE trigger) and releases —
# a live-pipe write that changes nothing, so the lock MECHANISM is validated in isolation. Pass = lock
# acked AND I1 advanced AND no underflow, all printed to klug. This call triggers it and reports the
# outcome. Under QEMU (no DCN) it returns reason 1 -> 96. First WRITE bite of work list B — the latch is
# now live; disarm with `rm /.modeset-armed` when done.
#   95 = lock OK (acked, pipe kept scanning, no underflow)     97 = a hardware check failed (detail in klug)
#   96 = no GPU here (QEMU / dark port) -- informational        98 = latch would not arm (blocked / read-only fs)
fn modeset_lock(): i64 {
    var rec[64];
    var i = 0;
    while (i < 16) { store32(&rec + i * 4, 0); i = i + 1; }
    store32(&rec + 0, 3);                                    # op = MDO_OP_LOCK (0x03)
    var r = sys_gpu_modeset_op(&rec, 64);
    if (r < 0) {
        var code = 0 - r;
        var reason = code & 0xFF;
        m_puts("modeset: #93 lock error idx="); m_num(code >> 8);
        m_puts(" reason="); m_num(reason); m_nl();
        if (reason == 1) { m_puts("modeset: no GPU / live pipe != 0 -- QEMU has no DCN"); m_nl(); return 96; }
        if (reason == 4) {
            m_puts("modeset: latch would not arm -- blocked (prior modeset did not disarm) or read-only fs"); m_nl();
            m_puts("modeset: recover with:  rm /.modeset-armed"); m_nl();
            return 98;
        }
        if (reason == 5) { m_puts("modeset: LOCK did not ack -- master update lock timed out (see klug)"); m_nl(); return 97; }
        if (reason == 6) { m_puts("modeset: STALL -- I1 did not advance under the lock (see klug)"); m_nl(); return 97; }
        if (reason == 7) { m_puts("modeset: UNDERFLOW -- OPTC bit10 set after the lock (see klug)"); m_nl(); return 97; }
        m_puts("modeset: (reasons: 2=badop 3=outbuf 11=desc 12=reserved)"); m_nl();
        return 97;
    }
    if (r != 0) {
        m_puts("modeset: #93 lock returned unexpected "); m_num(r); m_nl();
        return 99;
    }
    m_puts("modeset: LOCK OK -- acked, pipe kept scanning, no underflow -- capture:  run /bin/klug"); m_nl();
    m_puts("modeset: disarm when done with:  rm /.modeset-armed"); m_nl();
    return 95;
}

# M5 — the first REAL modeset (#93 op 0x04). The kernel op arms the H2 latch, then runs A/B/C phases:
# measure the inherited refresh (v_total 1481), write v_total 1501, restore 1481 — each write watchdog-guarded
# (if the frame counter stops, the inherited V_TOTAL is restored in-kernel). The proof is I2 (frame-counted
# refresh, printed to klug): 1481->1501 must drop it 59.951->59.152 Hz, then restore. This call triggers it
# and reports the outcome. Under QEMU (no DCN) it returns reason 1 -> 96. The latch is live afterward; disarm
# with `rm /.modeset-armed`. Exit codes name the outcome for the burn tracker:
#   95 = FIRST MODESET COMMITTED (refresh moved to prediction + restored)   93 = refresh did NOT move (shadow-only)
#   96 = no GPU here (QEMU)                92 = moved but off prediction     91 = watchdog fired (pipe restored)
#   94 = refused: pipe not the calibrated mode / DRR on   97 = unmeasurable   98 = latch would not arm
#   90 = OPTC underflow -- timing may be live but scanout is CORRUPT (the free-running-instrument blind spot)
fn modeset_vtotal(): i64 {
    var rec[64];
    var i = 0;
    while (i < 16) { store32(&rec + i * 4, 0); i = i + 1; }
    store32(&rec + 0, 4);                                    # op = MDO_OP_VTOTAL (0x04)
    var r = sys_gpu_modeset_op(&rec, 64);
    if (r < 0) {
        var code = 0 - r;
        var reason = code & 0xFF;
        m_puts("modeset: #93 vtotal error idx="); m_num(code >> 8);
        m_puts(" reason="); m_num(reason); m_nl();
        if (reason == 1) { m_puts("modeset: no GPU / live pipe != 0 -- QEMU has no DCN"); m_nl(); return 96; }
        if (reason == 4) {
            m_puts("modeset: latch would not arm -- blocked (prior modeset did not disarm) or read-only fs"); m_nl();
            m_puts("modeset: recover with:  rm /.modeset-armed"); m_nl();
            return 98;
        }
        if (reason == 7) { m_puts("modeset: OPTC UNDERFLOW -- scanout corrupt though timing may be live (see klug)"); m_nl(); return 90; }
        if (reason == 8) { m_puts("modeset: refused -- V_TOTAL is not the calibrated 1480 (pipe not the known mode)"); m_nl(); return 94; }
        if (reason == 9) { m_puts("modeset: refused -- V_TOTAL_CONTROL nonzero (DRR/VRR on) -- untested path"); m_nl(); return 94; }
        if (reason == 10) { m_puts("modeset: WATCHDOG fired -- pipe stopped, inherited V_TOTAL restored (see klug)"); m_nl(); return 91; }
        if (reason == 13) { m_puts("modeset: refresh did NOT move -- write landed in shadow, VUPDATE never swapped (see klug)"); m_nl(); return 93; }
        if (reason == 14) { m_puts("modeset: refresh moved but OFF prediction -- totals or stride wrong (see klug)"); m_nl(); return 92; }
        if (reason == 15) { m_puts("modeset: refresh unmeasurable -- pipe not counting cleanly (see klug)"); m_nl(); return 97; }
        return 97;
    }
    if (r != 0) {
        m_puts("modeset: #93 vtotal returned unexpected "); m_num(r); m_nl();
        return 99;
    }
    m_puts("modeset: FIRST MODESET COMMITTED -- refresh moved 59.951->59.152->59.951 Hz -- capture:  run /bin/klug"); m_nl();
    m_puts("modeset: disarm when done with:  rm /.modeset-armed"); m_nl();
    return 95;
}

# M6 — the same-mode OTG envelope re-commit (#93 op 0x05). The kernel op arms the H2 latch, then
# DISABLES the pipe (OTG_MASTER_EN=0 — the panel blanks briefly), reprograms the full timing group with its
# own saved values, and re-enables (OTG_MASTER_EN=1). The proof is I1 (frame counter): it must STOP during
# the disable window and RESUME after enable, printed to klug. This is the envelope M8 (the transmitter) will
# run #4/#76 inside. Under QEMU (no DCN) it returns reason 1 -> 96. Disarm with `rm /.modeset-armed` after.
#   95 = envelope OK (stopped then resumed, rate restored)   89 = disable did NOT stop the pipe (envelope no-op)
#   96 = no GPU here (QEMU)             91 = pipe DARK -- did not resume (recover via H2)   90 = OPTC underflow
#   92 = off-rate after re-enable       94 = refused (not calibrated / DRR on)   97 = unmeasurable   98 = latch
fn modeset_recommit(): i64 {
    var rec[64];
    var i = 0;
    while (i < 16) { store32(&rec + i * 4, 0); i = i + 1; }
    store32(&rec + 0, 5);                                    # op = MDO_OP_RECOMMIT (0x05)
    var r = sys_gpu_modeset_op(&rec, 64);
    if (r < 0) {
        var code = 0 - r;
        var reason = code & 0xFF;
        m_puts("modeset: #93 recommit error idx="); m_num(code >> 8);
        m_puts(" reason="); m_num(reason); m_nl();
        if (reason == 1) { m_puts("modeset: no GPU / live pipe != 0 -- QEMU has no DCN"); m_nl(); return 96; }
        if (reason == 4) {
            m_puts("modeset: latch would not arm -- blocked (prior modeset did not disarm) or read-only fs"); m_nl();
            m_puts("modeset: recover with:  rm /.modeset-armed"); m_nl();
            return 98;
        }
        if (reason == 8) { m_puts("modeset: refused -- V_TOTAL is not the calibrated 1480 (pipe not the known mode)"); m_nl(); return 94; }
        if (reason == 9) { m_puts("modeset: refused -- V_TOTAL_CONTROL nonzero (DRR/VRR on) -- untested path"); m_nl(); return 94; }
        if (reason == 16) { m_puts("modeset: OTG_MASTER_EN=0 did NOT stop the pipe -- the envelope is a no-op (see klug)"); m_nl(); return 89; }
        if (reason == 17) {
            m_puts("modeset: pipe DARK -- stopped but did NOT resume after re-enable (see klug)"); m_nl();
            m_puts("modeset: recover with:  rm /.modeset-armed  then power-cycle (H2)"); m_nl();
            return 91;
        }
        if (reason == 7) { m_puts("modeset: OPTC UNDERFLOW -- envelope corrupted scanout (see klug)"); m_nl(); return 90; }
        if (reason == 14) { m_puts("modeset: off-rate -- refresh did not return to the inherited value (see klug)"); m_nl(); return 92; }
        if (reason == 15) { m_puts("modeset: unmeasurable -- pipe resumed but will not count (see klug)"); m_nl(); return 97; }
        return 97;
    }
    if (r != 0) {
        m_puts("modeset: #93 recommit returned unexpected "); m_num(r); m_nl();
        return 99;
    }
    m_puts("modeset: RECOMMIT OK -- envelope 0->reprogram->1, stopped then resumed"); m_nl();
    m_puts("modeset: ⚠ EYE-CHECK the panel -- a green OK with a BLACK screen = the underflow-dark case (power-cycle, H2)"); m_nl();
    m_puts("modeset: capture:  run /bin/klug   then disarm:  rm /.modeset-armed"); m_nl();
    return 95;
}

# `--dump` = the M1/M2/M3 read-only pipe dump; `--lock` = the M4 OTG-lock proof (WRITES under the latch);
# `--caps` (or bare) = the caps probe. argc/argv come from the kernel's parked init stack; if that ever
# reads 0 (the argv-init trap) the tool falls back to caps, so a bare `run /bin/modeset` always works.
fn modeset_main(): i64 {
    args_init();
    if (argc() >= 2) {
        var a1 = argv(1);
        if (streq(a1, "--dump") == 1) { return modeset_dump(); }
        if (streq(a1, "--lock") == 1) { return modeset_lock(); }
        if (streq(a1, "--vtotal") == 1) { return modeset_vtotal(); }
        if (streq(a1, "--recommit") == 1) { return modeset_recommit(); }
        if (streq(a1, "--caps") == 1) { return modeset_caps(); }
    }
    return modeset_caps();
}

fn _entry(): i64 {
    var r = modeset_main();
    syscall(SYS_EXIT, r);
    return 0;
}
_entry();
