# gpucopy — agnos ring-3 proof of #90 gpu_readback_shm + #91 gpu_blit_bb. PROGRAMMATIC oracle only (no photo).
#
# #90 fails SILENTLY (a wrong/stale read returns plausible pixels, never an error), so this reads its verdict
# OUT to userland: draw a known frame, capture with #90, read pixels back with #73 shm_read, compare VALUES.
# `run /bin/gpucopy` -> `run: exit 95` = all pass.
#
# Arc (2026-07-23): burn1 exit84 (ambiguous) -> burn2 exit76 (source read wrong; #91 exonerated) -> burn3
# exit51 (a REUSED readback slot returned a STALE ghost — gpu.md C2g-1) -> burn4 exit95 (a wbinvd in #90
# fixed it). This build runs on the SCOPED fix (per-line clflush) and PROVES the whole surface with SPATIAL
# discrimination (per-row colour bands, not a solid fill) so a shift / short-copy / wrong-stride / wrong
# row-order cannot pass unseen:
#   A  (#90 fresh):  green square @ (100,100) — green inside, blue outside.
#   A2 (#90 REUSE):  4-band source @ (300,100) read into the SAME slot — proves the clflush coherence fix.
#   B-flat (#91):    top-down NON-overlap move (300,100)->(420,100) [dy==sy] — bands preserved.
#   B-down (#91):    bottom-up OVERLAPPING move (300,100)->(300,132) [dy>sy, 32-row overlap] — the memmove
#                    row-order case the bottom-up loop EXISTS for; a top-down bug smears the lower bands.
#
# Source @ (300,100), 64 wide, four 16-row bands (so row position is identifiable):
#   rows 0-15 RED 0xFF0000 · 16-31 GREEN 0x00FF00 · 32-47 YELLOW 0xFFFF00 · 48-63 CYAN 0x00FFFF
#
# EXIT: 95 all pass.
#   96 caps · 100 no-GPU(QEMU) · 101 no-carveout · 102 bb-w<512 · 103 bb-h<512 · 104 no-slot · 105 not-armed
#   90 gpu_fill · 98 gpu_fill_rect · 92 shm_create_gpu
#   A:      70 #90 nonzero · 71 shm_read nonzero · 72 green not green · 73 background not blue
#   A2:     74 #90 nonzero · 75 shm_read nonzero · 76 REUSED read bands wrong (⇒ coherence fix regressed)
#   B-flat: 77 #91 nonzero · 78 verify readback failed · 79 top-down dest bands wrong
#   B-down: 80 #91 nonzero · 81 verify readback failed · 82 bottom-up dest bands wrong · 83 over-copy past dest

var cap_pix[8192];                 # module-global ⇒ N x u64 = 65536 B = 128*128*4 (readback landing buffer)

fn cap_px(x, y, w): i64 {
    return load32(&cap_pix + (y * w + x) * 4) & 0xFFFFFFFF;
}

# Readback a w x h rect at (sx,sy) from slot `id` into cap_pix. 0 ok · -1 #90 rejected · -2 shm_read failed.
fn cap_read(id, sx, sy, w, h): i64 {
    if (syscall(90, id, (h * 65536) + w, (sy * 65536) + sx) != 0) { return 0 - 1; }
    if (syscall(73, id, &cap_pix, w * h * 4) != 0) { return 0 - 2; }
    return 0;
}

# A 64-wide capture whose rows carry the 4 bands red/green/yellow/cyan (16 rows each). Returns 0 if all four
# sampled rows match, else the 1-based band that mismatched — so a shift/short-copy/row-swap names itself.
fn check_bands(): i64 {
    if (cap_px(10, 5, 64)  != 0x00FF0000) { return 1; }   # B0 red    (rows 0-15)
    if (cap_px(10, 20, 64) != 0x0000FF00) { return 2; }   # B1 green  (rows 16-31)
    if (cap_px(10, 40, 64) != 0x00FFFF00) { return 3; }   # B2 yellow (rows 32-47)
    if (cap_px(10, 60, 64) != 0x0000FFFF) { return 4; }   # B3 cyan   (rows 48-63)
    return 0;
}

fn gpucopy_main(): i64 {
    var caps[32];
    if (syscall(89, &caps, 32) != 0) { return 96; }
    var flags     = load32(&caps + 0)  & 0xFFFFFFFF;
    var bbw       = load32(&caps + 8)  & 0xFFFFFFFF;
    var bbh       = load32(&caps + 12) & 0xFFFFFFFF;
    var freeslots = load32(&caps + 20) & 0xFFFFFFFF;
    if ((flags & 1) == 0) { return 100; }
    if ((flags & 4) == 0) { return 101; }
    if (bbw < 512) { return 102; }                     # test rects reach x=483, y=196
    if (bbh < 512) { return 103; }
    if (freeslots < 1) { return 104; }
    if ((flags & 2) == 0) { return 105; }

    if (sys_gpu_fill(0x00000080) != 0) { return 90; }                                            # blue bg
    if (syscall(88, 0x0000FF00, (64 * 65536) + 64, (100 * 65536) + 100) != 0) { return 98; }     # green square @ (100,100)
    # Banded source @ (300,100): 4 x 16-row bands so row order/position is verifiable.
    if (syscall(88, 0x00FF0000, (16 * 65536) + 64, (100 * 65536) + 300) != 0) { return 98; }     # B0 red    rows 100-115
    if (syscall(88, 0x0000FF00, (16 * 65536) + 64, (116 * 65536) + 300) != 0) { return 98; }     # B1 green  rows 116-131
    if (syscall(88, 0x00FFFF00, (16 * 65536) + 64, (132 * 65536) + 300) != 0) { return 98; }     # B2 yellow rows 132-147
    if (syscall(88, 0x0000FFFF, (16 * 65536) + 64, (148 * 65536) + 300) != 0) { return 98; }     # B3 cyan   rows 148-163

    var id = syscall(86, 128 * 128 * 4);               # one slot, sized for the largest capture, reused
    if (id < 1) { return 92; }

    # A — #90 fresh: 128x128 @ (100,100); green inside the 64x64 square, blue outside (spatial).
    var ra = cap_read(id, 100, 100, 128, 128);
    if (ra == 0 - 1) { syscall(74, id); return 70; }
    if (ra == 0 - 2) { syscall(74, id); return 71; }
    if (cap_px(10, 10, 128)   != 0x0000FF00) { syscall(74, id); return 72; }
    if (cap_px(64, 0, 128)    != 0x00000080) { syscall(74, id); return 73; }
    if (cap_px(100, 100, 128) != 0x00000080) { syscall(74, id); return 73; }

    # A2 — #90 REUSE (same slot): read the banded source @ (300,100); proves the clflush coherence fix.
    var r2 = cap_read(id, 300, 100, 64, 64);
    if (r2 == 0 - 1) { syscall(74, id); return 74; }
    if (r2 == 0 - 2) { syscall(74, id); return 75; }
    if (check_bands() != 0) { syscall(74, id); return 76; }

    # B-flat — #91 top-down (proven gpu_cp_dma_blit), NON-overlap horizontal (300,100)->(420,100), dy==sy.
    if (syscall(91, (100 * 65536) + 300, (64 * 65536) + 64, (100 * 65536) + 420) != 0) { syscall(74, id); return 77; }
    var rf = cap_read(id, 420, 100, 64, 64);
    if (rf != 0) { syscall(74, id); return 78; }
    if (check_bands() != 0) { syscall(74, id); return 79; }

    # B-down — #91 bottom-up (new loop), OVERLAPPING downward (300,100)->(300,132), dy>sy, 32-row overlap.
    # Correct bottom-up preserves the bands at the dest; a top-down copy would read a source row after the
    # dest row above it (which shares those pixels) was overwritten, smearing B2/B3. Read dst @ (300,132).
    if (syscall(91, (100 * 65536) + 300, (64 * 65536) + 64, (132 * 65536) + 300) != 0) { syscall(74, id); return 80; }
    var rd = cap_read(id, 300, 132, 64, 64);
    if (rd != 0) { syscall(74, id); return 81; }
    if (check_bands() != 0) { syscall(74, id); return 82; }
    # Over-copy guard: the move wrote dst rows [132,196); row 196 must be untouched blue background.
    var ro = cap_read(id, 300, 196, 64, 4);
    if (ro == 0) { if (cap_px(10, 0, 64) != 0x00000080) { syscall(74, id); return 83; } }

    sys_gpu_present();                                 # optional glance-check; exit code is the verdict
    syscall(74, id);
    return 95;
}

fn _entry(): i64 { var r = gpucopy_main(); syscall(SYS_EXIT, r); return 0; }
_entry();
